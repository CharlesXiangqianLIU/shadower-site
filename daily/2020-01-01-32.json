[{"index": 0, "text": "Lesson 63 Thank you, doctor.", "start": 0.75, "end": 5.091, "zh": "第63课 谢谢你,医生。", "zh_hant": "第63課 謝謝你,醫生。"}, {"index": 1, "text": "Listen to the tape then answer this question.", "start": 6.431, "end": 11.471, "zh": "听录音，然后回答这个问题。", "zh_hant": "聽錄音，然後回答這個問題。"}, {"index": 2, "text": "Who else is in bed today?", "start": 12.531, "end": 15.552, "zh": "今天还有谁卧床?", "zh_hant": "今天還有誰臥床?"}, {"index": 3, "text": "Why?", "start": 16.372, "end": 17.272, "zh": "为什么?", "zh_hant": "為什麼?"}, {"index": 4, "text": "How's Jimmy today?", "start": 19.132, "end": 21.172, "zh": "吉米今天怎么样？", "zh_hant": "吉米今天怎麼樣？"}, {"index": 5, "text": "Better.", "start": 21.492, "end": 22.412, "zh": "好些了。", "zh_hant": "好些了。"}, {"index": 6, "text": "Thank you, doctor.", "start": 22.613, "end": 24.313, "zh": "谢谢您，医生。", "zh_hant": "謝謝您，醫生。"}, {"index": 7, "text": "Can I see him please, Mrs. Williams?", "start": 24.893, "end": 28.473, "zh": "威廉姆斯太太，我能看看他吗？", "zh_hant": "威廉姆斯太太，我能看看他嗎？"}, {"index": 8, "text": "Certainly, doctor.", "start": 29.273, "end": 31.053, "zh": "当然可以，医生。", "zh_hant": "當然可以，醫生。"}, {"index": 9, "text": "Come upstairs.", "start": 31.253, "end": 33.134, "zh": "上楼来吧。", "zh_hant": "上樓來吧。"}, {"index": 10, "text": "You look very well, Jimmy.", "start": 34.074, "end": 36.534, "zh": "你看起来气色不错，吉米。", "zh_hant": "你看起來氣色不錯，吉米。"}, {"index": 11, "text": "You are better now, but you mustn't get up yet.", "start": 37.074, "end": 41.815, "zh": "你现在好些了，但还不能起床。", "zh_hant": "你現在好些了，但還不能起床。"}, {"index": 12, "text": "You must stay in bed for another two days.", "start": 42.395, "end": 47.035, "zh": "你还得再卧床两天。", "zh_hant": "你還得再臥床兩天。"}, {"index": 13, "text": "The boy mustn't go to school yet, Mrs. Williams.", "start": 48.235, "end": 52.776, "zh": "威廉姆斯太太，这孩子暂时还不能上学。", "zh_hant": "威廉姆斯太太，這孩子暫時還不能上學。"}, {"index": 14, "text": "And he mustn't eat rich food.", "start": 53.176, "end": 56.336, "zh": "而且他不能吃油腻的食物。", "zh_hant": "而且他不能吃油膩的食物。"}, {"index": 15, "text": "Does he have a temperature, doctor?", "start": 58.076, "end": 61.657, "zh": "他发烧吗，医生？", "zh_hant": "他發燒嗎，醫生？"}, {"index": 16, "text": "No, he doesn't.", "start": 62.057, "end": 63.917, "zh": "不，他没有发烧。", "zh_hant": "不，他沒有發燒。"}, {"index": 17, "text": "Must he stay in bed?", "start": 64.057, "end": 66.717, "zh": "他必须卧床吗？", "zh_hant": "他必須臥床嗎？"}, {"index": 18, "text": "Yes.", "start": 66.997, "end": 67.857, "zh": "是的。", "zh_hant": "是的。"}, {"index": 19, "text": "He must remain in bed for another two days.", "start": 67.838, "end": 72.318, "zh": "他必须再卧床两天。", "zh_hant": "他必須再臥床兩天。"}, {"index": 20, "text": "He can get up for about two hours each day, but you must keep the room warm.", "start": 72.758, "end": 81.499, "zh": "他每天可以起来大约两个小时，但你必须让房间保持温暖。", "zh_hant": "他每天可以起來大約兩個小時，但你必須讓房間保持溫暖。"}, {"index": 21, "text": "Where's Mr. Williams this evening?", "start": 83.379, "end": 86.84, "zh": "威廉姆斯先生今晚在哪里？", "zh_hant": "威廉姆斯先生今晚在哪裡？"}, {"index": 22, "text": "He's in bed, doctor.", "start": 87.32, "end": 90.0, "zh": "他在床上呢，医生。", "zh_hant": "他在床上呢，醫生。"}, {"index": 23, "text": "Can you see him please?", "start": 90.38, "end": 92.96, "zh": "您能看看他吗？", "zh_hant": "您能看看他嗎？"}, {"index": 24, "text": "He has a bad cold, too!", "start": 93.22, "end": 96.481, "zh": "他也得了重感冒！", "zh_hant": "他也得了重感冒！"}]