[{"index": 0, "text": "Lesson 95", "start": 1.55, "end": 2.565, "zh": "第95课"}, {"index": 1, "text": "Tickets, please.", "start": 4.031, "end": 5.232, "zh": "请出示车票。"}, {"index": 2, "text": "Listen to the tape then answer this question.", "start": 6.692, "end": 9.713, "zh": "听录音,然后回答这个问题。"}, {"index": 3, "text": "Why did George and Ken miss the train?", "start": 12.234, "end": 15.435, "zh": "乔治和肯为什么错过了火车?"}, {"index": 4, "text": "Two return tickets to London, please.", "start": 18.276, "end": 20.576, "zh": "请给我两张去伦敦的往返票。"}, {"index": 5, "text": "What time will the next train leave?", "start": 21.497, "end": 23.517, "zh": "下一班火车几点开?"}, {"index": 6, "text": "At nineteen minutes past eight.", "start": 24.878, "end": 29.099, "zh": "八点十九分。"}, {"index": 7, "text": "Which platform?", "start": 31.0, "end": 31.76, "zh": "哪个站台?"}, {"index": 8, "text": "Two.", "start": 32.001, "end": 32.291, "zh": "二号站台。"}, {"index": 9, "text": "Over the bridge.", "start": 32.291, "end": 33.241, "zh": "过桥就到。"}, {"index": 10, "text": "What time will the next train leave?", "start": 35.223, "end": 37.024, "zh": "下一班火车几点开?"}, {"index": 11, "text": "At eight nineteen.", "start": 38.185, "end": 39.366, "zh": "八点十九分。"}, {"index": 12, "text": "We've got plenty of time.", "start": 40.466, "end": 42.127, "zh": "我们时间很充裕。"}, {"index": 13, "text": "It's only three minutes to eight.", "start": 43.468, "end": 45.63, "zh": "现在才八点差三分。"}, {"index": 14, "text": "Let's go and have a drink.", "start": 46.971, "end": 48.452, "zh": "我们去喝一杯吧。"}, {"index": 15, "text": "There's a bar next door to the station.", "start": 49.052, "end": 51.574, "zh": "车站隔壁就有个酒吧。"}, {"index": 16, "text": "We had better go back to the station now, Ken.", "start": 53.876, "end": 63.253, "zh": "肯,我们现在最好回车站了。"}, {"index": 17, "text": "Tickets, please.", "start": 63.253, "end": 63.513, "zh": "请出示车票。"}, {"index": 18, "text": "We want to catch the eight nineteen to London.", "start": 63.513, "end": 64.813, "zh": "我们要赶八点十九分去伦敦的那班车。"}, {"index": 19, "text": "You've just missed it!", "start": 66.174, "end": 67.714, "zh": "你们刚好错过了!"}, {"index": 20, "text": "What!", "start": 68.795, "end": 69.195, "zh": "什么!"}, {"index": 21, "text": "It's only eight fifteen.", "start": 69.735, "end": 71.456, "zh": "现在才八点十五分。"}, {"index": 22, "text": "I'm sorry, sir.", "start": 72.676, "end": 73.777, "zh": "对不起,先生。"}, {"index": 23, "text": "That clock's ten minutes slow.", "start": 74.437, "end": 76.478, "zh": "那个钟慢了十分钟。"}, {"index": 24, "text": "When's the next train?", "start": 78.099, "end": 79.459, "zh": "下一班火车是几点?"}, {"index": 25, "text": "In five hours' time!", "start": 80.9, "end": 83.16, "zh": "要再等五个小时!"}]