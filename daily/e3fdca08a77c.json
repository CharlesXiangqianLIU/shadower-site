[{"index": 0, "text": "Lesson 95", "start": 1.55, "end": 2.565}, {"index": 1, "text": "Tickets, please.", "start": 4.031, "end": 5.232}, {"index": 2, "text": "Listen to the tape then answer this question.", "start": 6.692, "end": 9.713}, {"index": 3, "text": "Why did George and Ken miss the train?", "start": 12.234, "end": 15.435}, {"index": 4, "text": "Two return tickets to London, please.", "start": 18.276, "end": 20.576}, {"index": 5, "text": "What time will the next train leave?", "start": 21.497, "end": 23.517}, {"index": 6, "text": "At nineteen minutes past eight.", "start": 24.878, "end": 29.099}, {"index": 7, "text": "Which platform?", "start": 31.0, "end": 31.76}, {"index": 8, "text": "Platform Two.", "start": 32.001, "end": 32.341}, {"index": 9, "text": "Over the bridge.", "start": 32.241, "end": 33.241}, {"index": 10, "text": "What time will the next train leave?", "start": 35.223, "end": 37.024}, {"index": 11, "text": "At eight nineteen.", "start": 38.185, "end": 39.366}, {"index": 12, "text": "We've got plenty of time.", "start": 40.466, "end": 42.127}, {"index": 13, "text": "It's only three minutes to eight.", "start": 43.468, "end": 45.63}, {"index": 14, "text": "Let's go and have a drink.", "start": 46.971, "end": 48.452}, {"index": 15, "text": "There's a bar next door to the station.", "start": 49.052, "end": 51.574}, {"index": 16, "text": "We had better go back to the station now, Ken.", "start": 53.876, "end": 63.313}, {"index": 17, "text": "Tickets, please.", "start": 63.193, "end": 63.573}, {"index": 18, "text": "We want to catch the eight nineteen to London.", "start": 63.453, "end": 64.813}, {"index": 19, "text": "You've just missed it!", "start": 66.174, "end": 67.714}, {"index": 20, "text": "What!", "start": 68.795, "end": 69.195}, {"index": 21, "text": "It's only eight fifteen.", "start": 69.735, "end": 71.456}, {"index": 22, "text": "I'm sorry, sir.", "start": 72.676, "end": 73.777}, {"index": 23, "text": "That clock's ten minutes slow.", "start": 74.437, "end": 76.478}, {"index": 24, "text": "When's the next train?", "start": 78.099, "end": 79.459}, {"index": 25, "text": "In five hours' time!", "start": 80.9, "end": 83.16}]