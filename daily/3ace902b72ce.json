[{"index": 0, "text": "Lesson 29", "start": 1.621, "end": 2.225}, {"index": 1, "text": "Come in, Amy.", "start": 4.202, "end": 5.402}, {"index": 2, "text": "Listen to the tape then answer this question.", "start": 6.803, "end": 10.404}, {"index": 3, "text": "How must Amy clean the floor?", "start": 12.885, "end": 15.667}, {"index": 4, "text": "Come in, Amy.", "start": 18.368, "end": 19.508}, {"index": 5, "text": "Shut the door, please.", "start": 21.369, "end": 22.89}, {"index": 6, "text": "This bedroom's very untidy.", "start": 25.271, "end": 28.102}, {"index": 7, "text": "What must I do, Mrs. Jones?", "start": 28.102, "end": 28.692}, {"index": 8, "text": "Open the window and air the room.", "start": 36.033, "end": 39.435}, {"index": 9, "text": "Then put these clothes in the wardrobe.", "start": 41.976, "end": 45.518}, {"index": 10, "text": "Then make the bed.", "start": 45.518, "end": 45.828}, {"index": 11, "text": "Dust the dressing table.", "start": 45.828, "end": 47.86}, {"index": 12, "text": "Then sweep the floor.", "start": 47.86, "end": 48.78}]