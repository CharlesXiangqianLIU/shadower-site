[{"index": 0, "text": "Lesson 29", "start": 1.621, "end": 2.225, "zh": "第29课", "zh_hant": "第29課"}, {"index": 1, "text": "Come in, Amy.", "start": 4.202, "end": 5.402, "zh": "进来,艾米。", "zh_hant": "進來,艾米。"}, {"index": 2, "text": "Listen to the tape then answer this question.", "start": 6.803, "end": 10.404, "zh": "听录音,然后回答这个问题。", "zh_hant": "聽錄音,然後回答這個問題。"}, {"index": 3, "text": "How must Amy clean the floor?", "start": 12.885, "end": 15.667, "zh": "艾米必须怎样清扫地板?", "zh_hant": "艾米必須怎樣清掃地板?"}, {"index": 4, "text": "Come in, Amy.", "start": 18.368, "end": 19.508, "zh": "进来,艾米。", "zh_hant": "進來,艾米。"}, {"index": 5, "text": "Shut the door, please.", "start": 21.369, "end": 22.89, "zh": "请把门关上。", "zh_hant": "請把門關上。"}, {"index": 6, "text": "This bedroom's very untidy.", "start": 25.271, "end": 28.102, "zh": "这间卧室很乱。", "zh_hant": "這間臥室很亂。"}, {"index": 7, "text": "What must I do, Mrs. Jones?", "start": 28.102, "end": 28.692, "zh": "琼斯太太,我该做什么?", "zh_hant": "瓊斯太太,我該做什麼?"}, {"index": 8, "text": "Open the window and air the room.", "start": 36.033, "end": 39.435, "zh": "打开窗户,通通风。", "zh_hant": "開啟窗戶,通通風。"}, {"index": 9, "text": "Then put these clothes in the wardrobe.", "start": 41.976, "end": 45.518, "zh": "然后把这些衣服放进衣柜。", "zh_hant": "然後把這些衣服放進衣櫃。"}, {"index": 10, "text": "Then make the bed.", "start": 45.518, "end": 45.828, "zh": "然后把床铺好。", "zh_hant": "然後把床鋪好。"}, {"index": 11, "text": "Dust the dressing table.", "start": 45.828, "end": 47.86, "zh": "擦一擦梳妆台的灰尘。", "zh_hant": "擦一擦梳妝檯的灰塵。"}, {"index": 12, "text": "Then sweep the floor.", "start": 47.86, "end": 48.78, "zh": "然后把地板扫一扫。", "zh_hant": "然後把地板掃一掃。"}]