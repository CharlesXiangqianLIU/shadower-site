[{"index": 0, "text": "Lesson 65", "start": 1.611, "end": 2.34, "zh": "第65课"}, {"index": 1, "text": "Not a baby", "start": 4.253, "end": 5.553, "zh": "不是小孩子了"}, {"index": 2, "text": "Listen to the tape then answer this question.", "start": 7.074, "end": 10.337, "zh": "听录音,然后回答这个问题。"}, {"index": 3, "text": "Does Jill take the key to the front door?", "start": 12.958, "end": 16.1, "zh": "吉尔拿了前门的钥匙吗?"}, {"index": 4, "text": "What are you going to do this evening, Jill?", "start": 18.882, "end": 21.664, "zh": "吉尔,你今晚打算做什么?"}, {"index": 5, "text": "I'm going to meet some friends, Dad.", "start": 23.065, "end": 25.306, "zh": "爸爸,我要去见几个朋友。"}, {"index": 6, "text": "You mustn't come home late.", "start": 26.387, "end": 28.188, "zh": "你不能太晚回家。"}, {"index": 7, "text": "You must be home at half past ten.", "start": 28.849, "end": 31.595, "zh": "你必须在十点半前到家。"}, {"index": 8, "text": "I can't get home so early, Dad!", "start": 33.235, "end": 35.896, "zh": "爸爸,我没法那么早回来!"}, {"index": 9, "text": "Can I have the key to the front door, please?", "start": 37.556, "end": 40.437, "zh": "能把前门钥匙给我吗?"}, {"index": 10, "text": "No, you can't.", "start": 41.157, "end": 42.897, "zh": "不行。"}, {"index": 11, "text": "Jill's eighteen years old, Tom.", "start": 44.597, "end": 47.138, "zh": "汤姆,吉尔十八岁了。"}, {"index": 12, "text": "She's not a baby.", "start": 47.758, "end": 48.838, "zh": "她不是小孩子了。"}, {"index": 13, "text": "Give her the key.", "start": 49.578, "end": 50.618, "zh": "把钥匙给她吧。"}, {"index": 14, "text": "She always comes home early.", "start": 51.558, "end": 53.659, "zh": "她总是很早回家的。"}, {"index": 15, "text": "Oh, all right!", "start": 60.56, "end": 61.0, "zh": "哦,好吧!"}, {"index": 16, "text": "Here you are.", "start": 61.0, "end": 61.38, "zh": "给你。"}, {"index": 17, "text": "But you mustn't come home after a quarter past eleven.", "start": 61.38, "end": 63.401, "zh": "但你不能超过十一点一刻回来。"}, {"index": 18, "text": "Do you hear?", "start": 63.881, "end": 64.581, "zh": "听到了吗?"}, {"index": 19, "text": "Yes, Dad.", "start": 65.661, "end": 67.042, "zh": "听到了,爸爸。"}, {"index": 20, "text": "Thanks, Mum.", "start": 68.102, "end": 68.882, "zh": "谢谢你,妈妈。"}, {"index": 21, "text": "That's all right.", "start": 70.402, "end": 71.343, "zh": "没关系。"}, {"index": 22, "text": "Goodbye.", "start": 72.143, "end": 72.823, "zh": "再见。"}, {"index": 23, "text": "Enjoy yourself!", "start": 73.523, "end": 74.663, "zh": "玩得开心点!"}, {"index": 24, "text": "We always enjoy ourselves, Mum.", "start": 75.924, "end": 78.184, "zh": "妈妈,我们总是玩得很开心。"}, {"index": 25, "text": "Bye-bye.", "start": 78.884, "end": 79.404, "zh": "拜拜。"}]