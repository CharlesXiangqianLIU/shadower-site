[{"index": 0, "text": "Lesson 65", "start": 1.611, "end": 2.34}, {"index": 1, "text": "Not a baby", "start": 4.253, "end": 5.553}, {"index": 2, "text": "Listen to the tape then answer this question.", "start": 7.074, "end": 10.337}, {"index": 3, "text": "Does Jill take the key to the front door?", "start": 12.958, "end": 16.1}, {"index": 4, "text": "What are you going to do this evening, Jill?", "start": 18.882, "end": 21.664}, {"index": 5, "text": "I'm going to meet some friends, Dad.", "start": 23.065, "end": 25.306}, {"index": 6, "text": "You mustn't come home late.", "start": 26.387, "end": 28.188}, {"index": 7, "text": "You must be home at half past ten.", "start": 28.849, "end": 31.595}, {"index": 8, "text": "I can't get home so early, Dad!", "start": 33.235, "end": 35.896}, {"index": 9, "text": "Can I have the key to the front door, please?", "start": 37.556, "end": 40.437}, {"index": 10, "text": "No, you can't.", "start": 41.157, "end": 42.897}, {"index": 11, "text": "Jill's eighteen years old, Tom.", "start": 44.597, "end": 47.138}, {"index": 12, "text": "She's not a baby.", "start": 47.758, "end": 48.838}, {"index": 13, "text": "Give her the key.", "start": 49.578, "end": 50.618}, {"index": 14, "text": "She always comes home early.", "start": 51.558, "end": 53.659}, {"index": 15, "text": "Oh, all right!", "start": 60.56, "end": 61.0}, {"index": 16, "text": "Here you are.", "start": 61.0, "end": 61.38}, {"index": 17, "text": "But you mustn't come home after a quarter past eleven.", "start": 61.38, "end": 63.401}, {"index": 18, "text": "Do you hear?", "start": 63.881, "end": 64.581}, {"index": 19, "text": "Yes, Dad.", "start": 65.661, "end": 67.042}, {"index": 20, "text": "Thanks, Mum.", "start": 68.102, "end": 68.882}, {"index": 21, "text": "That's all right.", "start": 70.402, "end": 71.343}, {"index": 22, "text": "Goodbye.", "start": 72.143, "end": 72.823}, {"index": 23, "text": "Enjoy yourself!", "start": 73.523, "end": 74.663}, {"index": 24, "text": "We always enjoy ourselves, Mum.", "start": 75.924, "end": 78.184}, {"index": 25, "text": "Bye-bye.", "start": 78.884, "end": 79.404}]