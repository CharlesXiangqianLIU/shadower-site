[{"index": 0, "text": "Lesson 9", "start": 1.16, "end": 1.82}, {"index": 1, "text": "How are you today?", "start": 3.081, "end": 4.782}, {"index": 2, "text": "Listen to the tape then answer this question.", "start": 6.442, "end": 10.383}, {"index": 3, "text": "How is Emma?", "start": 11.804, "end": 13.104}, {"index": 4, "text": "Hello Helen.", "start": 16.205, "end": 17.086}, {"index": 5, "text": "Hi Steven.", "start": 18.266, "end": 19.446}, {"index": 6, "text": "How are you today?", "start": 20.707, "end": 22.387}, {"index": 7, "text": "I'm very well thank you.", "start": 23.748, "end": 25.768}, {"index": 8, "text": "And you?", "start": 27.009, "end": 27.569}, {"index": 9, "text": "I'm fine thanks.", "start": 28.729, "end": 30.17}, {"index": 10, "text": "How is Tony?", "start": 30.05, "end": 30.39}, {"index": 11, "text": "He's fine thanks.", "start": 32.441, "end": 36.544}, {"index": 12, "text": "How's Emma?", "start": 37.825, "end": 38.645}, {"index": 13, "text": "She's very well too Helen.", "start": 40.146, "end": 42.467}, {"index": 14, "text": "Goodbye Helen.", "start": 44.809, "end": 45.709}, {"index": 15, "text": "Nice to see you.", "start": 45.629, "end": 46.07}, {"index": 16, "text": "Nice to see you too Steven.", "start": 45.97, "end": 46.65}, {"index": 17, "text": "Goodbye.", "start": 46.57, "end": 46.87}]