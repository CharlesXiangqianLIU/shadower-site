[{"index": 0, "text": "Lesson 9", "start": 1.16, "end": 1.82, "zh": "第9课", "zh_hant": "第9課"}, {"index": 1, "text": "How are you today?", "start": 3.081, "end": 4.782, "zh": "你今天好吗?", "zh_hant": "你今天好嗎?"}, {"index": 2, "text": "Listen to the tape then answer this question.", "start": 6.442, "end": 10.383, "zh": "听录音,然后回答这个问题。", "zh_hant": "聽錄音,然後回答這個問題。"}, {"index": 3, "text": "How is Emma?", "start": 11.804, "end": 13.104, "zh": "艾玛好吗?", "zh_hant": "艾瑪好嗎?"}, {"index": 4, "text": "Hello Helen.", "start": 16.205, "end": 17.086, "zh": "你好,海伦。", "zh_hant": "你好,海倫。"}, {"index": 5, "text": "Hi Steven.", "start": 18.266, "end": 19.446, "zh": "你好,史蒂文。", "zh_hant": "你好,史蒂文。"}, {"index": 6, "text": "How are you today?", "start": 20.707, "end": 22.387, "zh": "你今天好吗?", "zh_hant": "你今天好嗎?"}, {"index": 7, "text": "I'm very well thank you.", "start": 23.748, "end": 25.768, "zh": "我很好,谢谢。", "zh_hant": "我很好,謝謝。"}, {"index": 8, "text": "And you?", "start": 27.009, "end": 27.569, "zh": "你呢?", "zh_hant": "你呢?"}, {"index": 9, "text": "I'm fine thanks.", "start": 28.729, "end": 30.11, "zh": "我很好,谢谢。", "zh_hant": "我很好,謝謝。"}, {"index": 10, "text": "How is Tony?", "start": 30.11, "end": 30.39, "zh": "托尼好吗?", "zh_hant": "託尼好嗎?"}, {"index": 11, "text": "He's fine thanks.", "start": 32.441, "end": 36.544, "zh": "他很好,谢谢。", "zh_hant": "他很好,謝謝。"}, {"index": 12, "text": "How's Emma?", "start": 37.825, "end": 38.645, "zh": "艾玛好吗?", "zh_hant": "艾瑪好嗎?"}, {"index": 13, "text": "She's very well too Helen.", "start": 40.146, "end": 42.467, "zh": "她也很好,海伦。", "zh_hant": "她也很好,海倫。"}, {"index": 14, "text": "Goodbye Helen.", "start": 44.809, "end": 45.669, "zh": "再见,海伦。", "zh_hant": "再見,海倫。"}, {"index": 15, "text": "Nice to see you.", "start": 45.669, "end": 46.02, "zh": "很高兴见到你。", "zh_hant": "很高興見到你。"}, {"index": 16, "text": "Nice to see you too Steven.", "start": 46.02, "end": 46.61, "zh": "我也很高兴见到你,史蒂文。", "zh_hant": "我也很高興見到你,史蒂文。"}, {"index": 17, "text": "Goodbye.", "start": 46.61, "end": 46.87, "zh": "再见。", "zh_hant": "再見。"}]