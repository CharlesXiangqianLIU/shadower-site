[{"index": 0, "text": "Lesson 31", "start": 1.591, "end": 2.075, "zh": "第31课"}, {"index": 1, "text": "Where's Sally?", "start": 4.331, "end": 5.652, "zh": "萨莉在哪儿?"}, {"index": 2, "text": "Listen to the tape then answer this question.", "start": 7.072, "end": 10.754, "zh": "听录音,然后回答这个问题。"}, {"index": 3, "text": "Is the cat climbing the tree?", "start": 13.274, "end": 16.155, "zh": "猫在爬树吗?"}, {"index": 4, "text": "Where's Sally, Jack?", "start": 18.916, "end": 20.417, "zh": "杰克,萨莉在哪儿?"}, {"index": 5, "text": "She's in the garden, Jean.", "start": 21.837, "end": 24.018, "zh": "琴,她在花园里。"}, {"index": 6, "text": "What's she doing?", "start": 26.019, "end": 27.239, "zh": "她在做什么?"}, {"index": 7, "text": "She's sitting under the tree.", "start": 28.579, "end": 30.06, "zh": "她坐在树下。"}, {"index": 8, "text": "Is Tim in the garden, too?", "start": 30.06, "end": 30.46, "zh": "蒂姆也在花园里吗?"}, {"index": 9, "text": "Yes, he is.", "start": 30.46, "end": 37.911, "zh": "是的,他在。"}, {"index": 10, "text": "He's climbing the tree.", "start": 38.952, "end": 41.013, "zh": "他在爬树。"}, {"index": 11, "text": "I beg your pardon?", "start": 42.954, "end": 44.395, "zh": "你说什么?"}, {"index": 12, "text": "Who's climbing the tree?", "start": 45.976, "end": 47.597, "zh": "谁在爬树?"}, {"index": 13, "text": "Tim is.", "start": 48.658, "end": 49.658, "zh": "是蒂姆。"}, {"index": 14, "text": "What about the dog?", "start": 49.658, "end": 50.779, "zh": "那狗呢?"}, {"index": 15, "text": "The dog's in the garden, too.", "start": 50.779, "end": 51.859, "zh": "狗也在花园里。"}, {"index": 16, "text": "It's running across the grass.", "start": 51.859, "end": 52.61, "zh": "它正在草地上跑。"}, {"index": 17, "text": "It's running after a cat.", "start": 52.61, "end": 53.12, "zh": "它在追一只猫。"}]