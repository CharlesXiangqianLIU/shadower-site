[{"index": 0, "text": "Lesson 31", "start": 1.591, "end": 2.075}, {"index": 1, "text": "Where's Sally?", "start": 4.331, "end": 5.652}, {"index": 2, "text": "Listen to the tape then answer this question.", "start": 7.072, "end": 10.754}, {"index": 3, "text": "Is the cat climbing the tree?", "start": 13.274, "end": 16.155}, {"index": 4, "text": "Where's Sally, Jack?", "start": 18.916, "end": 20.417}, {"index": 5, "text": "She's in the garden, Jean.", "start": 21.837, "end": 24.018}, {"index": 6, "text": "What's she doing?", "start": 26.019, "end": 27.239}, {"index": 7, "text": "She's sitting under the tree.", "start": 28.579, "end": 30.12}, {"index": 8, "text": "Is Tim in the garden, too?", "start": 30.0, "end": 30.52}, {"index": 9, "text": "Yes, he is.", "start": 30.4, "end": 37.911}, {"index": 10, "text": "He's climbing the tree.", "start": 38.952, "end": 41.013}, {"index": 11, "text": "I beg your pardon?", "start": 42.954, "end": 44.395}, {"index": 12, "text": "Who's climbing the tree?", "start": 45.976, "end": 47.597}, {"index": 13, "text": "Tim is.", "start": 48.658, "end": 49.698}, {"index": 14, "text": "What about the dog?", "start": 49.618, "end": 50.839}, {"index": 15, "text": "The dog's in the garden, too.", "start": 50.719, "end": 51.919}, {"index": 16, "text": "It's running across the grass.", "start": 51.799, "end": 52.66}, {"index": 17, "text": "It's running after a cat.", "start": 52.56, "end": 53.12}]