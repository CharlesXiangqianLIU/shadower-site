[{"index": 0, "text": "Lesson 21 Which book?", "start": 0.37, "end": 4.472, "zh": "第21课 哪本书?", "zh_hant": "第21課 哪本書?"}, {"index": 1, "text": "Listen to the tape then answer this question.", "start": 5.432, "end": 10.254, "zh": "先听录音,然后回答这个问题。", "zh_hant": "先聽錄音,然後回答這個問題。"}, {"index": 2, "text": "Which book does the man want?", "start": 11.535, "end": 14.696, "zh": "这个男人想要哪本书?", "zh_hant": "這個男人想要哪本書?"}, {"index": 3, "text": "Give me a book please, Jane.", "start": 16.677, "end": 19.658, "zh": "简,请给我一本书。", "zh_hant": "簡,請給我一本書。"}, {"index": 4, "text": "Which book?", "start": 20.158, "end": 21.538, "zh": "哪本书?", "zh_hant": "哪本書?"}, {"index": 5, "text": "This one?", "start": 21.779, "end": 22.979, "zh": "这本?", "zh_hant": "這本?"}, {"index": 6, "text": "No, not that one.", "start": 24.3, "end": 26.9, "zh": "不,不是那本。", "zh_hant": "不,不是那本。"}, {"index": 7, "text": "The red one.", "start": 27.161, "end": 28.641, "zh": "红色的那本。", "zh_hant": "紅色的那本。"}, {"index": 8, "text": "This one?", "start": 29.402, "end": 30.622, "zh": "这本?", "zh_hant": "這本?"}, {"index": 9, "text": "Yes, please.", "start": 30.942, "end": 32.683, "zh": "对,就是它。", "zh_hant": "對,就是它。"}, {"index": 10, "text": "Here you are.", "start": 32.703, "end": 34.243, "zh": "给你。", "zh_hant": "給你。"}, {"index": 11, "text": "Thank you.", "start": 34.664, "end": 35.644, "zh": "谢谢。", "zh_hant": "謝謝。"}]