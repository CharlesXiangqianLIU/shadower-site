[{"index": 0, "text": "Lesson 25 Mrs. Smith's Kitchen Listen to the tape then answer this question.", "start": 0.39, "end": 11.311, "zh": "第25课 史密斯太太的厨房 听录音,然后回答这个问题。", "zh_hant": "第25課 史密斯太太的廚房 聽錄音,然後回答這個問題。"}, {"index": 1, "text": "What colour is the electric cooker?", "start": 12.551, "end": 16.452, "zh": "电炊具是什么颜色的？", "zh_hant": "電炊具是什麼顏色的？"}, {"index": 2, "text": "Mrs. Smith's kitchen is small.", "start": 18.292, "end": 21.972, "zh": "史密斯太太的厨房很小。", "zh_hant": "史密斯太太的廚房很小。"}, {"index": 3, "text": "There is a refrigerator in the kitchen.", "start": 23.092, "end": 27.073, "zh": "厨房里有一台冰箱。", "zh_hant": "廚房裡有一臺冰箱。"}, {"index": 4, "text": "The refrigerator is white.", "start": 27.673, "end": 30.613, "zh": "冰箱是白色的。", "zh_hant": "冰箱是白色的。"}, {"index": 5, "text": "It is on the right.", "start": 31.593, "end": 33.933, "zh": "它在右边。", "zh_hant": "它在右邊。"}, {"index": 6, "text": "There is an electric cooker in the kitchen.", "start": 35.013, "end": 38.934, "zh": "厨房里有一个电炊具。", "zh_hant": "廚房裡有一個電炊具。"}, {"index": 7, "text": "The cooker is blue.", "start": 39.614, "end": 41.874, "zh": "炊具是蓝色的。", "zh_hant": "炊具是藍色的。"}, {"index": 8, "text": "It is on the left.", "start": 42.894, "end": 45.134, "zh": "它在左边。", "zh_hant": "它在左邊。"}, {"index": 9, "text": "There is a table in the middle of the room.", "start": 46.214, "end": 50.455, "zh": "房间中央有一张桌子。", "zh_hant": "房間中央有一張桌子。"}, {"index": 10, "text": "There is a bottle on the table.", "start": 51.515, "end": 54.595, "zh": "桌子上有一个瓶子。", "zh_hant": "桌子上有一個瓶子。"}, {"index": 11, "text": "The bottle is empty.", "start": 55.315, "end": 57.736, "zh": "瓶子是空的。", "zh_hant": "瓶子是空的。"}, {"index": 12, "text": "There is a cup on the table, too.", "start": 59.136, "end": 62.816, "zh": "桌子上还有一个杯子。", "zh_hant": "桌子上還有一個杯子。"}, {"index": 13, "text": "The cup is clean.", "start": 63.816, "end": 66.256, "zh": "杯子是干净的。", "zh_hant": "杯子是乾淨的。"}]