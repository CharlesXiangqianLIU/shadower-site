[{"index": 0, "text": "Lesson 105", "start": 1.561, "end": 2.18, "zh": "第105课", "zh_hant": "第105課"}, {"index": 1, "text": "Full of mistakes", "start": 4.783, "end": 5.924, "zh": "满是错误", "zh_hant": "滿是錯誤"}, {"index": 2, "text": "Listen to the tape then answer this question.", "start": 7.385, "end": 10.647, "zh": "听录音,然后回答这个问题。", "zh_hant": "聽錄音,然後回答這個問題。"}, {"index": 3, "text": "What was Sandra's present?", "start": 13.169, "end": 15.03, "zh": "桑德拉的礼物是什么?", "zh_hant": "桑德拉的禮物是什麼?"}, {"index": 4, "text": "Where's Sandra, Bob?", "start": 17.792, "end": 19.133, "zh": "鲍勃,桑德拉在哪儿?", "zh_hant": "鮑勃,桑德拉在哪兒?"}, {"index": 5, "text": "I want her.", "start": 19.973, "end": 20.594, "zh": "我要见她。", "zh_hant": "我要見她。"}, {"index": 6, "text": "Do you want to speak to her?", "start": 22.255, "end": 23.315, "zh": "你想跟她说话吗?", "zh_hant": "你想跟她說話嗎?"}, {"index": 7, "text": "Yes, I do.", "start": 24.316, "end": 27.038, "zh": "是的,我想。", "zh_hant": "是的,我想。"}, {"index": 8, "text": "I want her to come to my office.", "start": 27.398, "end": 30.606, "zh": "我要她来我办公室。", "zh_hant": "我要她來我辦公室。"}, {"index": 9, "text": "Tell her to come at once.", "start": 30.606, "end": 31.496, "zh": "叫她马上过来。", "zh_hant": "叫她馬上過來。"}, {"index": 10, "text": "Did you want to see me?", "start": 31.957, "end": 33.077, "zh": "你要见我吗?", "zh_hant": "你要見我嗎?"}, {"index": 11, "text": "Ah, yes, Sandra.", "start": 34.218, "end": 35.519, "zh": "啊,是的,桑德拉。", "zh_hant": "啊,是的,桑德拉。"}, {"index": 12, "text": "How do you spell 'intelligent'?", "start": 36.36, "end": 38.682, "zh": "'intelligent'这个词怎么拼?", "zh_hant": "'intelligent'這個詞怎麼拼?"}, {"index": 13, "text": "Can you tell me?", "start": 39.202, "end": 40.022, "zh": "你能告诉我吗?", "zh_hant": "你能告訴我嗎?"}, {"index": 14, "text": "I-N-T-E-L-L-I-G-E-N-T.", "start": 41.984, "end": 48.989, "zh": "I-N-T-E-L-L-I-G-E-N-T。", "zh_hant": "I-N-T-E-L-L-I-G-E-N-T。"}, {"index": 15, "text": "That's right.", "start": 60.31, "end": 60.67, "zh": "没错。", "zh_hant": "沒錯。"}, {"index": 16, "text": "You've typed it with only one 'L'.", "start": 60.67, "end": 61.531, "zh": "你打字的时候只打了一个'L'。", "zh_hant": "你打字的時候只打了一個'L'。"}, {"index": 17, "text": "This letter's full of mistakes.", "start": 61.531, "end": 62.131, "zh": "这封信满是错误。", "zh_hant": "這封信滿是錯誤。"}, {"index": 18, "text": "I want you to type it again.", "start": 62.131, "end": 62.551, "zh": "我要你重新打一遍。", "zh_hant": "我要你重新打一遍。"}, {"index": 19, "text": "Yes, I'll do that.", "start": 62.551, "end": 62.831, "zh": "好的,我会的。", "zh_hant": "好的,我會的。"}, {"index": 20, "text": "I'm sorry about that.", "start": 62.831, "end": 63.752, "zh": "对此我很抱歉。", "zh_hant": "對此我很抱歉。"}, {"index": 21, "text": "And here's a little present for you.", "start": 65.013, "end": 67.334, "zh": "这里有一份小礼物给你。", "zh_hant": "這裡有一份小禮物給你。"}, {"index": 22, "text": "What is it?", "start": 67.854, "end": 68.495, "zh": "这是什么?", "zh_hant": "這是什麼?"}, {"index": 23, "text": "It's a dictionary.", "start": 69.475, "end": 71.156, "zh": "是一本词典。", "zh_hant": "是一本詞典。"}, {"index": 24, "text": "I hope it'll help you.", "start": 71.997, "end": 73.538, "zh": "希望它能帮到你。", "zh_hant": "希望它能幫到你。"}]