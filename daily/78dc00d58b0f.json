[{"index": 0, "text": "Lesson 105", "start": 1.561, "end": 2.18}, {"index": 1, "text": "Full of mistakes", "start": 4.783, "end": 5.924}, {"index": 2, "text": "Listen to the tape then answer this question.", "start": 7.385, "end": 10.647}, {"index": 3, "text": "What was Sandra's present?", "start": 13.169, "end": 15.03}, {"index": 4, "text": "Where's Sandra, Bob?", "start": 17.792, "end": 19.133}, {"index": 5, "text": "I want her.", "start": 19.973, "end": 20.594}, {"index": 6, "text": "Do you want to speak to her?", "start": 22.255, "end": 23.315}, {"index": 7, "text": "Yes, I do.", "start": 24.316, "end": 27.038}, {"index": 8, "text": "I want her to come to my office.", "start": 27.398, "end": 30.656}, {"index": 9, "text": "Tell her to come at once.", "start": 30.556, "end": 31.496}, {"index": 10, "text": "Did you want to see me?", "start": 31.957, "end": 33.077}, {"index": 11, "text": "Ah, yes, Sandra.", "start": 34.218, "end": 35.519}, {"index": 12, "text": "How do you spell 'intelligent'?", "start": 36.36, "end": 38.682}, {"index": 13, "text": "Can you tell me?", "start": 39.202, "end": 40.022}, {"index": 14, "text": "I-N-T-E-L-L-I-G-E-N-T.", "start": 41.984, "end": 48.989}, {"index": 15, "text": "That's right.", "start": 60.31, "end": 60.73}, {"index": 16, "text": "You've typed it with only one 'L'.", "start": 60.61, "end": 61.591}, {"index": 17, "text": "This letter's full of mistakes.", "start": 61.471, "end": 62.191}, {"index": 18, "text": "I want you to type it again.", "start": 62.071, "end": 62.611}, {"index": 19, "text": "Yes, I'll do that.", "start": 62.491, "end": 62.891}, {"index": 20, "text": "I'm sorry about that.", "start": 62.771, "end": 63.752}, {"index": 21, "text": "And here's a little present for you.", "start": 65.013, "end": 67.334}, {"index": 22, "text": "What is it?", "start": 67.854, "end": 68.495}, {"index": 23, "text": "It's a dictionary.", "start": 69.475, "end": 71.156}, {"index": 24, "text": "I hope it'll help you.", "start": 71.997, "end": 73.538}]