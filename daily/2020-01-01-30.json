[{"index": 0, "text": "Lesson 59", "start": 0.67, "end": 3.651, "zh": "第59课", "zh_hant": "第59課"}, {"index": 1, "text": "Is that all?", "start": 3.151, "end": 4.731, "zh": "就这些吗?", "zh_hant": "就這些嗎?"}, {"index": 2, "text": "Listen to the tape then answer this question.", "start": 6.191, "end": 10.672, "zh": "听录音,然后回答这个问题。", "zh_hant": "聽錄音,然後回答這個問題。"}, {"index": 3, "text": "Does the lady buy any chalk?", "start": 11.732, "end": 14.532, "zh": "这位女士买粉笔了吗?", "zh_hant": "這位女士買粉筆了嗎?"}, {"index": 4, "text": "I want some envelopes, please.", "start": 16.493, "end": 19.653, "zh": "请给我一些信封。", "zh_hant": "請給我一些信封。"}, {"index": 5, "text": "Do you want the large size or the small size?", "start": 20.153, "end": 24.294, "zh": "您要大号的还是小号的?", "zh_hant": "您要大號的還是小號的?"}, {"index": 6, "text": "The large size, please.", "start": 25.194, "end": 27.815, "zh": "请给我大号的。", "zh_hant": "請給我大號的。"}, {"index": 7, "text": "Do you have any writing paper?", "start": 28.535, "end": 31.575, "zh": "你们有信纸吗?", "zh_hant": "你們有信紙嗎?"}, {"index": 8, "text": "Yes, we do.", "start": 31.795, "end": 33.196, "zh": "有的。", "zh_hant": "有的。"}, {"index": 9, "text": "I don't have any small pads.", "start": 34.536, "end": 37.796, "zh": "我没有小号的便笺本。", "zh_hant": "我沒有小號的便箋本。"}, {"index": 10, "text": "I only have large ones.", "start": 38.457, "end": 41.077, "zh": "我只有大号的。", "zh_hant": "我只有大號的。"}, {"index": 11, "text": "Do you want a pad?", "start": 41.557, "end": 43.817, "zh": "您要一个便笺本吗?", "zh_hant": "您要一個便箋本嗎?"}, {"index": 12, "text": "Yes, please.", "start": 44.158, "end": 46.038, "zh": "好的,请给我一个。", "zh_hant": "好的,請給我一個。"}, {"index": 13, "text": "And I want some glue.", "start": 46.438, "end": 48.978, "zh": "我还要一些胶水。", "zh_hant": "我還要一些膠水。"}, {"index": 14, "text": "A bottle of glue.", "start": 49.859, "end": 51.779, "zh": "一瓶胶水。", "zh_hant": "一瓶膠水。"}, {"index": 15, "text": "And I want a large box of chalk, too.", "start": 53.079, "end": 57.66, "zh": "我还要一大盒粉笔。", "zh_hant": "我還要一大盒粉筆。"}, {"index": 16, "text": "I only have small boxes.", "start": 58.34, "end": 61.14, "zh": "我只有小盒的。", "zh_hant": "我只有小盒的。"}, {"index": 17, "text": "Do you want one?", "start": 61.361, "end": 62.921, "zh": "您要一盒吗?", "zh_hant": "您要一盒嗎?"}, {"index": 18, "text": "No, thank you.", "start": 63.041, "end": 64.441, "zh": "不用了,谢谢。", "zh_hant": "不用了,謝謝。"}, {"index": 19, "text": "Is that all?", "start": 64.901, "end": 66.361, "zh": "就这些吗?", "zh_hant": "就這些嗎?"}, {"index": 20, "text": "That's all, thank you.", "start": 66.481, "end": 68.882, "zh": "就这些,谢谢。", "zh_hant": "就這些,謝謝。"}, {"index": 21, "text": "What else do you want?", "start": 69.222, "end": 71.202, "zh": "您还要别的吗?", "zh_hant": "您還要別的嗎?"}, {"index": 22, "text": "I want my change.", "start": 71.762, "end": 74.343, "zh": "我要找零。", "zh_hant": "我要找零。"}]