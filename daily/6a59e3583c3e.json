[{"index": 0, "text": "Lesson 21", "start": 1.581, "end": 1.91}, {"index": 1, "text": "Which book?", "start": 4.223, "end": 5.223}, {"index": 2, "text": "Listen to the tape then answer this question.", "start": 6.705, "end": 10.387}, {"index": 3, "text": "Which book does the man want?", "start": 12.949, "end": 15.43}, {"index": 4, "text": "Give me a book please, Jane.", "start": 18.252, "end": 20.414}, {"index": 5, "text": "Which book?", "start": 21.955, "end": 22.795}, {"index": 6, "text": "This one?", "start": 24.136, "end": 24.736}, {"index": 7, "text": "No, not that one. The red one.", "start": 25.977, "end": 29.68}, {"index": 8, "text": "This one?", "start": 29.58, "end": 31.426}, {"index": 9, "text": "Yes, please.", "start": 32.387, "end": 33.588}, {"index": 10, "text": "Here you are.", "start": 34.568, "end": 35.529}, {"index": 11, "text": "Thank you.", "start": 36.55, "end": 37.01}]