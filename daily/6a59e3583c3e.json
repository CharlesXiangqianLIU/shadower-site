[{"index": 0, "text": "Lesson 21", "start": 1.581, "end": 1.91, "zh": "第21课", "zh_hant": "第21課"}, {"index": 1, "text": "Which book?", "start": 4.223, "end": 5.223, "zh": "哪本书?", "zh_hant": "哪本書?"}, {"index": 2, "text": "Listen to the tape then answer this question.", "start": 6.705, "end": 10.387, "zh": "先听录音,然后回答这个问题。", "zh_hant": "先聽錄音,然後回答這個問題。"}, {"index": 3, "text": "Which book does the man want?", "start": 12.949, "end": 15.43, "zh": "这个男人想要哪本书?", "zh_hant": "這個男人想要哪本書?"}, {"index": 4, "text": "Give me a book please, Jane.", "start": 18.252, "end": 20.414, "zh": "简,请给我一本书。", "zh_hant": "簡,請給我一本書。"}, {"index": 5, "text": "Which book?", "start": 21.955, "end": 22.795, "zh": "哪本书?", "zh_hant": "哪本書?"}, {"index": 6, "text": "This one?", "start": 24.136, "end": 24.736, "zh": "这本?", "zh_hant": "這本?"}, {"index": 7, "text": "No, not that one. The red one.", "start": 25.977, "end": 29.63, "zh": "不,不是那本。红色的那本。", "zh_hant": "不,不是那本。紅色的那本。"}, {"index": 8, "text": "This one?", "start": 29.63, "end": 31.426, "zh": "这本?", "zh_hant": "這本?"}, {"index": 9, "text": "Yes, please.", "start": 32.387, "end": 33.588, "zh": "对,就是它。", "zh_hant": "對,就是它。"}, {"index": 10, "text": "Here you are.", "start": 34.568, "end": 35.529, "zh": "给你。", "zh_hant": "給你。"}, {"index": 11, "text": "Thank you.", "start": 36.55, "end": 37.01, "zh": "谢谢。", "zh_hant": "謝謝。"}]