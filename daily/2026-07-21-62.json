[{"index": 0, "text": "I need your advice.", "start": 0.0, "end": 1.07, "zh": "我需要你的建议。", "zh_hant": "我需要你的建議。"}, {"index": 1, "text": "I need your help.", "start": 0.67, "end": 1.631, "zh": "我需要你的帮助。", "zh_hant": "我需要你的幫助。"}, {"index": 2, "text": "Because I'm off to Paris in a few weeks for the Olympics.", "start": 1.231, "end": 4.733, "zh": "因为我几周后要去巴黎看奥运会。", "zh_hant": "因為我幾周後要去巴黎看奧運會。"}, {"index": 3, "text": "How do I not look like a tourist?", "start": 4.393, "end": 6.354, "zh": "我怎样才能不像个游客?", "zh_hant": "我怎樣才能不像個遊客?"}, {"index": 4, "text": "I want to respect.", "start": 5.954, "end": 7.374, "zh": "我想表示尊重。", "zh_hant": "我想表示尊重。"}, {"index": 5, "text": "This is respect to Paris, respect to France.", "start": 7.234, "end": 10.156, "zh": "这是对巴黎的尊重,对法国的尊重。", "zh_hant": "這是對巴黎的尊重,對法國的尊重。"}, {"index": 6, "text": "There's a lot of things.", "start": 9.996, "end": 11.437, "zh": "有很多事情要注意。", "zh_hant": "有很多事情要注意。"}, {"index": 7, "text": "Okay, no flip -flops.", "start": 11.777, "end": 13.278, "zh": "好的,不要穿人字拖。", "zh_hant": "好的,不要穿人字拖。"}, {"index": 8, "text": "Okay.", "start": 13.298, "end": 14.018, "zh": "好的。", "zh_hant": "好的。"}, {"index": 9, "text": "No flip -flops at all.", "start": 13.818, "end": 15.099, "zh": "完全不要穿人字拖。", "zh_hant": "完全不要穿人字拖。"}, {"index": 10, "text": "Christians don't wear flip -flops.", "start": 14.699, "end": 16.179, "zh": "巴黎人不穿人字拖。", "zh_hant": "巴黎人不穿人字拖。"}, {"index": 11, "text": "No shorts.", "start": 16.22, "end": 17.24, "zh": "不要穿短裤。", "zh_hant": "不要穿短褲。"}, {"index": 12, "text": "Okay.", "start": 17.761, "end": 18.501, "zh": "好的。", "zh_hant": "好的。"}, {"index": 13, "text": "Even in summer?", "start": 18.281, "end": 19.401, "zh": "就算夏天也不行吗?", "zh_hant": "就算夏天也不行嗎?"}, {"index": 14, "text": "It's a, like, you know it's an American if they're wearing shorts.", "start": 19.161, "end": 22.643, "zh": "一看穿短裤的,就知道是美国人。", "zh_hant": "一看穿短褲的,就知道是美國人。"}, {"index": 15, "text": "Okay.", "start": 22.243, "end": 23.003, "zh": "好的。", "zh_hant": "好的。"}, {"index": 16, "text": "Really?", "start": 23.404, "end": 24.084, "zh": "真的吗?", "zh_hant": "真的嗎?"}, {"index": 17, "text": "Okay.", "start": 23.684, "end": 24.364, "zh": "好的。", "zh_hant": "好的。"}, {"index": 18, "text": "This is all good.", "start": 23.964, "end": 25.085, "zh": "这些都没问题。", "zh_hant": "這些都沒問題。"}, {"index": 19, "text": "Red berets.", "start": 25.005, "end": 26.165, "zh": "红色贝雷帽。", "zh_hant": "紅色貝雷帽。"}, {"index": 20, "text": "Red berets.", "start": 26.466, "end": 27.566, "zh": "红色贝雷帽。", "zh_hant": "紅色貝雷帽。"}, {"index": 21, "text": "Funny.", "start": 27.726, "end": 28.387, "zh": "有点搞笑。", "zh_hant": "有點搞笑。"}, {"index": 22, "text": "It's cool.", "start": 28.747, "end": 29.567, "zh": "挺酷的。", "zh_hant": "挺酷的。"}, {"index": 23, "text": "No. Oh. It's a no -go.", "start": 29.427, "end": 32.609, "zh": "不。哦,这个不行。", "zh_hant": "不。哦,這個不行。"}, {"index": 24, "text": "It's a no -go.", "start": 32.309, "end": 33.45, "zh": "这个不行。", "zh_hant": "這個不行。"}, {"index": 25, "text": "It's a no -go.", "start": 33.23, "end": 34.15, "zh": "这个不行。", "zh_hant": "這個不行。"}]