[{"index": 0, "text": "I need your advice.", "start": 0.0, "end": 0.79, "zh": "我需要你的建议。", "zh_hant": "我需要你的建議。"}, {"index": 1, "text": "I need your help.", "start": 0.79, "end": 1.36, "zh": "我需要你的帮助。", "zh_hant": "我需要你的幫助。"}, {"index": 2, "text": "Because I'm off to Paris in a few weeks for the Olympics.", "start": 1.36, "end": 4.521, "zh": "因为再过几周我就要去巴黎看奥运会了。", "zh_hant": "因為再過幾周我就要去巴黎看奧運會了。"}, {"index": 3, "text": "How do I not look like a tourist?", "start": 4.521, "end": 6.071, "zh": "我怎样才能看起来不像个游客？", "zh_hant": "我怎樣才能看起來不像個遊客？"}, {"index": 4, "text": "I want to respect.", "start": 6.071, "end": 7.201, "zh": "我想表示尊重。", "zh_hant": "我想表示尊重。"}, {"index": 5, "text": "This is respect to Paris, respect to France.", "start": 7.201, "end": 9.982, "zh": "这是对巴黎的尊重，对法国的尊重。", "zh_hant": "這是對巴黎的尊重，對法國的尊重。"}, {"index": 6, "text": "There's a lot of things.", "start": 9.982, "end": 11.262, "zh": "有很多事情要注意。", "zh_hant": "有很多事情要注意。"}, {"index": 7, "text": "Okay, no flip -flops.", "start": 11.722, "end": 13.122, "zh": "好，不穿人字拖。", "zh_hant": "好，不穿人字拖。"}, {"index": 8, "text": "Okay. No flip -flops at all.", "start": 13.243, "end": 15.043, "zh": "好，绝对不穿人字拖。", "zh_hant": "好，絕對不穿人字拖。"}, {"index": 9, "text": "Christians don't wear flip -flops.", "start": 14.843, "end": 16.023, "zh": "法国人不穿人字拖。", "zh_hant": "法國人不穿人字拖。"}, {"index": 10, "text": "No shorts.", "start": 16.163, "end": 17.083, "zh": "不穿短裤。", "zh_hant": "不穿短褲。"}, {"index": 11, "text": "Okay. Even in summer?", "start": 17.703, "end": 19.244, "zh": "好，就算夏天也不穿吗？", "zh_hant": "好，就算夏天也不穿嗎？"}, {"index": 12, "text": "It's a, like, you know it's an American if they're wearing shorts.", "start": 19.174, "end": 22.334, "zh": "一看你穿短裤，就知道你是美国人。", "zh_hant": "一看你穿短褲，就知道你是美國人。"}, {"index": 13, "text": "Okay. Really?", "start": 22.184, "end": 23.964, "zh": "好，真的吗？", "zh_hant": "好，真的嗎？"}, {"index": 14, "text": "Okay. This is all good.", "start": 23.624, "end": 24.925, "zh": "好，这些都记下了。", "zh_hant": "好，這些都記下了。"}, {"index": 15, "text": "Red berets.", "start": 24.945, "end": 26.005, "zh": "红色贝雷帽。", "zh_hant": "紅色貝雷帽。"}, {"index": 16, "text": "Red berets.", "start": 26.405, "end": 27.405, "zh": "红色贝雷帽。", "zh_hant": "紅色貝雷帽。"}, {"index": 17, "text": "Funny. It's cool.", "start": 27.665, "end": 29.405, "zh": "挺搞笑的，不过还挺酷。", "zh_hant": "挺搞笑的，不過還挺酷。"}, {"index": 18, "text": "No. Oh. It's a no -go.", "start": 29.366, "end": 32.446, "zh": "不行，这个不行。", "zh_hant": "不行，這個不行。"}, {"index": 19, "text": "It's a no -go.", "start": 32.346, "end": 33.226, "zh": "这个不行。", "zh_hant": "這個不行。"}, {"index": 20, "text": "It's a no -go.", "start": 33.226, "end": 33.966, "zh": "这个不行。", "zh_hant": "這個不行。"}]