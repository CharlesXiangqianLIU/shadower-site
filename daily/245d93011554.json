[{"index": 0, "text": "Lesson 125", "start": 1.571, "end": 2.285, "zh": "第125课"}, {"index": 1, "text": "Tea for two", "start": 4.872, "end": 5.913, "zh": "两人共饮"}, {"index": 2, "text": "Listen to the tape then answer this question.", "start": 7.674, "end": 10.995, "zh": "听录音，然后回答问题。"}, {"index": 3, "text": "Does Susan have tea by herself?", "start": 13.577, "end": 16.018, "zh": "苏珊是一个人喝茶吗？"}, {"index": 4, "text": "Can't you come in and have tea now, Peter?", "start": 18.679, "end": 21.08, "zh": "彼得，你现在能不能进来喝杯茶？"}, {"index": 5, "text": "Not yet.", "start": 22.241, "end": 22.821, "zh": "还不行。"}, {"index": 6, "text": "I must water the garden first.", "start": 23.462, "end": 25.322, "zh": "我得先给花园浇水。"}, {"index": 7, "text": "Do you have to water it now?", "start": 26.563, "end": 28.324, "zh": "你非得现在浇水吗？"}, {"index": 8, "text": "I'm afraid I must.", "start": 29.224, "end": 30.51, "zh": "恐怕是的。"}, {"index": 9, "text": "Look at it!", "start": 31.151, "end": 31.831, "zh": "你看看它！"}, {"index": 10, "text": "It's terribly dry.", "start": 32.211, "end": 33.732, "zh": "干得不成样子了。"}, {"index": 11, "text": "What a nuisance!", "start": 34.532, "end": 35.713, "zh": "真麻烦！"}, {"index": 12, "text": "Last summer it was very dry, too.", "start": 36.733, "end": 39.114, "zh": "去年夏天也很干旱。"}, {"index": 13, "text": "Don't you remember?", "start": 39.775, "end": 40.615, "zh": "你不记得了吗？"}, {"index": 14, "text": "I had to water it every day.", "start": 41.275, "end": 43.176, "zh": "我那时得天天浇水。"}, {"index": 15, "text": "Well, I'll have tea by myself.", "start": 44.177, "end": 46.217, "zh": "好吧，那我就自己喝茶了。"}, {"index": 16, "text": "That was quick!", "start": 48.118, "end": 49.039, "zh": "这么快！"}, {"index": 17, "text": "Have you finished already?", "start": 49.239, "end": 50.379, "zh": "你已经浇完了？"}, {"index": 18, "text": "Yes.", "start": 51.02, "end": 51.44, "zh": "是的。"}, {"index": 19, "text": "Look out of the window.", "start": 52.1, "end": 60.146, "zh": "往窗外看看。"}, {"index": 20, "text": "It's raining!", "start": 60.267, "end": 61.247, "zh": "下雨了！"}, {"index": 21, "text": "That means you don't need to water the garden.", "start": 61.247, "end": 62.589, "zh": "这就是说你不用给花园浇水了。"}, {"index": 22, "text": "That was a pleasant surprise.", "start": 62.589, "end": 65.812, "zh": "真是个惊喜。"}, {"index": 23, "text": "It means I can have tea, instead.", "start": 65.812, "end": 67.854, "zh": "这意味着我可以喝茶了。"}]