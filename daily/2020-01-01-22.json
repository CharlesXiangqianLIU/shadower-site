[{"index": 0, "text": "Lesson 43 Hurry up!", "start": 0.75, "end": 4.491, "zh": "第43课 快点!", "zh_hant": "第43課 快點!"}, {"index": 1, "text": "Listen to the tape then answer this question.", "start": 5.732, "end": 10.193, "zh": "听录音,然后回答这个问题。", "zh_hant": "聽錄音,然後回答這個問題。"}, {"index": 2, "text": "How do you know Sam doesn't make the tea very often?", "start": 11.273, "end": 16.535, "zh": "你怎么知道山姆不常泡茶?", "zh_hant": "你怎麼知道山姆不常泡茶?"}, {"index": 3, "text": "Can you make the tea, Sam?", "start": 18.135, "end": 21.056, "zh": "你会泡茶吗,山姆?", "zh_hant": "你會泡茶嗎,山姆?"}, {"index": 4, "text": "Yes, of course I can, Penny.", "start": 22.157, "end": 25.598, "zh": "当然会,潘妮。", "zh_hant": "當然會,潘妮。"}, {"index": 5, "text": "Is there any water in this kettle?", "start": 27.278, "end": 30.239, "zh": "这个水壶里有水吗?", "zh_hant": "這個水壺裡有水嗎?"}, {"index": 6, "text": "Yes, there is.", "start": 31.039, "end": 32.92, "zh": "有。", "zh_hant": "有。"}, {"index": 7, "text": "Where's the tea?", "start": 33.6, "end": 35.06, "zh": "茶叶在哪儿?", "zh_hant": "茶葉在哪兒?"}, {"index": 8, "text": "It's over there, behind the teapot.", "start": 35.341, "end": 39.302, "zh": "在那边,茶壶后面。", "zh_hant": "在那邊,茶壺後面。"}, {"index": 9, "text": "Can you see it?", "start": 40.922, "end": 42.483, "zh": "你看得见吗?", "zh_hant": "你看得見嗎?"}, {"index": 10, "text": "I can see the teapot, but I can't see the tea.", "start": 43.683, "end": 49.345, "zh": "我看得见茶壶,但看不见茶叶。", "zh_hant": "我看得見茶壺,但看不見茶葉。"}, {"index": 11, "text": "There it is!", "start": 49.745, "end": 51.265, "zh": "在那儿!", "zh_hant": "在那兒!"}, {"index": 12, "text": "It's in front of you!", "start": 51.305, "end": 53.146, "zh": "就在你面前!", "zh_hant": "就在你面前!"}, {"index": 13, "text": "Ah yes, I can see it now.", "start": 53.586, "end": 57.767, "zh": "啊,对,我现在看见了。", "zh_hant": "啊,對,我現在看見了。"}, {"index": 14, "text": "Where are the cups?", "start": 58.748, "end": 60.608, "zh": "杯子在哪儿?", "zh_hant": "杯子在哪兒?"}, {"index": 15, "text": "There are some in the cupboard.", "start": 61.188, "end": 63.749, "zh": "橱柜里有几个。", "zh_hant": "櫥櫃裡有幾個。"}, {"index": 16, "text": "Can you find them?", "start": 64.029, "end": 65.87, "zh": "你能找到吗?", "zh_hant": "你能找到嗎?"}, {"index": 17, "text": "Yes.", "start": 66.33, "end": 67.33, "zh": "是的。", "zh_hant": "是的。"}, {"index": 18, "text": "Here they are.", "start": 67.11, "end": 68.691, "zh": "他们来了。", "zh_hant": "他們來了。"}, {"index": 19, "text": "Hurry up, Sam!", "start": 69.131, "end": 70.851, "zh": "快点,山姆!", "zh_hant": "快點,山姆!"}, {"index": 20, "text": "The kettle's boiling!", "start": 71.031, "end": 73.072, "zh": "水壶开了!", "zh_hant": "水壺開了!"}]