[{"index": 0, "text": "Lesson 97 A small blue case Listen to the tape then answer this question.", "start": 0.53, "end": 11.612, "zh": "第97课 一个小蓝箱子 听录音,然后回答这个问题。", "zh_hant": "第97課 一個小藍箱子 聽錄音,然後回答這個問題。"}, {"index": 1, "text": "Does Mr. Hall get his case back?", "start": 12.793, "end": 16.493, "zh": "霍尔先生找回他的箱子了吗?", "zh_hant": "霍爾先生找回他的箱子了嗎?"}, {"index": 2, "text": "I left a suitcase on the train to London the other day.", "start": 18.614, "end": 23.655, "zh": "前几天我把一个手提箱落在开往伦敦的火车上了。", "zh_hant": "前幾天我把一個手提箱落在開往倫敦的火車上了。"}, {"index": 3, "text": "Can you describe it, sir?", "start": 24.315, "end": 26.756, "zh": "先生,您能描述一下吗?", "zh_hant": "先生,您能描述一下嗎?"}, {"index": 4, "text": "It's a small blue case and it's got a zip.", "start": 27.796, "end": 32.917, "zh": "这是一个蓝色小箱子,上面有拉链。", "zh_hant": "這是一個藍色小箱子,上面有拉鍊。"}, {"index": 5, "text": "There's a label on the handle with my name and address on it.", "start": 34.237, "end": 39.858, "zh": "提手上有个标签,写着我的名字和地址。", "zh_hant": "提手上有個標籤,寫著我的名字和地址。"}, {"index": 6, "text": "Is this case yours?", "start": 40.378, "end": 42.739, "zh": "这个箱子是您的吗?", "zh_hant": "這個箱子是您的嗎?"}, {"index": 7, "text": "No, that's not mine.", "start": 43.099, "end": 45.419, "zh": "不,那不是我的。", "zh_hant": "不,那不是我的。"}, {"index": 8, "text": "What about this one?", "start": 45.8, "end": 48.14, "zh": "那这个呢?", "zh_hant": "那這個呢?"}, {"index": 9, "text": "This one's got a label.", "start": 48.22, "end": 50.641, "zh": "这个上面有标签。", "zh_hant": "這個上面有標籤。"}, {"index": 10, "text": "Let me see it.", "start": 51.561, "end": 53.241, "zh": "我看看。", "zh_hant": "我看看。"}, {"index": 11, "text": "What's your name and address?", "start": 53.921, "end": 56.642, "zh": "您的姓名和地址是什么?", "zh_hant": "您的姓名和地址是什麼?"}, {"index": 12, "text": "David Hall, 83, Bridge Street.", "start": 57.522, "end": 62.143, "zh": "大卫·霍尔,桥街83号。", "zh_hant": "大衛·霍爾,橋街83號。"}, {"index": 13, "text": "That's right.", "start": 62.543, "end": 63.763, "zh": "没错。", "zh_hant": "沒錯。"}, {"index": 14, "text": "D. N. Hall, 83, Bridge Street.", "start": 64.063, "end": 68.764, "zh": "D·N·霍尔,桥街83号。", "zh_hant": "D·N·霍爾,橋街83號。"}, {"index": 15, "text": "Three pounds fifty pence, please.", "start": 69.965, "end": 73.185, "zh": "三英镑五十便士,谢谢。", "zh_hant": "三英鎊五十便士,謝謝。"}, {"index": 16, "text": "Here you are.", "start": 73.705, "end": 75.266, "zh": "给您。", "zh_hant": "給您。"}, {"index": 17, "text": "Thank you.", "start": 75.486, "end": 76.446, "zh": "谢谢。", "zh_hant": "謝謝。"}, {"index": 18, "text": "Hey!", "start": 76.846, "end": 77.726, "zh": "嘿!", "zh_hant": "嘿!"}, {"index": 19, "text": "What's the matter?", "start": 78.066, "end": 79.547, "zh": "怎么了?", "zh_hant": "怎麼了?"}, {"index": 20, "text": "This case doesn't belong to me!", "start": 80.087, "end": 83.107, "zh": "这个箱子不是我的!", "zh_hant": "這個箱子不是我的!"}, {"index": 21, "text": "You've given me the wrong case!", "start": 84.528, "end": 87.468, "zh": "你把箱子拿错了!", "zh_hant": "你把箱子拿錯了!"}]