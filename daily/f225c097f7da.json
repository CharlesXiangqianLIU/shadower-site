[{"index": 0, "text": "Lesson 39", "start": 1.54, "end": 2.245, "zh": "第39课", "zh_hant": "第39課"}, {"index": 1, "text": "Don't drop it!", "start": 4.401, "end": 5.382, "zh": "别把它掉了！", "zh_hant": "別把它掉了！"}, {"index": 2, "text": "Listen to the tape then answer this question.", "start": 6.982, "end": 10.823, "zh": "听录音，然后回答这个问题。", "zh_hant": "聽錄音，然後回答這個問題。"}, {"index": 3, "text": "Where does Sam put the vase in the end?", "start": 13.404, "end": 16.945, "zh": "萨姆最后把花瓶放在哪里？", "zh_hant": "薩姆最後把花瓶放在哪裡？"}, {"index": 4, "text": "What are you going to do with that vase, Penny?", "start": 19.746, "end": 22.387, "zh": "佩妮，你打算拿这个花瓶做什么？", "zh_hant": "佩妮，你打算拿這個花瓶做什麼？"}, {"index": 5, "text": "I'm going to put it on this table, Sam.", "start": 24.048, "end": 26.909, "zh": "萨姆，我打算把它放在这张桌子上。", "zh_hant": "薩姆，我打算把它放在這張桌子上。"}, {"index": 6, "text": "Don't do that.", "start": 28.529, "end": 30.53, "zh": "别那样做。", "zh_hant": "別那樣做。"}, {"index": 7, "text": "Give it to me.", "start": 30.53, "end": 31.431, "zh": "把它给我。", "zh_hant": "把它給我。"}, {"index": 8, "text": "What are you going to do with it?", "start": 32.612, "end": 34.793, "zh": "你打算拿它怎么办？", "zh_hant": "你打算拿它怎麼辦？"}, {"index": 9, "text": "I'm going to put it here, in front of the window.", "start": 36.034, "end": 39.856, "zh": "我打算把它放在这儿，窗户前面。", "zh_hant": "我打算把它放在這兒，窗戶前面。"}, {"index": 10, "text": "Be careful! Don't drop it!", "start": 41.297, "end": 43.859, "zh": "小心点！别把它摔了！", "zh_hant": "小心點！別把它摔了！"}, {"index": 11, "text": "Don't put it there, Sam.", "start": 45.96, "end": 47.741, "zh": "萨姆，别把它放在那儿。", "zh_hant": "薩姆，別把它放在那兒。"}, {"index": 12, "text": "Put it here, on this shelf.", "start": 48.342, "end": 50.863, "zh": "把它放在这儿，这个架子上。", "zh_hant": "把它放在這兒，這個架子上。"}, {"index": 13, "text": "There we are!", "start": 52.805, "end": 53.785, "zh": "好啦！", "zh_hant": "好啦！"}, {"index": 14, "text": "It's a lovely vase.", "start": 54.586, "end": 56.467, "zh": "这是个漂亮的花瓶。", "zh_hant": "這是個漂亮的花瓶。"}, {"index": 15, "text": "Those flowers are lovely, too.", "start": 57.068, "end": 62.409, "zh": "那些花也很漂亮。", "zh_hant": "那些花也很漂亮。"}]