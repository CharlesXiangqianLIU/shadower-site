[{"index": 0, "text": "Lesson 39", "start": 1.54, "end": 2.245}, {"index": 1, "text": "Don't drop it!", "start": 4.401, "end": 5.382}, {"index": 2, "text": "Listen to the tape then answer this question.", "start": 6.982, "end": 10.823}, {"index": 3, "text": "Where does Sam put the vase in the end?", "start": 13.404, "end": 16.945}, {"index": 4, "text": "What are you going to do with that vase, Penny?", "start": 19.746, "end": 22.387}, {"index": 5, "text": "I'm going to put it on this table, Sam.", "start": 24.048, "end": 26.909}, {"index": 6, "text": "Don't do that.", "start": 28.529, "end": 30.53}, {"index": 7, "text": "Give it to me.", "start": 30.53, "end": 31.431}, {"index": 8, "text": "What are you going to do with it?", "start": 32.612, "end": 34.793}, {"index": 9, "text": "I'm going to put it here, in front of the window.", "start": 36.034, "end": 39.856}, {"index": 10, "text": "Be careful! Don't drop it!", "start": 41.297, "end": 43.859}, {"index": 11, "text": "Don't put it there, Sam.", "start": 45.96, "end": 47.741}, {"index": 12, "text": "Put it here, on this shelf.", "start": 48.342, "end": 50.863}, {"index": 13, "text": "There we are!", "start": 52.805, "end": 53.785}, {"index": 14, "text": "It's a lovely vase.", "start": 54.586, "end": 56.467}, {"index": 15, "text": "Those flowers are lovely, too.", "start": 57.068, "end": 62.409}]