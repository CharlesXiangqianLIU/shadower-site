[{"index": 0, "text": "Lesson 1", "start": 1.55, "end": 1.96}, {"index": 1, "text": "Excuse me!", "start": 3.151, "end": 3.871}, {"index": 2, "text": "Listen to the tape then answer this question.", "start": 5.332, "end": 8.413}, {"index": 3, "text": "Whose handbag is it?", "start": 10.894, "end": 12.554}, {"index": 4, "text": "Excuse me!", "start": 15.235, "end": 15.835}, {"index": 5, "text": "Yes?", "start": 16.895, "end": 17.496}, {"index": 6, "text": "Is this your handbag?", "start": 18.356, "end": 20.217}, {"index": 7, "text": "Pardon?", "start": 21.417, "end": 21.937}, {"index": 8, "text": "Is this your handbag?", "start": 23.178, "end": 25.278}, {"index": 9, "text": "Yes it is.", "start": 26.419, "end": 27.999}, {"index": 10, "text": "Thank you very much.", "start": 30.28, "end": 32.4}]