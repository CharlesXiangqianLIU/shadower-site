[{"index": 0, "text": "I just took a DNA test.", "start": 0.0, "end": 1.911, "zh": "我刚做了个DNA检测。", "zh_hant": "我剛做了個DNA檢測。"}, {"index": 1, "text": "Turns out...", "start": 2.152, "end": 3.312, "zh": "结果发现……", "zh_hant": "結果發現……"}, {"index": 2, "text": "I'm 100 % that bitch.", "start": 3.993, "end": 6.394, "zh": "我百分之百就是那个女人。", "zh_hant": "我百分之百就是那個女人。"}, {"index": 3, "text": "I did.", "start": 6.735, "end": 7.395, "zh": "是真的。", "zh_hant": "是真的。"}, {"index": 4, "text": "I took a DNA test, and it said that I was... It says I'm 51 % Jewish.", "start": 6.995, "end": 12.138, "zh": "我做了个DNA检测,结果说我……说我51%是犹太人。", "zh_hant": "我做了個DNA檢測,結果說我……說我51%是猶太人。"}, {"index": 5, "text": "And 49 % Irish Catholic.", "start": 13.619, "end": 16.941, "zh": "49%是爱尔兰天主教徒。", "zh_hant": "49%是愛爾蘭天主教徒。"}, {"index": 6, "text": "Yes.", "start": 17.142, "end": 18.462, "zh": "没错。", "zh_hant": "沒錯。"}, {"index": 7, "text": "So that means 100 % shame and guilt.", "start": 18.563, "end": 22.265, "zh": "所以加起来就是百分之百的羞愧和愧疚。", "zh_hant": "所以加起來就是百分之百的羞愧和愧疚。"}, {"index": 8, "text": "It's great to be Jewish.", "start": 21.965, "end": 24.346, "zh": "身为犹太人真好。", "zh_hant": "身為猶太人真好。"}, {"index": 9, "text": "Yeah, yeah.", "start": 23.946, "end": 25.147, "zh": "对,对。", "zh_hant": "對,對。"}, {"index": 10, "text": "It's great to be Jewish.", "start": 25.587, "end": 27.168, "zh": "身为犹太人真好。", "zh_hant": "身為猶太人真好。"}, {"index": 11, "text": "Rosh Hashanah.", "start": 26.908, "end": 27.929, "zh": "犹太新年快乐。", "zh_hant": "猶太新年快樂。"}, {"index": 12, "text": "L'shanah tovah, everybody.", "start": 27.529, "end": 29.05, "zh": "新年快乐,各位。", "zh_hant": "新年快樂,各位。"}, {"index": 13, "text": "Yeah.", "start": 28.65, "end": 29.31, "zh": "是啊。", "zh_hant": "是啊。"}]