[{"index": 0, "text": "I just took a DNA test.", "start": 0.0, "end": 1.761, "zh": "我刚做了个DNA检测。", "zh_hant": "我剛做了個DNA檢測。"}, {"index": 1, "text": "Turns out...", "start": 2.102, "end": 3.162, "zh": "结果发现……", "zh_hant": "結果發現……"}, {"index": 2, "text": "I'm 100 % that bitch.", "start": 3.943, "end": 6.244, "zh": "我百分之百就是那种人。", "zh_hant": "我百分之百就是那種人。"}, {"index": 3, "text": "I did.", "start": 6.685, "end": 7.105, "zh": "没错。", "zh_hant": "沒錯。"}, {"index": 4, "text": "I took a DNA test, and it said that I was...", "start": 7.105, "end": 9.126, "zh": "我做了DNA检测,结果显示我……", "zh_hant": "我做了DNA檢測,結果顯示我……"}, {"index": 5, "text": "It says I'm 51 % Jewish.", "start": 9.527, "end": 11.968, "zh": "上面说我51%是犹太人。", "zh_hant": "上面說我51%是猶太人。"}, {"index": 6, "text": "And 49 % Irish Catholic.", "start": 13.569, "end": 16.791, "zh": "49%是爱尔兰天主教徒。", "zh_hant": "49%是愛爾蘭天主教徒。"}, {"index": 7, "text": "Yes.", "start": 17.092, "end": 18.312, "zh": "是的。", "zh_hant": "是的。"}, {"index": 8, "text": "So that means 100 % shame and guilt.", "start": 18.513, "end": 21.965, "zh": "所以那就是百分之百的羞愧和愧疚。", "zh_hant": "所以那就是百分之百的羞愧和愧疚。"}, {"index": 9, "text": "It's great to be Jewish.", "start": 21.965, "end": 24.056, "zh": "身为犹太人真好。", "zh_hant": "身為猶太人真好。"}, {"index": 10, "text": "Yeah, yeah.", "start": 24.056, "end": 24.997, "zh": "没错,没错。", "zh_hant": "沒錯,沒錯。"}, {"index": 11, "text": "It's great to be Jewish.", "start": 25.538, "end": 26.938, "zh": "身为犹太人真好。", "zh_hant": "身為猶太人真好。"}, {"index": 12, "text": "Rosh Hashanah.", "start": 26.938, "end": 27.669, "zh": "犹太新年。", "zh_hant": "猶太新年。"}, {"index": 13, "text": "L'shanah tovah, everybody.", "start": 27.669, "end": 28.79, "zh": "祝大家新年快乐。", "zh_hant": "祝大家新年快樂。"}, {"index": 14, "text": "Yeah.", "start": 28.79, "end": 29.16, "zh": "是啊。", "zh_hant": "是啊。"}]