[{"index": 0, "text": "Lesson 37 Making a bookcase Listen to the tape then answer this question.", "start": 0.51, "end": 10.633, "zh": "第37课 制作书柜 听录音，然后回答问题。", "zh_hant": "第37課 製作書櫃 聽錄音，然後回答問題。"}, {"index": 1, "text": "What is Susan's favourite colour?", "start": 12.274, "end": 15.475, "zh": "苏珊最喜欢的颜色是什么?", "zh_hant": "蘇珊最喜歡的顏色是什麼?"}, {"index": 2, "text": "You're working hard, George.", "start": 17.415, "end": 19.896, "zh": "你干得很卖力啊,乔治。", "zh_hant": "你乾得很賣力啊,喬治。"}, {"index": 3, "text": "What are you doing?", "start": 20.616, "end": 22.517, "zh": "你在做什么?", "zh_hant": "你在做什麼?"}, {"index": 4, "text": "I'm making a bookcase.", "start": 23.417, "end": 25.818, "zh": "我在做一个书柜。", "zh_hant": "我在做一個書櫃。"}, {"index": 5, "text": "Give me that hammer please, Dan.", "start": 26.718, "end": 29.659, "zh": "丹,把那把锤子递给我。", "zh_hant": "丹,把那把錘子遞給我。"}, {"index": 6, "text": "Which hammer?", "start": 30.86, "end": 32.18, "zh": "哪把锤子?", "zh_hant": "哪把錘子?"}, {"index": 7, "text": "This one?", "start": 32.66, "end": 33.78, "zh": "这把吗?", "zh_hant": "這把嗎?"}, {"index": 8, "text": "No, not that one.", "start": 34.121, "end": 36.501, "zh": "不,不是那把。", "zh_hant": "不,不是那把。"}, {"index": 9, "text": "The big one.", "start": 36.481, "end": 37.942, "zh": "大的那把。", "zh_hant": "大的那把。"}, {"index": 10, "text": "Here you are.", "start": 38.882, "end": 40.282, "zh": "给你。", "zh_hant": "給你。"}, {"index": 11, "text": "Thanks, Dan.", "start": 40.503, "end": 41.883, "zh": "谢谢,丹。", "zh_hant": "謝謝,丹。"}, {"index": 12, "text": "What are you going to do now, George?", "start": 43.524, "end": 47.265, "zh": "乔治,你现在打算做什么?", "zh_hant": "喬治,你現在打算做什麼?"}, {"index": 13, "text": "I'm going to paint it.", "start": 48.005, "end": 50.085, "zh": "我打算给它上漆。", "zh_hant": "我打算給它上漆。"}, {"index": 14, "text": "What colour are you going to paint it?", "start": 51.146, "end": 54.507, "zh": "你打算把它漆成什么颜色?", "zh_hant": "你打算把它漆成什麼顏色?"}, {"index": 15, "text": "I'm going to paint it pink.", "start": 55.627, "end": 58.448, "zh": "我打算把它漆成粉红色。", "zh_hant": "我打算把它漆成粉紅色。"}, {"index": 16, "text": "Pink!", "start": 59.208, "end": 60.409, "zh": "粉红色！", "zh_hant": "粉紅色！"}, {"index": 17, "text": "This bookcase isn't for me.", "start": 60.949, "end": 63.49, "zh": "这个书柜不是给我用的。", "zh_hant": "這個書櫃不是給我用的。"}, {"index": 18, "text": "It's for my daughter, Susan.", "start": 63.95, "end": 66.691, "zh": "是给我女儿苏珊的。", "zh_hant": "是給我女兒蘇珊的。"}, {"index": 19, "text": "Pink's her favourite colour.", "start": 67.031, "end": 69.832, "zh": "粉红色是她最喜欢的颜色。", "zh_hant": "粉紅色是她最喜歡的顏色。"}]