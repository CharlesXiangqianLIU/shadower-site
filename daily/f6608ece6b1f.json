[{"index": 0, "text": "Lesson 67", "start": 1.551, "end": 2.325}, {"index": 1, "text": "The weekend", "start": 4.093, "end": 5.193}, {"index": 2, "text": "Listen to the tape then answer this question.", "start": 7.315, "end": 10.917}, {"index": 3, "text": "What are the Johnsons going to do at the weekend?", "start": 13.479, "end": 17.281}, {"index": 4, "text": "Hello. Were you at the butcher's?", "start": 19.903, "end": 22.725}, {"index": 5, "text": "Yes, I was.", "start": 23.586, "end": 24.786}, {"index": 6, "text": "Were you at the butcher's, too?", "start": 25.207, "end": 26.828}, {"index": 7, "text": "No, I wasn't.", "start": 27.808, "end": 29.289}, {"index": 8, "text": "I was at the greengrocer's.", "start": 30.07, "end": 31.771}, {"index": 9, "text": "How's Jimmy today?", "start": 32.531, "end": 34.031}, {"index": 10, "text": "He's very well, thank you.", "start": 35.272, "end": 36.772}, {"index": 11, "text": "Was he absent from school last week?", "start": 37.973, "end": 40.313}, {"index": 12, "text": "Yes, he was.", "start": 41.714, "end": 42.974}, {"index": 13, "text": "He was absent on Monday, Tuesday, Wednesday and Thursday.", "start": 43.655, "end": 48.816}, {"index": 14, "text": "How are you all keeping?", "start": 49.937, "end": 51.317}, {"index": 15, "text": "Very well, thank you.", "start": 52.137, "end": 60.085}, {"index": 16, "text": "We're going to spend three days in the country!", "start": 60.085, "end": 60.987}, {"index": 17, "text": "We're going to stay at my mother's for the weekend.", "start": 60.987, "end": 62.249}, {"index": 18, "text": "Friday, Saturday and Sunday in the country!", "start": 62.249, "end": 63.931}, {"index": 19, "text": "Aren't you lucky!", "start": 64.713, "end": 65.614}]