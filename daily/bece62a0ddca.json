[{"index": 0, "text": "Lesson 5", "start": 1.501, "end": 1.79}, {"index": 1, "text": "Nice to meet you.", "start": 4.022, "end": 5.083}, {"index": 2, "text": "Listen to the tape then answer this question.", "start": 7.164, "end": 10.706}, {"index": 3, "text": "Is Chang-woo Chinese?", "start": 13.247, "end": 15.849}, {"index": 4, "text": "Good morning.", "start": 18.59, "end": 19.331}, {"index": 5, "text": "Good morning Mr. Blake.", "start": 19.231, "end": 22.072}, {"index": 6, "text": "This is Miss Sophie Dupont.", "start": 23.573, "end": 26.075}, {"index": 7, "text": "Sophie is a new student.", "start": 27.215, "end": 29.436}, {"index": 8, "text": "She is French.", "start": 29.316, "end": 29.677}, {"index": 9, "text": "Sophie this is Hans.", "start": 29.557, "end": 36.789}, {"index": 10, "text": "He is German.", "start": 37.75, "end": 39.171}, {"index": 11, "text": "Nice to meet you.", "start": 41.212, "end": 42.673}, {"index": 12, "text": "And this is Naoko.", "start": 44.855, "end": 46.816}, {"index": 13, "text": "She's Japanese.", "start": 48.117, "end": 49.818}, {"index": 14, "text": "Nice to meet you.", "start": 51.139, "end": 53.06}, {"index": 15, "text": "And this is Chang-woo.", "start": 54.661, "end": 57.163}, {"index": 16, "text": "He's Korean.", "start": 57.043, "end": 57.383}, {"index": 17, "text": "Nice to meet you.", "start": 57.283, "end": 57.743}, {"index": 18, "text": "And this is Luming.", "start": 57.663, "end": 58.984}, {"index": 19, "text": "He's Chinese.", "start": 58.864, "end": 59.604}, {"index": 20, "text": "Nice to meet you.", "start": 59.484, "end": 59.964}, {"index": 21, "text": "And this is Xiaohui.", "start": 59.884, "end": 62.224}, {"index": 22, "text": "She is Chinese too.", "start": 62.104, "end": 66.297}, {"index": 23, "text": "Nice to meet you.", "start": 66.257, "end": 67.16}]