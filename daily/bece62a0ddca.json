[{"index": 0, "text": "Lesson 5", "start": 1.501, "end": 1.79, "zh": "第5课"}, {"index": 1, "text": "Nice to meet you.", "start": 4.022, "end": 5.083, "zh": "很高兴认识你。"}, {"index": 2, "text": "Listen to the tape then answer this question.", "start": 7.164, "end": 10.706, "zh": "听录音,然后回答这个问题。"}, {"index": 3, "text": "Is Chang-woo Chinese?", "start": 13.247, "end": 15.849, "zh": "昌宇是中国人吗?"}, {"index": 4, "text": "Good morning.", "start": 18.59, "end": 19.281, "zh": "早上好。"}, {"index": 5, "text": "Good morning Mr. Blake.", "start": 19.281, "end": 22.072, "zh": "早上好,布莱克先生。"}, {"index": 6, "text": "This is Miss Sophie Dupont.", "start": 23.573, "end": 26.075, "zh": "这位是苏菲·杜邦小姐。"}, {"index": 7, "text": "Sophie is a new student.", "start": 27.215, "end": 29.376, "zh": "苏菲是新来的学生。"}, {"index": 8, "text": "She is French.", "start": 29.376, "end": 29.617, "zh": "她是法国人。"}, {"index": 9, "text": "Sophie this is Hans.", "start": 29.617, "end": 36.789, "zh": "苏菲,这位是汉斯。"}, {"index": 10, "text": "He is German.", "start": 37.75, "end": 39.171, "zh": "他是德国人。"}, {"index": 11, "text": "Nice to meet you.", "start": 41.212, "end": 42.673, "zh": "很高兴认识你。"}, {"index": 12, "text": "And this is Naoko.", "start": 44.855, "end": 46.816, "zh": "这位是直子。"}, {"index": 13, "text": "She's Japanese.", "start": 48.117, "end": 49.818, "zh": "她是日本人。"}, {"index": 14, "text": "Nice to meet you.", "start": 51.139, "end": 53.06, "zh": "很高兴认识你。"}, {"index": 15, "text": "And this is Chang-woo.", "start": 54.661, "end": 57.103, "zh": "这位是昌宇。"}, {"index": 16, "text": "He's Korean.", "start": 57.103, "end": 57.333, "zh": "他是韩国人。"}, {"index": 17, "text": "Nice to meet you.", "start": 57.333, "end": 57.703, "zh": "很高兴认识你。"}, {"index": 18, "text": "And this is Luming.", "start": 57.703, "end": 58.924, "zh": "这位是路明。"}, {"index": 19, "text": "He's Chinese.", "start": 58.924, "end": 59.544, "zh": "他是中国人。"}, {"index": 20, "text": "Nice to meet you.", "start": 59.544, "end": 59.924, "zh": "很高兴认识你。"}, {"index": 21, "text": "And this is Xiaohui.", "start": 59.924, "end": 62.164, "zh": "这位是晓慧。"}, {"index": 22, "text": "She is Chinese too.", "start": 62.164, "end": 66.277, "zh": "她也是中国人。"}, {"index": 23, "text": "Nice to meet you.", "start": 66.277, "end": 67.16, "zh": "很高兴认识你。"}]