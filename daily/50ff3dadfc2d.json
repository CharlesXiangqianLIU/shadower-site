[{"index": 0, "text": "Why was the writer's aunt surprised?", "start": 13.491, "end": 16.932}, {"index": 1, "text": "It was Sunday.", "start": 19.713, "end": 20.774}, {"index": 2, "text": "I never get up early on Sundays.", "start": 21.874, "end": 24.255}, {"index": 3, "text": "I sometimes stay in bed until lunchtime.", "start": 25.395, "end": 28.416}, {"index": 4, "text": "Last Sunday I got up very late.", "start": 29.837, "end": 33.338}, {"index": 5, "text": "I looked out of the window.", "start": 34.978, "end": 36.659}, {"index": 6, "text": "It was dark outside.", "start": 38.639, "end": 39.36}, {"index": 7, "text": "'What a day!' I thought.", "start": 39.24, "end": 40.1}, {"index": 8, "text": "'It's raining again.'", "start": 40.06, "end": 47.386}, {"index": 9, "text": "Just then, the telephone rang.", "start": 48.766, "end": 51.127}, {"index": 10, "text": "It was my aunt Lucy.", "start": 52.428, "end": 53.928}, {"index": 11, "text": "'I've just arrived by train,' she said.", "start": 53.868, "end": 58.99}, {"index": 12, "text": "'I'm coming to see you.'", "start": 59.031, "end": 60.931}, {"index": 13, "text": "'But I'm still having breakfast,' I said.", "start": 61.011, "end": 66.293}, {"index": 14, "text": "'What are you doing?' she asked.", "start": 67.014, "end": 69.415}, {"index": 15, "text": "'I'm having breakfast,' I repeated.", "start": 69.315, "end": 70.055}, {"index": 16, "text": "'Dear me,' she said.", "start": 69.935, "end": 70.135}, {"index": 17, "text": "'Do you always get up so late?", "start": 70.0, "end": 73.406}, {"index": 18, "text": "It's one o'clock!'", "start": 73.506, "end": 75.549}]