[{"index": 0, "text": "Why was the writer's aunt surprised?", "start": 13.491, "end": 16.932, "zh": "为什么作者的姑姑感到惊讶?", "zh_hant": "為什麼作者的姑姑感到驚訝?"}, {"index": 1, "text": "It was Sunday.", "start": 19.713, "end": 20.774, "zh": "那天是星期天。", "zh_hant": "那天是星期天。"}, {"index": 2, "text": "I never get up early on Sundays.", "start": 21.874, "end": 24.255, "zh": "我星期天从不早起。", "zh_hant": "我星期天從不早起。"}, {"index": 3, "text": "I sometimes stay in bed until lunchtime.", "start": 25.395, "end": 28.416, "zh": "我有时会一直睡到中午。", "zh_hant": "我有時會一直睡到中午。"}, {"index": 4, "text": "Last Sunday I got up very late.", "start": 29.837, "end": 33.338, "zh": "上周日我起得很晚。", "zh_hant": "上週日我起得很晚。"}, {"index": 5, "text": "I looked out of the window.", "start": 34.978, "end": 36.659, "zh": "我朝窗外看了看。", "zh_hant": "我朝窗外看了看。"}, {"index": 6, "text": "It was dark outside.", "start": 38.639, "end": 39.3, "zh": "外面天很黑。", "zh_hant": "外面天很黑。"}, {"index": 7, "text": "'What a day!' I thought.", "start": 39.3, "end": 40.08, "zh": "“真是糟糕的一天!”我心想。", "zh_hant": "“真是糟糕的一天!”我心想。"}, {"index": 8, "text": "'It's raining again.'", "start": 40.08, "end": 47.386, "zh": "“又下雨了。”", "zh_hant": "“又下雨了。”"}, {"index": 9, "text": "Just then, the telephone rang.", "start": 48.766, "end": 51.127, "zh": "就在这时,电话铃响了。", "zh_hant": "就在這時,電話鈴響了。"}, {"index": 10, "text": "It was my aunt Lucy.", "start": 52.428, "end": 53.898, "zh": "是我姑姑露西打来的。", "zh_hant": "是我姑姑露西打來的。"}, {"index": 11, "text": "'I've just arrived by train,' she said.", "start": 53.898, "end": 58.99, "zh": "“我刚坐火车到,”她说。", "zh_hant": "“我剛坐火車到,”她說。"}, {"index": 12, "text": "'I'm coming to see you.'", "start": 59.031, "end": 60.931, "zh": "“我要来看你了。”", "zh_hant": "“我要來看你了。”"}, {"index": 13, "text": "'But I'm still having breakfast,' I said.", "start": 61.011, "end": 66.293, "zh": "“可我还在吃早饭呢,”我说。", "zh_hant": "“可我還在吃早飯呢,”我說。"}, {"index": 14, "text": "'What are you doing?' she asked.", "start": 67.014, "end": 69.365, "zh": "“你在干什么?”她问道。", "zh_hant": "“你在幹什麼?”她問道。"}, {"index": 15, "text": "'I'm having breakfast,' I repeated.", "start": 69.365, "end": 69.995, "zh": "“我在吃早饭,”我又说了一遍。", "zh_hant": "“我在吃早飯,”我又說了一遍。"}, {"index": 16, "text": "'Dear me,' she said.", "start": 69.995, "end": 70.067, "zh": "“天哪,”她说。", "zh_hant": "“天哪,”她說。"}, {"index": 17, "text": "'Do you always get up so late?", "start": 70.067, "end": 73.406, "zh": "“你总是起这么晚吗?", "zh_hant": "“你總是起這麼晚嗎?"}, {"index": 18, "text": "It's one o'clock!'", "start": 73.506, "end": 75.549, "zh": "现在都一点了!”", "zh_hant": "現在都一點了!”"}]