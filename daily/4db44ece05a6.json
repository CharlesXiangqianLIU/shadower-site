[{"index": 0, "text": "Lesson 33", "start": 1.59, "end": 2.285}, {"index": 1, "text": "A fine day", "start": 4.311, "end": 5.472}, {"index": 2, "text": "Listen to the tape then answer this question.", "start": 7.512, "end": 11.274}, {"index": 3, "text": "Where is the Jones family?", "start": 13.835, "end": 15.955}, {"index": 4, "text": "It is a fine day today.", "start": 18.716, "end": 20.917}, {"index": 5, "text": "There are some clouds in the sky,", "start": 22.417, "end": 25.238}, {"index": 6, "text": "but the sun is shining.", "start": 26.859, "end": 28.859}, {"index": 7, "text": "Mr. Jones is with his family.", "start": 28.859, "end": 34.774}, {"index": 8, "text": "They are walking over the bridge.", "start": 36.494, "end": 39.535}, {"index": 9, "text": "There are some boats on the river.", "start": 41.655, "end": 44.376}, {"index": 10, "text": "Mr. Jones and his wife are looking at them.", "start": 47.136, "end": 51.437}, {"index": 11, "text": "Sally is looking at a big ship.", "start": 53.578, "end": 57.158}, {"index": 12, "text": "The ship is going under the bridge.", "start": 57.158, "end": 59.739}, {"index": 13, "text": "Tim is looking at an aeroplane.", "start": 59.739, "end": 60.299}, {"index": 14, "text": "The aeroplane is flying over the river.", "start": 60.299, "end": 62.741}]