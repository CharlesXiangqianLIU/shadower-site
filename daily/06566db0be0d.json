[{"index": 0, "text": "Lesson 47", "start": 1.601, "end": 2.235, "zh": "第47课"}, {"index": 1, "text": "A cup of coffee", "start": 4.343, "end": 5.764, "zh": "一杯咖啡"}, {"index": 2, "text": "Listen to the tape then answer this question.", "start": 7.425, "end": 11.107, "zh": "听录音,然后回答这个问题。"}, {"index": 3, "text": "How does Ann like her coffee?", "start": 13.629, "end": 16.03, "zh": "安喜欢怎样的咖啡?"}, {"index": 4, "text": "Do you like coffee, Ann?", "start": 18.692, "end": 20.553, "zh": "你喜欢咖啡吗,安?"}, {"index": 5, "text": "Yes, I do.", "start": 21.414, "end": 22.695, "zh": "是的,我喜欢。"}, {"index": 6, "text": "you want a cup?", "start": 24.076, "end": 25.176, "zh": "你要一杯吗?"}, {"index": 7, "text": "Yes, please, Christine.", "start": 26.057, "end": 27.758, "zh": "好的,谢谢,克里斯汀。"}, {"index": 8, "text": "Do you want any sugar?", "start": 29.319, "end": 31.905, "zh": "你要糖吗?"}, {"index": 9, "text": "Yes, please.", "start": 31.905, "end": 32.885, "zh": "好的,谢谢。"}, {"index": 10, "text": "Do you want any milk?", "start": 34.426, "end": 35.847, "zh": "你要牛奶吗?"}, {"index": 11, "text": "No, thank you.", "start": 36.948, "end": 37.828, "zh": "不,谢谢。"}, {"index": 12, "text": "I don't like milk in my coffee.", "start": 38.709, "end": 41.861, "zh": "我的咖啡里不喜欢加牛奶。"}, {"index": 13, "text": "I like black coffee.", "start": 41.861, "end": 43.431, "zh": "我喜欢喝黑咖啡。"}, {"index": 14, "text": "Do you like biscuits?", "start": 45.353, "end": 46.613, "zh": "你喜欢饼干吗?"}, {"index": 15, "text": "Yes, I do.", "start": 47.534, "end": 48.755, "zh": "是的,我喜欢。"}, {"index": 16, "text": "you want one?", "start": 51.056, "end": 51.836, "zh": "你要一块吗?"}, {"index": 17, "text": "Yes, please.", "start": 52.637, "end": 53.577, "zh": "好的,谢谢。"}]