[{"index": 0, "text": "Lesson 3", "start": 1.53, "end": 2.185}, {"index": 1, "text": "Sorry sir.", "start": 3.591, "end": 4.492}, {"index": 2, "text": "Listen to the tape then answer this question.", "start": 6.032, "end": 9.213}, {"index": 3, "text": "Does the man get his umbrella back?", "start": 11.815, "end": 14.356}, {"index": 4, "text": "My coat and my umbrella please.", "start": 17.057, "end": 19.898}, {"index": 5, "text": "Here is my ticket.", "start": 21.598, "end": 23.059}, {"index": 6, "text": "Thank you sir.", "start": 25.9, "end": 26.46}, {"index": 7, "text": "Number five.", "start": 26.46, "end": 26.72}, {"index": 8, "text": "Here's your umbrella and your coat.", "start": 26.72, "end": 36.435}, {"index": 9, "text": "This is not my umbrella.", "start": 38.916, "end": 41.176}, {"index": 10, "text": "Sorry sir.", "start": 42.317, "end": 43.117}, {"index": 11, "text": "Is this your umbrella?", "start": 45.538, "end": 47.158}, {"index": 12, "text": "No it isn't.", "start": 48.999, "end": 50.839}, {"index": 13, "text": "Is this it?", "start": 52.22, "end": 52.86}, {"index": 14, "text": "Yes it is.", "start": 52.86, "end": 53.1}, {"index": 15, "text": "Thank you very much.", "start": 53.1, "end": 53.48}]