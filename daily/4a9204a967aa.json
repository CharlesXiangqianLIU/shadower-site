[{"index": 0, "text": "Lesson 3", "start": 1.53, "end": 2.185, "zh": "第三课"}, {"index": 1, "text": "Sorry sir.", "start": 3.591, "end": 4.492, "zh": "对不起,先生。"}, {"index": 2, "text": "Listen to the tape then answer this question.", "start": 6.032, "end": 9.213, "zh": "先听录音,然后回答这个问题。"}, {"index": 3, "text": "Does the man get his umbrella back?", "start": 11.815, "end": 14.356, "zh": "这位男士拿回他的伞了吗?"}, {"index": 4, "text": "My coat and my umbrella please.", "start": 17.057, "end": 19.898, "zh": "请给我拿一下外套和伞。"}, {"index": 5, "text": "Here is my ticket.", "start": 21.598, "end": 23.059, "zh": "这是我的票。"}, {"index": 6, "text": "Thank you sir.", "start": 25.9, "end": 26.46, "zh": "谢谢您,先生。"}, {"index": 7, "text": "Number five.", "start": 26.46, "end": 26.72, "zh": "五号。"}, {"index": 8, "text": "Here's your umbrella and your coat.", "start": 26.72, "end": 36.435, "zh": "这是您的伞和外套。"}, {"index": 9, "text": "This is not my umbrella.", "start": 38.916, "end": 41.176, "zh": "这不是我的伞。"}, {"index": 10, "text": "Sorry sir.", "start": 42.317, "end": 43.117, "zh": "对不起,先生。"}, {"index": 11, "text": "Is this your umbrella?", "start": 45.538, "end": 47.158, "zh": "这是您的伞吗?"}, {"index": 12, "text": "No it isn't.", "start": 48.999, "end": 50.839, "zh": "不,不是。"}, {"index": 13, "text": "Is this it?", "start": 52.22, "end": 52.86, "zh": "是这把吗?"}, {"index": 14, "text": "Yes it is.", "start": 52.86, "end": 53.1, "zh": "对,就是这把。"}, {"index": 15, "text": "Thank you very much.", "start": 53.1, "end": 53.48, "zh": "非常感谢。"}]