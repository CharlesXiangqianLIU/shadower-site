[{"index": 0, "text": "Lesson 27", "start": 1.571, "end": 2.17, "zh": "第27课", "zh_hant": "第27課"}, {"index": 1, "text": "Mrs. Smith's living room", "start": 4.313, "end": 6.335, "zh": "史密斯太太的客厅", "zh_hant": "史密斯太太的客廳"}, {"index": 2, "text": "Listen to the tape then answer this question.", "start": 7.816, "end": 11.779, "zh": "听录音,然后回答这个问题。", "zh_hant": "聽錄音,然後回答這個問題。"}, {"index": 3, "text": "Where are the books?", "start": 14.361, "end": 15.922, "zh": "书在哪里?", "zh_hant": "書在哪裡?"}, {"index": 4, "text": "Mrs. Smith's living room is large.", "start": 18.724, "end": 22.367, "zh": "史密斯太太的客厅很大。", "zh_hant": "史密斯太太的客廳很大。"}, {"index": 5, "text": "There is a television in the room.", "start": 24.388, "end": 26.89, "zh": "房间里有一台电视机。", "zh_hant": "房間裡有一臺電視機。"}, {"index": 6, "text": "The television is near the window.", "start": 29.532, "end": 32.688, "zh": "电视机在窗户附近。", "zh_hant": "電視機在窗戶附近。"}, {"index": 7, "text": "There are some magazines on the television.", "start": 35.589, "end": 38.911, "zh": "电视机上有一些杂志。", "zh_hant": "電視機上有一些雜誌。"}, {"index": 8, "text": "There is a table in the room.", "start": 41.052, "end": 43.173, "zh": "房间里有一张桌子。", "zh_hant": "房間裡有一張桌子。"}, {"index": 9, "text": "There are some newspapers on the table.", "start": 45.854, "end": 48.875, "zh": "桌子上有一些报纸。", "zh_hant": "桌子上有一些報紙。"}, {"index": 10, "text": "There are some armchairs in the room.", "start": 51.256, "end": 53.857, "zh": "房间里有一些扶手椅。", "zh_hant": "房間裡有一些扶手椅。"}, {"index": 11, "text": "The armchairs are near the table.", "start": 56.218, "end": 59.29, "zh": "扶手椅在桌子附近。", "zh_hant": "扶手椅在桌子附近。"}, {"index": 12, "text": "There is a stereo in the room.", "start": 59.29, "end": 59.82, "zh": "房间里有一套音响。", "zh_hant": "房間裡有一套音響。"}, {"index": 13, "text": "The stereo is near the door.", "start": 59.82, "end": 62.712, "zh": "音响在门附近。", "zh_hant": "音響在門附近。"}, {"index": 14, "text": "There are some books on the stereo.", "start": 62.732, "end": 66.805, "zh": "音响上有一些书。", "zh_hant": "音響上有一些書。"}, {"index": 15, "text": "There are some pictures in the room.", "start": 66.805, "end": 71.519, "zh": "房间里有一些图画。", "zh_hant": "房間裡有一些圖畫。"}, {"index": 16, "text": "The pictures are on the wall.", "start": 71.519, "end": 72.82, "zh": "这些图画挂在墙上。", "zh_hant": "這些圖畫掛在牆上。"}]