[{"index": 0, "text": "Lesson 61", "start": 1.501, "end": 2.13}, {"index": 1, "text": "A bad cold", "start": 3.562, "end": 4.922}, {"index": 2, "text": "Listen to the tape then answer this question.", "start": 6.183, "end": 9.604}, {"index": 3, "text": "What is good news for Jimmy?", "start": 12.126, "end": 14.186}, {"index": 4, "text": "Where's Jimmy?", "start": 17.008, "end": 17.948}, {"index": 5, "text": "He's in bed.", "start": 18.549, "end": 19.509}, {"index": 6, "text": "What's the matter with him?", "start": 20.409, "end": 21.89}, {"index": 7, "text": "He feels ill.", "start": 22.31, "end": 23.291}, {"index": 8, "text": "He looks ill.", "start": 24.571, "end": 25.812}, {"index": 9, "text": "We must call the doctor.", "start": 26.892, "end": 30.092}, {"index": 10, "text": "Yes, we must.", "start": 30.092, "end": 31.493}, {"index": 11, "text": "Can you remember the doctor's telephone number?", "start": 31.573, "end": 34.574}, {"index": 12, "text": "Yes. It's 09754.", "start": 35.174, "end": 43.357}, {"index": 13, "text": "Open your mouth, Jimmy.", "start": 43.357, "end": 44.818}, {"index": 14, "text": "Show me your tongue. Say, 'Ah'.", "start": 45.718, "end": 52.181}, {"index": 15, "text": "What's the matter with him, doctor?", "start": 52.181, "end": 53.781}, {"index": 16, "text": "He has a bad cold, Mr. Williams, so he must stay in bed for a week.", "start": 55.142, "end": 61.783}, {"index": 17, "text": "That's good news for Jimmy.", "start": 61.783, "end": 63.505}, {"index": 18, "text": "Good news? Why?", "start": 64.427, "end": 66.269}, {"index": 19, "text": "Because he doesn't like school!", "start": 67.55, "end": 70.173}]