[{"index": 0, "text": "Lesson 61", "start": 1.501, "end": 2.13, "zh": "第61课", "zh_hant": "第61課"}, {"index": 1, "text": "A bad cold", "start": 3.562, "end": 4.922, "zh": "重感冒", "zh_hant": "重感冒"}, {"index": 2, "text": "Listen to the tape then answer this question.", "start": 6.183, "end": 9.604, "zh": "听录音,然后回答这个问题。", "zh_hant": "聽錄音,然後回答這個問題。"}, {"index": 3, "text": "What is good news for Jimmy?", "start": 12.126, "end": 14.186, "zh": "什么事对吉米来说是好消息?", "zh_hant": "什麼事對吉米來說是好訊息?"}, {"index": 4, "text": "Where's Jimmy?", "start": 17.008, "end": 17.948, "zh": "吉米在哪儿?", "zh_hant": "吉米在哪兒?"}, {"index": 5, "text": "He's in bed.", "start": 18.549, "end": 19.509, "zh": "他在床上。", "zh_hant": "他在床上。"}, {"index": 6, "text": "What's the matter with him?", "start": 20.409, "end": 21.89, "zh": "他怎么了?", "zh_hant": "他怎麼了?"}, {"index": 7, "text": "He feels ill.", "start": 22.31, "end": 23.291, "zh": "他觉得不舒服。", "zh_hant": "他覺得不舒服。"}, {"index": 8, "text": "He looks ill.", "start": 24.571, "end": 25.812, "zh": "他看起来病了。", "zh_hant": "他看起來病了。"}, {"index": 9, "text": "We must call the doctor.", "start": 26.892, "end": 30.092, "zh": "我们得叫医生。", "zh_hant": "我們得叫醫生。"}, {"index": 10, "text": "Yes, we must.", "start": 30.092, "end": 31.493, "zh": "是的,我们必须叫医生。", "zh_hant": "是的,我們必須叫醫生。"}, {"index": 11, "text": "Can you remember the doctor's telephone number?", "start": 31.573, "end": 34.574, "zh": "你还记得医生的电话号码吗?", "zh_hant": "你還記得醫生的電話號碼嗎?"}, {"index": 12, "text": "Yes. It's 09754.", "start": 35.174, "end": 43.357, "zh": "记得,是09754。", "zh_hant": "記得,是09754。"}, {"index": 13, "text": "Open your mouth, Jimmy.", "start": 43.357, "end": 44.818, "zh": "张开嘴,吉米。", "zh_hant": "張開嘴,吉米。"}, {"index": 14, "text": "Show me your tongue. Say, 'Ah'.", "start": 45.718, "end": 52.181, "zh": "把舌头伸给我看。说,‘啊’。", "zh_hant": "把舌頭伸給我看。說,‘啊’。"}, {"index": 15, "text": "What's the matter with him, doctor?", "start": 52.181, "end": 53.781, "zh": "他怎么了,医生?", "zh_hant": "他怎麼了,醫生?"}, {"index": 16, "text": "He has a bad cold, Mr. Williams, so he must stay in bed for a week.", "start": 55.142, "end": 61.783, "zh": "他得了重感冒,威廉姆斯先生,所以他必须卧床一周。", "zh_hant": "他得了重感冒,威廉姆斯先生,所以他必須臥床一週。"}, {"index": 17, "text": "That's good news for Jimmy.", "start": 61.783, "end": 63.505, "zh": "这对吉米来说是好消息。", "zh_hant": "這對吉米來說是好訊息。"}, {"index": 18, "text": "Good news? Why?", "start": 64.427, "end": 66.269, "zh": "好消息?为什么?", "zh_hant": "好訊息?為什麼?"}, {"index": 19, "text": "Because he doesn't like school!", "start": 67.55, "end": 70.173, "zh": "因为他不喜欢上学!", "zh_hant": "因為他不喜歡上學!"}]