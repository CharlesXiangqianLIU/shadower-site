[{"index": 0, "text": "Lesson 5 Nice to meet you.", "start": 0.55, "end": 4.131, "zh": "第5课 很高兴认识你", "zh_hant": "第5課 很高興認識你"}, {"index": 1, "text": "Listen to the tape then answer this question.", "start": 5.051, "end": 9.312, "zh": "听录音,然后回答这个问题。", "zh_hant": "聽錄音,然後回答這個問題。"}, {"index": 2, "text": "Is Chang-woo Chinese?", "start": 9.932, "end": 12.653, "zh": "昌宇是中国人吗?", "zh_hant": "昌宇是中國人嗎?"}, {"index": 3, "text": "Good morning.", "start": 14.193, "end": 15.374, "zh": "早上好。", "zh_hant": "早上好。"}, {"index": 4, "text": "Good morning Mr. Blake.", "start": 15.994, "end": 18.794, "zh": "早上好,布莱克先生。", "zh_hant": "早上好,布萊克先生。"}, {"index": 5, "text": "This is Miss Sophie Dupont.", "start": 19.735, "end": 23.055, "zh": "这位是苏菲·杜邦小姐。", "zh_hant": "這位是蘇菲·杜邦小姐。"}, {"index": 6, "text": "Sophie is a new student.", "start": 23.696, "end": 26.276, "zh": "苏菲是新来的学生。", "zh_hant": "蘇菲是新來的學生。"}, {"index": 7, "text": "She is French.", "start": 26.616, "end": 28.417, "zh": "她是法国人。", "zh_hant": "她是法國人。"}, {"index": 8, "text": "Sophie this is Hans.", "start": 29.037, "end": 32.277, "zh": "苏菲,这位是汉斯。", "zh_hant": "蘇菲,這位是漢斯。"}, {"index": 9, "text": "He is German.", "start": 32.498, "end": 34.158, "zh": "他是德国人。", "zh_hant": "他是德國人。"}, {"index": 10, "text": "Nice to meet you.", "start": 34.558, "end": 36.358, "zh": "很高兴认识你。", "zh_hant": "很高興認識你。"}, {"index": 11, "text": "And this is Naoko.", "start": 37.299, "end": 39.599, "zh": "这位是直子。", "zh_hant": "這位是直子。"}, {"index": 12, "text": "She's Japanese.", "start": 40.059, "end": 42.0, "zh": "她是日本人。", "zh_hant": "她是日本人。"}, {"index": 13, "text": "Nice to meet you.", "start": 42.24, "end": 44.02, "zh": "很高兴认识你。", "zh_hant": "很高興認識你。"}, {"index": 14, "text": "And this is Chang-woo.", "start": 44.78, "end": 47.181, "zh": "这位是昌宇。", "zh_hant": "這位是昌宇。"}, {"index": 15, "text": "He's Korean.", "start": 47.421, "end": 48.961, "zh": "他是韩国人。", "zh_hant": "他是韓國人。"}, {"index": 16, "text": "Nice to meet you.", "start": 49.141, "end": 50.902, "zh": "很高兴认识你。", "zh_hant": "很高興認識你。"}, {"index": 17, "text": "And this is Luming.", "start": 51.642, "end": 54.003, "zh": "这位是路明。", "zh_hant": "這位是路明。"}, {"index": 18, "text": "He's Chinese.", "start": 54.123, "end": 55.963, "zh": "他是中国人。", "zh_hant": "他是中國人。"}, {"index": 19, "text": "Nice to meet you.", "start": 56.143, "end": 57.743, "zh": "很高兴认识你。", "zh_hant": "很高興認識你。"}, {"index": 20, "text": "And this is Xiaohui.", "start": 58.544, "end": 61.204, "zh": "这位是晓慧。", "zh_hant": "這位是曉慧。"}, {"index": 21, "text": "She is Chinese too.", "start": 61.724, "end": 63.785, "zh": "她也是中国人。", "zh_hant": "她也是中國人。"}, {"index": 22, "text": "Nice to meet you.", "start": 64.205, "end": 65.725, "zh": "很高兴认识你。", "zh_hant": "很高興認識你。"}]