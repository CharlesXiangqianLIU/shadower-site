[{"index": 0, "text": "Lesson 109 A good idea Listen to the tape then answer this question.", "start": 0.71, "end": 10.711, "zh": "第109课 一个好主意 听录音,然后回答这个问题。", "zh_hant": "第109課 一個好主意 聽錄音,然後回答這個問題。"}, {"index": 1, "text": "What does Jane have with her coffee?", "start": 11.651, "end": 14.871, "zh": "简女的咖啡里加了什么?", "zh_hant": "簡女的咖啡里加了什麼?"}, {"index": 2, "text": "Shall I make some coffee, Jane?", "start": 17.011, "end": 20.612, "zh": "简,我煮点咖啡好吗?", "zh_hant": "簡,我煮點咖啡好嗎?"}, {"index": 3, "text": "That's a good idea, Charlotte.", "start": 21.532, "end": 25.152, "zh": "夏洛特,好主意。", "zh_hant": "夏洛特,好主意。"}, {"index": 4, "text": "It's ready.", "start": 26.052, "end": 27.272, "zh": "咖啡好了。", "zh_hant": "咖啡好了。"}, {"index": 5, "text": "Do you want any milk?", "start": 27.952, "end": 30.312, "zh": "要加牛奶吗?", "zh_hant": "要加牛奶嗎?"}, {"index": 6, "text": "Just a little, please.", "start": 30.833, "end": 33.273, "zh": "请加一点点。", "zh_hant": "請加一點點。"}, {"index": 7, "text": "What about some sugar?", "start": 34.393, "end": 36.653, "zh": "加糖怎么样?", "zh_hant": "加糖怎麼樣?"}, {"index": 8, "text": "Two teaspoonfuls?", "start": 37.393, "end": 39.733, "zh": "两茶匙?", "zh_hant": "兩茶匙?"}, {"index": 9, "text": "No, less than that.", "start": 40.693, "end": 43.194, "zh": "不,少一点。", "zh_hant": "不,少一點。"}, {"index": 10, "text": "One and a half teaspoonfuls, please.", "start": 43.734, "end": 47.854, "zh": "请加一茶匙半。", "zh_hant": "請加一茶匙半。"}, {"index": 11, "text": "That's enough for me.", "start": 48.194, "end": 50.054, "zh": "这对我来说够了。", "zh_hant": "這對我來說夠了。"}, {"index": 12, "text": "That was very nice.", "start": 51.894, "end": 54.694, "zh": "刚才真好喝。", "zh_hant": "剛才真好喝。"}, {"index": 13, "text": "Would you like some more?", "start": 55.215, "end": 57.295, "zh": "还要再来点吗?", "zh_hant": "還要再來點嗎?"}, {"index": 14, "text": "Yes, please.", "start": 58.075, "end": 60.575, "zh": "好,麻烦你。", "zh_hant": "好,麻煩你。"}, {"index": 15, "text": "I'd like a cigarette, too.", "start": 61.495, "end": 64.415, "zh": "我还想抽支烟。", "zh_hant": "我還想抽支菸。"}, {"index": 16, "text": "May I have one?", "start": 64.835, "end": 66.715, "zh": "可以给我一支吗?", "zh_hant": "可以給我一支嗎?"}, {"index": 17, "text": "Of course.", "start": 67.476, "end": 69.056, "zh": "当然可以。", "zh_hant": "當然可以。"}, {"index": 18, "text": "I think there are a few in that box.", "start": 69.596, "end": 73.556, "zh": "我想那个盒子里还有几支。", "zh_hant": "我想那個盒子裡還有幾支。"}, {"index": 19, "text": "I'm afraid it's empty.", "start": 74.696, "end": 77.056, "zh": "恐怕是空的。", "zh_hant": "恐怕是空的。"}, {"index": 20, "text": "What a pity!", "start": 78.196, "end": 79.817, "zh": "真可惜!", "zh_hant": "真可惜!"}, {"index": 21, "text": "It doesn't matter.", "start": 80.417, "end": 82.197, "zh": "没关系。", "zh_hant": "沒關係。"}, {"index": 22, "text": "Have a biscuit instead.", "start": 83.197, "end": 85.717, "zh": "吃块饼干代替吧。", "zh_hant": "吃塊餅乾代替吧。"}, {"index": 23, "text": "Eat more and smoke less!", "start": 86.217, "end": 89.617, "zh": "多吃点,少抽点烟!", "zh_hant": "多吃點,少抽點菸!"}, {"index": 24, "text": "That's very good advice!", "start": 90.217, "end": 93.218, "zh": "这个建议真好!", "zh_hant": "這個建議真好!"}]