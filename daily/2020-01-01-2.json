[{"index": 0, "text": "Lesson 3", "start": 0.73, "end": 3.491, "zh": "第三课", "zh_hant": "第三課"}, {"index": 1, "text": "Sorry sir.", "start": 2.991, "end": 4.432, "zh": "对不起,先生。", "zh_hant": "對不起,先生。"}, {"index": 2, "text": "Listen to the tape then answer this question.", "start": 5.732, "end": 10.314, "zh": "先听录音,然后回答这个问题。", "zh_hant": "先聽錄音,然後回答這個問題。"}, {"index": 3, "text": "Does the man get his umbrella back?", "start": 11.735, "end": 15.076, "zh": "这位男士拿回他的伞了吗?", "zh_hant": "這位男士拿回他的傘了嗎?"}, {"index": 4, "text": "My coat and my umbrella please.", "start": 17.517, "end": 21.078, "zh": "请给我拿一下外套和伞。", "zh_hant": "請給我拿一下外套和傘。"}, {"index": 5, "text": "Here is my ticket.", "start": 21.939, "end": 23.9, "zh": "这是我的票。", "zh_hant": "這是我的票。"}, {"index": 6, "text": "Thank you sir.", "start": 24.94, "end": 26.501, "zh": "谢谢您,先生。", "zh_hant": "謝謝您,先生。"}, {"index": 7, "text": "Number five.", "start": 26.841, "end": 28.421, "zh": "五号。", "zh_hant": "五號。"}, {"index": 8, "text": "Here's your umbrella and your coat.", "start": 29.002, "end": 32.543, "zh": "这是您的伞和外套。", "zh_hant": "這是您的傘和外套。"}, {"index": 9, "text": "This is not my umbrella.", "start": 33.764, "end": 36.985, "zh": "这不是我的伞。", "zh_hant": "這不是我的傘。"}, {"index": 10, "text": "Sorry sir.", "start": 37.485, "end": 38.906, "zh": "对不起,先生。", "zh_hant": "對不起,先生。"}, {"index": 11, "text": "Is this your umbrella?", "start": 39.666, "end": 41.927, "zh": "这是您的伞吗?", "zh_hant": "這是您的傘嗎?"}, {"index": 12, "text": "No it isn't.", "start": 42.647, "end": 44.548, "zh": "不,不是。", "zh_hant": "不,不是。"}, {"index": 13, "text": "Is this it?", "start": 45.689, "end": 47.269, "zh": "是这把吗?", "zh_hant": "是這把嗎?"}, {"index": 14, "text": "Yes it is.", "start": 47.83, "end": 50.03, "zh": "对,就是这把。", "zh_hant": "對,就是這把。"}, {"index": 15, "text": "Thank you very much.", "start": 50.451, "end": 52.771, "zh": "非常感谢。", "zh_hant": "非常感謝。"}]