[{"index": 0, "text": "Lesson 83 Going on holiday Listen to the tape then answer this question.", "start": 0.85, "end": 11.093, "zh": "第83课 去度假 听录音,然后回答这个问题。", "zh_hant": "第83課 去度假 聽錄音,然後回答這個問題。"}, {"index": 1, "text": "Where did Sam go for his holiday this year?", "start": 12.193, "end": 16.634, "zh": "萨姆今年去哪里度假了?", "zh_hant": "薩姆今年去哪裡度假了?"}, {"index": 2, "text": "Hello, Sam.", "start": 18.875, "end": 20.495, "zh": "你好,萨姆。", "zh_hant": "你好,薩姆。"}, {"index": 3, "text": "Come in.", "start": 20.475, "end": 21.615, "zh": "进来吧。", "zh_hant": "進來吧。"}, {"index": 4, "text": "Hi, Sam.", "start": 22.996, "end": 24.436, "zh": "嗨,萨姆。", "zh_hant": "嗨,薩姆。"}, {"index": 5, "text": "We're having lunch.", "start": 24.656, "end": 26.416, "zh": "我们正在吃午饭。", "zh_hant": "我們正在吃午飯。"}, {"index": 6, "text": "Do you want to have lunch with us?", "start": 26.857, "end": 30.117, "zh": "你要和我们一起吃午饭吗?", "zh_hant": "你要和我們一起吃午飯嗎?"}, {"index": 7, "text": "No, thank you, Tom.", "start": 30.978, "end": 33.078, "zh": "不了,谢谢你,汤姆。", "zh_hant": "不了,謝謝你,湯姆。"}, {"index": 8, "text": "I've already had lunch.", "start": 33.278, "end": 35.599, "zh": "我已经吃过午饭了。", "zh_hant": "我已經吃過午飯了。"}, {"index": 9, "text": "I had lunch at half past twelve.", "start": 36.079, "end": 39.48, "zh": "我十二点半吃的午饭。", "zh_hant": "我十二點半吃的午飯。"}, {"index": 10, "text": "Have a cup of coffee then.", "start": 39.94, "end": 42.52, "zh": "那喝杯咖啡吧。", "zh_hant": "那喝杯咖啡吧。"}, {"index": 11, "text": "I've just had a cup, thank you.", "start": 43.02, "end": 45.981, "zh": "我刚喝过一杯了,谢谢。", "zh_hant": "我剛喝過一杯了,謝謝。"}, {"index": 12, "text": "I had one after my lunch.", "start": 46.341, "end": 48.902, "zh": "我午饭后喝了一杯。", "zh_hant": "我午飯後喝了一杯。"}, {"index": 13, "text": "Let's go into the living room, Carol.", "start": 49.942, "end": 53.283, "zh": "我们去客厅吧,卡罗尔。", "zh_hant": "我們去客廳吧,卡羅爾。"}, {"index": 14, "text": "We can have our coffee there.", "start": 53.683, "end": 56.384, "zh": "我们可以在那儿喝咖啡。", "zh_hant": "我們可以在那兒喝咖啡。"}, {"index": 15, "text": "Excuse the mess, Sam.", "start": 57.064, "end": 59.764, "zh": "抱歉这里有点乱,萨姆。", "zh_hant": "抱歉這裡有點亂,薩姆。"}, {"index": 16, "text": "This room's very untidy.", "start": 60.225, "end": 63.005, "zh": "这个房间很不整洁。", "zh_hant": "這個房間很不整潔。"}, {"index": 17, "text": "We're packing our suitcases.", "start": 63.425, "end": 66.126, "zh": "我们正在收拾行李箱。", "zh_hant": "我們正在收拾行李箱。"}, {"index": 18, "text": "We're going to leave tomorrow.", "start": 66.446, "end": 69.287, "zh": "我们明天要出发。", "zh_hant": "我們明天要出發。"}, {"index": 19, "text": "Tom and I are going to have a holiday.", "start": 69.787, "end": 73.788, "zh": "汤姆和我要去度假了。", "zh_hant": "湯姆和我要去度假了。"}, {"index": 20, "text": "Aren't you lucky!", "start": 74.368, "end": 76.108, "zh": "你们真幸运啊!", "zh_hant": "你們真幸運啊!"}, {"index": 21, "text": "When are you going to have a holiday, Sam?", "start": 77.509, "end": 81.25, "zh": "萨姆,你什么时候去度假?", "zh_hant": "薩姆,你什麼時候去度假?"}, {"index": 22, "text": "I don't know.", "start": 81.81, "end": 83.19, "zh": "我不知道。", "zh_hant": "我不知道。"}, {"index": 23, "text": "I've already had my holiday this year.", "start": 83.53, "end": 87.171, "zh": "我今年已经度过假了。", "zh_hant": "我今年已經度過假了。"}, {"index": 24, "text": "Where did you go?", "start": 88.071, "end": 89.632, "zh": "你去哪儿了?", "zh_hant": "你去哪兒了?"}, {"index": 25, "text": "I stayed at home!", "start": 90.392, "end": 92.192, "zh": "我待在家里!", "zh_hant": "我待在家裡!"}]