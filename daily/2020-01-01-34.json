[{"index": 0, "text": "Lesson 67 The weekend Listen to the tape then answer this question.", "start": 0.73, "end": 9.951, "zh": "第67课 周末 听录音,然后回答这个问题。", "zh_hant": "第67課 週末 聽錄音,然後回答這個問題。"}, {"index": 1, "text": "What are the Johnsons going to do at the weekend?", "start": 10.871, "end": 15.411, "zh": "约翰逊一家周末打算做什么？", "zh_hant": "約翰遜一家週末打算做什麼？"}, {"index": 2, "text": "Hello.", "start": 17.771, "end": 18.591, "zh": "你好。", "zh_hant": "你好。"}, {"index": 3, "text": "Were you at the butcher's?", "start": 19.111, "end": 21.431, "zh": "你去肉店了吗?", "zh_hant": "你去肉店了嗎?"}, {"index": 4, "text": "Yes, I was.", "start": 21.771, "end": 23.612, "zh": "是的，我在。", "zh_hant": "是的，我在。"}, {"index": 5, "text": "Were you at the butcher's, too?", "start": 23.812, "end": 26.732, "zh": "你也在肉店吗？", "zh_hant": "你也在肉店嗎？"}, {"index": 6, "text": "No, I wasn't.", "start": 27.412, "end": 29.872, "zh": "不，我不在。", "zh_hant": "不，我不在。"}, {"index": 7, "text": "I was at the greengrocer's.", "start": 30.772, "end": 33.692, "zh": "我在蔬果店。", "zh_hant": "我在蔬果店。"}, {"index": 8, "text": "How's Jimmy today?", "start": 34.232, "end": 36.252, "zh": "吉米今天怎么样？", "zh_hant": "吉米今天怎麼樣？"}, {"index": 9, "text": "He's very well, thank you.", "start": 37.112, "end": 40.093, "zh": "他很好，谢谢。", "zh_hant": "他很好，謝謝。"}, {"index": 10, "text": "Was he absent from school last week?", "start": 41.133, "end": 45.113, "zh": "他上星期没去上学吗？", "zh_hant": "他上星期沒去上學嗎？"}, {"index": 11, "text": "Yes, he was.", "start": 45.713, "end": 47.753, "zh": "是的，没去。", "zh_hant": "是的，沒去。"}, {"index": 12, "text": "He was absent on Monday, Tuesday, Wednesday and Thursday.", "start": 48.193, "end": 55.074, "zh": "他星期一、星期二、星期三和星期四都没去。", "zh_hant": "他星期一、星期二、星期三和星期四都沒去。"}, {"index": 13, "text": "How are you all keeping?", "start": 55.874, "end": 58.394, "zh": "你们都还好吗？", "zh_hant": "你們都還好嗎？"}, {"index": 14, "text": "Very well, thank you.", "start": 59.494, "end": 61.774, "zh": "很好，谢谢。", "zh_hant": "很好，謝謝。"}, {"index": 15, "text": "We're going to spend three days in the country!", "start": 62.334, "end": 66.754, "zh": "我们打算在乡下待三天！", "zh_hant": "我們打算在鄉下待三天！"}, {"index": 16, "text": "We're going to stay at my mother's for the weekend.", "start": 67.494, "end": 72.315, "zh": "我们周末打算去我妈妈家住。", "zh_hant": "我們週末打算去我媽媽家住。"}, {"index": 17, "text": "Friday, Saturday and Sunday in the country!", "start": 73.435, "end": 78.455, "zh": "星期五、星期六和星期天都在乡下！", "zh_hant": "星期五、星期六和星期天都在鄉下！"}, {"index": 18, "text": "Aren't you lucky!", "start": 78.975, "end": 81.315, "zh": "你们真幸运！", "zh_hant": "你們真幸運！"}]