[{"index": 0, "text": "Why is Joe's garden", "start": 14.663, "end": 16.404}, {"index": 1, "text": "the most beautiful one in the town?", "start": 16.625, "end": 19.547}, {"index": 2, "text": "Joe Sanders has the most beautiful garden", "start": 22.288, "end": 26.011}, {"index": 3, "text": "in our town.", "start": 26.031, "end": 26.971}, {"index": 4, "text": "Nearly everybody enters for", "start": 28.212, "end": 30.154}, {"index": 5, "text": "'The Nicest Garden Competition' each year,", "start": 30.154, "end": 33.055}, {"index": 6, "text": "but Joe wins every time.", "start": 33.956, "end": 36.257}, {"index": 7, "text": "Bill Frith's garden is larger than Joe's.", "start": 38.539, "end": 39.44}, {"index": 8, "text": "Bill works harder than Joe", "start": 39.44, "end": 39.9}, {"index": 9, "text": "and grows more flowers and vegetables,", "start": 39.9, "end": 47.085}, {"index": 10, "text": "but Joe's garden is more interesting.", "start": 48.006, "end": 50.708}, {"index": 11, "text": "He has made neat paths", "start": 51.809, "end": 53.83}, {"index": 12, "text": "and has built a wooden bridge over a pool.", "start": 54.19, "end": 57.032}, {"index": 13, "text": "I like gardens too,", "start": 58.574, "end": 60.095}, {"index": 14, "text": "but I do not like hard work.", "start": 60.855, "end": 62.776}, {"index": 15, "text": "Every year", "start": 64.438, "end": 65.198}, {"index": 16, "text": "I enter for the garden competition too,", "start": 65.679, "end": 68.06}, {"index": 17, "text": "and I always win a little prize", "start": 68.06, "end": 68.621}, {"index": 18, "text": "for the worst garden in the town!", "start": 68.621, "end": 69.241}]