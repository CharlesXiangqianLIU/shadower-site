[{"index": 0, "text": "What's a good party trick?", "start": 0.0, "end": 1.351, "zh": "有什么拿手的派对小把戏吗?", "zh_hant": "有什麼拿手的派對小把戲嗎?"}, {"index": 1, "text": "I can make myself look like I have a facelift.", "start": 1.331, "end": 3.972, "zh": "我能让自己看起来像做了拉皮手术。", "zh_hant": "我能讓自己看起來像做了拉皮手術。"}, {"index": 2, "text": "You can make yourself look like you've got a facelift?", "start": 3.813, "end": 5.954, "zh": "你能让自己看起来像做了拉皮手术?", "zh_hant": "你能讓自己看起來像做了拉皮手術?"}, {"index": 3, "text": "Mm -hmm.", "start": 5.554, "end": 6.214, "zh": "嗯哼。", "zh_hant": "嗯哼。"}, {"index": 4, "text": "Can you show it to me?", "start": 5.974, "end": 7.114, "zh": "能给我看看吗?", "zh_hant": "能給我看看嗎?"}, {"index": 5, "text": "You're never gonna be able to unsee this.", "start": 6.795, "end": 8.696, "zh": "你看了就再也忘不掉了。", "zh_hant": "你看了就再也忘不掉了。"}, {"index": 6, "text": "How do you do it?", "start": 8.336, "end": 9.316, "zh": "你是怎么做到的?", "zh_hant": "你是怎麼做到的?"}, {"index": 7, "text": "First is Botox.", "start": 9.276, "end": 10.617, "zh": "首先是打肉毒杆菌。", "zh_hant": "首先是打肉毒桿菌。"}, {"index": 8, "text": "Then is a nose job.", "start": 11.298, "end": 12.658, "zh": "然后是隆鼻。", "zh_hant": "然後是隆鼻。"}, {"index": 9, "text": "Then is lift.", "start": 12.819, "end": 24.026, "zh": "然后是拉皮。", "zh_hant": "然後是拉皮。"}, {"index": 10, "text": "unbelievable!", "start": 23.826, "end": 24.966, "zh": "难以置信!", "zh_hant": "難以置信!"}, {"index": 11, "text": "I know.", "start": 24.566, "end": 25.447, "zh": "我知道。", "zh_hant": "我知道。"}, {"index": 12, "text": "Can you do one more time?", "start": 25.047, "end": 26.547, "zh": "能再做一次吗?", "zh_hant": "能再做一次嗎?"}, {"index": 13, "text": "It's the best thing I've ever seen.", "start": 26.147, "end": 27.708, "zh": "这是我见过最厉害的了。", "zh_hant": "這是我見過最厲害的了。"}, {"index": 14, "text": "That is a great party trick.", "start": 27.308, "end": 32.131, "zh": "这真是个绝佳的派对小把戏。", "zh_hant": "這真是個絕佳的派對小把戲。"}, {"index": 15, "text": "Oh, my gosh.", "start": 31.731, "end": 33.012, "zh": "天哪。", "zh_hant": "天哪。"}, {"index": 16, "text": "-\"The stickiest stick ever sticked.\"", "start": 32.612, "end": 34.152, "zh": "'史上最粘的粘粘卷。'", "zh_hant": "'史上最粘的粘粘卷。'"}, {"index": 17, "text": "That is the best move I've ever seen.", "start": 33.752, "end": 35.994, "zh": "这是我见过最棒的招数。", "zh_hant": "這是我見過最棒的招數。"}]