[{"index": 0, "text": "What's a good party trick?", "start": 0.0, "end": 1.201, "zh": "有什么好的派对小把戏？", "zh_hant": "有什麼好的派對小把戲？"}, {"index": 1, "text": "I can make myself look like I have a facelift.", "start": 1.281, "end": 3.792, "zh": "我能让自己看起来像做了拉皮手术。", "zh_hant": "我能讓自己看起來像做了拉皮手術。"}, {"index": 2, "text": "You can make yourself look like you've got a facelift?", "start": 3.792, "end": 5.653, "zh": "你能让自己看起来像做了拉皮手术？", "zh_hant": "你能讓自己看起來像做了拉皮手術？"}, {"index": 3, "text": "Mm -hmm.", "start": 5.653, "end": 5.993, "zh": "嗯哼。", "zh_hant": "嗯哼。"}, {"index": 4, "text": "Can you show it to me?", "start": 5.993, "end": 6.854, "zh": "能给我看看吗？", "zh_hant": "能給我看看嗎？"}, {"index": 5, "text": "You're never gonna be able to unsee this.", "start": 6.854, "end": 8.415, "zh": "你看了这个绝对忘不掉。", "zh_hant": "你看了這個絕對忘不掉。"}, {"index": 6, "text": "How do you do it?", "start": 8.415, "end": 9.165, "zh": "你怎么做到的？", "zh_hant": "你怎麼做到的？"}, {"index": 7, "text": "First is Botox.", "start": 9.225, "end": 10.466, "zh": "首先是打肉毒杆菌。", "zh_hant": "首先是打肉毒桿菌。"}, {"index": 8, "text": "Then is a nose job.", "start": 11.246, "end": 12.507, "zh": "然后是隆鼻。", "zh_hant": "然後是隆鼻。"}, {"index": 9, "text": "Then is lift.", "start": 12.767, "end": 23.823, "zh": "然后是拉皮。", "zh_hant": "然後是拉皮。"}, {"index": 10, "text": "unbelievable!", "start": 23.823, "end": 24.714, "zh": "难以置信！", "zh_hant": "難以置信！"}, {"index": 11, "text": "I know.", "start": 24.714, "end": 25.144, "zh": "我知道。", "zh_hant": "我知道。"}, {"index": 12, "text": "Can you do one more time?", "start": 25.144, "end": 26.275, "zh": "能再做一次吗？", "zh_hant": "能再做一次嗎？"}, {"index": 13, "text": "It's the best thing I've ever seen.", "start": 26.275, "end": 27.445, "zh": "这是我见过最厉害的东西。", "zh_hant": "這是我見過最厲害的東西。"}, {"index": 14, "text": "That is a great party trick.", "start": 27.445, "end": 31.828, "zh": "这真是个绝妙的派对小把戏。", "zh_hant": "這真是個絕妙的派對小把戲。"}, {"index": 15, "text": "Oh, my gosh.", "start": 31.828, "end": 32.758, "zh": "哦，天呐。", "zh_hant": "哦，天吶。"}, {"index": 16, "text": "-\"The stickiest stick ever sticked.\"", "start": 32.758, "end": 33.899, "zh": "“史上最粘的粘棒。”", "zh_hant": "“史上最粘的粘棒。”"}, {"index": 17, "text": "That is the best move I've ever seen.", "start": 33.899, "end": 35.82, "zh": "这是我见过最厉害的招数。", "zh_hant": "這是我見過最厲害的招數。"}]