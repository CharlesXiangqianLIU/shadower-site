[{"index": 0, "text": "Lesson 13 A new dress Listen to the tape then answer this question.", "start": 0.43, "end": 10.432, "zh": "第13课 一件新裙子 听录音,然后回答这个问题。", "zh_hant": "第13課 一件新裙子 聽錄音,然後回答這個問題。"}, {"index": 1, "text": "What colour is Anna's hat?", "start": 11.692, "end": 14.953, "zh": "安娜的帽子是什么颜色的?", "zh_hant": "安娜的帽子是什麼顏色的?"}, {"index": 2, "text": "What colour's your new dress?", "start": 16.673, "end": 19.714, "zh": "你的新裙子是什么颜色的?", "zh_hant": "你的新裙子是什麼顏色的?"}, {"index": 3, "text": "It's green.", "start": 20.394, "end": 21.854, "zh": "是绿色的。", "zh_hant": "是綠色的。"}, {"index": 4, "text": "Come upstairs and see it.", "start": 22.434, "end": 25.155, "zh": "上楼来看看吧。", "zh_hant": "上樓來看看吧。"}, {"index": 5, "text": "Thank you.", "start": 25.615, "end": 26.675, "zh": "谢谢。", "zh_hant": "謝謝。"}, {"index": 6, "text": "Look!", "start": 27.495, "end": 28.335, "zh": "看!", "zh_hant": "看!"}, {"index": 7, "text": "Here it is!", "start": 28.576, "end": 30.056, "zh": "在这儿呢!", "zh_hant": "在這兒呢!"}, {"index": 8, "text": "That's a nice dress.", "start": 30.796, "end": 33.176, "zh": "这条裙子真漂亮。", "zh_hant": "這條裙子真漂亮。"}, {"index": 9, "text": "It's very smart.", "start": 33.457, "end": 35.437, "zh": "非常时髦。", "zh_hant": "非常時髦。"}, {"index": 10, "text": "My hat's new too.", "start": 36.117, "end": 38.397, "zh": "我的帽子也是新的。", "zh_hant": "我的帽子也是新的。"}, {"index": 11, "text": "What colour is it?", "start": 39.198, "end": 41.058, "zh": "它是什么颜色的?", "zh_hant": "它是什麼顏色的?"}, {"index": 12, "text": "It's the same colour.", "start": 41.758, "end": 43.919, "zh": "颜色一样。", "zh_hant": "顏色一樣。"}, {"index": 13, "text": "It's green too.", "start": 44.139, "end": 46.179, "zh": "也是绿色的。", "zh_hant": "也是綠色的。"}, {"index": 14, "text": "That is a lovely hat!", "start": 47.119, "end": 50.26, "zh": "这顶帽子真可爱!", "zh_hant": "這頂帽子真可愛!"}]