[{"index": 0, "text": "Lesson 35", "start": 1.581, "end": 2.245}, {"index": 1, "text": "Our village", "start": 4.463, "end": 5.623}, {"index": 2, "text": "Listen to the tape then answer this question.", "start": 7.865, "end": 11.968}, {"index": 3, "text": "Are the children coming out of the park or going into it?", "start": 14.509, "end": 20.013}, {"index": 4, "text": "This is a photograph of our village.", "start": 22.755, "end": 26.177}, {"index": 5, "text": "Our village is in a valley.", "start": 28.358, "end": 30.29}, {"index": 6, "text": "It is between two hills.", "start": 30.29, "end": 30.82}, {"index": 7, "text": "The village is on a river.", "start": 30.82, "end": 40.645}, {"index": 8, "text": "Here is another photograph of the village.", "start": 43.465, "end": 46.966}, {"index": 9, "text": "My wife and I are walking along the banks of the river.", "start": 48.927, "end": 53.968}, {"index": 10, "text": "We are on the left.", "start": 56.449, "end": 58.119}, {"index": 11, "text": "There is a boy in the water.", "start": 58.119, "end": 59.81}, {"index": 12, "text": "He is swimming across the river.", "start": 59.81, "end": 60.39}, {"index": 13, "text": "Here is another photograph.", "start": 60.39, "end": 60.625}, {"index": 14, "text": "This is the school building.", "start": 60.625, "end": 65.448}, {"index": 15, "text": "It is beside a park.", "start": 65.468, "end": 69.4}, {"index": 16, "text": "The park is on the right.", "start": 69.4, "end": 71.041}, {"index": 17, "text": "Some children are coming out of the building.", "start": 71.041, "end": 75.393}, {"index": 18, "text": "Some of them are going into the park.", "start": 75.393, "end": 79.055}]