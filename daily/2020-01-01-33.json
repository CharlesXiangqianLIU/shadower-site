[{"index": 0, "text": "Lesson 65 Not a baby Listen to the tape then answer this question.", "start": 0.75, "end": 10.651, "zh": "第65课 不是小孩子了 听录音,然后回答这个问题。", "zh_hant": "第65課 不是小孩子了 聽錄音,然後回答這個問題。"}, {"index": 1, "text": "Does Jill take the key to the front door?", "start": 11.552, "end": 15.552, "zh": "吉尔拿了前门的钥匙吗?", "zh_hant": "吉爾拿了前門的鑰匙嗎?"}, {"index": 2, "text": "What are you going to do this evening, Jill?", "start": 17.672, "end": 21.893, "zh": "吉尔,你今晚打算做什么?", "zh_hant": "吉爾,你今晚打算做什麼?"}, {"index": 3, "text": "I'm going to meet some friends, Dad.", "start": 22.753, "end": 26.334, "zh": "爸爸,我要去见几个朋友。", "zh_hant": "爸爸,我要去見幾個朋友。"}, {"index": 4, "text": "You mustn't come home late.", "start": 27.094, "end": 29.754, "zh": "你不能太晚回家。", "zh_hant": "你不能太晚回家。"}, {"index": 5, "text": "You must be home at half past ten.", "start": 30.134, "end": 34.215, "zh": "你必须在十点半前到家。", "zh_hant": "你必須在十點半前到家。"}, {"index": 6, "text": "I can't get home so early, Dad!", "start": 34.975, "end": 38.775, "zh": "爸爸,我没法那么早回来!", "zh_hant": "爸爸,我沒法那麼早回來!"}, {"index": 7, "text": "Can I have the key to the front door, please?", "start": 39.295, "end": 44.016, "zh": "能把前门钥匙给我吗?", "zh_hant": "能把前門鑰匙給我嗎?"}, {"index": 8, "text": "No, you can't.", "start": 44.456, "end": 46.416, "zh": "不行。", "zh_hant": "不行。"}, {"index": 9, "text": "Jill's eighteen years old, Tom.", "start": 47.617, "end": 51.457, "zh": "汤姆,吉尔十八岁了。", "zh_hant": "湯姆,吉爾十八歲了。"}, {"index": 10, "text": "She's not a baby.", "start": 51.937, "end": 54.237, "zh": "她不是小孩子了。", "zh_hant": "她不是小孩子了。"}, {"index": 11, "text": "Give her the key.", "start": 54.698, "end": 56.398, "zh": "把钥匙给她吧。", "zh_hant": "把鑰匙給她吧。"}, {"index": 12, "text": "She always comes home early.", "start": 56.978, "end": 60.218, "zh": "她总是很早回家的。", "zh_hant": "她總是很早回家的。"}, {"index": 13, "text": "Oh, all right!", "start": 61.078, "end": 63.299, "zh": "哦,好吧!", "zh_hant": "哦,好吧!"}, {"index": 14, "text": "Here you are.", "start": 64.399, "end": 65.939, "zh": "给你。", "zh_hant": "給你。"}, {"index": 15, "text": "But you mustn't come home after a quarter past eleven.", "start": 66.219, "end": 71.22, "zh": "但你不能超过十一点一刻回来。", "zh_hant": "但你不能超過十一點一刻回來。"}, {"index": 16, "text": "Do you hear?", "start": 71.42, "end": 72.94, "zh": "听到了吗?", "zh_hant": "聽到了嗎?"}, {"index": 17, "text": "Yes, Dad.", "start": 73.56, "end": 75.14, "zh": "听到了,爸爸。", "zh_hant": "聽到了,爸爸。"}, {"index": 18, "text": "Thanks, Mum.", "start": 75.72, "end": 77.281, "zh": "谢谢你,妈妈。", "zh_hant": "謝謝你,媽媽。"}, {"index": 19, "text": "That's all right.", "start": 77.841, "end": 79.521, "zh": "没关系。", "zh_hant": "沒關係。"}, {"index": 20, "text": "Goodbye.", "start": 79.821, "end": 81.081, "zh": "再见。", "zh_hant": "再見。"}, {"index": 21, "text": "Enjoy yourself!", "start": 81.501, "end": 83.381, "zh": "玩得开心点!", "zh_hant": "玩得開心點!"}, {"index": 22, "text": "We always enjoy ourselves, Mum.", "start": 84.382, "end": 87.862, "zh": "妈妈,我们总是玩得很开心。", "zh_hant": "媽媽,我們總是玩得很開心。"}, {"index": 23, "text": "Bye-bye.", "start": 88.202, "end": 89.422, "zh": "拜拜。", "zh_hant": "拜拜。"}]