[{"index": 0, "text": "Lesson 61 A bad cold Listen to the tape then answer this question.", "start": 0.59, "end": 10.091, "zh": "第61课 重感冒 听录音,然后回答问题。", "zh_hant": "第61課 重感冒 聽錄音,然後回答問題。"}, {"index": 1, "text": "What is good news for Jimmy?", "start": 11.111, "end": 14.252, "zh": "什么事对吉米来说是好消息?", "zh_hant": "什麼事對吉米來說是好訊息?"}, {"index": 2, "text": "Where's Jimmy?", "start": 16.552, "end": 17.892, "zh": "吉米在哪儿?", "zh_hant": "吉米在哪兒?"}, {"index": 3, "text": "He's in bed.", "start": 18.112, "end": 19.792, "zh": "他在床上。", "zh_hant": "他在床上。"}, {"index": 4, "text": "What's the matter with him?", "start": 20.652, "end": 22.853, "zh": "他怎么了?", "zh_hant": "他怎麼了?"}, {"index": 5, "text": "He feels ill.", "start": 22.853, "end": 24.913, "zh": "他觉得不舒服。", "zh_hant": "他覺得不舒服。"}, {"index": 6, "text": "He looks ill.", "start": 25.853, "end": 27.653, "zh": "他看起来病了。", "zh_hant": "他看起來病了。"}, {"index": 7, "text": "We must call the doctor.", "start": 27.813, "end": 30.313, "zh": "我们得叫医生。", "zh_hant": "我們得叫醫生。"}, {"index": 8, "text": "Yes, we must.", "start": 31.054, "end": 32.994, "zh": "是的,我们必须叫医生。", "zh_hant": "是的,我們必須叫醫生。"}, {"index": 9, "text": "Can you remember the doctor's telephone number?", "start": 34.074, "end": 38.494, "zh": "你还记得医生的电话号码吗?", "zh_hant": "你還記得醫生的電話號碼嗎?"}, {"index": 10, "text": "Yes.", "start": 38.734, "end": 39.715, "zh": "是的。", "zh_hant": "是的。"}, {"index": 11, "text": "It's 09754.", "start": 40.015, "end": 46.155, "zh": "是09754。", "zh_hant": "是09754。"}, {"index": 12, "text": "Open your mouth, Jimmy.", "start": 45.755, "end": 47.815, "zh": "张开嘴,吉米。", "zh_hant": "張開嘴,吉米。"}, {"index": 13, "text": "Show me your tongue.", "start": 48.376, "end": 50.296, "zh": "把舌头伸出来给我看看。", "zh_hant": "把舌頭伸出來給我看看。"}, {"index": 14, "text": "Say, 'Ah'.", "start": 50.576, "end": 51.956, "zh": "说,'啊'。", "zh_hant": "說,'啊'。"}, {"index": 15, "text": "What's the matter with him, doctor?", "start": 53.676, "end": 56.556, "zh": "他怎么了,医生?", "zh_hant": "他怎麼了,醫生?"}, {"index": 16, "text": "He has a bad cold, Mr. Williams, so he must stay in bed for a week.", "start": 57.157, "end": 64.737, "zh": "他得了重感冒,威廉姆斯先生,所以他必须卧床一周。", "zh_hant": "他得了重感冒,威廉姆斯先生,所以他必須臥床一週。"}, {"index": 17, "text": "That's good news for Jimmy.", "start": 65.818, "end": 68.658, "zh": "这对吉米来说是好消息。", "zh_hant": "這對吉米來說是好訊息。"}, {"index": 18, "text": "Good news?", "start": 69.258, "end": 70.558, "zh": "是好消息吗?", "zh_hant": "是好訊息嗎?"}, {"index": 19, "text": "Why?", "start": 70.678, "end": 71.518, "zh": "为什么?", "zh_hant": "為什麼?"}, {"index": 20, "text": "Because he doesn't like school!", "start": 72.338, "end": 75.539, "zh": "因为他不喜欢上学!", "zh_hant": "因為他不喜歡上學!"}]