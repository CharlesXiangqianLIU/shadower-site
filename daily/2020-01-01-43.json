[{"index": 0, "text": "Lesson 85 'Paris in the Spring'.", "start": 0.55, "end": 5.312, "zh": "第85课《春天的巴黎》", "zh_hant": "第85課《春天的巴黎》"}, {"index": 1, "text": "Listen to the tape then answer this question.", "start": 6.352, "end": 10.573, "zh": "听录音,然后回答这个问题。", "zh_hant": "聽錄音,然後回答這個問題。"}, {"index": 2, "text": "At what time of year did Ken visit Paris?", "start": 11.714, "end": 16.395, "zh": "肯是在一年中的什么时候去的巴黎?", "zh_hant": "肯是在一年中的什麼時候去的巴黎?"}, {"index": 3, "text": "Hello, Ken.", "start": 18.556, "end": 19.856, "zh": "你好,肯。", "zh_hant": "你好,肯。"}, {"index": 4, "text": "Hi, George.", "start": 20.196, "end": 21.696, "zh": "嗨,乔治。", "zh_hant": "嗨,喬治。"}, {"index": 5, "text": "Have you just been to the cinema?", "start": 22.157, "end": 24.957, "zh": "你刚看电影回来吗?", "zh_hant": "你剛看電影回來嗎?"}, {"index": 6, "text": "Yes, I have.", "start": 25.178, "end": 27.058, "zh": "是的。", "zh_hant": "是的。"}, {"index": 7, "text": "What's on?", "start": 27.538, "end": 28.659, "zh": "上映的是什么片子?", "zh_hant": "上映的是什麼片子?"}, {"index": 8, "text": "'Paris in the Spring'.", "start": 29.039, "end": 31.459, "zh": "《春天的巴黎》", "zh_hant": "《春天的巴黎》"}, {"index": 9, "text": "Oh, I've already seen it.", "start": 31.66, "end": 34.36, "zh": "哦,我已经看过了。", "zh_hant": "哦,我已經看過了。"}, {"index": 10, "text": "I saw it on television last year.", "start": 35.021, "end": 38.282, "zh": "我去年在电视上看过。", "zh_hant": "我去年在電視上看過。"}, {"index": 11, "text": "It's an old film, but it's very good.", "start": 38.802, "end": 42.843, "zh": "这是部老电影,不过很不错。", "zh_hant": "這是部老電影,不過很不錯。"}, {"index": 12, "text": "Paris is a beautiful city.", "start": 43.343, "end": 46.264, "zh": "巴黎是座美丽的城市。", "zh_hant": "巴黎是座美麗的城市。"}, {"index": 13, "text": "I've never been there.", "start": 46.984, "end": 48.725, "zh": "我从没去过那儿。", "zh_hant": "我從沒去過那兒。"}, {"index": 14, "text": "Have you ever been there, Ken?", "start": 48.925, "end": 51.566, "zh": "肯,你去过那儿吗?", "zh_hant": "肯,你去過那兒嗎?"}, {"index": 15, "text": "Yes, I have.", "start": 51.986, "end": 53.866, "zh": "是的,我去过。", "zh_hant": "是的,我去過。"}, {"index": 16, "text": "I was there in April.", "start": 54.026, "end": 56.247, "zh": "我四月份在那儿。", "zh_hant": "我四月份在那兒。"}, {"index": 17, "text": "Paris in the spring, eh?", "start": 57.267, "end": 59.928, "zh": "春天的巴黎,是吧?", "zh_hant": "春天的巴黎,是吧?"}, {"index": 18, "text": "It was spring, but the weather was awful.", "start": 60.448, "end": 64.589, "zh": "是春天没错,可天气糟透了。", "zh_hant": "是春天沒錯,可天氣糟透了。"}, {"index": 19, "text": "It rained all the time.", "start": 64.65, "end": 67.33, "zh": "一直在下雨。", "zh_hant": "一直在下雨。"}, {"index": 20, "text": "Just like London!", "start": 67.951, "end": 70.151, "zh": "跟伦敦一样!", "zh_hant": "跟倫敦一樣!"}]