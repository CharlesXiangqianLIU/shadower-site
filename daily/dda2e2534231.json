[{"index": 0, "text": "Lesson 83", "start": 1.6, "end": 2.3, "zh": "第83课", "zh_hant": "第83課"}, {"index": 1, "text": "Going on holiday", "start": 4.141, "end": 5.621, "zh": "去度假", "zh_hant": "去度假"}, {"index": 2, "text": "Listen to the tape then answer this question.", "start": 6.822, "end": 10.263, "zh": "听录音,然后回答这个问题。", "zh_hant": "聽錄音,然後回答這個問題。"}, {"index": 3, "text": "Where did Sam go for his holiday this year?", "start": 12.823, "end": 15.744, "zh": "萨姆今年去哪里度假了?", "zh_hant": "薩姆今年去哪裡度假了?"}, {"index": 4, "text": "Hello, Sam.", "start": 18.445, "end": 19.505, "zh": "你好,萨姆。", "zh_hant": "你好,薩姆。"}, {"index": 5, "text": "Come in.", "start": 19.785, "end": 20.425, "zh": "进来吧。", "zh_hant": "進來吧。"}, {"index": 6, "text": "Hi, Sam.", "start": 21.726, "end": 22.406, "zh": "嗨,萨姆。", "zh_hant": "嗨,薩姆。"}, {"index": 7, "text": "We're having lunch.", "start": 23.026, "end": 23.986, "zh": "我们正在吃午饭。", "zh_hant": "我們正在吃午飯。"}, {"index": 8, "text": "Do you want to have lunch with us?", "start": 24.866, "end": 26.467, "zh": "你要和我们一起吃午饭吗?", "zh_hant": "你要和我們一起吃午飯嗎?"}, {"index": 9, "text": "No, thank you, Tom.", "start": 30.46, "end": 30.94, "zh": "不了,谢谢你,汤姆。", "zh_hant": "不了,謝謝你,湯姆。"}, {"index": 10, "text": "I've already had lunch.", "start": 30.94, "end": 32.381, "zh": "我已经吃过午饭了。", "zh_hant": "我已經吃過午飯了。"}, {"index": 11, "text": "I had lunch at half past twelve.", "start": 32.381, "end": 33.881, "zh": "我十二点半吃的午饭。", "zh_hant": "我十二點半吃的午飯。"}, {"index": 12, "text": "Have a cup of coffee then.", "start": 34.601, "end": 36.022, "zh": "那喝杯咖啡吧。", "zh_hant": "那喝杯咖啡吧。"}, {"index": 13, "text": "I've just had a cup, thank you.", "start": 37.222, "end": 38.803, "zh": "我刚喝过一杯了,谢谢。", "zh_hant": "我剛喝過一杯了,謝謝。"}, {"index": 14, "text": "I had one after my lunch.", "start": 39.563, "end": 41.344, "zh": "我午饭后喝了一杯。", "zh_hant": "我午飯後喝了一杯。"}, {"index": 15, "text": "Let's go into the living room, Carol.", "start": 43.004, "end": 44.865, "zh": "我们去客厅吧,卡罗尔。", "zh_hant": "我們去客廳吧,卡羅爾。"}, {"index": 16, "text": "We can have our coffee there.", "start": 45.385, "end": 46.825, "zh": "我们可以在那儿喝咖啡。", "zh_hant": "我們可以在那兒喝咖啡。"}, {"index": 17, "text": "Excuse the mess, Sam.", "start": 48.146, "end": 56.589, "zh": "抱歉这里有点乱,萨姆。", "zh_hant": "抱歉這裡有點亂,薩姆。"}, {"index": 18, "text": "This room's very untidy.", "start": 57.629, "end": 61.405, "zh": "这个房间很不整洁。", "zh_hant": "這個房間很不整潔。"}, {"index": 19, "text": "We're packing our suitcases.", "start": 61.405, "end": 61.946, "zh": "我们正在收拾行李箱。", "zh_hant": "我們正在收拾行李箱。"}, {"index": 20, "text": "We're going to leave tomorrow.", "start": 61.946, "end": 62.706, "zh": "我们明天要出发。", "zh_hant": "我們明天要出發。"}, {"index": 21, "text": "Tom and I are going to have a holiday.", "start": 62.706, "end": 63.587, "zh": "汤姆和我要去度假了。", "zh_hant": "湯姆和我要去度假了。"}, {"index": 22, "text": "Aren't you lucky!", "start": 63.587, "end": 63.947, "zh": "你们真幸运啊!", "zh_hant": "你們真幸運啊!"}, {"index": 23, "text": "When are you going to have a holiday, Sam?", "start": 63.947, "end": 66.008, "zh": "萨姆,你什么时候去度假?", "zh_hant": "薩姆,你什麼時候去度假?"}, {"index": 24, "text": "I don't know.", "start": 67.209, "end": 67.989, "zh": "我不知道。", "zh_hant": "我不知道。"}, {"index": 25, "text": "I've already had my holiday this year.", "start": 68.87, "end": 71.211, "zh": "我今年已经度过假了。", "zh_hant": "我今年已經度過假了。"}, {"index": 26, "text": "Where did you go?", "start": 72.052, "end": 72.752, "zh": "你去哪儿了?", "zh_hant": "你去哪兒了?"}, {"index": 27, "text": "I stayed at home!", "start": 74.093, "end": 92.77, "zh": "我待在家里!", "zh_hant": "我待在家裡!"}]