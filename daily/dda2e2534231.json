[{"index": 0, "text": "Lesson 83", "start": 1.6, "end": 2.3}, {"index": 1, "text": "Going on holiday", "start": 4.141, "end": 5.621}, {"index": 2, "text": "Listen to the tape then answer this question.", "start": 6.822, "end": 10.263}, {"index": 3, "text": "Where did Sam go for his holiday this year?", "start": 12.823, "end": 15.744}, {"index": 4, "text": "Hello, Sam.", "start": 18.445, "end": 19.505}, {"index": 5, "text": "Come in.", "start": 19.785, "end": 20.425}, {"index": 6, "text": "Hi, Sam.", "start": 21.726, "end": 22.406}, {"index": 7, "text": "We're having lunch.", "start": 23.026, "end": 23.986}, {"index": 8, "text": "Do you want to have lunch with us?", "start": 24.866, "end": 26.467}, {"index": 9, "text": "No, thank you, Tom.", "start": 30.46, "end": 30.94}, {"index": 10, "text": "I've already had lunch.", "start": 30.94, "end": 32.381}, {"index": 11, "text": "I had lunch at half past twelve.", "start": 32.381, "end": 33.881}, {"index": 12, "text": "Have a cup of coffee then.", "start": 34.601, "end": 36.022}, {"index": 13, "text": "I've just had a cup, thank you.", "start": 37.222, "end": 38.803}, {"index": 14, "text": "I had one after my lunch.", "start": 39.563, "end": 41.344}, {"index": 15, "text": "Let's go into the living room, Carol.", "start": 43.004, "end": 44.865}, {"index": 16, "text": "We can have our coffee there.", "start": 45.385, "end": 46.825}, {"index": 17, "text": "Excuse the mess, Sam.", "start": 48.146, "end": 56.589}, {"index": 18, "text": "This room's very untidy.", "start": 57.629, "end": 61.405}, {"index": 19, "text": "We're packing our suitcases.", "start": 61.405, "end": 61.946}, {"index": 20, "text": "We're going to leave tomorrow.", "start": 61.946, "end": 62.706}, {"index": 21, "text": "Tom and I are going to have a holiday.", "start": 62.706, "end": 63.587}, {"index": 22, "text": "Aren't you lucky!", "start": 63.587, "end": 63.947}, {"index": 23, "text": "When are you going to have a holiday, Sam?", "start": 63.947, "end": 66.008}, {"index": 24, "text": "I don't know.", "start": 67.209, "end": 67.989}, {"index": 25, "text": "I've already had my holiday this year.", "start": 68.87, "end": 71.211}, {"index": 26, "text": "Where did you go?", "start": 72.052, "end": 72.752}, {"index": 27, "text": "I stayed at home!", "start": 74.093, "end": 92.77}]