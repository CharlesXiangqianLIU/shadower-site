[{"index": 0, "text": "Lesson 41", "start": 1.54, "end": 2.0}, {"index": 1, "text": "Penny's bag", "start": 4.041, "end": 5.181}, {"index": 2, "text": "Listen to the tape then answer this question.", "start": 6.982, "end": 10.763}, {"index": 3, "text": "Who is the tin of tobacco for?", "start": 13.243, "end": 15.864}, {"index": 4, "text": "Is that bag heavy, Penny?", "start": 18.625, "end": 20.345}, {"index": 5, "text": "Not very.", "start": 21.086, "end": 21.726}, {"index": 6, "text": "Here!", "start": 22.846, "end": 23.286}, {"index": 7, "text": "Put it on this chair.", "start": 24.026, "end": 25.387}, {"index": 8, "text": "What's in it?", "start": 26.527, "end": 27.207}, {"index": 9, "text": "A piece of cheese.", "start": 28.247, "end": 30.785}, {"index": 10, "text": "A loaf of bread.", "start": 30.665, "end": 31.806}, {"index": 11, "text": "A bar of soap.", "start": 32.766, "end": 33.787}, {"index": 12, "text": "A bar of chocolate.", "start": 34.747, "end": 36.028}, {"index": 13, "text": "A bottle of milk.", "start": 37.009, "end": 38.029}, {"index": 14, "text": "A pound of sugar.", "start": 39.25, "end": 40.31}, {"index": 15, "text": "Half a pound of coffee.", "start": 41.911, "end": 43.232}, {"index": 16, "text": "A quarter of a pound of tea.", "start": 44.793, "end": 46.433}, {"index": 17, "text": "And a tin of tobacco.", "start": 47.474, "end": 48.695}, {"index": 18, "text": "Is that tin of tobacco for me?", "start": 50.256, "end": 60.605}, {"index": 19, "text": "Well, it's certainly not for me!", "start": 60.505, "end": 63.196}]