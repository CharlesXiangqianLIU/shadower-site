[{"index": 0, "text": "Lesson 41", "start": 1.54, "end": 2.0, "zh": "第41课", "zh_hant": "第41課"}, {"index": 1, "text": "Penny's bag", "start": 4.041, "end": 5.181, "zh": "佩妮的包", "zh_hant": "佩妮的包"}, {"index": 2, "text": "Listen to the tape then answer this question.", "start": 6.982, "end": 10.763, "zh": "听录音,然后回答这个问题。", "zh_hant": "聽錄音,然後回答這個問題。"}, {"index": 3, "text": "Who is the tin of tobacco for?", "start": 13.243, "end": 15.864, "zh": "这罐烟草是给谁的?", "zh_hant": "這罐菸草是給誰的?"}, {"index": 4, "text": "Is that bag heavy, Penny?", "start": 18.625, "end": 20.345, "zh": "佩妮,那个包重吗?", "zh_hant": "佩妮,那個包重嗎?"}, {"index": 5, "text": "Not very.", "start": 21.086, "end": 21.726, "zh": "不太重。", "zh_hant": "不太重。"}, {"index": 6, "text": "Here!", "start": 22.846, "end": 23.286, "zh": "给!", "zh_hant": "給!"}, {"index": 7, "text": "Put it on this chair.", "start": 24.026, "end": 25.387, "zh": "把它放在这把椅子上。", "zh_hant": "把它放在這把椅子上。"}, {"index": 8, "text": "What's in it?", "start": 26.527, "end": 27.207, "zh": "里面是什么?", "zh_hant": "裡面是什麼?"}, {"index": 9, "text": "A piece of cheese.", "start": 28.247, "end": 30.725, "zh": "一块奶酪。", "zh_hant": "一塊乳酪。"}, {"index": 10, "text": "A loaf of bread.", "start": 30.725, "end": 31.806, "zh": "一条面包。", "zh_hant": "一條麵包。"}, {"index": 11, "text": "A bar of soap.", "start": 32.766, "end": 33.787, "zh": "一块肥皂。", "zh_hant": "一塊肥皂。"}, {"index": 12, "text": "A bar of chocolate.", "start": 34.747, "end": 36.028, "zh": "一块巧克力。", "zh_hant": "一塊巧克力。"}, {"index": 13, "text": "A bottle of milk.", "start": 37.009, "end": 38.029, "zh": "一瓶牛奶。", "zh_hant": "一瓶牛奶。"}, {"index": 14, "text": "A pound of sugar.", "start": 39.25, "end": 40.31, "zh": "一磅糖。", "zh_hant": "一磅糖。"}, {"index": 15, "text": "Half a pound of coffee.", "start": 41.911, "end": 43.232, "zh": "半磅咖啡。", "zh_hant": "半磅咖啡。"}, {"index": 16, "text": "A quarter of a pound of tea.", "start": 44.793, "end": 46.433, "zh": "四分之一磅茶叶。", "zh_hant": "四分之一磅茶葉。"}, {"index": 17, "text": "And a tin of tobacco.", "start": 47.474, "end": 48.695, "zh": "还有一罐烟草。", "zh_hant": "還有一罐菸草。"}, {"index": 18, "text": "Is that tin of tobacco for me?", "start": 50.256, "end": 60.555, "zh": "那罐烟草是给我的吗?", "zh_hant": "那罐菸草是給我的嗎?"}, {"index": 19, "text": "Well, it's certainly not for me!", "start": 60.555, "end": 63.196, "zh": "嗯,反正不是给我的!", "zh_hant": "嗯,反正不是給我的!"}]