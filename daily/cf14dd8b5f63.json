[{"index": 0, "text": "Lesson 113", "start": 1.55, "end": 2.605, "zh": "第113课", "zh_hant": "第113課"}, {"index": 1, "text": "Small change", "start": 4.751, "end": 5.931, "zh": "零钱", "zh_hant": "零錢"}, {"index": 2, "text": "Listen to the tape then answer this question.", "start": 7.251, "end": 10.192, "zh": "听录音,然后回答问题。", "zh_hant": "聽錄音,然後回答問題。"}, {"index": 3, "text": "Who has got some small change?", "start": 12.612, "end": 14.652, "zh": "谁有零钱?", "zh_hant": "誰有零錢?"}, {"index": 4, "text": "Fares, please!", "start": 17.313, "end": 18.213, "zh": "请买票!", "zh_hant": "請買票!"}, {"index": 5, "text": "Trafalgar Square, please.", "start": 19.473, "end": 20.733, "zh": "请到特拉法加广场。", "zh_hant": "請到特拉法加廣場。"}, {"index": 6, "text": "I'm sorry, sir.", "start": 22.014, "end": 22.974, "zh": "对不起,先生。", "zh_hant": "對不起,先生。"}, {"index": 7, "text": "I can't change a ten-pound note.", "start": 23.534, "end": 25.674, "zh": "我没法换开十英镑的钞票。", "zh_hant": "我沒法換開十英鎊的鈔票。"}, {"index": 8, "text": "Haven't you got any small change?", "start": 26.134, "end": 30.733, "zh": "您没有零钱吗?", "zh_hant": "您沒有零錢嗎?"}, {"index": 9, "text": "I've got no small change,", "start": 30.733, "end": 31.344, "zh": "恐怕我没有零钱。", "zh_hant": "恐怕我沒有零錢。"}, {"index": 10, "text": "I am afraid.", "start": 31.344, "end": 32.894, "zh": "恐怕没有。", "zh_hant": "恐怕沒有。"}, {"index": 11, "text": "I'll ask some of the passengers.", "start": 32.894, "end": 34.335, "zh": "我问问其他乘客。", "zh_hant": "我問問其他乘客。"}, {"index": 12, "text": "Have you any small change, sir?", "start": 35.616, "end": 37.277, "zh": "先生,您有零钱吗?", "zh_hant": "先生,您有零錢嗎?"}, {"index": 13, "text": "I'm sorry.", "start": 38.217, "end": 38.838, "zh": "对不起。", "zh_hant": "對不起。"}, {"index": 14, "text": "I've got none.", "start": 39.438, "end": 40.359, "zh": "我没有。", "zh_hant": "我沒有。"}, {"index": 15, "text": "I haven't got any either.", "start": 42.24, "end": 43.68, "zh": "我也没有。", "zh_hant": "我也沒有。"}, {"index": 16, "text": "Can you change this ten-pound note, madam?", "start": 45.141, "end": 47.583, "zh": "夫人,您能换开这张十英镑的钞票吗?", "zh_hant": "夫人,您能換開這張十英鎊的鈔票嗎?"}, {"index": 17, "text": "I'm afraid I can't.", "start": 48.503, "end": 49.604, "zh": "恐怕不行。", "zh_hant": "恐怕不行。"}, {"index": 18, "text": "Neither can I.", "start": 51.485, "end": 60.697, "zh": "我也不行。", "zh_hant": "我也不行。"}, {"index": 19, "text": "I'm very sorry, sir.", "start": 60.697, "end": 61.218, "zh": "先生,非常抱歉。", "zh_hant": "先生,非常抱歉。"}, {"index": 20, "text": "You must get off the bus.", "start": 61.218, "end": 61.788, "zh": "您得下车了。", "zh_hant": "您得下車了。"}, {"index": 21, "text": "None of our passengers can change this note.", "start": 61.788, "end": 63.229, "zh": "我们车上没人能换开这张钞票。", "zh_hant": "我們車上沒人能換開這張鈔票。"}, {"index": 22, "text": "They're all millionaires!", "start": 63.229, "end": 64.15, "zh": "他们都是百万富翁!", "zh_hant": "他們都是百萬富翁!"}, {"index": 23, "text": "Except us.", "start": 65.932, "end": 66.713, "zh": "除了我们。", "zh_hant": "除了我們。"}, {"index": 24, "text": "I've got some small change.", "start": 68.254, "end": 69.455, "zh": "我有零钱。", "zh_hant": "我有零錢。"}, {"index": 25, "text": "So have I.", "start": 70.456, "end": 71.057, "zh": "我也有。", "zh_hant": "我也有。"}]