[{"index": 0, "text": "Lesson 113", "start": 1.55, "end": 2.605}, {"index": 1, "text": "Small change", "start": 4.751, "end": 5.931}, {"index": 2, "text": "Listen to the tape then answer this question.", "start": 7.251, "end": 10.192}, {"index": 3, "text": "Who has got some small change?", "start": 12.612, "end": 14.652}, {"index": 4, "text": "Fares, please!", "start": 17.313, "end": 18.213}, {"index": 5, "text": "Trafalgar Square, please.", "start": 19.473, "end": 20.733}, {"index": 6, "text": "I'm sorry, sir.", "start": 22.014, "end": 22.974}, {"index": 7, "text": "I can't change a ten-pound note.", "start": 23.534, "end": 25.674}, {"index": 8, "text": "Haven't you got any small change?", "start": 26.134, "end": 30.793}, {"index": 9, "text": "I've got no small change,", "start": 30.673, "end": 31.374}, {"index": 10, "text": "I am afraid.", "start": 31.314, "end": 32.954}, {"index": 11, "text": "I'll ask some of the passengers.", "start": 32.834, "end": 34.335}, {"index": 12, "text": "Have you any small change, sir?", "start": 35.616, "end": 37.277}, {"index": 13, "text": "I'm sorry.", "start": 38.217, "end": 38.838}, {"index": 14, "text": "I've got none.", "start": 39.438, "end": 40.359}, {"index": 15, "text": "I haven't got any either.", "start": 42.24, "end": 43.68}, {"index": 16, "text": "Can you change this ten-pound note, madam?", "start": 45.141, "end": 47.583}, {"index": 17, "text": "I'm afraid I can't.", "start": 48.503, "end": 49.604}, {"index": 18, "text": "Neither can I.", "start": 51.485, "end": 60.747}, {"index": 19, "text": "I'm very sorry, sir.", "start": 60.647, "end": 61.268}, {"index": 20, "text": "You must get off the bus.", "start": 61.168, "end": 61.848}, {"index": 21, "text": "None of our passengers can change this note.", "start": 61.728, "end": 63.289}, {"index": 22, "text": "They're all millionaires!", "start": 63.169, "end": 64.15}, {"index": 23, "text": "Except us.", "start": 65.932, "end": 66.713}, {"index": 24, "text": "I've got some small change.", "start": 68.254, "end": 69.455}, {"index": 25, "text": "So have I.", "start": 70.456, "end": 71.057}]