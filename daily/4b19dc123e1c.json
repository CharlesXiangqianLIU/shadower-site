[{"index": 0, "text": "Why did the writer complain to the people behind him?", "start": 12.912, "end": 17.874, "zh": "为什么作者向坐在他后面的人抱怨?"}, {"index": 1, "text": "Last week I went to the theatre.", "start": 20.596, "end": 23.077, "zh": "上星期我去看戏。"}, {"index": 2, "text": "I had a very good seat.", "start": 24.217, "end": 25.738, "zh": "我的座位非常好。"}, {"index": 3, "text": "The play was very interesting.", "start": 27.419, "end": 29.48, "zh": "这出戏非常有趣。"}, {"index": 4, "text": "I did not enjoy it.", "start": 30.861, "end": 32.281, "zh": "但我没能好好欣赏。"}, {"index": 5, "text": "A young man and a young woman were sitting behind me.", "start": 33.482, "end": 37.264, "zh": "有一对青年男女坐在我后面。"}, {"index": 6, "text": "They were talking loudly.", "start": 38.184, "end": 39.025, "zh": "他们大声说话。"}, {"index": 7, "text": "I got very angry.", "start": 39.025, "end": 39.405, "zh": "我非常生气。"}, {"index": 8, "text": "I could not hear the actors.", "start": 39.405, "end": 45.487, "zh": "我听不见演员的台词。"}, {"index": 9, "text": "I turned round.", "start": 46.587, "end": 47.908, "zh": "我转过身去。"}, {"index": 10, "text": "I looked at the man and the woman angrily.", "start": 49.149, "end": 52.07, "zh": "我怒视着那对男女。"}, {"index": 11, "text": "They did not pay any attention.", "start": 53.471, "end": 55.432, "zh": "他们毫不理会。"}, {"index": 12, "text": "In the end, I could not bear it.", "start": 56.473, "end": 59.314, "zh": "最后,我实在无法忍受了。"}, {"index": 13, "text": "I turned round again.", "start": 59.835, "end": 61.135, "zh": "我又一次转过身去。"}, {"index": 14, "text": "'I can't hear a word!' I said angrily.", "start": 61.656, "end": 66.298, "zh": "“我一个字都听不见!”我生气地说。"}, {"index": 15, "text": "'It's none of your business,'", "start": 66.438, "end": 68.96, "zh": "“不关你的事,”"}, {"index": 16, "text": "the young man said rudely.", "start": 68.96, "end": 69.54, "zh": "那个年轻男人无礼地说道。"}, {"index": 17, "text": "'This is a private conversation!'", "start": 69.54, "end": 72.08, "zh": "“这是我们的私人谈话!”"}]