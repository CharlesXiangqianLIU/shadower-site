[{"index": 0, "text": "Why did the writer complain to the people behind him?", "start": 12.912, "end": 17.874}, {"index": 1, "text": "Last week I went to the theatre.", "start": 20.596, "end": 23.077}, {"index": 2, "text": "I had a very good seat.", "start": 24.217, "end": 25.738}, {"index": 3, "text": "The play was very interesting.", "start": 27.419, "end": 29.48}, {"index": 4, "text": "I did not enjoy it.", "start": 30.861, "end": 32.281}, {"index": 5, "text": "A young man and a young woman were sitting behind me.", "start": 33.482, "end": 37.264}, {"index": 6, "text": "They were talking loudly.", "start": 38.184, "end": 39.025}, {"index": 7, "text": "I got very angry.", "start": 39.025, "end": 39.405}, {"index": 8, "text": "I could not hear the actors.", "start": 39.405, "end": 45.487}, {"index": 9, "text": "I turned round.", "start": 46.587, "end": 47.908}, {"index": 10, "text": "I looked at the man and the woman angrily.", "start": 49.149, "end": 52.07}, {"index": 11, "text": "They did not pay any attention.", "start": 53.471, "end": 55.432}, {"index": 12, "text": "In the end, I could not bear it.", "start": 56.473, "end": 59.314}, {"index": 13, "text": "I turned round again.", "start": 59.835, "end": 61.135}, {"index": 14, "text": "'I can't hear a word!' I said angrily.", "start": 61.656, "end": 66.298}, {"index": 15, "text": "'It's none of your business,'", "start": 66.438, "end": 68.96}, {"index": 16, "text": "the young man said rudely.", "start": 68.96, "end": 69.54}, {"index": 17, "text": "'This is a private conversation!'", "start": 69.54, "end": 72.08}]