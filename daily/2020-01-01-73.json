[{"index": 0, "text": "Why did the writer complain to the people behind him?", "start": 9.791, "end": 14.212, "zh": "为什么作者向坐在他后面的人抱怨?", "zh_hant": "為什麼作者向坐在他後面的人抱怨?"}, {"index": 1, "text": "Last week I went to the theatre.", "start": 15.932, "end": 19.032, "zh": "上星期我去看戏。", "zh_hant": "上星期我去看戲。"}, {"index": 2, "text": "I had a very good seat.", "start": 19.473, "end": 21.693, "zh": "我的座位非常好。", "zh_hant": "我的座位非常好。"}, {"index": 3, "text": "The play was very interesting.", "start": 22.053, "end": 24.593, "zh": "这出戏非常有趣。", "zh_hant": "這出戏非常有趣。"}, {"index": 4, "text": "I did not enjoy it.", "start": 25.313, "end": 26.993, "zh": "但我没能好好欣赏。", "zh_hant": "但我沒能好好欣賞。"}, {"index": 5, "text": "A young man and a young woman were sitting behind me.", "start": 27.414, "end": 31.474, "zh": "有一对青年男女坐在我后面。", "zh_hant": "有一對青年男女坐在我後面。"}, {"index": 6, "text": "They were talking loudly.", "start": 31.974, "end": 34.154, "zh": "他们大声说话。", "zh_hant": "他們大聲說話。"}, {"index": 7, "text": "I got very angry.", "start": 34.735, "end": 36.875, "zh": "我非常生气。", "zh_hant": "我非常生氣。"}, {"index": 8, "text": "I could not hear the actors.", "start": 37.455, "end": 40.135, "zh": "我听不见演员的台词。", "zh_hant": "我聽不見演員的臺詞。"}, {"index": 9, "text": "I turned round.", "start": 40.715, "end": 42.235, "zh": "我转过身去。", "zh_hant": "我轉過身去。"}, {"index": 10, "text": "I looked at the man and the woman angrily.", "start": 42.916, "end": 46.416, "zh": "我怒视着那对男女。", "zh_hant": "我怒視著那對男女。"}, {"index": 11, "text": "They did not pay any attention.", "start": 47.256, "end": 50.016, "zh": "他们毫不理会。", "zh_hant": "他們毫不理會。"}, {"index": 12, "text": "In the end, I could not bear it.", "start": 50.677, "end": 54.437, "zh": "最后,我实在无法忍受了。", "zh_hant": "最後,我實在無法忍受了。"}, {"index": 13, "text": "I turned round again.", "start": 55.057, "end": 56.837, "zh": "我又一次转过身去。", "zh_hant": "我又一次轉過身去。"}, {"index": 14, "text": "'I can't hear a word!'", "start": 56.597, "end": 60.698, "zh": "“我一个字都听不见！”", "zh_hant": "“我一個字都聽不見！”"}, {"index": 15, "text": "I said angrily.", "start": 61.018, "end": 62.698, "zh": "我生气地说。", "zh_hant": "我生氣地說。"}, {"index": 16, "text": "'It's none of your business,' the young man said rudely.", "start": 62.298, "end": 68.559, "zh": "“不关你的事，”那年轻人粗鲁地说。", "zh_hant": "“不關你的事，”那年輕人粗魯地說。"}, {"index": 17, "text": "'This is a private conversation!'", "start": 68.359, "end": 72.039, "zh": "“这是我们的私人谈话!”", "zh_hant": "“這是我們的私人談話!”"}]