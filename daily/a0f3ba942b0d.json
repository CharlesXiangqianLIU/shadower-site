[{"index": 0, "text": "Lesson 17", "start": 1.56, "end": 2.035, "zh": "第17课", "zh_hant": "第17課"}, {"index": 1, "text": "How do you do?", "start": 3.961, "end": 4.982, "zh": "你好", "zh_hant": "你好"}, {"index": 2, "text": "Listen to the tape then answer this question.", "start": 6.822, "end": 10.343, "zh": "听录音,然后回答这个问题。", "zh_hant": "聽錄音,然後回答這個問題。"}, {"index": 3, "text": "What are Michael Baker and Jeremy Short's jobs?", "start": 12.864, "end": 17.086, "zh": "迈克尔·贝克和杰里米·肖特是做什么工作的?", "zh_hant": "邁克爾·貝克和傑里米·肖特是做什麼工作的?"}, {"index": 4, "text": "Come and meet our employees Mr.Richards.", "start": 19.907, "end": 23.108, "zh": "理查兹先生,来见见我们的员工。", "zh_hant": "理查茲先生,來見見我們的員工。"}, {"index": 5, "text": "Thank you Mr. Jackson.", "start": 24.708, "end": 26.249, "zh": "谢谢你,杰克逊先生。", "zh_hant": "謝謝你,傑克遜先生。"}, {"index": 6, "text": "This is Nicola Grey", "start": 27.989, "end": 31.29, "zh": "这位是妮可拉·格雷,", "zh_hant": "這位是妮可拉·格雷,"}, {"index": 7, "text": "and this is Claire Taylor.", "start": 31.37, "end": 33.931, "zh": "这位是克莱尔·泰勒。", "zh_hant": "這位是克萊爾·泰勒。"}, {"index": 8, "text": "How do you do?", "start": 35.231, "end": 35.911, "zh": "你好。", "zh_hant": "你好。"}, {"index": 9, "text": "Those women are very hard-working.", "start": 37.732, "end": 40.492, "zh": "那些女士都非常勤奋。", "zh_hant": "那些女士都非常勤奮。"}, {"index": 10, "text": "What are their jobs?", "start": 41.453, "end": 42.913, "zh": "她们是做什么工作的?", "zh_hant": "她們是做什麼工作的?"}, {"index": 11, "text": "They're keyboard operators.", "start": 44.733, "end": 46.854, "zh": "她们是键盘操作员。", "zh_hant": "她們是鍵盤操作員。"}, {"index": 12, "text": "This is Michael Baker", "start": 48.874, "end": 50.635, "zh": "这位是迈克尔·贝克,", "zh_hant": "這位是邁克爾·貝克,"}, {"index": 13, "text": "and this is Jeremy Short.", "start": 51.875, "end": 54.155, "zh": "这位是杰里米·肖特。", "zh_hant": "這位是傑里米·肖特。"}, {"index": 14, "text": "How do you do?", "start": 55.896, "end": 56.596, "zh": "你好。", "zh_hant": "你好。"}, {"index": 15, "text": "They aren't very busy!", "start": 60.15, "end": 60.63, "zh": "他们不太忙啊!", "zh_hant": "他們不太忙啊!"}, {"index": 16, "text": "What are their jobs?", "start": 61.731, "end": 63.253, "zh": "他们是做什么工作的?", "zh_hant": "他們是做什麼工作的?"}, {"index": 17, "text": "They're sales reps.", "start": 65.034, "end": 66.736, "zh": "他们是销售代表。", "zh_hant": "他們是銷售代表。"}, {"index": 18, "text": "They're very lazy.", "start": 67.657, "end": 69.258, "zh": "他们很懒。", "zh_hant": "他們很懶。"}, {"index": 19, "text": "Who is this young man?", "start": 71.74, "end": 73.422, "zh": "这位年轻人是谁?", "zh_hant": "這位年輕人是誰?"}, {"index": 20, "text": "This is Jim.", "start": 75.204, "end": 76.385, "zh": "这是吉姆。", "zh_hant": "這是吉姆。"}, {"index": 21, "text": "He's our office assistant.", "start": 77.426, "end": 79.848, "zh": "他是我们的办公室助理。", "zh_hant": "他是我們的辦公室助理。"}]