[{"index": 0, "text": "Lesson 17", "start": 1.56, "end": 2.035}, {"index": 1, "text": "How do you do?", "start": 3.961, "end": 4.982}, {"index": 2, "text": "Listen to the tape then answer this question.", "start": 6.822, "end": 10.343}, {"index": 3, "text": "What are Michael Baker and Jeremy Short's jobs?", "start": 12.864, "end": 17.086}, {"index": 4, "text": "Come and meet our employees Mr.Richards.", "start": 19.907, "end": 23.108}, {"index": 5, "text": "Thank you Mr. Jackson.", "start": 24.708, "end": 26.249}, {"index": 6, "text": "This is Nicola Grey", "start": 27.989, "end": 31.29}, {"index": 7, "text": "and this is Claire Taylor.", "start": 31.37, "end": 33.931}, {"index": 8, "text": "How do you do?", "start": 35.231, "end": 35.911}, {"index": 9, "text": "Those women are very hard-working.", "start": 37.732, "end": 40.492}, {"index": 10, "text": "What are their jobs?", "start": 41.453, "end": 42.913}, {"index": 11, "text": "They're keyboard operators.", "start": 44.733, "end": 46.854}, {"index": 12, "text": "This is Michael Baker", "start": 48.874, "end": 50.635}, {"index": 13, "text": "and this is Jeremy Short.", "start": 51.875, "end": 54.155}, {"index": 14, "text": "How do you do?", "start": 55.896, "end": 56.596}, {"index": 15, "text": "They aren't very busy!", "start": 60.15, "end": 60.63}, {"index": 16, "text": "What are their jobs?", "start": 61.731, "end": 63.253}, {"index": 17, "text": "They're sales reps.", "start": 65.034, "end": 66.736}, {"index": 18, "text": "They're very lazy.", "start": 67.657, "end": 69.258}, {"index": 19, "text": "Who is this young man?", "start": 71.74, "end": 73.422}, {"index": 20, "text": "This is Jim.", "start": 75.204, "end": 76.385}, {"index": 21, "text": "He's our office assistant.", "start": 77.426, "end": 79.848}]