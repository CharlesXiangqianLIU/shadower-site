[{"index": 0, "text": "Lesson 123 A trip to Australia Listen to the tape then answer this question.", "start": 0.73, "end": 12.031, "zh": "第123课 澳大利亚之旅 听录音,然后回答这个问题。", "zh_hant": "第123課 澳大利亞之旅 聽錄音,然後回答這個問題。"}, {"index": 1, "text": "Who is the man with the beard?", "start": 12.892, "end": 15.852, "zh": "那个留胡子的男人是谁?", "zh_hant": "那個留鬍子的男人是誰?"}, {"index": 2, "text": "Look, Scott.", "start": 17.832, "end": 19.192, "zh": "看,斯科特。", "zh_hant": "看,斯科特。"}, {"index": 3, "text": "This is a photograph I took during my trip to Australia.", "start": 19.992, "end": 25.873, "zh": "这是我在澳大利亚旅行时拍的一张照片。", "zh_hant": "這是我在澳大利亞旅行時拍的一張照片。"}, {"index": 4, "text": "Let me see it, Mike.", "start": 26.633, "end": 28.773, "zh": "让我看看,迈克。", "zh_hant": "讓我看看,邁克。"}, {"index": 5, "text": "This is a good photograph.", "start": 29.194, "end": 31.714, "zh": "这张照片拍得真好。", "zh_hant": "這張照片拍得真好。"}, {"index": 6, "text": "Who are these people?", "start": 31.914, "end": 33.954, "zh": "这些人是谁?", "zh_hant": "這些人是誰?"}, {"index": 7, "text": "They're people I met during the trip.", "start": 35.014, "end": 38.415, "zh": "他们是我在旅途中认识的人。", "zh_hant": "他們是我在旅途中認識的人。"}, {"index": 8, "text": "That's the ship we travelled on.", "start": 39.475, "end": 41.975, "zh": "那就是我们乘坐的那艘船。", "zh_hant": "那就是我們乘坐的那艘船。"}, {"index": 9, "text": "What a beautiful ship!", "start": 42.335, "end": 44.615, "zh": "多漂亮的一艘船啊!", "zh_hant": "多漂亮的一艘船啊!"}, {"index": 10, "text": "Who's this?", "start": 44.975, "end": 46.316, "zh": "这是谁?", "zh_hant": "這是誰?"}, {"index": 11, "text": "That's the man I told you about.", "start": 47.116, "end": 50.096, "zh": "那就是我跟你提过的那个人。", "zh_hant": "那就是我跟你提過的那個人。"}, {"index": 12, "text": "Remember?", "start": 50.156, "end": 51.216, "zh": "还记得吗?", "zh_hant": "還記得嗎?"}, {"index": 13, "text": "Ah yes.", "start": 51.616, "end": 52.976, "zh": "啊,记得。", "zh_hant": "啊,記得。"}, {"index": 14, "text": "The one who offered you a job in Australia.", "start": 53.016, "end": 56.977, "zh": "就是那个在澳大利亚给你提供工作的人。", "zh_hant": "就是那個在澳大利亞給你提供工作的人。"}, {"index": 15, "text": "That's right.", "start": 57.317, "end": 58.617, "zh": "没错。", "zh_hant": "沒錯。"}, {"index": 16, "text": "Who's this?", "start": 58.877, "end": 60.217, "zh": "这是谁?", "zh_hant": "這是誰?"}, {"index": 17, "text": "Guess!", "start": 60.537, "end": 61.497, "zh": "猜猜看!", "zh_hant": "猜猜看!"}, {"index": 18, "text": "It's not you, is it?", "start": 61.757, "end": 64.118, "zh": "不会是你吧?", "zh_hant": "不會是你吧?"}, {"index": 19, "text": "That's right.", "start": 64.058, "end": 65.638, "zh": "没错。", "zh_hant": "沒錯。"}, {"index": 20, "text": "I grew a beard during the trip, but I shaved it off when I came home.", "start": 66.698, "end": 73.419, "zh": "我在旅行期间留了胡子,但回家后就剃掉了。", "zh_hant": "我在旅行期間留了鬍子,但回家後就剃掉了。"}, {"index": 21, "text": "Why did you shave it off?", "start": 73.479, "end": 75.819, "zh": "你为什么把胡子剃掉了?", "zh_hant": "你為什麼把鬍子剃掉了?"}, {"index": 22, "text": "My wife didn't like it!", "start": 76.139, "end": 78.599, "zh": "我妻子不喜欢。", "zh_hant": "我妻子不喜歡。"}]