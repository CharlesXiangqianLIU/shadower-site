[{"index": 0, "text": "Lesson 77", "start": 1.601, "end": 2.09}, {"index": 1, "text": "Terrible toothache", "start": 4.323, "end": 5.783}, {"index": 2, "text": "Listen to the tape then answer this question.", "start": 7.585, "end": 10.867}, {"index": 3, "text": "What time of day is it, do you think? How do you know?", "start": 13.448, "end": 17.311}, {"index": 4, "text": "Good morning, Mr. Croft.", "start": 20.032, "end": 21.593}, {"index": 5, "text": "Good morning, nurse.", "start": 22.454, "end": 23.655}, {"index": 6, "text": "I want to see the dentist, please.", "start": 24.275, "end": 30.594}, {"index": 7, "text": "Do you have an appointment?", "start": 30.594, "end": 31.154}, {"index": 8, "text": "No, I don't.", "start": 31.154, "end": 32.314}, {"index": 9, "text": "Is it urgent?", "start": 32.314, "end": 33.335}, {"index": 10, "text": "Yes, it is.", "start": 34.175, "end": 35.675}, {"index": 11, "text": "It's very urgent.", "start": 36.275, "end": 37.835}, {"index": 12, "text": "I feel awful.", "start": 38.896, "end": 40.496}, {"index": 13, "text": "I have a terrible toothache.", "start": 41.516, "end": 43.597}, {"index": 14, "text": "Can you come at 10 a.m. on Monday, April 24th?", "start": 44.757, "end": 51.478}, {"index": 15, "text": "I must see the dentist now, nurse.", "start": 53.819, "end": 60.38}, {"index": 16, "text": "The dentist is very busy at the moment.", "start": 60.38, "end": 61.42}, {"index": 17, "text": "Can you come at 2 p.m. ?", "start": 62.561, "end": 66.062}, {"index": 18, "text": "That's very late.", "start": 66.062, "end": 67.523}, {"index": 19, "text": "Can the dentist see me now?", "start": 68.463, "end": 70.664}, {"index": 20, "text": "I'm afraid that he can't, Mr. Croft.", "start": 71.944, "end": 74.906}, {"index": 21, "text": "Can't you wait till this afternoon?", "start": 75.766, "end": 78.327}, {"index": 22, "text": "I can wait, but my toothache can't!", "start": 79.627, "end": 82.688}]