[{"index": 0, "text": "Lesson 77", "start": 1.601, "end": 2.09, "zh": "第77课", "zh_hant": "第77課"}, {"index": 1, "text": "Terrible toothache", "start": 4.323, "end": 5.783, "zh": "牙痛难忍", "zh_hant": "牙痛難忍"}, {"index": 2, "text": "Listen to the tape then answer this question.", "start": 7.585, "end": 10.867, "zh": "听录音，然后回答这个问题。", "zh_hant": "聽錄音，然後回答這個問題。"}, {"index": 3, "text": "What time of day is it, do you think? How do you know?", "start": 13.448, "end": 17.311, "zh": "你觉得现在是一天中的什么时间？你是怎么知道的？", "zh_hant": "你覺得現在是一天中的什麼時間？你是怎麼知道的？"}, {"index": 4, "text": "Good morning, Mr. Croft.", "start": 20.032, "end": 21.593, "zh": "早上好，克罗夫特先生。", "zh_hant": "早上好，克羅夫特先生。"}, {"index": 5, "text": "Good morning, nurse.", "start": 22.454, "end": 23.655, "zh": "早上好，护士。", "zh_hant": "早上好，護士。"}, {"index": 6, "text": "I want to see the dentist, please.", "start": 24.275, "end": 30.594, "zh": "我想看牙医。", "zh_hant": "我想看牙醫。"}, {"index": 7, "text": "Do you have an appointment?", "start": 30.594, "end": 31.154, "zh": "您预约了吗？", "zh_hant": "您預約了嗎？"}, {"index": 8, "text": "No, I don't.", "start": 31.154, "end": 32.314, "zh": "不，我没有。", "zh_hant": "不，我沒有。"}, {"index": 9, "text": "Is it urgent?", "start": 32.314, "end": 33.335, "zh": "情况紧急吗？", "zh_hant": "情況緊急嗎？"}, {"index": 10, "text": "Yes, it is.", "start": 34.175, "end": 35.675, "zh": "是的，很紧急。", "zh_hant": "是的，很緊急。"}, {"index": 11, "text": "It's very urgent.", "start": 36.275, "end": 37.835, "zh": "非常紧急。", "zh_hant": "非常緊急。"}, {"index": 12, "text": "I feel awful.", "start": 38.896, "end": 40.496, "zh": "我感觉很难受。", "zh_hant": "我感覺很難受。"}, {"index": 13, "text": "I have a terrible toothache.", "start": 41.516, "end": 43.597, "zh": "我牙疼得厉害。", "zh_hant": "我牙疼得厲害。"}, {"index": 14, "text": "Can you come at 10 a.m. on Monday, April 24th?", "start": 44.757, "end": 51.478, "zh": "您能在4月24日星期一上午10点来吗？", "zh_hant": "您能在4月24日星期一上午10點來嗎？"}, {"index": 15, "text": "I must see the dentist now, nurse.", "start": 53.819, "end": 60.38, "zh": "护士，我现在就得看牙医。", "zh_hant": "護士，我現在就得看牙醫。"}, {"index": 16, "text": "The dentist is very busy at the moment.", "start": 60.38, "end": 61.42, "zh": "牙医现在很忙。", "zh_hant": "牙醫現在很忙。"}, {"index": 17, "text": "Can you come at 2 p.m. ?", "start": 62.561, "end": 66.062, "zh": "您能下午2点来吗？", "zh_hant": "您能下午2點來嗎？"}, {"index": 18, "text": "That's very late.", "start": 66.062, "end": 67.523, "zh": "那太晚了。", "zh_hant": "那太晚了。"}, {"index": 19, "text": "Can the dentist see me now?", "start": 68.463, "end": 70.664, "zh": "牙医现在能见我吗？", "zh_hant": "牙醫現在能見我嗎？"}, {"index": 20, "text": "I'm afraid that he can't, Mr. Croft.", "start": 71.944, "end": 74.906, "zh": "恐怕不行，克罗夫特先生。", "zh_hant": "恐怕不行，克羅夫特先生。"}, {"index": 21, "text": "Can't you wait till this afternoon?", "start": 75.766, "end": 78.327, "zh": "您不能等到今天下午吗？", "zh_hant": "您不能等到今天下午嗎？"}, {"index": 22, "text": "I can wait, but my toothache can't!", "start": 79.627, "end": 82.688, "zh": "我可以等，可我的牙疼等不了！", "zh_hant": "我可以等，可我的牙疼等不了！"}]