[{"index": 0, "text": "Lesson 25", "start": 1.551, "end": 2.095, "zh": "第25课"}, {"index": 1, "text": "Mrs. Smith's Kitchen", "start": 4.192, "end": 5.773, "zh": "史密斯太太的厨房"}, {"index": 2, "text": "Listen to the tape then answer this question.", "start": 7.674, "end": 11.276, "zh": "听录音，然后回答问题。"}, {"index": 3, "text": "What colour is the electric cooker?", "start": 13.857, "end": 16.738, "zh": "电炊具是什么颜色的？"}, {"index": 4, "text": "Mrs. Smith's kitchen is small.", "start": 19.5, "end": 23.001, "zh": "史密斯太太的厨房很小。"}, {"index": 5, "text": "There is a refrigerator in the kitchen.", "start": 24.962, "end": 28.364, "zh": "厨房里有一台冰箱。"}, {"index": 6, "text": "The refrigerator is white.", "start": 28.364, "end": 34.065, "zh": "冰箱是白色的。"}, {"index": 7, "text": "It is on the right.", "start": 35.947, "end": 37.367, "zh": "它在右边。"}, {"index": 8, "text": "There is an electric cooker in the kitchen.", "start": 39.989, "end": 43.631, "zh": "厨房里有一个电炊具。"}, {"index": 9, "text": "The cooker is blue.", "start": 45.493, "end": 47.834, "zh": "炊具是蓝色的。"}, {"index": 10, "text": "It is on the left.", "start": 49.675, "end": 51.076, "zh": "它在左边。"}, {"index": 11, "text": "There is a table in the middle of the room.", "start": 53.457, "end": 57.12, "zh": "房间中央有一张桌子。"}, {"index": 12, "text": "There is a bottle on the table.", "start": 59.341, "end": 60.362, "zh": "桌子上有一个瓶子。"}, {"index": 13, "text": "The bottle is empty.", "start": 60.362, "end": 60.702, "zh": "瓶子是空的。"}, {"index": 14, "text": "There is a cup on the table, too.", "start": 60.702, "end": 64.348, "zh": "桌子上还有一个杯子。"}, {"index": 15, "text": "The cup is clean.", "start": 64.348, "end": 65.939, "zh": "杯子是干净的。"}]