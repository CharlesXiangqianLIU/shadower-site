[{"index": 0, "text": "Lesson 25", "start": 1.551, "end": 2.095}, {"index": 1, "text": "Mrs. Smith's Kitchen", "start": 4.192, "end": 5.773}, {"index": 2, "text": "Listen to the tape then answer this question.", "start": 7.674, "end": 11.276}, {"index": 3, "text": "What colour is the electric cooker?", "start": 13.857, "end": 16.738}, {"index": 4, "text": "Mrs. Smith's kitchen is small.", "start": 19.5, "end": 23.001}, {"index": 5, "text": "There is a refrigerator in the kitchen.", "start": 24.962, "end": 28.424}, {"index": 6, "text": "The refrigerator is white.", "start": 28.304, "end": 34.065}, {"index": 7, "text": "It is on the right.", "start": 35.947, "end": 37.367}, {"index": 8, "text": "There is an electric cooker in the kitchen.", "start": 39.989, "end": 43.631}, {"index": 9, "text": "The cooker is blue.", "start": 45.493, "end": 47.834}, {"index": 10, "text": "It is on the left.", "start": 49.675, "end": 51.076}, {"index": 11, "text": "There is a table in the middle of the room.", "start": 53.457, "end": 57.12}, {"index": 12, "text": "There is a bottle on the table.", "start": 59.341, "end": 60.422}, {"index": 13, "text": "The bottle is empty.", "start": 60.302, "end": 60.762}, {"index": 14, "text": "There is a cup on the table, too.", "start": 60.642, "end": 64.378}, {"index": 15, "text": "The cup is clean.", "start": 64.318, "end": 65.939}]