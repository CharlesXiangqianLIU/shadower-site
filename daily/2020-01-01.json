[{"index": 0, "text": "Lesson 1 Excuse me!", "start": 0.63, "end": 4.211, "zh": "第一课 打扰一下!", "zh_hant": "第一課 打擾一下!"}, {"index": 1, "text": "Listen to the tape then answer this question.", "start": 5.591, "end": 10.032, "zh": "听录音,然后回答这个问题。", "zh_hant": "聽錄音,然後回答這個問題。"}, {"index": 2, "text": "Whose handbag is it?", "start": 10.552, "end": 13.013, "zh": "这是谁的手提包?", "zh_hant": "這是誰的手提包?"}, {"index": 3, "text": "Excuse me!", "start": 15.093, "end": 16.273, "zh": "打扰一下!", "zh_hant": "打擾一下!"}, {"index": 4, "text": "Yes?", "start": 16.594, "end": 17.734, "zh": "什么事?", "zh_hant": "什麼事?"}, {"index": 5, "text": "Is this your handbag?", "start": 18.254, "end": 20.834, "zh": "这是你的手提包吗?", "zh_hant": "這是你的手提包嗎?"}, {"index": 6, "text": "Pardon?", "start": 21.354, "end": 22.495, "zh": "你说什么?", "zh_hant": "你說什麼?"}, {"index": 7, "text": "Is this your handbag?", "start": 23.175, "end": 26.215, "zh": "这是你的手提包吗?", "zh_hant": "這是你的手提包嗎?"}, {"index": 8, "text": "Yes it is.", "start": 26.756, "end": 28.736, "zh": "是的,是我的。", "zh_hant": "是的,是我的。"}, {"index": 9, "text": "Thank you very much.", "start": 29.416, "end": 31.577, "zh": "非常感谢。", "zh_hant": "非常感謝。"}]