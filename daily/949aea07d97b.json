[{"index": 0, "text": "Lesson 99", "start": 1.59, "end": 2.05}, {"index": 1, "text": "Ow!", "start": 4.111, "end": 4.531}, {"index": 2, "text": "Listen to the tape then answer this question.", "start": 5.992, "end": 9.373}, {"index": 3, "text": "Must Andy go to see the doctor?", "start": 11.914, "end": 14.495}, {"index": 4, "text": "Ow!", "start": 17.256, "end": 17.696}, {"index": 5, "text": "What's the matter, Andy?", "start": 18.636, "end": 19.816}, {"index": 6, "text": "I slipped and fell downstairs.", "start": 20.617, "end": 23.057}, {"index": 7, "text": "Have you hurt yourself?", "start": 23.818, "end": 25.298}, {"index": 8, "text": "Yes, I have.", "start": 25.818, "end": 27.119}, {"index": 9, "text": "I think that I've hurt my back.", "start": 27.699, "end": 30.8}, {"index": 10, "text": "Try and stand up.", "start": 30.82, "end": 32.141}, {"index": 11, "text": "Can you stand up?", "start": 33.381, "end": 34.401}, {"index": 12, "text": "Here.", "start": 35.662, "end": 36.042}, {"index": 13, "text": "Let me help you.", "start": 36.342, "end": 37.302}, {"index": 14, "text": "I'm sorry, Lucy.", "start": 38.563, "end": 39.903}, {"index": 15, "text": "I'm afraid that I can't get up.", "start": 40.383, "end": 42.644}, {"index": 16, "text": "I think that the doctor had better see you.", "start": 44.305, "end": 46.605}, {"index": 17, "text": "I'll phone Dr. Carter.", "start": 47.426, "end": 48.946}, {"index": 18, "text": "The doctor says that he will come at once.", "start": 50.807, "end": 61.291}, {"index": 19, "text": "I'm sure that you need an X-ray, Andy.", "start": 61.291, "end": 64.935}]