[{"index": 0, "text": "What does 'a cold welcome' refer to?", "start": 13.253, "end": 17.936}, {"index": 1, "text": "On Wednesday evening, we went to the Town Hall.", "start": 20.797, "end": 24.119}, {"index": 2, "text": "It was the last day of the year", "start": 25.24, "end": 27.281}, {"index": 3, "text": "and a large crowd of people had gathered under the Town Hall clock.", "start": 27.842, "end": 32.625}, {"index": 4, "text": "It would strike twelve in twenty minutes' time.", "start": 34.446, "end": 37.818}, {"index": 5, "text": "Fifteen minutes passed and then,", "start": 37.818, "end": 38.728}, {"index": 6, "text": "at five to twelve, the clock stopped.", "start": 38.728, "end": 39.389}, {"index": 7, "text": "The big minute hand did not move.", "start": 39.389, "end": 39.661}, {"index": 8, "text": "We waited and waited,", "start": 39.661, "end": 40.681}, {"index": 9, "text": "but nothing happened.", "start": 40.681, "end": 43.532}, {"index": 10, "text": "Suddenly someone shouted.", "start": 43.532, "end": 46.043}, {"index": 11, "text": "'It's two minutes past twelve!", "start": 46.383, "end": 50.234}, {"index": 12, "text": "The clock has stopped!'", "start": 50.234, "end": 52.664}, {"index": 13, "text": "I looked at my watch.", "start": 52.664, "end": 54.345}, {"index": 14, "text": "It was true.", "start": 54.345, "end": 55.585}, {"index": 15, "text": "The big clock refused to welcome the New Year.", "start": 55.585, "end": 60.666}, {"index": 16, "text": "At that moment, everybody began to laugh and sing.", "start": 60.666, "end": 64.027}]