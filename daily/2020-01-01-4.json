[{"index": 0, "text": "Lesson 7 Are you a teacher?", "start": 0.49, "end": 4.891, "zh": "第7课 你是老师吗?", "zh_hant": "第7課 你是老師嗎?"}, {"index": 1, "text": "Listen to the tape then answer this question.", "start": 5.992, "end": 10.133, "zh": "听录音,然后回答这个问题。", "zh_hant": "聽錄音,然後回答這個問題。"}, {"index": 2, "text": "What is Rober's job?", "start": 10.953, "end": 13.474, "zh": "罗伯特是做什么工作的?", "zh_hant": "羅伯特是做什麼工作的?"}, {"index": 3, "text": "I am a new student.", "start": 15.495, "end": 17.695, "zh": "我是新来的学生。", "zh_hant": "我是新來的學生。"}, {"index": 4, "text": "My name's Robert.", "start": 17.976, "end": 20.136, "zh": "我叫罗伯特。", "zh_hant": "我叫羅伯特。"}, {"index": 5, "text": "Nice to meet you.", "start": 20.576, "end": 22.257, "zh": "很高兴认识你。", "zh_hant": "很高興認識你。"}, {"index": 6, "text": "My name's Sophie.", "start": 22.457, "end": 24.537, "zh": "我叫索菲。", "zh_hant": "我叫索菲。"}, {"index": 7, "text": "Are you French?", "start": 25.698, "end": 27.538, "zh": "你是法国人吗?", "zh_hant": "你是法國人嗎?"}, {"index": 8, "text": "Yes I am.", "start": 27.698, "end": 29.599, "zh": "是的,我是。", "zh_hant": "是的,我是。"}, {"index": 9, "text": "Are you French too?", "start": 30.359, "end": 32.48, "zh": "你也是法国人吗?", "zh_hant": "你也是法國人嗎?"}, {"index": 10, "text": "No I am not.", "start": 33.26, "end": 35.961, "zh": "不,我不是。", "zh_hant": "不,我不是。"}, {"index": 11, "text": "What nationality are you?", "start": 36.481, "end": 39.002, "zh": "你是哪国人?", "zh_hant": "你是哪國人?"}, {"index": 12, "text": "I'm Italian.", "start": 40.262, "end": 42.103, "zh": "我是意大利人。", "zh_hant": "我是義大利人。"}, {"index": 13, "text": "Are you a teacher?", "start": 43.503, "end": 45.724, "zh": "你是老师吗?", "zh_hant": "你是老師嗎?"}, {"index": 14, "text": "No I'm not.", "start": 45.944, "end": 48.005, "zh": "不,我不是。", "zh_hant": "不,我不是。"}, {"index": 15, "text": "What's your job?", "start": 48.445, "end": 50.325, "zh": "你是做什么工作的?", "zh_hant": "你是做什麼工作的?"}, {"index": 16, "text": "I'm a keyboard operator.", "start": 50.806, "end": 53.626, "zh": "我是一名键盘操作员。", "zh_hant": "我是一名鍵盤操作員。"}, {"index": 17, "text": "What's your job?", "start": 54.067, "end": 55.707, "zh": "你是做什么工作的?", "zh_hant": "你是做什麼工作的?"}, {"index": 18, "text": "I'm an engineer.", "start": 56.607, "end": 58.608, "zh": "我是一名工程师。", "zh_hant": "我是一名工程師。"}]