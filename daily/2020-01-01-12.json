[{"index": 0, "text": "Lesson 23 Which glasses?", "start": 0.35, "end": 4.692, "zh": "第23课 哪副眼镜?", "zh_hant": "第23課 哪副眼鏡?"}, {"index": 1, "text": "Listen to the tape then answer this question.", "start": 5.613, "end": 10.555, "zh": "听录音,然后回答这个问题。", "zh_hant": "聽錄音,然後回答這個問題。"}, {"index": 2, "text": "Which glasses does the man want?", "start": 11.756, "end": 15.418, "zh": "这个男人想要哪副眼镜?", "zh_hant": "這個男人想要哪副眼鏡?"}, {"index": 3, "text": "Give me some glasses please, Jane.", "start": 17.139, "end": 20.681, "zh": "简,请给我拿副眼镜。", "zh_hant": "簡,請給我拿副眼鏡。"}, {"index": 4, "text": "Which glasses?", "start": 21.081, "end": 22.802, "zh": "哪副眼镜?", "zh_hant": "哪副眼鏡?"}, {"index": 5, "text": "These glasses?", "start": 23.263, "end": 25.103, "zh": "这副眼镜吗?", "zh_hant": "這副眼鏡嗎?"}, {"index": 6, "text": "No, not those.", "start": 25.804, "end": 28.225, "zh": "不,不是那副。", "zh_hant": "不,不是那副。"}, {"index": 7, "text": "The ones on the shelf.", "start": 28.585, "end": 30.846, "zh": "架子上的那副。", "zh_hant": "架子上的那副。"}, {"index": 8, "text": "These?", "start": 31.407, "end": 32.647, "zh": "这副?", "zh_hant": "這副?"}, {"index": 9, "text": "Yes, please.", "start": 32.848, "end": 34.628, "zh": "是的,麻烦你了。", "zh_hant": "是的,麻煩你了。"}, {"index": 10, "text": "Here you are.", "start": 34.909, "end": 36.469, "zh": "给你。", "zh_hant": "給你。"}, {"index": 11, "text": "Thanks.", "start": 36.99, "end": 38.03, "zh": "谢谢。", "zh_hant": "謝謝。"}]