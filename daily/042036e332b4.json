[{"index": 0, "text": "Lesson 81", "start": 1.551, "end": 2.11, "zh": "第81课", "zh_hant": "第81課"}, {"index": 1, "text": "Roast beef and potatoes", "start": 3.933, "end": 6.134, "zh": "烤牛肉和马铃薯", "zh_hant": "烤牛肉和馬鈴薯"}, {"index": 2, "text": "Listen to the tape then answer this question.", "start": 7.875, "end": 11.257, "zh": "先听录音,然后回答这个问题。", "zh_hant": "先聽錄音,然後回答這個問題。"}, {"index": 3, "text": "Why is Carol disappointed?", "start": 13.859, "end": 16.2, "zh": "卡罗尔为什么失望?", "zh_hant": "卡羅爾為什麼失望?"}, {"index": 4, "text": "Hi, Carol! Where's Tom?", "start": 18.862, "end": 20.663, "zh": "嗨,卡罗尔!汤姆在哪儿?", "zh_hant": "嗨,卡羅爾!湯姆在哪兒?"}, {"index": 5, "text": "He's upstairs.", "start": 21.064, "end": 22.044, "zh": "他在楼上。", "zh_hant": "他在樓上。"}, {"index": 6, "text": "He's having a bath.", "start": 22.325, "end": 23.385, "zh": "他在洗澡。", "zh_hant": "他在洗澡。"}, {"index": 7, "text": "Tom!", "start": 24.566, "end": 25.286, "zh": "汤姆!", "zh_hant": "湯姆!"}, {"index": 8, "text": "Yes?", "start": 25.687, "end": 26.307, "zh": "什么事?", "zh_hant": "什麼事?"}, {"index": 9, "text": "Sam's here.", "start": 26.887, "end": 29.469, "zh": "萨姆来了。", "zh_hant": "薩姆來了。"}, {"index": 10, "text": "I'm nearly ready.", "start": 29.469, "end": 32.308, "zh": "我快准备好了。", "zh_hant": "我快準備好了。"}, {"index": 11, "text": "Hello, Sam.", "start": 32.308, "end": 33.109, "zh": "你好,萨姆。", "zh_hant": "你好,薩姆。"}, {"index": 12, "text": "Have a cigarette.", "start": 33.71, "end": 34.81, "zh": "来根烟吧。", "zh_hant": "來根菸吧。"}, {"index": 13, "text": "No, thanks, Tom.", "start": 36.272, "end": 37.633, "zh": "不,谢谢,汤姆。", "zh_hant": "不,謝謝,湯姆。"}, {"index": 14, "text": "Have a glass of whisky then.", "start": 38.994, "end": 40.515, "zh": "那就来杯威士忌吧。", "zh_hant": "那就來杯威士忌吧。"}, {"index": 15, "text": "OK.", "start": 42.056, "end": 42.357, "zh": "好的。", "zh_hant": "好的。"}, {"index": 16, "text": "Thanks.", "start": 43.197, "end": 43.678, "zh": "谢谢。", "zh_hant": "謝謝。"}, {"index": 17, "text": "Is dinnner ready, Carol?", "start": 46.08, "end": 47.261, "zh": "晚饭准备好了吗,卡罗尔?", "zh_hant": "晚飯準備好了嗎,卡羅爾?"}, {"index": 18, "text": "It's nearly ready.", "start": 47.821, "end": 48.722, "zh": "快好了。", "zh_hant": "快好了。"}, {"index": 19, "text": "We can have dinner at seven o'clock.", "start": 49.322, "end": 51.404, "zh": "我们可以七点吃晚饭。", "zh_hant": "我們可以七點吃晚飯。"}, {"index": 20, "text": "Sam and I had lunch together today.", "start": 52.505, "end": 54.807, "zh": "萨姆和我今天一起吃了午饭。", "zh_hant": "薩姆和我今天一起吃了午飯。"}, {"index": 21, "text": "We went to a restaurant.", "start": 55.528, "end": 60.516, "zh": "我们去了一家餐馆。", "zh_hant": "我們去了一家餐館。"}, {"index": 22, "text": "What did you have?", "start": 60.516, "end": 60.826, "zh": "你们吃了什么?", "zh_hant": "你們吃了什麼?"}, {"index": 23, "text": "We had roast beef and potatoes.", "start": 60.826, "end": 62.428, "zh": "我们吃了烤牛肉和马铃薯。", "zh_hant": "我們吃了烤牛肉和馬鈴薯。"}, {"index": 24, "text": "Oh!", "start": 63.428, "end": 63.809, "zh": "哦!", "zh_hant": "哦!"}, {"index": 25, "text": "What's the matter, Carol?", "start": 65.09, "end": 66.431, "zh": "怎么了,卡罗尔?", "zh_hant": "怎麼了,卡羅爾?"}, {"index": 26, "text": "Well, you're going to have roast beef and potatoes again tonight!", "start": 67.492, "end": 71.815, "zh": "是这样,你们今晚又要吃烤牛肉和马铃薯了!", "zh_hant": "是這樣,你們今晚又要吃烤牛肉和馬鈴薯了!"}]