[{"index": 0, "text": "Lesson 81", "start": 1.551, "end": 2.11}, {"index": 1, "text": "Roast beef and potatoes", "start": 3.933, "end": 6.134}, {"index": 2, "text": "Listen to the tape then answer this question.", "start": 7.875, "end": 11.257}, {"index": 3, "text": "Why is Carol disappointed?", "start": 13.859, "end": 16.2}, {"index": 4, "text": "Hi, Carol! Where's Tom?", "start": 18.862, "end": 20.663}, {"index": 5, "text": "He's upstairs.", "start": 21.064, "end": 22.044}, {"index": 6, "text": "He's having a bath.", "start": 22.325, "end": 23.385}, {"index": 7, "text": "Tom!", "start": 24.566, "end": 25.286}, {"index": 8, "text": "Yes?", "start": 25.687, "end": 26.307}, {"index": 9, "text": "Sam's here.", "start": 26.887, "end": 29.509}, {"index": 10, "text": "I'm nearly ready.", "start": 29.429, "end": 32.368}, {"index": 11, "text": "Hello, Sam.", "start": 32.248, "end": 33.109}, {"index": 12, "text": "Have a cigarette.", "start": 33.71, "end": 34.81}, {"index": 13, "text": "No, thanks, Tom.", "start": 36.272, "end": 37.633}, {"index": 14, "text": "Have a glass of whisky then.", "start": 38.994, "end": 40.515}, {"index": 15, "text": "OK.", "start": 42.056, "end": 42.357}, {"index": 16, "text": "Thanks.", "start": 43.197, "end": 43.678}, {"index": 17, "text": "Is dinnner ready, Carol?", "start": 46.08, "end": 47.261}, {"index": 18, "text": "It's nearly ready.", "start": 47.821, "end": 48.722}, {"index": 19, "text": "We can have dinner at seven o'clock.", "start": 49.322, "end": 51.404}, {"index": 20, "text": "Sam and I had lunch together today.", "start": 52.505, "end": 54.807}, {"index": 21, "text": "We went to a restaurant.", "start": 55.528, "end": 60.566}, {"index": 22, "text": "What did you have?", "start": 60.466, "end": 60.886}, {"index": 23, "text": "We had roast beef and potatoes.", "start": 60.766, "end": 62.428}, {"index": 24, "text": "Oh!", "start": 63.428, "end": 63.809}, {"index": 25, "text": "What's the matter, Carol?", "start": 65.09, "end": 66.431}, {"index": 26, "text": "Well, you're going to have roast beef and potatoes again tonight!", "start": 67.492, "end": 71.815}]