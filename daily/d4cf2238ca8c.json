[{"index": 0, "text": "Lesson 123", "start": 1.591, "end": 2.665, "zh": "第123课"}, {"index": 1, "text": "A trip to Australia", "start": 5.052, "end": 6.533, "zh": "澳大利亚之旅"}, {"index": 2, "text": "Listen to the tape then answer this question.", "start": 8.034, "end": 11.155, "zh": "听录音,然后回答这个问题。"}, {"index": 3, "text": "Who is the man with the beard?", "start": 13.596, "end": 15.777, "zh": "那个留胡子的男人是谁?"}, {"index": 4, "text": "Look, Scott.", "start": 18.498, "end": 19.179, "zh": "看,斯科特。"}, {"index": 5, "text": "This is a photograph I took during my trip to Australia.", "start": 19.779, "end": 23.12, "zh": "这是我在澳大利亚旅行时拍的一张照片。"}, {"index": 6, "text": "Let me see it, Mike.", "start": 24.721, "end": 26.022, "zh": "让我看看,迈克。"}, {"index": 7, "text": "This is a good photograph.", "start": 27.382, "end": 30.706, "zh": "这张照片拍得真好。"}, {"index": 8, "text": "Who are these people?", "start": 30.706, "end": 32.308, "zh": "这些人是谁?"}, {"index": 9, "text": "They're people I met during the trip.", "start": 32.308, "end": 34.189, "zh": "他们是我在旅途中认识的人。"}, {"index": 10, "text": "That's the ship we travelled on.", "start": 35.79, "end": 37.552, "zh": "那就是我们乘坐的那艘船。"}, {"index": 11, "text": "What a beautiful ship!", "start": 39.553, "end": 40.954, "zh": "多漂亮的一艘船啊!"}, {"index": 12, "text": "Who's this?", "start": 42.536, "end": 43.356, "zh": "这是谁?"}, {"index": 13, "text": "That's the man I told you about.", "start": 44.477, "end": 46.099, "zh": "那就是我跟你提过的那个人。"}, {"index": 14, "text": "Remember?", "start": 46.359, "end": 46.839, "zh": "还记得吗?"}, {"index": 15, "text": "Ah yes.", "start": 48.14, "end": 49.141, "zh": "啊,记得。"}, {"index": 16, "text": "The one who offered you a job in Australia.", "start": 49.581, "end": 52.003, "zh": "就是那个在澳大利亚给你提供工作的人。"}, {"index": 17, "text": "That's right.", "start": 52.984, "end": 53.745, "zh": "没错。"}, {"index": 18, "text": "Who's this?", "start": 55.246, "end": 57.768, "zh": "这是谁?"}, {"index": 19, "text": "Guess!", "start": 60.12, "end": 60.37, "zh": "猜猜看!"}, {"index": 20, "text": "It's not you, is it?", "start": 60.37, "end": 61.571, "zh": "不会是你吧?"}, {"index": 21, "text": "That's right.", "start": 61.571, "end": 62.282, "zh": "没错。"}, {"index": 22, "text": "I grew a beard during the trip, but I shaved it off when I came home.", "start": 62.923, "end": 67.608, "zh": "我在旅行期间留了胡子,但回家后就剃掉了。"}, {"index": 23, "text": "Why did you shave it off?", "start": 69.029, "end": 70.411, "zh": "你为什么把胡子剃掉了?"}, {"index": 24, "text": "My wife didn't like it!", "start": 71.832, "end": 73.474, "zh": "我妻子不喜欢。"}]