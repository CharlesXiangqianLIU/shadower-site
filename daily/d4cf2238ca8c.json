[{"index": 0, "text": "Lesson 123", "start": 1.591, "end": 2.665}, {"index": 1, "text": "A trip to Australia", "start": 5.052, "end": 6.533}, {"index": 2, "text": "Listen to the tape then answer this question.", "start": 8.034, "end": 11.155}, {"index": 3, "text": "Who is the man with the beard?", "start": 13.596, "end": 15.777}, {"index": 4, "text": "Look, Scott.", "start": 18.498, "end": 19.179}, {"index": 5, "text": "This is a photograph I took during my trip to Australia.", "start": 19.779, "end": 23.12}, {"index": 6, "text": "Let me see it, Mike.", "start": 24.721, "end": 26.022}, {"index": 7, "text": "This is a good photograph.", "start": 27.382, "end": 30.706}, {"index": 8, "text": "Who are these people?", "start": 30.706, "end": 32.308}, {"index": 9, "text": "They're people I met during the trip.", "start": 32.308, "end": 34.189}, {"index": 10, "text": "That's the ship we travelled on.", "start": 35.79, "end": 37.552}, {"index": 11, "text": "What a beautiful ship!", "start": 39.553, "end": 40.954}, {"index": 12, "text": "Who's this?", "start": 42.536, "end": 43.356}, {"index": 13, "text": "That's the man I told you about.", "start": 44.477, "end": 46.099}, {"index": 14, "text": "Remember?", "start": 46.359, "end": 46.839}, {"index": 15, "text": "Ah yes.", "start": 48.14, "end": 49.141}, {"index": 16, "text": "The one who offered you a job in Australia.", "start": 49.581, "end": 52.003}, {"index": 17, "text": "That's right.", "start": 52.984, "end": 53.745}, {"index": 18, "text": "Who's this?", "start": 55.246, "end": 57.768}, {"index": 19, "text": "Guess!", "start": 60.12, "end": 60.37}, {"index": 20, "text": "It's not you, is it?", "start": 60.37, "end": 61.571}, {"index": 21, "text": "That's right.", "start": 61.571, "end": 62.282}, {"index": 22, "text": "I grew a beard during the trip, but I shaved it off when I came home.", "start": 62.923, "end": 67.608}, {"index": 23, "text": "Why did you shave it off?", "start": 69.029, "end": 70.411}, {"index": 24, "text": "My wife didn't like it!", "start": 71.832, "end": 73.474}]