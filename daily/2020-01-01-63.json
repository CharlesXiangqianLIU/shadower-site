[{"index": 0, "text": "Lesson 125 Tea for two Listen to the tape then answer this question.", "start": 0.55, "end": 10.532, "zh": "第125课 两人份的茶 听录音,然后回答这个问题。", "zh_hant": "第125課 兩人份的茶 聽錄音,然後回答這個問題。"}, {"index": 1, "text": "Does Susan have tea by herself?", "start": 11.232, "end": 14.512, "zh": "苏珊是一个人喝茶吗？", "zh_hant": "蘇珊是一個人喝茶嗎？"}, {"index": 2, "text": "Can't you come in and have tea now, Peter?", "start": 16.413, "end": 20.573, "zh": "彼得，你现在能不能进来喝杯茶？", "zh_hant": "彼得，你現在能不能進來喝杯茶？"}, {"index": 3, "text": "Not yet.", "start": 20.954, "end": 22.174, "zh": "还不行。", "zh_hant": "還不行。"}, {"index": 4, "text": "I must water the garden first.", "start": 22.514, "end": 25.354, "zh": "我得先给花园浇水。", "zh_hant": "我得先給花園澆水。"}, {"index": 5, "text": "Do you have to water it now?", "start": 25.754, "end": 28.755, "zh": "你非得现在浇水吗？", "zh_hant": "你非得現在澆水嗎？"}, {"index": 6, "text": "I'm afraid I must.", "start": 29.475, "end": 31.415, "zh": "恐怕是的。", "zh_hant": "恐怕是的。"}, {"index": 7, "text": "Look at it!", "start": 31.635, "end": 32.795, "zh": "你看看它！", "zh_hant": "你看看它！"}, {"index": 8, "text": "It's terribly dry.", "start": 32.996, "end": 35.196, "zh": "干得不成样子了。", "zh_hant": "幹得不成樣子了。"}, {"index": 9, "text": "What a nuisance!", "start": 35.416, "end": 37.516, "zh": "真麻烦！", "zh_hant": "真麻煩！"}, {"index": 10, "text": "Last summer it was very dry, too.", "start": 37.976, "end": 41.477, "zh": "去年夏天也很干旱。", "zh_hant": "去年夏天也很乾旱。"}, {"index": 11, "text": "Don't you remember?", "start": 41.937, "end": 43.577, "zh": "你不记得了吗？", "zh_hant": "你不記得了嗎？"}, {"index": 12, "text": "I had to water it every day.", "start": 44.278, "end": 47.078, "zh": "我那时得天天浇水。", "zh_hant": "我那時得天天澆水。"}, {"index": 13, "text": "Well, I'll have tea by myself.", "start": 47.498, "end": 51.499, "zh": "好吧，那我就自己喝茶了。", "zh_hant": "好吧，那我就自己喝茶了。"}, {"index": 14, "text": "That was quick!", "start": 52.679, "end": 54.379, "zh": "这么快！", "zh_hant": "這麼快！"}, {"index": 15, "text": "Have you finished already?", "start": 54.659, "end": 57.04, "zh": "你已经浇完了？", "zh_hant": "你已經澆完了？"}, {"index": 16, "text": "Yes.", "start": 57.38, "end": 58.28, "zh": "是的。", "zh_hant": "是的。"}, {"index": 17, "text": "Look out of the window.", "start": 58.62, "end": 60.66, "zh": "往窗外看看。", "zh_hant": "往窗外看看。"}, {"index": 18, "text": "It's raining!", "start": 61.32, "end": 63.141, "zh": "下雨了！", "zh_hant": "下雨了！"}, {"index": 19, "text": "That means you don't need to water the garden.", "start": 63.421, "end": 67.961, "zh": "这就是说你不用给花园浇水了。", "zh_hant": "這就是說你不用給花園澆水了。"}, {"index": 20, "text": "That was a pleasant surprise.", "start": 68.822, "end": 71.582, "zh": "真是个惊喜。", "zh_hant": "真是個驚喜。"}, {"index": 21, "text": "It means I can have tea, instead.", "start": 72.242, "end": 75.503, "zh": "这意味着我可以喝茶了。", "zh_hant": "這意味著我可以喝茶了。"}]