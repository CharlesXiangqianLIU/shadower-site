[{"index": 0, "text": "Lesson 71", "start": 1.551, "end": 2.11, "zh": "第71课", "zh_hant": "第71課"}, {"index": 1, "text": "He's awful!", "start": 4.072, "end": 5.492, "zh": "他真讨厌!", "zh_hant": "他真討厭!"}, {"index": 2, "text": "Listen to the tape then answer this question.", "start": 6.773, "end": 10.334, "zh": "听录音,然后回答这个问题。", "zh_hant": "聽錄音,然後回答這個問題。"}, {"index": 3, "text": "How did Pauline answer the telephone at nine o'clock?", "start": 12.815, "end": 16.777, "zh": "九点钟的时候,波琳是怎么接电话的?", "zh_hant": "九點鐘的時候,波琳是怎麼接電話的?"}, {"index": 4, "text": "What's Ron Marston like, Pauline?", "start": 19.518, "end": 22.499, "zh": "罗恩·马斯顿是个什么样的人,波琳?", "zh_hant": "羅恩·馬斯頓是個什麼樣的人,波琳?"}, {"index": 5, "text": "He's awful!", "start": 23.979, "end": 25.0, "zh": "他真讨厌!", "zh_hant": "他真討厭!"}, {"index": 6, "text": "He telephoned me four times yesterday and three times the day before yesterday.", "start": 25.54, "end": 32.218, "zh": "他昨天给我打了四次电话,前天打了三次。", "zh_hant": "他昨天給我打了四次電話,前天打了三次。"}, {"index": 7, "text": "He telephoned the office yesterday morning and yesterday afternoon.", "start": 33.338, "end": 38.52, "zh": "他昨天上午和下午都给办公室打了电话。", "zh_hant": "他昨天上午和下午都給辦公室打了電話。"}, {"index": 8, "text": "My boss answered the telephone.", "start": 39.48, "end": 41.681, "zh": "是我老板接的电话。", "zh_hant": "是我老闆接的電話。"}, {"index": 9, "text": "What did your boss say to him?", "start": 43.081, "end": 44.962, "zh": "你老板对他说了什么?", "zh_hant": "你老闆對他說了什麼?"}, {"index": 10, "text": "He said, 'Pauline is typing letters.", "start": 46.602, "end": 49.623, "zh": "他说:'波琳正在打信。", "zh_hant": "他說:'波琳正在打信。"}, {"index": 11, "text": "She can't speak to you now!'", "start": 50.184, "end": 60.17, "zh": "她现在不能和你说话!'", "zh_hant": "她現在不能和你說話!'"}, {"index": 12, "text": "Then I arrived home at six o'clock yesterday evening.", "start": 60.17, "end": 66.694, "zh": "后来我昨天傍晚六点到家。", "zh_hant": "後來我昨天傍晚六點到家。"}, {"index": 13, "text": "He telephoned again.", "start": 67.455, "end": 69.096, "zh": "他又打来了电话。", "zh_hant": "他又打來了電話。"}, {"index": 14, "text": "But I didn't answer the phone!", "start": 71.398, "end": 74.379, "zh": "可我没接!", "zh_hant": "可我沒接!"}, {"index": 15, "text": "Did he telephone again last night?", "start": 74.379, "end": 76.671, "zh": "他昨晚又打电话了吗?", "zh_hant": "他昨晚又打電話了嗎?"}, {"index": 16, "text": "Yes, he did.", "start": 76.671, "end": 78.182, "zh": "是的,他打了。", "zh_hant": "是的,他打了。"}, {"index": 17, "text": "He telephoned at nine o'clock.", "start": 78.202, "end": 81.944, "zh": "他九点钟打来的。", "zh_hant": "他九點鐘打來的。"}, {"index": 18, "text": "What did you say to him?", "start": 81.944, "end": 84.206, "zh": "你对他说了什么?", "zh_hant": "你對他說了什麼?"}, {"index": 19, "text": "I said, 'This is Pauline's mother.", "start": 84.206, "end": 93.727, "zh": "我说:'我是波琳的妈妈。", "zh_hant": "我說:'我是波琳的媽媽。"}, {"index": 20, "text": "Please don't telephone my daughter again!'", "start": 93.907, "end": 97.782, "zh": "请不要再给我女儿打电话了!'", "zh_hant": "請不要再給我女兒打電話了!'"}, {"index": 21, "text": "Did he telephone again?", "start": 97.782, "end": 99.854, "zh": "他还打了吗?", "zh_hant": "他還打了嗎?"}, {"index": 22, "text": "No, he didn't!", "start": 99.874, "end": 102.117, "zh": "没有,没再打!", "zh_hant": "沒有,沒再打!"}]