[{"index": 0, "text": "Lesson 71", "start": 1.551, "end": 2.11}, {"index": 1, "text": "He's awful!", "start": 4.072, "end": 5.492}, {"index": 2, "text": "Listen to the tape then answer this question.", "start": 6.773, "end": 10.334}, {"index": 3, "text": "How did Pauline answer the telephone at nine o'clock?", "start": 12.815, "end": 16.777}, {"index": 4, "text": "What's Ron Marston like, Pauline?", "start": 19.518, "end": 22.499}, {"index": 5, "text": "He's awful!", "start": 23.979, "end": 25.0}, {"index": 6, "text": "He telephoned me four times yesterday and three times the day before yesterday.", "start": 25.54, "end": 32.218}, {"index": 7, "text": "He telephoned the office yesterday morning and yesterday afternoon.", "start": 33.338, "end": 38.52}, {"index": 8, "text": "My boss answered the telephone.", "start": 39.48, "end": 41.681}, {"index": 9, "text": "What did your boss say to him?", "start": 43.081, "end": 44.962}, {"index": 10, "text": "He said, 'Pauline is typing letters.", "start": 46.602, "end": 49.623}, {"index": 11, "text": "She can't speak to you now!'", "start": 50.184, "end": 60.17}, {"index": 12, "text": "Then I arrived home at six o'clock yesterday evening.", "start": 60.17, "end": 66.694}, {"index": 13, "text": "He telephoned again.", "start": 67.455, "end": 69.096}, {"index": 14, "text": "But I didn't answer the phone!", "start": 71.398, "end": 74.379}, {"index": 15, "text": "Did he telephone again last night?", "start": 74.379, "end": 76.671}, {"index": 16, "text": "Yes, he did.", "start": 76.671, "end": 78.182}, {"index": 17, "text": "He telephoned at nine o'clock.", "start": 78.202, "end": 81.944}, {"index": 18, "text": "What did you say to him?", "start": 81.944, "end": 84.206}, {"index": 19, "text": "I said, 'This is Pauline's mother.", "start": 84.206, "end": 93.727}, {"index": 20, "text": "Please don't telephone my daughter again!'", "start": 93.907, "end": 97.782}, {"index": 21, "text": "Did he telephone again?", "start": 97.782, "end": 99.854}, {"index": 22, "text": "No, he didn't!", "start": 99.874, "end": 102.117}]