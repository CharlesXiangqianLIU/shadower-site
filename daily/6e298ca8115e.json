[{"index": 0, "text": "Lesson 85", "start": 1.561, "end": 2.021}, {"index": 1, "text": "'Paris in the Spring'.", "start": 1.901, "end": 5.922}, {"index": 2, "text": "Listen to the tape then answer this question.", "start": 7.002, "end": 10.543}, {"index": 3, "text": "At what time of year did Ken visit Paris?", "start": 13.024, "end": 16.866}, {"index": 4, "text": "Hello, Ken.", "start": 19.566, "end": 20.787}, {"index": 5, "text": "Hi, George.", "start": 21.707, "end": 22.507}, {"index": 6, "text": "Have you just been to the cinema?", "start": 23.788, "end": 25.788}, {"index": 7, "text": "Yes, I have.", "start": 26.929, "end": 28.209}, {"index": 8, "text": "What's on?", "start": 29.37, "end": 29.93}, {"index": 9, "text": "'Paris in the Spring'.", "start": 29.83, "end": 32.762}, {"index": 10, "text": "Oh, I've already seen it.", "start": 34.283, "end": 36.704}, {"index": 11, "text": "I saw it on television last year.", "start": 37.565, "end": 40.246}, {"index": 12, "text": "It's an old film, but it's very good.", "start": 41.327, "end": 44.449}, {"index": 13, "text": "Paris is a beautiful city.", "start": 45.869, "end": 48.191}, {"index": 14, "text": "I've never been there.", "start": 49.532, "end": 50.812}, {"index": 15, "text": "Have you ever been there, Ken?", "start": 51.693, "end": 53.414}, {"index": 16, "text": "Yes, I have.", "start": 54.655, "end": 56.115}, {"index": 17, "text": "I was there in April.", "start": 56.976, "end": 58.997}, {"index": 18, "text": "Paris in the spring, eh?", "start": 58.877, "end": 60.478}, {"index": 19, "text": "It was spring, but the weather was awful.", "start": 60.721, "end": 67.547}, {"index": 20, "text": "It rained all the time.", "start": 68.308, "end": 69.889}, {"index": 21, "text": "Just like London!", "start": 69.769, "end": 70.59}]