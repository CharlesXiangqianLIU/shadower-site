[{"index": 0, "text": "Lesson 85", "start": 1.561, "end": 1.961, "zh": "第85课", "zh_hant": "第85課"}, {"index": 1, "text": "'Paris in the Spring'.", "start": 1.961, "end": 5.922, "zh": "《春天的巴黎》", "zh_hant": "《春天的巴黎》"}, {"index": 2, "text": "Listen to the tape then answer this question.", "start": 7.002, "end": 10.543, "zh": "听录音,然后回答这个问题。", "zh_hant": "聽錄音,然後回答這個問題。"}, {"index": 3, "text": "At what time of year did Ken visit Paris?", "start": 13.024, "end": 16.866, "zh": "肯是在一年中的什么时候去的巴黎?", "zh_hant": "肯是在一年中的什麼時候去的巴黎?"}, {"index": 4, "text": "Hello, Ken.", "start": 19.566, "end": 20.787, "zh": "你好,肯。", "zh_hant": "你好,肯。"}, {"index": 5, "text": "Hi, George.", "start": 21.707, "end": 22.507, "zh": "嗨,乔治。", "zh_hant": "嗨,喬治。"}, {"index": 6, "text": "Have you just been to the cinema?", "start": 23.788, "end": 25.788, "zh": "你刚看电影回来吗?", "zh_hant": "你剛看電影回來嗎?"}, {"index": 7, "text": "Yes, I have.", "start": 26.929, "end": 28.209, "zh": "是的。", "zh_hant": "是的。"}, {"index": 8, "text": "What's on?", "start": 29.37, "end": 29.88, "zh": "上映的是什么片子?", "zh_hant": "上映的是什麼片子?"}, {"index": 9, "text": "'Paris in the Spring'.", "start": 29.88, "end": 32.762, "zh": "《春天的巴黎》。", "zh_hant": "《春天的巴黎》。"}, {"index": 10, "text": "Oh, I've already seen it.", "start": 34.283, "end": 36.704, "zh": "哦,我已经看过了。", "zh_hant": "哦,我已經看過了。"}, {"index": 11, "text": "I saw it on television last year.", "start": 37.565, "end": 40.246, "zh": "我去年在电视上看过。", "zh_hant": "我去年在電視上看過。"}, {"index": 12, "text": "It's an old film, but it's very good.", "start": 41.327, "end": 44.449, "zh": "这是部老电影,不过很不错。", "zh_hant": "這是部老電影,不過很不錯。"}, {"index": 13, "text": "Paris is a beautiful city.", "start": 45.869, "end": 48.191, "zh": "巴黎是座美丽的城市。", "zh_hant": "巴黎是座美麗的城市。"}, {"index": 14, "text": "I've never been there.", "start": 49.532, "end": 50.812, "zh": "我从没去过那儿。", "zh_hant": "我從沒去過那兒。"}, {"index": 15, "text": "Have you ever been there, Ken?", "start": 51.693, "end": 53.414, "zh": "肯,你去过那儿吗?", "zh_hant": "肯,你去過那兒嗎?"}, {"index": 16, "text": "Yes, I have.", "start": 54.655, "end": 56.115, "zh": "是的,我去过。", "zh_hant": "是的,我去過。"}, {"index": 17, "text": "I was there in April.", "start": 56.976, "end": 58.937, "zh": "我四月份在那儿。", "zh_hant": "我四月份在那兒。"}, {"index": 18, "text": "Paris in the spring, eh?", "start": 58.937, "end": 60.478, "zh": "春天的巴黎,是吧?", "zh_hant": "春天的巴黎,是吧?"}, {"index": 19, "text": "It was spring, but the weather was awful.", "start": 60.721, "end": 67.547, "zh": "是春天没错,可天气糟透了。", "zh_hant": "是春天沒錯,可天氣糟透了。"}, {"index": 20, "text": "It rained all the time.", "start": 68.308, "end": 69.829, "zh": "一直在下雨。", "zh_hant": "一直在下雨。"}, {"index": 21, "text": "Just like London!", "start": 69.829, "end": 70.59, "zh": "跟伦敦一样!", "zh_hant": "跟倫敦一樣!"}]