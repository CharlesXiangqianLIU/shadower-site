[{"index": 0, "text": "Lesson 39 Don't drop it!", "start": 0.77, "end": 4.932, "zh": "第39课 别把它摔了!", "zh_hant": "第39課 別把它摔了!"}, {"index": 1, "text": "Listen to the tape then answer this question.", "start": 6.252, "end": 10.814, "zh": "听录音，然后回答这个问题。", "zh_hant": "聽錄音，然後回答這個問題。"}, {"index": 2, "text": "Where does Sam put the vase in the end?", "start": 12.434, "end": 16.596, "zh": "萨姆最后把花瓶放在哪里？", "zh_hant": "薩姆最後把花瓶放在哪裡？"}, {"index": 3, "text": "What are you going to do with that vase, Penny?", "start": 18.436, "end": 23.098, "zh": "佩妮，你打算拿这个花瓶做什么？", "zh_hant": "佩妮，你打算拿這個花瓶做什麼？"}, {"index": 4, "text": "I'm going to put it on this table, Sam.", "start": 24.138, "end": 28.12, "zh": "萨姆，我打算把它放在这张桌子上。", "zh_hant": "薩姆，我打算把它放在這張桌子上。"}, {"index": 5, "text": "Don't do that.", "start": 29.06, "end": 30.761, "zh": "别那样做。", "zh_hant": "別那樣做。"}, {"index": 6, "text": "Give it to me.", "start": 31.341, "end": 32.881, "zh": "把它给我。", "zh_hant": "把它給我。"}, {"index": 7, "text": "What are you going to do with it?", "start": 33.642, "end": 36.543, "zh": "你打算拿它怎么办？", "zh_hant": "你打算拿它怎麼辦？"}, {"index": 8, "text": "I'm going to put it here, in front of the window.", "start": 37.463, "end": 42.585, "zh": "我打算把它放在这儿，窗户前面。", "zh_hant": "我打算把它放在這兒，窗戶前面。"}, {"index": 9, "text": "Be careful!", "start": 42.945, "end": 44.585, "zh": "小心!", "zh_hant": "小心!"}, {"index": 10, "text": "Don't drop it!", "start": 44.726, "end": 46.426, "zh": "别把它掉了！", "zh_hant": "別把它掉了！"}, {"index": 11, "text": "Don't put it there, Sam.", "start": 47.326, "end": 50.047, "zh": "萨姆，别把它放在那儿。", "zh_hant": "薩姆，別把它放在那兒。"}, {"index": 12, "text": "Put it here, on this shelf.", "start": 50.227, "end": 53.488, "zh": "把它放在这儿，这个架子上。", "zh_hant": "把它放在這兒，這個架子上。"}, {"index": 13, "text": "There we are!", "start": 54.709, "end": 56.349, "zh": "好啦！", "zh_hant": "好啦！"}, {"index": 14, "text": "It's a lovely vase.", "start": 56.71, "end": 58.79, "zh": "这是个漂亮的花瓶。", "zh_hant": "這是個漂亮的花瓶。"}, {"index": 15, "text": "Those flowers are lovely, too.", "start": 59.471, "end": 62.792, "zh": "那些花也很漂亮。", "zh_hant": "那些花也很漂亮。"}]