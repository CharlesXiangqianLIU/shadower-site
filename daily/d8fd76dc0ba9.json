[{"index": 0, "text": "Lesson 45", "start": 1.621, "end": 1.965, "zh": "第45课", "zh_hant": "第45課"}, {"index": 1, "text": "The boss's letter", "start": 3.882, "end": 5.323, "zh": "老板的信", "zh_hant": "老闆的信"}, {"index": 2, "text": "Listen to the tape then answer this question.", "start": 7.004, "end": 10.526, "zh": "听录音,然后回答这个问题。", "zh_hant": "聽錄音,然後回答這個問題。"}, {"index": 3, "text": "Why can't Pamela type the letter?", "start": 13.107, "end": 15.868, "zh": "帕梅拉为什么不能打这封信?", "zh_hant": "帕梅拉為什麼不能打這封信?"}, {"index": 4, "text": "Can you come here a minute please, Bob?", "start": 18.73, "end": 21.091, "zh": "鲍勃,你能过来一下吗?", "zh_hant": "鮑勃,你能過來一下嗎?"}, {"index": 5, "text": "Yes, sir?", "start": 22.232, "end": 22.712, "zh": "是,先生?", "zh_hant": "是,先生?"}, {"index": 6, "text": "Where's Pamela?", "start": 24.333, "end": 25.473, "zh": "帕梅拉在哪儿?", "zh_hant": "帕梅拉在哪兒?"}, {"index": 7, "text": "She's next door.", "start": 26.834, "end": 27.755, "zh": "她在隔壁。", "zh_hant": "她在隔壁。"}, {"index": 8, "text": "She's in her office, sir.", "start": 28.495, "end": 29.984, "zh": "她在她的办公室里,先生。", "zh_hant": "她在她的辦公室裡,先生。"}, {"index": 9, "text": "Can she type this letter for me?", "start": 32.085, "end": 34.065, "zh": "她能帮我打这封信吗?", "zh_hant": "她能幫我打這封信嗎?"}, {"index": 10, "text": "Ask her please.", "start": 35.205, "end": 36.146, "zh": "请你去问问她。", "zh_hant": "請你去問問她。"}, {"index": 11, "text": "Yes, sir.", "start": 37.446, "end": 38.006, "zh": "好的,先生。", "zh_hant": "好的,先生。"}, {"index": 12, "text": "Can you type this letter for the boss please, Pamela?", "start": 40.287, "end": 43.247, "zh": "帕梅拉,你能帮老板打一下这封信吗?", "zh_hant": "帕梅拉,你能幫老闆打一下這封信嗎?"}, {"index": 13, "text": "Yes, of course I can.", "start": 44.028, "end": 45.568, "zh": "当然可以。", "zh_hant": "當然可以。"}, {"index": 14, "text": "Here you are.", "start": 46.668, "end": 47.489, "zh": "给你。", "zh_hant": "給你。"}, {"index": 15, "text": "Thank you, Bob.", "start": 48.569, "end": 49.409, "zh": "谢谢你,鲍勃。", "zh_hant": "謝謝你,鮑勃。"}, {"index": 16, "text": "Bob!", "start": 51.57, "end": 52.09, "zh": "鲍勃!", "zh_hant": "鮑勃!"}, {"index": 17, "text": "Yes?", "start": 52.73, "end": 53.15, "zh": "什么事?", "zh_hant": "什麼事?"}, {"index": 18, "text": "What's the matter?", "start": 53.97, "end": 54.89, "zh": "怎么了?", "zh_hant": "怎麼了?"}, {"index": 19, "text": "I can't type this letter.", "start": 56.391, "end": 58.031, "zh": "我打不了这封信。", "zh_hant": "我打不了這封信。"}, {"index": 20, "text": "I can't read it!", "start": 58.892, "end": 61.156, "zh": "我看不懂!", "zh_hant": "我看不懂!"}, {"index": 21, "text": "The boss's handwriting is terrible!", "start": 61.156, "end": 64.39, "zh": "老板的字迹太糟糕了!", "zh_hant": "老闆的字跡太糟糕了!"}]