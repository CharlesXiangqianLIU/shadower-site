[{"index": 0, "text": "Lesson 45", "start": 1.621, "end": 1.965}, {"index": 1, "text": "The boss's letter", "start": 3.882, "end": 5.323}, {"index": 2, "text": "Listen to the tape then answer this question.", "start": 7.004, "end": 10.526}, {"index": 3, "text": "Why can't Pamela type the letter?", "start": 13.107, "end": 15.868}, {"index": 4, "text": "Can you come here a minute please, Bob?", "start": 18.73, "end": 21.091}, {"index": 5, "text": "Yes, sir?", "start": 22.232, "end": 22.712}, {"index": 6, "text": "Where's Pamela?", "start": 24.333, "end": 25.473}, {"index": 7, "text": "She's next door.", "start": 26.834, "end": 27.755}, {"index": 8, "text": "She's in her office, sir.", "start": 28.495, "end": 29.984}, {"index": 9, "text": "Can she type this letter for me?", "start": 32.085, "end": 34.065}, {"index": 10, "text": "Ask her please.", "start": 35.205, "end": 36.146}, {"index": 11, "text": "Yes, sir.", "start": 37.446, "end": 38.006}, {"index": 12, "text": "Can you type this letter for the boss please, Pamela?", "start": 40.287, "end": 43.247}, {"index": 13, "text": "Yes, of course I can.", "start": 44.028, "end": 45.568}, {"index": 14, "text": "Here you are.", "start": 46.668, "end": 47.489}, {"index": 15, "text": "Thank you, Bob.", "start": 48.569, "end": 49.409}, {"index": 16, "text": "Bob!", "start": 51.57, "end": 52.09}, {"index": 17, "text": "Yes?", "start": 52.73, "end": 53.15}, {"index": 18, "text": "What's the matter?", "start": 53.97, "end": 54.89}, {"index": 19, "text": "I can't type this letter.", "start": 56.391, "end": 58.031}, {"index": 20, "text": "I can't read it!", "start": 58.892, "end": 61.156}, {"index": 21, "text": "The boss's handwriting is terrible!", "start": 61.156, "end": 64.39}]