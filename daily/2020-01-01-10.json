[{"index": 0, "text": "Lesson 19 Tired and thirsty Listen to the tape then answer this question.", "start": 0.61, "end": 11.094, "zh": "第19课 又累又渴 听录音,然后回答问题。", "zh_hant": "第19課 又累又渴 聽錄音,然後回答問題。"}, {"index": 1, "text": "Why do the children thank their mother?", "start": 12.234, "end": 15.875, "zh": "孩子们为什么要感谢妈妈?", "zh_hant": "孩子們為什麼要感謝媽媽?"}, {"index": 2, "text": "What's the matter children?", "start": 17.916, "end": 20.136, "zh": "孩子们,怎么了?", "zh_hant": "孩子們,怎麼了?"}, {"index": 3, "text": "We're tired ... ... and thirsty Mum.", "start": 20.777, "end": 24.798, "zh": "妈妈,我们又累又渴。", "zh_hant": "媽媽,我們又累又渴。"}, {"index": 4, "text": "Sit down here.", "start": 25.258, "end": 27.019, "zh": "坐这儿吧。", "zh_hant": "坐這兒吧。"}, {"index": 5, "text": "Are you all right now?", "start": 27.799, "end": 29.9, "zh": "你们现在好点了吗?", "zh_hant": "你們現在好點了嗎?"}, {"index": 6, "text": "No we aren't.", "start": 30.12, "end": 32.18, "zh": "不,还没有。", "zh_hant": "不,還沒有。"}, {"index": 7, "text": "Look!", "start": 32.481, "end": 33.481, "zh": "看!", "zh_hant": "看!"}, {"index": 8, "text": "There's an ice cream man.", "start": 33.581, "end": 36.202, "zh": "有个卖冰淇淋的人。", "zh_hant": "有個賣冰淇淋的人。"}, {"index": 9, "text": "Two ice cream please.", "start": 36.862, "end": 39.723, "zh": "请给我们两个冰淇淋。", "zh_hant": "請給我們兩個冰淇淋。"}, {"index": 10, "text": "Here you are children.", "start": 40.623, "end": 42.824, "zh": "给你们,孩子们。", "zh_hant": "給你們,孩子們。"}, {"index": 11, "text": "Thanks Mum.", "start": 43.604, "end": 45.425, "zh": "谢谢,妈妈。", "zh_hant": "謝謝,媽媽。"}, {"index": 12, "text": "These ice creams are nice.", "start": 46.005, "end": 49.126, "zh": "这些冰淇淋真好吃。", "zh_hant": "這些冰淇淋真好吃。"}, {"index": 13, "text": "Are you all right now?", "start": 49.806, "end": 51.987, "zh": "你们现在好点了吗?", "zh_hant": "你們現在好點了嗎?"}, {"index": 14, "text": "Yes we are thank you!", "start": 52.807, "end": 56.468, "zh": "是的,好多了,谢谢!", "zh_hant": "是的,好多了,謝謝!"}]