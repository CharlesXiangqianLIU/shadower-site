[{"index": 0, "text": "Lesson 11 Is this your shirt?", "start": 0.81, "end": 5.33, "zh": "第11课 这是你的衬衫吗？", "zh_hant": "第11課 這是你的襯衫嗎？"}, {"index": 1, "text": "Listen to the tape then answer this question.", "start": 6.651, "end": 11.551, "zh": "听录音,然后回答这个问题。", "zh_hant": "聽錄音,然後回答這個問題。"}, {"index": 2, "text": "Whose shirt is white?", "start": 13.151, "end": 15.391, "zh": "谁的衬衫是白色的?", "zh_hant": "誰的襯衫是白色的?"}, {"index": 3, "text": "Whose shirt is that?", "start": 17.052, "end": 19.172, "zh": "那是谁的衬衫?", "zh_hant": "那是誰的襯衫?"}, {"index": 4, "text": "Is this your shirt Dave?", "start": 20.052, "end": 22.532, "zh": "戴夫,这是你的衬衫吗?", "zh_hant": "戴夫,這是你的襯衫嗎?"}, {"index": 5, "text": "No. Sir.", "start": 23.172, "end": 24.372, "zh": "不,先生。", "zh_hant": "不,先生。"}, {"index": 6, "text": "It's not my shirt.", "start": 24.512, "end": 26.633, "zh": "这不是我的衬衫。", "zh_hant": "這不是我的襯衫。"}, {"index": 7, "text": "This is my shirt.", "start": 27.853, "end": 29.953, "zh": "这才是我的衬衫。", "zh_hant": "這才是我的襯衫。"}, {"index": 8, "text": "My shirt's blue.", "start": 30.413, "end": 32.253, "zh": "我的衬衫是蓝色的。", "zh_hant": "我的襯衫是藍色的。"}, {"index": 9, "text": "Is this shirt Tim's?", "start": 33.253, "end": 35.693, "zh": "这件衬衫是蒂姆的吗?", "zh_hant": "這件襯衫是蒂姆的嗎?"}, {"index": 10, "text": "Perhaps it is sir.", "start": 36.414, "end": 38.614, "zh": "也许是的,先生。", "zh_hant": "也許是的,先生。"}, {"index": 11, "text": "Tim's shirt's white.", "start": 39.434, "end": 41.674, "zh": "蒂姆的衬衫是白色的。", "zh_hant": "蒂姆的襯衫是白色的。"}, {"index": 12, "text": "Tim!", "start": 42.154, "end": 42.974, "zh": "蒂姆!", "zh_hant": "蒂姆!"}, {"index": 13, "text": "Yes sir?", "start": 43.694, "end": 44.734, "zh": "什么事,先生?", "zh_hant": "什麼事,先生?"}, {"index": 14, "text": "Is this your shirt?", "start": 45.294, "end": 47.175, "zh": "这是你的衬衫吗?", "zh_hant": "這是你的襯衫嗎?"}, {"index": 15, "text": "Yes sir.", "start": 47.295, "end": 48.435, "zh": "是的,先生。", "zh_hant": "是的,先生。"}, {"index": 16, "text": "Here you are.", "start": 48.715, "end": 50.175, "zh": "给你。", "zh_hant": "給你。"}, {"index": 17, "text": "Catch!", "start": 50.355, "end": 51.275, "zh": "接住!", "zh_hant": "接住!"}, {"index": 18, "text": "Thank you sir.", "start": 51.495, "end": 52.995, "zh": "谢谢您,先生。", "zh_hant": "謝謝您,先生。"}]