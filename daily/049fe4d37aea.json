[{"index": 0, "text": "Lesson 49", "start": 1.58, "end": 2.145, "zh": "第49课", "zh_hant": "第49課"}, {"index": 1, "text": "At the butcher's", "start": 4.041, "end": 5.362, "zh": "在肉店", "zh_hant": "在肉店"}, {"index": 2, "text": "Listen to the tape then answer this question.", "start": 6.982, "end": 10.743, "zh": "听录音,然后回答这个问题。", "zh_hant": "聽錄音,然後回答這個問題。"}, {"index": 3, "text": "What does Mr. Bird like?", "start": 13.284, "end": 15.565, "zh": "伯德先生喜欢吃什么?", "zh_hant": "伯德先生喜歡吃什麼?"}, {"index": 4, "text": "Do you want any meat today, Mrs. Bird?", "start": 18.246, "end": 20.787, "zh": "伯德太太,您今天要买肉吗?", "zh_hant": "伯德太太,您今天要買肉嗎?"}, {"index": 5, "text": "Yes, please.", "start": 21.607, "end": 22.587, "zh": "是的,麻烦您。", "zh_hant": "是的,麻煩您。"}, {"index": 6, "text": "Do you want beef or lamb?", "start": 24.328, "end": 26.609, "zh": "您要牛肉还是羊肉?", "zh_hant": "您要牛肉還是羊肉?"}, {"index": 7, "text": "Beef, please.", "start": 27.209, "end": 28.629, "zh": "牛肉,谢谢。", "zh_hant": "牛肉,謝謝。"}, {"index": 8, "text": "This lamb's very good.", "start": 29.75, "end": 31.466, "zh": "这羊肉很不错。", "zh_hant": "這羊肉很不錯。"}, {"index": 9, "text": "I like lamb, but my husband doesn't.", "start": 32.846, "end": 36.328, "zh": "我喜欢吃羊肉,可我丈夫不喜欢。", "zh_hant": "我喜歡吃羊肉,可我丈夫不喜歡。"}, {"index": 10, "text": "What about some steak?", "start": 37.909, "end": 39.369, "zh": "来点牛排怎么样?", "zh_hant": "來點牛排怎麼樣?"}, {"index": 11, "text": "This is a nice piece.", "start": 40.19, "end": 41.991, "zh": "这块不错。", "zh_hant": "這塊不錯。"}, {"index": 12, "text": "Give me that piece, please.", "start": 43.452, "end": 45.493, "zh": "请给我这块吧。", "zh_hant": "請給我這塊吧。"}, {"index": 13, "text": "And a pound of mince, too.", "start": 46.873, "end": 49.034, "zh": "再来一磅肉馅。", "zh_hant": "再來一磅肉餡。"}, {"index": 14, "text": "Do you want a chicken, Mrs. Bird?", "start": 50.995, "end": 53.356, "zh": "伯德太太,您要只鸡吗?", "zh_hant": "伯德太太,您要只雞嗎?"}, {"index": 15, "text": "They're very nice.", "start": 54.157, "end": 55.618, "zh": "这些鸡很不错。", "zh_hant": "這些雞很不錯。"}, {"index": 16, "text": "No, thank you.", "start": 56.898, "end": 60.383, "zh": "不用了,谢谢。", "zh_hant": "不用了,謝謝。"}, {"index": 17, "text": "My husband likes steak,", "start": 60.383, "end": 61.203, "zh": "我丈夫喜欢吃牛排,", "zh_hant": "我丈夫喜歡吃牛排,"}, {"index": 18, "text": "but he doesn't like chicken.", "start": 61.203, "end": 63.164, "zh": "但他不喜欢吃鸡肉。", "zh_hant": "但他不喜歡吃雞肉。"}, {"index": 19, "text": "To tell you the truth, Mrs. Bird,", "start": 64.505, "end": 66.506, "zh": "跟您说实话吧,伯德太太,", "zh_hant": "跟您說實話吧,伯德太太,"}, {"index": 20, "text": "I don't like chicken either!", "start": 67.246, "end": 69.027, "zh": "我也不喜欢吃鸡肉!", "zh_hant": "我也不喜歡吃雞肉!"}]