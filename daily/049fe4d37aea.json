[{"index": 0, "text": "Lesson 49", "start": 1.58, "end": 2.145}, {"index": 1, "text": "At the butcher's", "start": 4.041, "end": 5.362}, {"index": 2, "text": "Listen to the tape then answer this question.", "start": 6.982, "end": 10.743}, {"index": 3, "text": "What does Mr. Bird like?", "start": 13.284, "end": 15.565}, {"index": 4, "text": "Do you want any meat today, Mrs. Bird?", "start": 18.246, "end": 20.787}, {"index": 5, "text": "Yes, please.", "start": 21.607, "end": 22.587}, {"index": 6, "text": "Do you want beef or lamb?", "start": 24.328, "end": 26.609}, {"index": 7, "text": "Beef, please.", "start": 27.209, "end": 28.629}, {"index": 8, "text": "This lamb's very good.", "start": 29.75, "end": 31.466}, {"index": 9, "text": "I like lamb, but my husband doesn't.", "start": 32.846, "end": 36.328}, {"index": 10, "text": "What about some steak?", "start": 37.909, "end": 39.369}, {"index": 11, "text": "This is a nice piece.", "start": 40.19, "end": 41.991}, {"index": 12, "text": "Give me that piece, please.", "start": 43.452, "end": 45.493}, {"index": 13, "text": "And a pound of mince, too.", "start": 46.873, "end": 49.034}, {"index": 14, "text": "Do you want a chicken, Mrs. Bird?", "start": 50.995, "end": 53.356}, {"index": 15, "text": "They're very nice.", "start": 54.157, "end": 55.618}, {"index": 16, "text": "No, thank you.", "start": 56.898, "end": 60.383}, {"index": 17, "text": "My husband likes steak,", "start": 60.383, "end": 61.203}, {"index": 18, "text": "but he doesn't like chicken.", "start": 61.203, "end": 63.164}, {"index": 19, "text": "To tell you the truth, Mrs. Bird,", "start": 64.505, "end": 66.506}, {"index": 20, "text": "I don't like chicken either!", "start": 67.246, "end": 69.027}]