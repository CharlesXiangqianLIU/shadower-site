[{"index": 0, "text": "Lesson 115 Knock, knock!", "start": 0.61, "end": 5.791, "zh": "第115课 敲敲门!", "zh_hant": "第115課 敲敲門!"}, {"index": 1, "text": "Listen to the tape then answer this question.", "start": 6.992, "end": 11.613, "zh": "听录音，然后回答这个问题。", "zh_hant": "聽錄音，然後回答這個問題。"}, {"index": 2, "text": "What does Jim have to drink?", "start": 12.753, "end": 15.794, "zh": "吉姆有什么喝的？", "zh_hant": "吉姆有什麼喝的？"}, {"index": 3, "text": "Isn't there anyone at home?", "start": 18.015, "end": 20.755, "zh": "家里没人吗？", "zh_hant": "家裡沒人嗎？"}, {"index": 4, "text": "I'll knock again, Helen.", "start": 21.676, "end": 23.876, "zh": "我再敲一次门，海伦。", "zh_hant": "我再敲一次門，海倫。"}, {"index": 5, "text": "Everything's very quiet.", "start": 24.556, "end": 26.997, "zh": "一切都很安静。", "zh_hant": "一切都很安靜。"}, {"index": 6, "text": "I'm sure there's no one at home.", "start": 27.717, "end": 30.758, "zh": "我确定家里没人。", "zh_hant": "我確定家裡沒人。"}, {"index": 7, "text": "But that's impossible.", "start": 30.798, "end": 33.158, "zh": "但那不可能。", "zh_hant": "但那不可能。"}, {"index": 8, "text": "Carol and Tom invited us to lunch.", "start": 33.539, "end": 37.46, "zh": "卡罗尔和汤姆邀请我们来吃午饭。", "zh_hant": "卡羅爾和湯姆邀請我們來吃午飯。"}, {"index": 9, "text": "Look through the window.", "start": 37.74, "end": 39.68, "zh": "透过窗户看看。", "zh_hant": "透過窗戶看看。"}, {"index": 10, "text": "Can you see anything?", "start": 40.64, "end": 42.721, "zh": "你能看到什么吗？", "zh_hant": "你能看到什麼嗎？"}, {"index": 11, "text": "Nothing at all.", "start": 43.701, "end": 45.302, "zh": "什么也没有。", "zh_hant": "什麼也沒有。"}, {"index": 12, "text": "Let's try the back door.", "start": 45.782, "end": 48.402, "zh": "我们试试后门吧。", "zh_hant": "我們試試後門吧。"}, {"index": 13, "text": "Look!", "start": 49.263, "end": 50.123, "zh": "看!", "zh_hant": "看!"}, {"index": 14, "text": "Everyone's in the garden.", "start": 50.523, "end": 52.843, "zh": "大家都在花园里。", "zh_hant": "大家都在花園裡。"}, {"index": 15, "text": "Hello, Helen.", "start": 53.184, "end": 54.924, "zh": "你好,海伦。", "zh_hant": "你好,海倫。"}, {"index": 16, "text": "Hello, Jim.", "start": 55.104, "end": 56.704, "zh": "你好,吉姆。", "zh_hant": "你好,吉姆。"}, {"index": 17, "text": "Everybody wants to have lunch in the garden.", "start": 57.325, "end": 61.046, "zh": "大家都想在花园里吃午饭。", "zh_hant": "大家都想在花園裡吃午飯。"}, {"index": 18, "text": "It's nice and warm out here.", "start": 61.346, "end": 64.166, "zh": "这里又暖和又舒服。", "zh_hant": "這裡又暖和又舒服。"}, {"index": 19, "text": "Come and have something to drink.", "start": 64.867, "end": 67.767, "zh": "过来喝点什么吧。", "zh_hant": "過來喝點什麼吧。"}, {"index": 20, "text": "Thanks, Carol.", "start": 68.668, "end": 70.208, "zh": "谢谢，卡罗尔。", "zh_hant": "謝謝，卡羅爾。"}, {"index": 21, "text": "May I have a glass of beer please?", "start": 70.728, "end": 74.269, "zh": "可以给我来杯啤酒吗？", "zh_hant": "可以給我來杯啤酒嗎？"}, {"index": 22, "text": "Beer?", "start": 74.489, "end": 75.389, "zh": "啤酒？", "zh_hant": "啤酒？"}, {"index": 23, "text": "There's none left.", "start": 75.729, "end": 77.67, "zh": "一点都不剩了。", "zh_hant": "一點都不剩了。"}, {"index": 24, "text": "You can have some lemonade.", "start": 77.85, "end": 80.851, "zh": "你可以喝点柠檬水。", "zh_hant": "你可以喝點檸檬水。"}, {"index": 25, "text": "Lemonade!", "start": 81.131, "end": 82.531, "zh": "柠檬水！", "zh_hant": "檸檬水！"}, {"index": 26, "text": "Don't believe her, Jim.", "start": 82.591, "end": 84.732, "zh": "别相信她，吉姆。", "zh_hant": "別相信她，吉姆。"}, {"index": 27, "text": "She's only joking.", "start": 84.692, "end": 86.532, "zh": "她只是在开玩笑。", "zh_hant": "她只是在開玩笑。"}, {"index": 28, "text": "Have some beer!", "start": 86.572, "end": 88.032, "zh": "喝点啤酒吧！", "zh_hant": "喝點啤酒吧！"}]