[{"index": 0, "text": "Lesson 43", "start": 1.561, "end": 2.27}, {"index": 1, "text": "Hurry up!", "start": 4.062, "end": 4.723}, {"index": 2, "text": "Listen to the tape then answer this question.", "start": 6.124, "end": 9.646}, {"index": 3, "text": "How do you know Sam doesn't make the tea very often?", "start": 12.168, "end": 15.53}, {"index": 4, "text": "Can you make the tea, Sam?", "start": 18.252, "end": 20.093}, {"index": 5, "text": "Yes, of course I can, Penny.", "start": 21.154, "end": 23.455}, {"index": 6, "text": "Is there any water in this kettle?", "start": 25.957, "end": 28.178}, {"index": 7, "text": "Yes, there is.", "start": 31.75, "end": 32.211}, {"index": 8, "text": "Where's the tea?", "start": 32.211, "end": 33.051}, {"index": 9, "text": "It's over there, behind the teapot.", "start": 34.531, "end": 37.492}, {"index": 10, "text": "Can you see it?", "start": 38.213, "end": 39.173}, {"index": 11, "text": "I can see the teapot, but I can't see the tea.", "start": 40.693, "end": 45.035}, {"index": 12, "text": "There it is!", "start": 46.235, "end": 47.395}, {"index": 13, "text": "It's in front of you!", "start": 48.276, "end": 49.616}, {"index": 14, "text": "Ah yes, I can see it now.", "start": 50.717, "end": 54.058}, {"index": 15, "text": "Where are the cups?", "start": 56.218, "end": 57.919}, {"index": 16, "text": "There are some in the cupboard.", "start": 60.71, "end": 61.391}, {"index": 17, "text": "Can you find them?", "start": 63.174, "end": 64.215}, {"index": 18, "text": "Yes. Here they are.", "start": 65.698, "end": 67.54}, {"index": 19, "text": "Hurry up, Sam!", "start": 68.382, "end": 69.463}, {"index": 20, "text": "The kettle's boiling!", "start": 70.345, "end": 71.947}]