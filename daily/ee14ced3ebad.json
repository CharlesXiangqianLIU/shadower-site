[{"index": 0, "text": "Lesson 43", "start": 1.561, "end": 2.27, "zh": "第43课"}, {"index": 1, "text": "Hurry up!", "start": 4.062, "end": 4.723, "zh": "快点!"}, {"index": 2, "text": "Listen to the tape then answer this question.", "start": 6.124, "end": 9.646, "zh": "听录音,然后回答这个问题。"}, {"index": 3, "text": "How do you know Sam doesn't make the tea very often?", "start": 12.168, "end": 15.53, "zh": "你怎么知道山姆不常泡茶?"}, {"index": 4, "text": "Can you make the tea, Sam?", "start": 18.252, "end": 20.093, "zh": "你会泡茶吗,山姆?"}, {"index": 5, "text": "Yes, of course I can, Penny.", "start": 21.154, "end": 23.455, "zh": "当然会,潘妮。"}, {"index": 6, "text": "Is there any water in this kettle?", "start": 25.957, "end": 28.178, "zh": "这个水壶里有水吗?"}, {"index": 7, "text": "Yes, there is.", "start": 31.75, "end": 32.211, "zh": "有。"}, {"index": 8, "text": "Where's the tea?", "start": 32.211, "end": 33.051, "zh": "茶叶在哪儿?"}, {"index": 9, "text": "It's over there, behind the teapot.", "start": 34.531, "end": 37.492, "zh": "在那边,茶壶后面。"}, {"index": 10, "text": "Can you see it?", "start": 38.213, "end": 39.173, "zh": "你看得见吗?"}, {"index": 11, "text": "I can see the teapot, but I can't see the tea.", "start": 40.693, "end": 45.035, "zh": "我看得见茶壶,但看不见茶叶。"}, {"index": 12, "text": "There it is!", "start": 46.235, "end": 47.395, "zh": "在那儿!"}, {"index": 13, "text": "It's in front of you!", "start": 48.276, "end": 49.616, "zh": "就在你面前!"}, {"index": 14, "text": "Ah yes, I can see it now.", "start": 50.717, "end": 54.058, "zh": "啊,对,我现在看见了。"}, {"index": 15, "text": "Where are the cups?", "start": 56.218, "end": 57.919, "zh": "杯子在哪儿?"}, {"index": 16, "text": "There are some in the cupboard.", "start": 60.71, "end": 61.391, "zh": "橱柜里有几个。"}, {"index": 17, "text": "Can you find them?", "start": 63.174, "end": 64.215, "zh": "你能找到吗?"}, {"index": 18, "text": "Yes. Here they are.", "start": 65.698, "end": 67.54, "zh": "能。它们在这儿。"}, {"index": 19, "text": "Hurry up, Sam!", "start": 68.382, "end": 69.463, "zh": "快点,山姆!"}, {"index": 20, "text": "The kettle's boiling!", "start": 70.345, "end": 71.947, "zh": "水壶开了!"}]