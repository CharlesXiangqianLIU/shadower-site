[{"index": 0, "text": "Lesson 73", "start": 1.581, "end": 2.3}, {"index": 1, "text": "The way to King Street", "start": 4.262, "end": 6.143}, {"index": 2, "text": "Listen to the tape then answer this question.", "start": 7.644, "end": 10.866}, {"index": 3, "text": "Why did the man need a phrasebook?", "start": 13.387, "end": 16.009}, {"index": 4, "text": "Last week Mrs. Mills went to London.", "start": 18.81, "end": 21.692}, {"index": 5, "text": "She does not know London very well, and she lost her way.", "start": 22.853, "end": 26.595}, {"index": 6, "text": "Suddenly, she saw a man near a bus stop.", "start": 29.99, "end": 31.481}, {"index": 7, "text": "'I can ask him the way,' she said to herself.", "start": 31.481, "end": 36.013}, {"index": 8, "text": "'Excuse me,' she said.", "start": 36.714, "end": 39.956}, {"index": 9, "text": "'Can you tell me the way to King Street, please?'", "start": 39.996, "end": 44.378}, {"index": 10, "text": "The man smiled pleasantly.", "start": 46.159, "end": 48.06}, {"index": 11, "text": "He did not understand English!", "start": 49.321, "end": 51.782}, {"index": 12, "text": "He spoke German.", "start": 52.643, "end": 59.943}, {"index": 13, "text": "He was a tourist.", "start": 59.943, "end": 60.223}, {"index": 14, "text": "Then he put his hand into his pocket, and took out a phrasebook.", "start": 60.223, "end": 62.605}, {"index": 15, "text": "He opened the book and found a phrase.", "start": 64.426, "end": 67.187}, {"index": 16, "text": "He read the phrase slowly.", "start": 68.548, "end": 70.93}, {"index": 17, "text": "'I am sorry,' he said.", "start": 71.57, "end": 76.353}, {"index": 18, "text": "'I do not speak English.'", "start": 76.353, "end": 85.098}]