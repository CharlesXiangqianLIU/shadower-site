[{"index": 0, "text": "Lesson 81 Roast beef and potatoes Listen to the tape then answer this question.", "start": 0.53, "end": 11.492, "zh": "第81课 烤牛肉和土豆 听录音，然后回答这个问题。", "zh_hant": "第81課 烤牛肉和土豆 聽錄音，然後回答這個問題。"}, {"index": 1, "text": "Why is Carol disappointed?", "start": 12.393, "end": 15.393, "zh": "卡罗尔为什么失望?", "zh_hant": "卡羅爾為什麼失望?"}, {"index": 2, "text": "Hi, Carol!", "start": 16.954, "end": 18.354, "zh": "嗨，卡罗尔！", "zh_hant": "嗨，卡羅爾！"}, {"index": 3, "text": "Where's Tom?", "start": 18.634, "end": 20.054, "zh": "汤姆在哪儿？", "zh_hant": "湯姆在哪兒？"}, {"index": 4, "text": "He's upstairs.", "start": 20.314, "end": 22.375, "zh": "他在楼上。", "zh_hant": "他在樓上。"}, {"index": 5, "text": "He's having a bath.", "start": 22.395, "end": 24.615, "zh": "他在洗澡。", "zh_hant": "他在洗澡。"}, {"index": 6, "text": "Tom!", "start": 25.176, "end": 26.276, "zh": "汤姆!", "zh_hant": "湯姆!"}, {"index": 7, "text": "Yes?", "start": 26.776, "end": 27.876, "zh": "什么事?", "zh_hant": "什麼事?"}, {"index": 8, "text": "Sam's here.", "start": 27.996, "end": 29.396, "zh": "萨姆来了。", "zh_hant": "薩姆來了。"}, {"index": 9, "text": "I'm nearly ready.", "start": 30.297, "end": 31.837, "zh": "我快准备好了。", "zh_hant": "我快準備好了。"}, {"index": 10, "text": "Hello, Sam.", "start": 32.757, "end": 34.237, "zh": "你好,萨姆。", "zh_hant": "你好,薩姆。"}, {"index": 11, "text": "Have a cigarette.", "start": 34.618, "end": 36.418, "zh": "来根烟吧。", "zh_hant": "來根菸吧。"}, {"index": 12, "text": "No, thanks, Tom.", "start": 36.598, "end": 38.498, "zh": "不,谢谢,汤姆。", "zh_hant": "不,謝謝,湯姆。"}, {"index": 13, "text": "Have a glass of whisky then.", "start": 39.039, "end": 41.519, "zh": "那就来杯威士忌吧。", "zh_hant": "那就來杯威士忌吧。"}, {"index": 14, "text": "OK.", "start": 41.699, "end": 42.379, "zh": "好的。", "zh_hant": "好的。"}, {"index": 15, "text": "Thanks.", "start": 42.539, "end": 43.479, "zh": "谢谢。", "zh_hant": "謝謝。"}, {"index": 16, "text": "Is dinnner ready, Carol?", "start": 44.16, "end": 46.24, "zh": "晚饭准备好了吗,卡罗尔?", "zh_hant": "晚飯準備好了嗎,卡羅爾?"}, {"index": 17, "text": "It's nearly ready.", "start": 47.78, "end": 49.701, "zh": "快好了。", "zh_hant": "快好了。"}, {"index": 18, "text": "We can have dinner at seven o'clock.", "start": 50.041, "end": 53.682, "zh": "我们可以七点吃晚饭。", "zh_hant": "我們可以七點吃晚飯。"}, {"index": 19, "text": "Sam and I had lunch together today.", "start": 54.862, "end": 58.163, "zh": "萨姆和我今天一起吃了午饭。", "zh_hant": "薩姆和我今天一起吃了午飯。"}, {"index": 20, "text": "We went to a restaurant.", "start": 58.623, "end": 60.863, "zh": "我们去了一家餐馆。", "zh_hant": "我們去了一家餐館。"}, {"index": 21, "text": "What did you have?", "start": 61.123, "end": 62.964, "zh": "你们吃了什么?", "zh_hant": "你們吃了什麼?"}, {"index": 22, "text": "We had roast beef and potatoes.", "start": 63.404, "end": 66.864, "zh": "我们吃了烤牛肉和马铃薯。", "zh_hant": "我們吃了烤牛肉和馬鈴薯。"}, {"index": 23, "text": "Oh!", "start": 67.065, "end": 67.945, "zh": "哦!", "zh_hant": "哦!"}, {"index": 24, "text": "What's the matter, Carol?", "start": 68.685, "end": 70.665, "zh": "怎么了,卡罗尔?", "zh_hant": "怎麼了,卡羅爾?"}, {"index": 25, "text": "Well, you're going to have roast beef and potatoes again tonight!", "start": 71.045, "end": 77.847, "zh": "是这样,你们今晚又要吃烤牛肉和马铃薯了!", "zh_hant": "是這樣,你們今晚又要吃烤牛肉和馬鈴薯了!"}]