[{"index": 0, "text": "Lesson 91", "start": 1.59, "end": 2.48}, {"index": 1, "text": "Poor Ian!", "start": 4.091, "end": 5.231}, {"index": 2, "text": "Listen to the tape then answer this question.", "start": 6.291, "end": 9.532}, {"index": 3, "text": "Who wanted to sell the house?", "start": 11.973, "end": 14.133}, {"index": 4, "text": "Has Ian sold his house yet?", "start": 16.854, "end": 19.274}, {"index": 5, "text": "Yes, he has.", "start": 20.735, "end": 22.115}, {"index": 6, "text": "He sold it last week.", "start": 22.555, "end": 24.295}, {"index": 7, "text": "Has he moved to his new house yet?", "start": 25.976, "end": 30.564}, {"index": 8, "text": "No, not yet.", "start": 30.444, "end": 31.904}, {"index": 9, "text": "He's still here.", "start": 32.464, "end": 33.585}, {"index": 10, "text": "He's going to move tomorrow.", "start": 34.505, "end": 36.505}, {"index": 11, "text": "When? Tomorrow morning?", "start": 39.066, "end": 41.366}, {"index": 12, "text": "No. Tomorrow afternoon.", "start": 42.626, "end": 45.267}, {"index": 13, "text": "I'll miss him.", "start": 46.507, "end": 47.447}, {"index": 14, "text": "He has always been a good neighbour.", "start": 48.188, "end": 50.788}, {"index": 15, "text": "He's a very nice person.", "start": 52.228, "end": 54.009}, {"index": 16, "text": "We'll all miss him.", "start": 54.929, "end": 60.86}, {"index": 17, "text": "When will the new people move into this house?", "start": 60.74, "end": 63.321}, {"index": 18, "text": "I think that they'll move in the day after tomorrow.", "start": 65.502, "end": 68.843}, {"index": 19, "text": "Will you see Ian today, Jenny?", "start": 71.103, "end": 73.184}, {"index": 20, "text": "Yes, I will.", "start": 74.905, "end": 76.385}, {"index": 21, "text": "Please give him my regards.", "start": 77.966, "end": 79.866}, {"index": 22, "text": "Poor Ian! He didn't want to leave this house.", "start": 81.507, "end": 91.692}, {"index": 23, "text": "No, he didn't want to leave, but his wife did!", "start": 91.572, "end": 97.89}]