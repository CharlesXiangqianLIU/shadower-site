[{"index": 0, "text": "Lesson 91", "start": 1.59, "end": 2.48, "zh": "第91课"}, {"index": 1, "text": "Poor Ian!", "start": 4.091, "end": 5.231, "zh": "可怜的伊恩!"}, {"index": 2, "text": "Listen to the tape then answer this question.", "start": 6.291, "end": 9.532, "zh": "听录音,然后回答这个问题。"}, {"index": 3, "text": "Who wanted to sell the house?", "start": 11.973, "end": 14.133, "zh": "谁想卖房子?"}, {"index": 4, "text": "Has Ian sold his house yet?", "start": 16.854, "end": 19.274, "zh": "伊恩把房子卖了吗?"}, {"index": 5, "text": "Yes, he has.", "start": 20.735, "end": 22.115, "zh": "是的,他卖了。"}, {"index": 6, "text": "He sold it last week.", "start": 22.555, "end": 24.295, "zh": "他上周把房子卖了。"}, {"index": 7, "text": "Has he moved to his new house yet?", "start": 25.976, "end": 30.504, "zh": "他搬到新家了吗?"}, {"index": 8, "text": "No, not yet.", "start": 30.504, "end": 31.904, "zh": "还没有。"}, {"index": 9, "text": "He's still here.", "start": 32.464, "end": 33.585, "zh": "他还在这儿。"}, {"index": 10, "text": "He's going to move tomorrow.", "start": 34.505, "end": 36.505, "zh": "他明天要搬家。"}, {"index": 11, "text": "When? Tomorrow morning?", "start": 39.066, "end": 41.366, "zh": "什么时候?明天上午吗?"}, {"index": 12, "text": "No. Tomorrow afternoon.", "start": 42.626, "end": 45.267, "zh": "不,明天下午。"}, {"index": 13, "text": "I'll miss him.", "start": 46.507, "end": 47.447, "zh": "我会想念他的。"}, {"index": 14, "text": "He has always been a good neighbour.", "start": 48.188, "end": 50.788, "zh": "他一直是个好邻居。"}, {"index": 15, "text": "He's a very nice person.", "start": 52.228, "end": 54.009, "zh": "他是个很好的人。"}, {"index": 16, "text": "We'll all miss him.", "start": 54.929, "end": 60.8, "zh": "我们都会想念他的。"}, {"index": 17, "text": "When will the new people move into this house?", "start": 60.8, "end": 63.321, "zh": "新住户什么时候搬进这所房子?"}, {"index": 18, "text": "I think that they'll move in the day after tomorrow.", "start": 65.502, "end": 68.843, "zh": "我想他们后天就搬进来。"}, {"index": 19, "text": "Will you see Ian today, Jenny?", "start": 71.103, "end": 73.184, "zh": "珍妮,你今天会见到伊恩吗?"}, {"index": 20, "text": "Yes, I will.", "start": 74.905, "end": 76.385, "zh": "是的,我会见到他。"}, {"index": 21, "text": "Please give him my regards.", "start": 77.966, "end": 79.866, "zh": "请代我向他问好。"}, {"index": 22, "text": "Poor Ian! He didn't want to leave this house.", "start": 81.507, "end": 91.632, "zh": "可怜的伊恩!他本不想离开这所房子。"}, {"index": 23, "text": "No, he didn't want to leave, but his wife did!", "start": 91.632, "end": 97.89, "zh": "是的,他不想离开,可他妻子想!"}]