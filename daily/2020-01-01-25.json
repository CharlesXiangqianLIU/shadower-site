[{"index": 0, "text": "Lesson 49 At the butcher's Listen to the tape then answer this question.", "start": 0.59, "end": 10.191, "zh": "第49课 在肉店 听录音,然后回答问题。", "zh_hant": "第49課 在肉店 聽錄音,然後回答問題。"}, {"index": 1, "text": "What does Mr. Bird like?", "start": 11.392, "end": 14.232, "zh": "伯德先生喜欢吃什么?", "zh_hant": "伯德先生喜歡吃什麼?"}, {"index": 2, "text": "Do you want any meat today, Mrs. Bird?", "start": 15.712, "end": 19.713, "zh": "伯德太太,您今天要买肉吗?", "zh_hant": "伯德太太,您今天要買肉嗎?"}, {"index": 3, "text": "Yes, please.", "start": 20.593, "end": 22.193, "zh": "是的,麻烦您。", "zh_hant": "是的,麻煩您。"}, {"index": 4, "text": "Do you want beef or lamb?", "start": 23.193, "end": 26.554, "zh": "您要牛肉还是羊肉?", "zh_hant": "您要牛肉還是羊肉?"}, {"index": 5, "text": "Beef, please.", "start": 26.954, "end": 28.674, "zh": "牛肉,谢谢。", "zh_hant": "牛肉,謝謝。"}, {"index": 6, "text": "This lamb's very good.", "start": 29.754, "end": 32.315, "zh": "这羊肉很不错。", "zh_hant": "這羊肉很不錯。"}, {"index": 7, "text": "I like lamb, but my husband doesn't.", "start": 33.895, "end": 37.675, "zh": "我喜欢吃羊肉,可我丈夫不喜欢。", "zh_hant": "我喜歡吃羊肉,可我丈夫不喜歡。"}, {"index": 8, "text": "What about some steak?", "start": 38.576, "end": 40.936, "zh": "来点牛排怎么样?", "zh_hant": "來點牛排怎麼樣?"}, {"index": 9, "text": "This is a nice piece.", "start": 41.616, "end": 44.176, "zh": "这块不错。", "zh_hant": "這塊不錯。"}, {"index": 10, "text": "Give me that piece, please.", "start": 45.077, "end": 47.777, "zh": "请给我这块吧。", "zh_hant": "請給我這塊吧。"}, {"index": 11, "text": "And a pound of mince, too.", "start": 48.257, "end": 51.417, "zh": "再来一磅肉馅。", "zh_hant": "再來一磅肉餡。"}, {"index": 12, "text": "Do you want a chicken, Mrs. Bird?", "start": 52.958, "end": 56.758, "zh": "伯德太太,您要只鸡吗?", "zh_hant": "伯德太太,您要只雞嗎?"}, {"index": 13, "text": "They're very nice.", "start": 57.438, "end": 59.499, "zh": "这些鸡很不错。", "zh_hant": "這些雞很不錯。"}, {"index": 14, "text": "No, thank you.", "start": 59.859, "end": 61.339, "zh": "不用了,谢谢。", "zh_hant": "不用了,謝謝。"}, {"index": 15, "text": "My husband likes steak, but he doesn't like chicken.", "start": 62.219, "end": 67.38, "zh": "我丈夫喜欢牛排,但他不喜欢鸡肉。", "zh_hant": "我丈夫喜歡牛排,但他不喜歡雞肉。"}, {"index": 16, "text": "To tell you the truth, Mrs. Bird, I don't like chicken either!", "start": 68.58, "end": 75.941, "zh": "说实话,伯德夫人,我也不喜欢鸡肉!", "zh_hant": "說實話,伯德夫人,我也不喜歡雞肉!"}]