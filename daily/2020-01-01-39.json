[{"index": 0, "text": "Lesson 77 Terrible toothache Listen to the tape then answer this question.", "start": 0.53, "end": 11.192, "zh": "第77课 严重的牙痛 听录音,然后回答这个问题。", "zh_hant": "第77課 嚴重的牙痛 聽錄音,然後回答這個問題。"}, {"index": 1, "text": "What time of day is it, do you think?", "start": 12.112, "end": 16.453, "zh": "你觉得现在是一天中的什么时间?", "zh_hant": "你覺得現在是一天中的什麼時間?"}, {"index": 2, "text": "How do you know?", "start": 17.033, "end": 18.893, "zh": "你怎么知道的?", "zh_hant": "你怎麼知道的?"}, {"index": 3, "text": "Good morning, Mr. Croft.", "start": 21.214, "end": 24.314, "zh": "早上好，克罗夫特先生。", "zh_hant": "早上好，克羅夫特先生。"}, {"index": 4, "text": "Good morning, nurse.", "start": 24.974, "end": 26.855, "zh": "早上好，护士。", "zh_hant": "早上好，護士。"}, {"index": 5, "text": "I want to see the dentist, please.", "start": 27.615, "end": 31.035, "zh": "我想看牙医。", "zh_hant": "我想看牙醫。"}, {"index": 6, "text": "Do you have an appointment?", "start": 31.216, "end": 34.236, "zh": "您预约了吗？", "zh_hant": "您預約了嗎？"}, {"index": 7, "text": "No, I don't.", "start": 34.636, "end": 36.516, "zh": "不，我没有。", "zh_hant": "不，我沒有。"}, {"index": 8, "text": "Is it urgent?", "start": 36.596, "end": 38.377, "zh": "情况紧急吗？", "zh_hant": "情況緊急嗎？"}, {"index": 9, "text": "Yes, it is.", "start": 38.757, "end": 40.937, "zh": "是的，很紧急。", "zh_hant": "是的，很緊急。"}, {"index": 10, "text": "It's very urgent.", "start": 41.297, "end": 43.678, "zh": "非常紧急。", "zh_hant": "非常緊急。"}, {"index": 11, "text": "I feel awful.", "start": 44.598, "end": 46.418, "zh": "我感觉很难受。", "zh_hant": "我感覺很難受。"}, {"index": 12, "text": "I have a terrible toothache.", "start": 46.978, "end": 50.139, "zh": "我牙疼得厉害。", "zh_hant": "我牙疼得厲害。"}, {"index": 13, "text": "Can you come at 10 a.m. on Monday, April 24th?", "start": 50.819, "end": 56.84, "zh": "您能在4月24日星期一上午10点来吗？", "zh_hant": "您能在4月24日星期一上午10點來嗎？"}, {"index": 14, "text": "I must see the dentist now, nurse.", "start": 57.72, "end": 62.081, "zh": "护士，我现在就得看牙医。", "zh_hant": "護士，我現在就得看牙醫。"}, {"index": 15, "text": "The dentist is very busy at the moment.", "start": 62.801, "end": 67.042, "zh": "牙医现在很忙。", "zh_hant": "牙醫現在很忙。"}, {"index": 16, "text": "Can you come at 2 p.m. ?", "start": 67.262, "end": 71.663, "zh": "您能下午2点来吗？", "zh_hant": "您能下午2點來嗎？"}, {"index": 17, "text": "That's very late.", "start": 71.263, "end": 73.703, "zh": "那太晚了。", "zh_hant": "那太晚了。"}, {"index": 18, "text": "Can the dentist see me now?", "start": 74.243, "end": 77.064, "zh": "牙医现在能见我吗？", "zh_hant": "牙醫現在能見我嗎？"}, {"index": 19, "text": "I'm afraid that he can't, Mr. Croft.", "start": 77.584, "end": 81.804, "zh": "恐怕不行，克罗夫特先生。", "zh_hant": "恐怕不行，克羅夫特先生。"}, {"index": 20, "text": "Can't you wait till this afternoon?", "start": 82.044, "end": 85.485, "zh": "您不能等到今天下午吗？", "zh_hant": "您不能等到今天下午嗎？"}, {"index": 21, "text": "I can wait, but my toothache can't!", "start": 86.485, "end": 90.786, "zh": "我可以等，可我的牙疼等不了！", "zh_hant": "我可以等，可我的牙疼等不了！"}]