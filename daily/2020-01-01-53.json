[{"index": 0, "text": "Lesson 105 Full of mistakes Listen to the tape then answer this question.", "start": 0.49, "end": 12.371, "zh": "第105课 错误百出 听录音,然后回答这个问题。", "zh_hant": "第105課 錯誤百出 聽錄音,然後回答這個問題。"}, {"index": 1, "text": "What was Sandra's present?", "start": 13.411, "end": 16.071, "zh": "桑德拉的礼物是什么?", "zh_hant": "桑德拉的禮物是什麼?"}, {"index": 2, "text": "Where's Sandra, Bob?", "start": 18.311, "end": 20.392, "zh": "鲍勃,桑德拉在哪儿?", "zh_hant": "鮑勃,桑德拉在哪兒?"}, {"index": 3, "text": "I want her.", "start": 20.772, "end": 22.012, "zh": "我要见她。", "zh_hant": "我要見她。"}, {"index": 4, "text": "Do you want to speak to her?", "start": 23.332, "end": 26.032, "zh": "你想跟她说话吗?", "zh_hant": "你想跟她說話嗎?"}, {"index": 5, "text": "Yes, I do.", "start": 27.392, "end": 28.932, "zh": "是的,我想。", "zh_hant": "是的,我想。"}, {"index": 6, "text": "I want her to come to my office.", "start": 29.732, "end": 32.973, "zh": "我要她来我办公室。", "zh_hant": "我要她來我辦公室。"}, {"index": 7, "text": "Tell her to come at once.", "start": 33.333, "end": 36.253, "zh": "叫她马上过来。", "zh_hant": "叫她馬上過來。"}, {"index": 8, "text": "Did you want to see me?", "start": 37.133, "end": 39.973, "zh": "你要见我吗?", "zh_hant": "你要見我嗎?"}, {"index": 9, "text": "Ah, yes, Sandra.", "start": 40.673, "end": 42.973, "zh": "啊,是的,桑德拉。", "zh_hant": "啊,是的,桑德拉。"}, {"index": 10, "text": "How do you spell 'intelligent'?", "start": 43.694, "end": 47.034, "zh": "'intelligent'这个词怎么拼?", "zh_hant": "'intelligent'這個詞怎麼拼?"}, {"index": 11, "text": "Can you tell me?", "start": 47.174, "end": 48.954, "zh": "你能告诉我吗?", "zh_hant": "你能告訴我嗎?"}, {"index": 12, "text": "That's right.", "start": 60.815, "end": 62.195, "zh": "没错。", "zh_hant": "沒錯。"}, {"index": 13, "text": "You've typed it with only one 'L'.", "start": 62.755, "end": 66.235, "zh": "你打字的时候只打了一个'L'。", "zh_hant": "你打字的時候只打了一個'L'。"}, {"index": 14, "text": "This letter's full of mistakes.", "start": 66.755, "end": 70.216, "zh": "这封信满是错误。", "zh_hant": "這封信滿是錯誤。"}, {"index": 15, "text": "I want you to type it again.", "start": 70.776, "end": 73.936, "zh": "我要你重新打一遍。", "zh_hant": "我要你重新打一遍。"}, {"index": 16, "text": "Yes, I'll do that.", "start": 74.856, "end": 77.316, "zh": "好的,我会的。", "zh_hant": "好的,我會的。"}, {"index": 17, "text": "I'm sorry about that.", "start": 77.676, "end": 80.096, "zh": "对此我很抱歉。", "zh_hant": "對此我很抱歉。"}, {"index": 18, "text": "And here's a little present for you.", "start": 80.417, "end": 83.457, "zh": "这里有一份小礼物给你。", "zh_hant": "這裡有一份小禮物給你。"}, {"index": 19, "text": "What is it?", "start": 83.737, "end": 85.197, "zh": "这是什么?", "zh_hant": "這是什麼?"}, {"index": 20, "text": "It's a dictionary.", "start": 85.437, "end": 87.137, "zh": "是一本词典。", "zh_hant": "是一本詞典。"}, {"index": 21, "text": "I hope it'll help you.", "start": 87.817, "end": 89.757, "zh": "希望它能帮到你。", "zh_hant": "希望它能幫到你。"}]