[{"index": 0, "text": "Lesson 97", "start": 1.551, "end": 2.0, "zh": "第97课"}, {"index": 1, "text": "A small blue case", "start": 3.932, "end": 5.753, "zh": "一个蓝色小箱子"}, {"index": 2, "text": "Listen to the tape then answer this question.", "start": 7.675, "end": 11.297, "zh": "听录音,然后回答这个问题。"}, {"index": 3, "text": "Does Mr. Hall get his case back?", "start": 13.898, "end": 16.88, "zh": "霍尔先生找回他的箱子了吗?"}, {"index": 4, "text": "I left a suitcase on the train to London the other day.", "start": 19.602, "end": 22.643, "zh": "前几天我把一个手提箱落在开往伦敦的火车上了。"}, {"index": 5, "text": "Can you describe it, sir?", "start": 24.244, "end": 25.825, "zh": "先生,您能描述一下吗?"}, {"index": 6, "text": "It's a small blue case and it's got a zip.", "start": 27.166, "end": 30.855, "zh": "这是一个蓝色小箱子,上面有拉链。"}, {"index": 7, "text": "There's a label on the handle with my name and address on it.", "start": 31.956, "end": 36.239, "zh": "提手上有个标签,写着我的名字和地址。"}, {"index": 8, "text": "Is this case yours?", "start": 37.96, "end": 39.681, "zh": "这个箱子是您的吗?"}, {"index": 9, "text": "No, that's not mine.", "start": 40.902, "end": 42.523, "zh": "不,那不是我的。"}, {"index": 10, "text": "What about this one?", "start": 43.764, "end": 45.385, "zh": "那这个呢?"}, {"index": 11, "text": "This one's got a label.", "start": 46.346, "end": 47.967, "zh": "这个上面有标签。"}, {"index": 12, "text": "Let me see it.", "start": 49.348, "end": 50.329, "zh": "我看看。"}, {"index": 13, "text": "What's your name and address?", "start": 51.99, "end": 53.891, "zh": "您的姓名和地址是什么?"}, {"index": 14, "text": "David Hall, 83, Bridge Street.", "start": 55.393, "end": 60.694, "zh": "大卫·霍尔,桥街83号。"}, {"index": 15, "text": "That's right.", "start": 60.694, "end": 61.465, "zh": "没错。"}, {"index": 16, "text": "D. N. Hall, 83, Bridge Street.", "start": 62.345, "end": 67.688, "zh": "D·N·霍尔,桥街83号。"}, {"index": 17, "text": "Three pounds fifty pence, please.", "start": 69.069, "end": 71.411, "zh": "三英镑五十便士,谢谢。"}, {"index": 18, "text": "Here you are.", "start": 72.771, "end": 73.372, "zh": "给您。"}, {"index": 19, "text": "Thank you.", "start": 74.372, "end": 75.033, "zh": "谢谢。"}, {"index": 20, "text": "Hey!", "start": 76.534, "end": 76.874, "zh": "嘿!"}, {"index": 21, "text": "What's the matter?", "start": 77.514, "end": 78.415, "zh": "怎么了?"}, {"index": 22, "text": "This case doesn't belong to me!", "start": 79.715, "end": 81.476, "zh": "这个箱子不是我的!"}, {"index": 23, "text": "You've given me the wrong case!", "start": 82.057, "end": 84.258, "zh": "你把箱子拿错了!"}]