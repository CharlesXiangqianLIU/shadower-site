[{"index": 0, "text": "Lesson 99 Ow!", "start": 0.61, "end": 3.711, "zh": "第99课 哎呦！", "zh_hant": "第99課 哎呦！"}, {"index": 1, "text": "Listen to the tape then answer this question.", "start": 4.771, "end": 9.352, "zh": "听录音,然后回答这个问题。", "zh_hant": "聽錄音,然後回答這個問題。"}, {"index": 2, "text": "Must Andy go to see the doctor?", "start": 10.532, "end": 13.812, "zh": "安迪必须去看医生吗?", "zh_hant": "安迪必須去看醫生嗎?"}, {"index": 3, "text": "Ow!", "start": 15.553, "end": 16.573, "zh": "哎哟!", "zh_hant": "哎喲!"}, {"index": 4, "text": "What's the matter, Andy?", "start": 16.953, "end": 19.393, "zh": "怎么了,安迪?", "zh_hant": "怎麼了,安迪?"}, {"index": 5, "text": "I slipped and fell downstairs.", "start": 20.134, "end": 23.394, "zh": "我滑了一跤,摔下楼梯了。", "zh_hant": "我滑了一跤,摔下樓梯了。"}, {"index": 6, "text": "Have you hurt yourself?", "start": 23.574, "end": 26.054, "zh": "你伤到自己了吗?", "zh_hant": "你傷到自己了嗎?"}, {"index": 7, "text": "Yes, I have.", "start": 26.175, "end": 27.995, "zh": "是的,伤到了。", "zh_hant": "是的,傷到了。"}, {"index": 8, "text": "I think that I've hurt my back.", "start": 28.555, "end": 31.635, "zh": "我想我的背受伤了。", "zh_hant": "我想我的背受傷了。"}, {"index": 9, "text": "Try and stand up.", "start": 32.456, "end": 34.816, "zh": "试着站起来。", "zh_hant": "試著站起來。"}, {"index": 10, "text": "Can you stand up?", "start": 35.196, "end": 37.196, "zh": "你能站起来吗?", "zh_hant": "你能站起來嗎?"}, {"index": 11, "text": "Here.", "start": 37.417, "end": 38.297, "zh": "来。", "zh_hant": "來。"}, {"index": 12, "text": "Let me help you.", "start": 38.497, "end": 40.317, "zh": "让我帮你。", "zh_hant": "讓我幫你。"}, {"index": 13, "text": "I'm sorry, Lucy.", "start": 41.597, "end": 43.277, "zh": "对不起,露西。", "zh_hant": "對不起,露西。"}, {"index": 14, "text": "I'm afraid that I can't get up.", "start": 43.938, "end": 47.038, "zh": "恐怕我起不来了。", "zh_hant": "恐怕我起不來了。"}, {"index": 15, "text": "I think that the doctor had better see you.", "start": 48.198, "end": 52.379, "zh": "我想还是让医生来看看你比较好。", "zh_hant": "我想還是讓醫生來看看你比較好。"}, {"index": 16, "text": "I'll phone Dr. Carter.", "start": 53.099, "end": 55.74, "zh": "我打电话给卡特医生。", "zh_hant": "我打電話給卡特醫生。"}, {"index": 17, "text": "The doctor says that he will come at once.", "start": 56.94, "end": 61.401, "zh": "医生说他马上就来。", "zh_hant": "醫生說他馬上就來。"}, {"index": 18, "text": "I'm sure that you need an X-ray, Andy.", "start": 61.921, "end": 66.442, "zh": "我肯定你需要照X光,安迪。", "zh_hant": "我肯定你需要照X光,安迪。"}]