[{"index": 0, "text": "Lesson 115", "start": 1.581, "end": 2.715, "zh": "第115课"}, {"index": 1, "text": "Knock, knock!", "start": 4.603, "end": 5.323, "zh": "咚咚！"}, {"index": 2, "text": "Listen to the tape then answer this question.", "start": 7.004, "end": 10.426, "zh": "听录音，然后回答这个问题。"}, {"index": 3, "text": "What does Jim have to drink?", "start": 12.967, "end": 14.828, "zh": "吉姆有什么喝的？"}, {"index": 4, "text": "Isn't there anyone at home?", "start": 17.53, "end": 19.151, "zh": "家里没人吗？"}, {"index": 5, "text": "I'll knock again, Helen.", "start": 20.511, "end": 21.572, "zh": "我再敲一次门，海伦。"}, {"index": 6, "text": "Everything's very quiet.", "start": 22.392, "end": 23.573, "zh": "一切都很安静。"}, {"index": 7, "text": "I'm sure there's no one at home.", "start": 24.274, "end": 30.109, "zh": "我确定家里没人。"}, {"index": 8, "text": "But that's impossible.", "start": 30.109, "end": 30.669, "zh": "但那不可能。"}, {"index": 9, "text": "Carol and Tom invited us to lunch.", "start": 30.669, "end": 32.12, "zh": "卡罗尔和汤姆邀请我们来吃午饭。"}, {"index": 10, "text": "Look through the window.", "start": 32.12, "end": 33.15, "zh": "透过窗户看看。"}, {"index": 11, "text": "Can you see anything?", "start": 34.791, "end": 35.871, "zh": "你能看到什么吗？"}, {"index": 12, "text": "Nothing at all.", "start": 36.812, "end": 38.012, "zh": "什么也没有。"}, {"index": 13, "text": "Let's try the back door.", "start": 38.993, "end": 40.393, "zh": "我们试试后门吧。"}, {"index": 14, "text": "Look! Everyone's in the garden.", "start": 41.674, "end": 44.175, "zh": "看！大家都在花园里。"}, {"index": 15, "text": "Hello, Helen. Hello, Jim.", "start": 45.935, "end": 48.316, "zh": "你好，海伦。你好，吉姆。"}, {"index": 16, "text": "Everybody wants to have lunch in the garden.", "start": 49.417, "end": 60.067, "zh": "大家都想在花园里吃午饭。"}, {"index": 17, "text": "It's nice and warm out here.", "start": 60.067, "end": 60.748, "zh": "这里又暖和又舒服。"}, {"index": 18, "text": "Come and have something to drink.", "start": 60.748, "end": 61.308, "zh": "过来喝点什么吧。"}, {"index": 19, "text": "Thanks, Carol.", "start": 61.308, "end": 61.548, "zh": "谢谢，卡罗尔。"}, {"index": 20, "text": "May I have a glass of beer please?", "start": 61.548, "end": 62.329, "zh": "可以给我来杯啤酒吗？"}, {"index": 21, "text": "Beer?", "start": 62.329, "end": 62.439, "zh": "啤酒？"}, {"index": 22, "text": "There's none left.", "start": 62.439, "end": 62.789, "zh": "一点都不剩了。"}, {"index": 23, "text": "You can have some lemonade.", "start": 62.789, "end": 64.27, "zh": "你可以喝点柠檬水。"}, {"index": 24, "text": "Lemonade!", "start": 64.871, "end": 65.791, "zh": "柠檬水！"}, {"index": 25, "text": "Don't believe her, Jim.", "start": 66.732, "end": 68.093, "zh": "别相信她，吉姆。"}, {"index": 26, "text": "She's only joking.", "start": 68.353, "end": 69.514, "zh": "她只是在开玩笑。"}, {"index": 27, "text": "Have some beer!", "start": 69.914, "end": 71.055, "zh": "喝点啤酒吧！"}]