[{"index": 0, "text": "Lesson 115", "start": 1.581, "end": 2.715}, {"index": 1, "text": "Knock, knock!", "start": 4.603, "end": 5.323}, {"index": 2, "text": "Listen to the tape then answer this question.", "start": 7.004, "end": 10.426}, {"index": 3, "text": "What does Jim have to drink?", "start": 12.967, "end": 14.828}, {"index": 4, "text": "Isn't there anyone at home?", "start": 17.53, "end": 19.151}, {"index": 5, "text": "I'll knock again, Helen.", "start": 20.511, "end": 21.572}, {"index": 6, "text": "Everything's very quiet.", "start": 22.392, "end": 23.573}, {"index": 7, "text": "I'm sure there's no one at home.", "start": 24.274, "end": 30.169}, {"index": 8, "text": "But that's impossible.", "start": 30.049, "end": 30.729}, {"index": 9, "text": "Carol and Tom invited us to lunch.", "start": 30.609, "end": 32.17}, {"index": 10, "text": "Look through the window.", "start": 32.07, "end": 33.15}, {"index": 11, "text": "Can you see anything?", "start": 34.791, "end": 35.871}, {"index": 12, "text": "Nothing at all.", "start": 36.812, "end": 38.012}, {"index": 13, "text": "Let's try the back door.", "start": 38.993, "end": 40.393}, {"index": 14, "text": "Look! Everyone's in the garden.", "start": 41.674, "end": 44.175}, {"index": 15, "text": "Hello, Helen. Hello, Jim.", "start": 45.935, "end": 48.316}, {"index": 16, "text": "Everybody wants to have lunch in the garden.", "start": 49.417, "end": 60.127}, {"index": 17, "text": "It's nice and warm out here.", "start": 60.007, "end": 60.808}, {"index": 18, "text": "Come and have something to drink.", "start": 60.688, "end": 61.368}, {"index": 19, "text": "Thanks, Carol.", "start": 61.248, "end": 61.608}, {"index": 20, "text": "May I have a glass of beer please?", "start": 61.488, "end": 62.389}, {"index": 21, "text": "Beer?", "start": 62.269, "end": 62.489}, {"index": 22, "text": "There's none left.", "start": 62.389, "end": 62.849}, {"index": 23, "text": "You can have some lemonade.", "start": 62.729, "end": 64.27}, {"index": 24, "text": "Lemonade!", "start": 64.871, "end": 65.791}, {"index": 25, "text": "Don't believe her, Jim.", "start": 66.732, "end": 68.093}, {"index": 26, "text": "She's only joking.", "start": 68.353, "end": 69.514}, {"index": 27, "text": "Have some beer!", "start": 69.914, "end": 71.055}]