[{"index": 0, "text": "Lesson 17 How do you do?", "start": 0.59, "end": 4.431, "zh": "第17课 你好吗?", "zh_hant": "第17課 你好嗎?"}, {"index": 1, "text": "Listen to the tape then answer this question.", "start": 6.371, "end": 11.072, "zh": "听录音,然后回答这个问题。", "zh_hant": "聽錄音,然後回答這個問題。"}, {"index": 2, "text": "What are Michael Baker and Jeremy Short's jobs?", "start": 12.592, "end": 17.833, "zh": "迈克尔·贝克和杰里米·肖特是做什么工作的?", "zh_hant": "邁克爾·貝克和傑里米·肖特是做什麼工作的?"}, {"index": 3, "text": "Come and meet our employees Mr.Richards.", "start": 19.493, "end": 24.094, "zh": "理查兹先生,来见见我们的员工。", "zh_hant": "理查茲先生,來見見我們的員工。"}, {"index": 4, "text": "Thank you Mr. Jackson.", "start": 25.094, "end": 27.514, "zh": "谢谢你,杰克逊先生。", "zh_hant": "謝謝你,傑克遜先生。"}, {"index": 5, "text": "This is Nicola Grey and this is Claire Taylor.", "start": 28.415, "end": 34.256, "zh": "这是妮古拉·格雷,这是克莱尔·泰勒。", "zh_hant": "這是妮古拉·格雷,這是克萊爾·泰勒。"}, {"index": 6, "text": "How do you do?", "start": 35.236, "end": 36.716, "zh": "你好", "zh_hant": "你好"}, {"index": 7, "text": "Those women are very hard-working.", "start": 38.396, "end": 41.917, "zh": "那些女士都非常勤奋。", "zh_hant": "那些女士都非常勤奮。"}, {"index": 8, "text": "What are their jobs?", "start": 43.157, "end": 45.117, "zh": "她们是做什么工作的?", "zh_hant": "她們是做什麼工作的?"}, {"index": 9, "text": "They're keyboard operators.", "start": 46.598, "end": 49.518, "zh": "她们是键盘操作员。", "zh_hant": "她們是鍵盤操作員。"}, {"index": 10, "text": "This is Michael Baker and this is Jeremy Short.", "start": 50.858, "end": 56.759, "zh": "这是迈克尔·贝克,这是杰里米·肖特。", "zh_hant": "這是邁克爾·貝克,這是傑里米·肖特。"}, {"index": 11, "text": "How do you do?", "start": 57.359, "end": 59.02, "zh": "你好。", "zh_hant": "你好。"}, {"index": 12, "text": "They aren't very busy!", "start": 60.58, "end": 62.98, "zh": "他们不太忙啊!", "zh_hant": "他們不太忙啊!"}, {"index": 13, "text": "What are their jobs?", "start": 63.8, "end": 66.261, "zh": "他们是做什么工作的?", "zh_hant": "他們是做什麼工作的?"}, {"index": 14, "text": "They're sales reps.", "start": 67.921, "end": 69.821, "zh": "他们是销售代表。", "zh_hant": "他們是銷售代表。"}, {"index": 15, "text": "They're very lazy.", "start": 70.161, "end": 72.302, "zh": "他们很懒。", "zh_hant": "他們很懶。"}, {"index": 16, "text": "Who is this young man?", "start": 73.182, "end": 75.842, "zh": "这位年轻人是谁?", "zh_hant": "這位年輕人是誰?"}, {"index": 17, "text": "This is Jim.", "start": 77.043, "end": 78.863, "zh": "这是吉姆。", "zh_hant": "這是吉姆。"}, {"index": 18, "text": "He's our office assistant.", "start": 79.343, "end": 82.123, "zh": "他是我们的办公室助理。", "zh_hant": "他是我們的辦公室助理。"}]