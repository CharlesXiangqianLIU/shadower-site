[{"index": 0, "text": "Lesson 41 Penny's bag Listen to the tape then answer this question.", "start": 0.49, "end": 10.492, "zh": "第41课 佩妮的包 听录音,然后回答这个问题。", "zh_hant": "第41課 佩妮的包 聽錄音,然後回答這個問題。"}, {"index": 1, "text": "Who is the tin of tobacco for?", "start": 11.733, "end": 15.393, "zh": "这罐烟草是给谁的?", "zh_hant": "這罐菸草是給誰的?"}, {"index": 2, "text": "Is that bag heavy, Penny?", "start": 17.854, "end": 20.655, "zh": "佩妮,那个包重吗?", "zh_hant": "佩妮,那個包重嗎?"}, {"index": 3, "text": "Not very.", "start": 20.815, "end": 22.295, "zh": "不太重。", "zh_hant": "不太重。"}, {"index": 4, "text": "Here!", "start": 22.975, "end": 23.815, "zh": "给!", "zh_hant": "給!"}, {"index": 5, "text": "Put it on this chair.", "start": 24.236, "end": 26.556, "zh": "把它放在这把椅子上。", "zh_hant": "把它放在這把椅子上。"}, {"index": 6, "text": "What's in it?", "start": 27.096, "end": 28.716, "zh": "里面是什么?", "zh_hant": "裡面是什麼?"}, {"index": 7, "text": "A piece of cheese.", "start": 29.237, "end": 31.397, "zh": "一块奶酪。", "zh_hant": "一塊乳酪。"}, {"index": 8, "text": "A loaf of bread.", "start": 32.057, "end": 33.978, "zh": "一条面包。", "zh_hant": "一條麵包。"}, {"index": 9, "text": "A bar of soap.", "start": 34.718, "end": 36.618, "zh": "一块肥皂。", "zh_hant": "一塊肥皂。"}, {"index": 10, "text": "A bar of chocolate.", "start": 37.479, "end": 39.619, "zh": "一块巧克力。", "zh_hant": "一塊巧克力。"}, {"index": 11, "text": "A bottle of milk.", "start": 40.159, "end": 41.999, "zh": "一瓶牛奶。", "zh_hant": "一瓶牛奶。"}, {"index": 12, "text": "A pound of sugar.", "start": 42.72, "end": 44.7, "zh": "一磅糖。", "zh_hant": "一磅糖。"}, {"index": 13, "text": "Half a pound of coffee.", "start": 45.66, "end": 48.161, "zh": "半磅咖啡。", "zh_hant": "半磅咖啡。"}, {"index": 14, "text": "A quarter of a pound of tea.", "start": 49.121, "end": 52.042, "zh": "四分之一磅茶叶。", "zh_hant": "四分之一磅茶葉。"}, {"index": 15, "text": "And a tin of tobacco.", "start": 53.102, "end": 55.843, "zh": "还有一罐烟草。", "zh_hant": "還有一罐菸草。"}, {"index": 16, "text": "Is that tin of tobacco for me?", "start": 57.543, "end": 60.904, "zh": "那罐烟草是给我的吗?", "zh_hant": "那罐菸草是給我的嗎?"}, {"index": 17, "text": "Well, it's certainly not for me!", "start": 61.984, "end": 65.325, "zh": "嗯,反正不是给我的!", "zh_hant": "嗯,反正不是給我的!"}]