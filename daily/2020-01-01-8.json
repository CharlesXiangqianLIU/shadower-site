[{"index": 0, "text": "Lesson 15 Your passports please.", "start": 0.53, "end": 5.351, "zh": "第15课 请出示护照", "zh_hant": "第15課 請出示護照"}, {"index": 1, "text": "Listen to the tape then answer this question.", "start": 6.352, "end": 11.053, "zh": "听录音,然后回答这个问题。", "zh_hant": "聽錄音,然後回答這個問題。"}, {"index": 2, "text": "Is there a problem with the Customs officer?", "start": 12.253, "end": 16.194, "zh": "海关官员遇到什么问题了吗?", "zh_hant": "海關官員遇到什麼問題了嗎?"}, {"index": 3, "text": "Are you Swedish?", "start": 18.795, "end": 20.655, "zh": "你们是瑞典人吗?", "zh_hant": "你們是瑞典人嗎?"}, {"index": 4, "text": "No we are not.", "start": 21.356, "end": 23.776, "zh": "不,我们不是。", "zh_hant": "不,我們不是。"}, {"index": 5, "text": "We are Danish.", "start": 23.916, "end": 25.677, "zh": "我们是丹麦人。", "zh_hant": "我們是丹麥人。"}, {"index": 6, "text": "Are your friends Danish too?", "start": 26.597, "end": 29.458, "zh": "你们的朋友也是丹麦人吗?", "zh_hant": "你們的朋友也是丹麥人嗎?"}, {"index": 7, "text": "No they aren't.", "start": 30.218, "end": 32.718, "zh": "不,他们不是。", "zh_hant": "不,他們不是。"}, {"index": 8, "text": "They are Norwegian.", "start": 33.739, "end": 35.999, "zh": "他们是挪威人。", "zh_hant": "他們是挪威人。"}, {"index": 9, "text": "Your passports please.", "start": 37.44, "end": 39.84, "zh": "请出示你们的护照。", "zh_hant": "請出示你們的護照。"}, {"index": 10, "text": "Here they are.", "start": 40.521, "end": 42.141, "zh": "给您。", "zh_hant": "給您。"}, {"index": 11, "text": "these your cases?", "start": 43.101, "end": 45.322, "zh": "这些是你们的箱子吗?", "zh_hant": "這些是你們的箱子嗎?"}, {"index": 12, "text": "No they aren't.", "start": 46.042, "end": 47.882, "zh": "不,不是。", "zh_hant": "不,不是。"}, {"index": 13, "text": "Our cases are brown.", "start": 48.903, "end": 51.483, "zh": "我们的箱子是棕色的。", "zh_hant": "我們的箱子是棕色的。"}, {"index": 14, "text": "Here they are.", "start": 52.944, "end": 54.504, "zh": "给您。", "zh_hant": "給您。"}, {"index": 15, "text": "you tourists?", "start": 56.065, "end": 57.985, "zh": "你们是游客吗?", "zh_hant": "你們是遊客嗎?"}, {"index": 16, "text": "Yes we are.", "start": 58.865, "end": 61.006, "zh": "是的,我们是。", "zh_hant": "是的,我們是。"}, {"index": 17, "text": "your friends tourists too?", "start": 61.846, "end": 64.847, "zh": "你们的朋友也是游客吗?", "zh_hant": "你們的朋友也是遊客嗎?"}, {"index": 18, "text": "Yes they are.", "start": 65.407, "end": 67.367, "zh": "是的,他们是。", "zh_hant": "是的,他們是。"}, {"index": 19, "text": "That's fine.", "start": 68.648, "end": 70.048, "zh": "好的,没问题。", "zh_hant": "好的,沒問題。"}, {"index": 20, "text": "Thank you very much.", "start": 70.648, "end": 72.809, "zh": "非常感谢。", "zh_hant": "非常感謝。"}]