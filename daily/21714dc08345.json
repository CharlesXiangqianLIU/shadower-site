[{"index": 0, "text": "Lesson 63", "start": 1.621, "end": 2.415}, {"index": 1, "text": "Thank you, doctor.", "start": 3.962, "end": 5.022}, {"index": 2, "text": "Listen to the tape then answer this question.", "start": 6.803, "end": 10.125}, {"index": 3, "text": "Who else is in bed today? Why?", "start": 12.606, "end": 16.148}, {"index": 4, "text": "How's Jimmy today?", "start": 18.889, "end": 20.31}, {"index": 5, "text": "Better.", "start": 21.23, "end": 21.65}, {"index": 6, "text": "Thank you, doctor.", "start": 21.65, "end": 22.631}, {"index": 7, "text": "Can I see him please, Mrs. Williams?", "start": 23.711, "end": 26.313}, {"index": 8, "text": "Certainly, doctor.", "start": 26.613, "end": 28.974}, {"index": 9, "text": "Come upstairs.", "start": 30.83, "end": 31.15}, {"index": 10, "text": "You look very well, Jimmy.", "start": 31.15, "end": 33.011}, {"index": 11, "text": "You are better now, but you mustn't get up yet.", "start": 33.931, "end": 37.973}, {"index": 12, "text": "You must stay in bed for another two days.", "start": 38.893, "end": 42.275}, {"index": 13, "text": "The boy mustn't go to school yet, Mrs. Williams.", "start": 44.156, "end": 46.997}, {"index": 14, "text": "And he mustn't eat rich food.", "start": 47.697, "end": 49.978}, {"index": 15, "text": "Does he have a temperature, doctor?", "start": 51.119, "end": 61.207}, {"index": 16, "text": "No, he doesn't.", "start": 61.207, "end": 61.648}, {"index": 17, "text": "Must he stay in bed?", "start": 61.648, "end": 62.368}, {"index": 18, "text": "Yes. He must remain in bed for another two days.", "start": 62.368, "end": 63.309}, {"index": 19, "text": "He can get up for about two hours each day, but you must keep the room warm.", "start": 63.309, "end": 69.274}, {"index": 20, "text": "Where's Mr. Williams this evening?", "start": 71.156, "end": 73.297}, {"index": 21, "text": "He's in bed, doctor.", "start": 74.258, "end": 75.719}, {"index": 22, "text": "Can you see him please?", "start": 76.74, "end": 92.988}, {"index": 23, "text": "He has a bad cold, too!", "start": 93.12, "end": 96.04}]