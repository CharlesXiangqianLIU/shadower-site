[{"index": 0, "text": "Lesson 63", "start": 1.621, "end": 2.415, "zh": "第63课"}, {"index": 1, "text": "Thank you, doctor.", "start": 3.962, "end": 5.022, "zh": "谢谢您，医生。"}, {"index": 2, "text": "Listen to the tape then answer this question.", "start": 6.803, "end": 10.125, "zh": "听录音，然后回答这个问题。"}, {"index": 3, "text": "Who else is in bed today? Why?", "start": 12.606, "end": 16.148, "zh": "今天还有谁卧病在床？为什么？"}, {"index": 4, "text": "How's Jimmy today?", "start": 18.889, "end": 20.31, "zh": "吉米今天怎么样？"}, {"index": 5, "text": "Better.", "start": 21.23, "end": 21.65, "zh": "好些了。"}, {"index": 6, "text": "Thank you, doctor.", "start": 21.65, "end": 22.631, "zh": "谢谢您，医生。"}, {"index": 7, "text": "Can I see him please, Mrs. Williams?", "start": 23.711, "end": 26.313, "zh": "威廉姆斯太太，我能看看他吗？"}, {"index": 8, "text": "Certainly, doctor.", "start": 26.613, "end": 28.974, "zh": "当然可以，医生。"}, {"index": 9, "text": "Come upstairs.", "start": 30.83, "end": 31.15, "zh": "上楼来吧。"}, {"index": 10, "text": "You look very well, Jimmy.", "start": 31.15, "end": 33.011, "zh": "你看起来气色不错，吉米。"}, {"index": 11, "text": "You are better now, but you mustn't get up yet.", "start": 33.931, "end": 37.973, "zh": "你现在好些了，但还不能起床。"}, {"index": 12, "text": "You must stay in bed for another two days.", "start": 38.893, "end": 42.275, "zh": "你还得再卧床两天。"}, {"index": 13, "text": "The boy mustn't go to school yet, Mrs. Williams.", "start": 44.156, "end": 46.997, "zh": "威廉姆斯太太，这孩子暂时还不能上学。"}, {"index": 14, "text": "And he mustn't eat rich food.", "start": 47.697, "end": 49.978, "zh": "而且他不能吃油腻的食物。"}, {"index": 15, "text": "Does he have a temperature, doctor?", "start": 51.119, "end": 61.207, "zh": "他发烧吗，医生？"}, {"index": 16, "text": "No, he doesn't.", "start": 61.207, "end": 61.648, "zh": "不，他没有发烧。"}, {"index": 17, "text": "Must he stay in bed?", "start": 61.648, "end": 62.368, "zh": "他必须卧床吗？"}, {"index": 18, "text": "Yes. He must remain in bed for another two days.", "start": 62.368, "end": 63.309, "zh": "是的，他还得再卧床两天。"}, {"index": 19, "text": "He can get up for about two hours each day, but you must keep the room warm.", "start": 63.309, "end": 69.274, "zh": "他每天可以起来大约两个小时，但你必须让房间保持温暖。"}, {"index": 20, "text": "Where's Mr. Williams this evening?", "start": 71.156, "end": 73.297, "zh": "威廉姆斯先生今晚在哪里？"}, {"index": 21, "text": "He's in bed, doctor.", "start": 74.258, "end": 75.719, "zh": "他在床上呢，医生。"}, {"index": 22, "text": "Can you see him please?", "start": 76.74, "end": 92.988, "zh": "您能看看他吗？"}, {"index": 23, "text": "He has a bad cold, too!", "start": 93.12, "end": 96.04, "zh": "他也得了重感冒！"}]