[{"index": 0, "text": "Lesson 109", "start": 1.591, "end": 2.27, "zh": "第109课"}, {"index": 1, "text": "A good idea", "start": 4.732, "end": 6.253, "zh": "一个好主意"}, {"index": 2, "text": "Listen to the tape then answer this question.", "start": 7.774, "end": 10.876, "zh": "听录音,然后回答这个问题。"}, {"index": 3, "text": "What does Jane have with her coffee?", "start": 13.377, "end": 15.758, "zh": "简女的咖啡里加了什么?"}, {"index": 4, "text": "Shall I make some coffee, Jane?", "start": 18.46, "end": 20.18, "zh": "简,我煮点咖啡好吗?"}, {"index": 5, "text": "That's a good idea, Charlotte.", "start": 21.141, "end": 22.702, "zh": "夏洛特,好主意。"}, {"index": 6, "text": "It's ready.", "start": 24.042, "end": 24.623, "zh": "咖啡好了。"}, {"index": 7, "text": "Do you want any milk?", "start": 25.063, "end": 26.103, "zh": "要加牛奶吗?"}, {"index": 8, "text": "Just a little, please.", "start": 30.42, "end": 30.84, "zh": "请加一点点。"}, {"index": 9, "text": "What about some sugar?", "start": 30.84, "end": 31.76, "zh": "加糖怎么样?"}, {"index": 10, "text": "Two teaspoonfuls?", "start": 31.76, "end": 32.92, "zh": "两茶匙?"}, {"index": 11, "text": "No, less than that.", "start": 34.041, "end": 35.841, "zh": "不,少一点。"}, {"index": 12, "text": "One and a half teaspoonfuls, please.", "start": 36.521, "end": 38.961, "zh": "请加一茶匙半。"}, {"index": 13, "text": "That's enough for me.", "start": 39.161, "end": 40.142, "zh": "这对我来说够了。"}, {"index": 14, "text": "That was very nice.", "start": 42.042, "end": 43.762, "zh": "刚才真好喝。"}, {"index": 15, "text": "Would you like some more?", "start": 45.022, "end": 46.203, "zh": "还要再来点吗?"}, {"index": 16, "text": "Yes, please.", "start": 47.103, "end": 54.864, "zh": "好,麻烦你。"}, {"index": 17, "text": "I'd like a cigarette, too.", "start": 61.26, "end": 62.801, "zh": "我还想抽支烟。"}, {"index": 18, "text": "May I have one?", "start": 62.801, "end": 63.121, "zh": "可以给我一支吗?"}, {"index": 19, "text": "Of course.", "start": 63.121, "end": 63.461, "zh": "当然可以。"}, {"index": 20, "text": "I think there are a few in that box.", "start": 63.461, "end": 65.222, "zh": "我想那个盒子里还有几支。"}, {"index": 21, "text": "I'm afraid it's empty.", "start": 65.222, "end": 67.083, "zh": "恐怕是空的。"}, {"index": 22, "text": "What a pity!", "start": 67.143, "end": 67.744, "zh": "真可惜!"}, {"index": 23, "text": "It doesn't matter.", "start": 67.744, "end": 68.744, "zh": "没关系。"}, {"index": 24, "text": "Have a biscuit instead.", "start": 71.205, "end": 71.686, "zh": "吃块饼干代替吧。"}, {"index": 25, "text": "Eat more and smoke less!", "start": 71.686, "end": 72.146, "zh": "多吃点,少抽点烟!"}, {"index": 26, "text": "That's very good advice!", "start": 72.146, "end": 92.87, "zh": "这个建议真好!"}]