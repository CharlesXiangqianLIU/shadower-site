[{"index": 0, "text": "Lesson 7", "start": 1.551, "end": 1.855}, {"index": 1, "text": "Are you a teacher?", "start": 3.653, "end": 4.974}, {"index": 2, "text": "Listen to the tape then answer this question.", "start": 6.415, "end": 9.797}, {"index": 3, "text": "What is Rober's job?", "start": 12.339, "end": 14.621}, {"index": 4, "text": "I am a new student.", "start": 17.583, "end": 19.165}, {"index": 5, "text": "My name's Robert.", "start": 19.925, "end": 21.726}, {"index": 6, "text": "Nice to meet you.", "start": 23.348, "end": 25.109}, {"index": 7, "text": "My name's Sophie.", "start": 26.19, "end": 28.251}, {"index": 8, "text": "Are you French?", "start": 29.773, "end": 30.073}, {"index": 9, "text": "Yes I am.", "start": 30.073, "end": 30.253}, {"index": 10, "text": "Are you French too?", "start": 35.564, "end": 37.385}, {"index": 11, "text": "No I am not.", "start": 38.586, "end": 40.968}, {"index": 12, "text": "What nationality are you?", "start": 42.168, "end": 44.89}, {"index": 13, "text": "I'm Italian.", "start": 46.471, "end": 48.132}, {"index": 14, "text": "Are you a teacher?", "start": 50.634, "end": 52.235}, {"index": 15, "text": "No I'm not.", "start": 52.235, "end": 53.636}, {"index": 16, "text": "What's your job?", "start": 53.636, "end": 54.237}, {"index": 17, "text": "I'm a keyboard operator.", "start": 54.237, "end": 56.638}, {"index": 18, "text": "What's your job?", "start": 56.638, "end": 58.099}, {"index": 19, "text": "I'm an engineer.", "start": 58.24, "end": 59.04}]