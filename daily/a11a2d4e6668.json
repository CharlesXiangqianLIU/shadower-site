[{"index": 0, "text": "Lesson 7", "start": 1.551, "end": 1.855, "zh": "第7课", "zh_hant": "第7課"}, {"index": 1, "text": "Are you a teacher?", "start": 3.653, "end": 4.974, "zh": "你是老师吗?", "zh_hant": "你是老師嗎?"}, {"index": 2, "text": "Listen to the tape then answer this question.", "start": 6.415, "end": 9.797, "zh": "听录音,然后回答这个问题。", "zh_hant": "聽錄音,然後回答這個問題。"}, {"index": 3, "text": "What is Rober's job?", "start": 12.339, "end": 14.621, "zh": "罗伯特是做什么工作的?", "zh_hant": "羅伯特是做什麼工作的?"}, {"index": 4, "text": "I am a new student.", "start": 17.583, "end": 19.165, "zh": "我是新来的学生。", "zh_hant": "我是新來的學生。"}, {"index": 5, "text": "My name's Robert.", "start": 19.925, "end": 21.726, "zh": "我叫罗伯特。", "zh_hant": "我叫羅伯特。"}, {"index": 6, "text": "Nice to meet you.", "start": 23.348, "end": 25.109, "zh": "很高兴认识你。", "zh_hant": "很高興認識你。"}, {"index": 7, "text": "My name's Sophie.", "start": 26.19, "end": 28.251, "zh": "我叫索菲。", "zh_hant": "我叫索菲。"}, {"index": 8, "text": "Are you French?", "start": 29.773, "end": 30.073, "zh": "你是法国人吗?", "zh_hant": "你是法國人嗎?"}, {"index": 9, "text": "Yes I am.", "start": 30.073, "end": 30.253, "zh": "是的,我是。", "zh_hant": "是的,我是。"}, {"index": 10, "text": "Are you French too?", "start": 35.564, "end": 37.385, "zh": "你也是法国人吗?", "zh_hant": "你也是法國人嗎?"}, {"index": 11, "text": "No I am not.", "start": 38.586, "end": 40.968, "zh": "不,我不是。", "zh_hant": "不,我不是。"}, {"index": 12, "text": "What nationality are you?", "start": 42.168, "end": 44.89, "zh": "你是哪国人?", "zh_hant": "你是哪國人?"}, {"index": 13, "text": "I'm Italian.", "start": 46.471, "end": 48.132, "zh": "我是意大利人。", "zh_hant": "我是義大利人。"}, {"index": 14, "text": "Are you a teacher?", "start": 50.634, "end": 52.235, "zh": "你是老师吗?", "zh_hant": "你是老師嗎?"}, {"index": 15, "text": "No I'm not.", "start": 52.235, "end": 53.636, "zh": "不,我不是。", "zh_hant": "不,我不是。"}, {"index": 16, "text": "What's your job?", "start": 53.636, "end": 54.237, "zh": "你是做什么工作的?", "zh_hant": "你是做什麼工作的?"}, {"index": 17, "text": "I'm a keyboard operator.", "start": 54.237, "end": 56.638, "zh": "我是一名键盘操作员。", "zh_hant": "我是一名鍵盤操作員。"}, {"index": 18, "text": "What's your job?", "start": 56.638, "end": 58.099, "zh": "你是做什么工作的?", "zh_hant": "你是做什麼工作的?"}, {"index": 19, "text": "I'm an engineer.", "start": 58.24, "end": 59.04, "zh": "我是一名工程师。", "zh_hant": "我是一名工程師。"}]