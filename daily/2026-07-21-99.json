[{"index": 0, "text": "My mom is the most amazing person, but she embarrasses me in front of a lot of people.", "start": 0.06, "end": 5.293, "zh": "我妈妈是最了不起的人,但她总是在很多人面前让我丢脸。", "zh_hant": "我媽媽是最了不起的人,但她總是在很多人面前讓我丟臉。"}, {"index": 1, "text": "Really?", "start": 5.293, "end": 5.923, "zh": "真的吗?", "zh_hant": "真的嗎?"}, {"index": 2, "text": "But yes, Jonathan Taylor Thomas.", "start": 6.163, "end": 8.144, "zh": "但是没错,乔纳森·泰勒·托马斯。", "zh_hant": "但是沒錯,喬納森·泰勒·托馬斯。"}, {"index": 3, "text": "Yeah.", "start": 9.165, "end": 9.605, "zh": "是啊。", "zh_hant": "是啊。"}, {"index": 4, "text": "JTT.", "start": 9.605, "end": 10.325, "zh": "JTT。", "zh_hant": "JTT。"}, {"index": 5, "text": "Total babe.", "start": 10.325, "end": 11.366, "zh": "超级帅哥。", "zh_hant": "超級帥哥。"}, {"index": 6, "text": "Saw him in the airport, and I was like, oh my God, Mom.", "start": 12.366, "end": 16.128, "zh": "我在机场看到他,当时就想,天哪,妈妈。", "zh_hant": "我在機場看到他,當時就想,天哪,媽媽。"}, {"index": 7, "text": "I think I was eight.", "start": 16.468, "end": 17.769, "zh": "我记得我八岁。", "zh_hant": "我記得我八歲。"}, {"index": 8, "text": "Right.", "start": 17.829, "end": 18.229, "zh": "对。", "zh_hant": "對。"}, {"index": 9, "text": "Oh my God, Mom, it's him.", "start": 18.229, "end": 19.35, "zh": "天哪,妈妈,是他。", "zh_hant": "天哪,媽媽,是他。"}, {"index": 10, "text": "It's really him.", "start": 19.35, "end": 20.25, "zh": "真的是他。", "zh_hant": "真的是他。"}, {"index": 11, "text": "And I was like, we're going to be married.", "start": 20.25, "end": 21.961, "zh": "我当时就想,我们以后要结婚了。", "zh_hant": "我當時就想,我們以後要結婚了。"}, {"index": 12, "text": "We're going to be together forever.", "start": 21.961, "end": 23.342, "zh": "我们要永远在一起。", "zh_hant": "我們要永遠在一起。"}, {"index": 13, "text": "He was like, I was like, we're the same.", "start": 23.342, "end": 25.473, "zh": "他好像,我当时觉得,我们是一样的。", "zh_hant": "他好像,我當時覺得,我們是一樣的。"}, {"index": 14, "text": "We love each other.", "start": 25.473, "end": 26.934, "zh": "我们彼此相爱。", "zh_hant": "我們彼此相愛。"}, {"index": 15, "text": "Yeah.", "start": 26.934, "end": 27.244, "zh": "是啊。", "zh_hant": "是啊。"}, {"index": 16, "text": "She was like, Jonathan.", "start": 27.244, "end": 29.295, "zh": "她就喊,乔纳森。", "zh_hant": "她就喊,喬納森。"}, {"index": 17, "text": "Jonathan!", "start": 29.795, "end": 30.205, "zh": "乔纳森!", "zh_hant": "喬納森!"}, {"index": 18, "text": "I'm Melanie Griffith.", "start": 30.765, "end": 32.116, "zh": "我是梅兰妮·格里菲斯。", "zh_hant": "我是梅蘭妮·格里菲斯。"}, {"index": 19, "text": "And I was, like, across the airport in, um, behind a plant.", "start": 32.116, "end": 36.859, "zh": "而我当时就躲在机场那头,呃,一株植物后面。", "zh_hant": "而我當時就躲在機場那頭,呃,一株植物後面。"}, {"index": 20, "text": "Like this.", "start": 36.859, "end": 37.519, "zh": "就这样。", "zh_hant": "就這樣。"}, {"index": 21, "text": "But did you meet him?", "start": 37.739, "end": 39.34, "zh": "但你后来见到他了吗?", "zh_hant": "但你後來見到他了嗎?"}, {"index": 22, "text": "Trying to be invisible.", "start": 39.34, "end": 40.315, "zh": "想尽量让自己隐形。", "zh_hant": "想盡量讓自己隱形。"}]