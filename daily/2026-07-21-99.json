[{"index": 0, "text": "My mom is the most amazing person, but she embarrasses me in front of a lot of people.", "start": 0.11, "end": 5.471, "zh": "我妈妈是最了不起的人,但她经常在很多人面前让我尴尬。", "zh_hant": "我媽媽是最了不起的人,但她經常在很多人面前讓我尷尬。"}, {"index": 1, "text": "Really?", "start": 5.311, "end": 6.091, "zh": "真的吗?", "zh_hant": "真的嗎?"}, {"index": 2, "text": "But yes, Jonathan Taylor Thomas.", "start": 6.211, "end": 8.292, "zh": "不过是真的,乔纳森·泰勒·托马斯。", "zh_hant": "不過是真的,喬納森·泰勒·托馬斯。"}, {"index": 3, "text": "Yeah.", "start": 9.212, "end": 9.892, "zh": "对啊。", "zh_hant": "對啊。"}, {"index": 4, "text": "JTT.", "start": 9.492, "end": 10.472, "zh": "JTT。", "zh_hant": "JTT。"}, {"index": 5, "text": "Total babe.", "start": 11.212, "end": 12.292, "zh": "超级帅哥。", "zh_hant": "超級帥哥。"}, {"index": 6, "text": "Saw him in the airport, and I was like, oh my God, Mom.", "start": 12.412, "end": 16.273, "zh": "我在机场看到他,当时就想,天哪,妈。", "zh_hant": "我在機場看到他,當時就想,天哪,媽。"}, {"index": 7, "text": "I think I was eight.", "start": 16.513, "end": 17.913, "zh": "我记得我那时八岁。", "zh_hant": "我記得我那時八歲。"}, {"index": 8, "text": "Right.", "start": 17.873, "end": 18.474, "zh": "对。", "zh_hant": "對。"}, {"index": 9, "text": "Oh my God, Mom, it's him.", "start": 18.074, "end": 19.634, "zh": "天哪,妈,是他。", "zh_hant": "天哪,媽,是他。"}, {"index": 10, "text": "It's really him.", "start": 19.234, "end": 20.534, "zh": "真的是他本人。", "zh_hant": "真的是他本人。"}, {"index": 11, "text": "And I was like, we're going to be married.", "start": 20.154, "end": 22.174, "zh": "我当时就想,我们以后会结婚的。", "zh_hant": "我當時就想,我們以後會結婚的。"}, {"index": 12, "text": "We're going to be together forever.", "start": 21.934, "end": 23.634, "zh": "我们会永远在一起。", "zh_hant": "我們會永遠在一起。"}, {"index": 13, "text": "He was like, I was like, we're the same.", "start": 23.235, "end": 25.755, "zh": "他好像,我当时觉得,我们是一样的人。", "zh_hant": "他好像,我當時覺得,我們是一樣的人。"}, {"index": 14, "text": "We love each other.", "start": 25.355, "end": 27.195, "zh": "我们彼此相爱。", "zh_hant": "我們彼此相愛。"}, {"index": 15, "text": "Yeah.", "start": 26.855, "end": 27.475, "zh": "是啊。", "zh_hant": "是啊。"}, {"index": 16, "text": "She was like, Jonathan.", "start": 27.195, "end": 29.436, "zh": "她就喊,乔纳森。", "zh_hant": "她就喊,喬納森。"}, {"index": 17, "text": "Jonathan!", "start": 29.836, "end": 30.916, "zh": "乔纳森!", "zh_hant": "喬納森!"}, {"index": 18, "text": "I'm Melanie Griffith.", "start": 30.796, "end": 32.396, "zh": "我是梅兰妮·格里菲斯。", "zh_hant": "我是梅蘭妮·格里菲斯。"}, {"index": 19, "text": "And I was, like, across the airport in, um, behind a plant.", "start": 31.996, "end": 37.137, "zh": "而我呢,就躲在机场那头的一盆植物后面。", "zh_hant": "而我呢,就躲在機場那頭的一盆植物後面。"}, {"index": 20, "text": "Like this.", "start": 36.817, "end": 37.657, "zh": "就像这样。", "zh_hant": "就像這樣。"}, {"index": 21, "text": "But did you meet him?", "start": 37.777, "end": 39.538, "zh": "那你见到他了吗?", "zh_hant": "那你見到他了嗎?"}, {"index": 22, "text": "Trying to be invisible.", "start": 39.238, "end": 41.538, "zh": "努力让自己隐形。", "zh_hant": "努力讓自己隱形。"}]