[{"index": 0, "text": "Lesson 45 The boss's letter Listen to the tape then answer this question.", "start": 0.35, "end": 10.971, "zh": "第45课 老板的信 听录音,然后回答这个问题。", "zh_hant": "第45課 老闆的信 聽錄音,然後回答這個問題。"}, {"index": 1, "text": "Why can't Pamela type the letter?", "start": 11.931, "end": 15.532, "zh": "帕梅拉为什么不能打这封信?", "zh_hant": "帕梅拉為什麼不能打這封信?"}, {"index": 2, "text": "Can you come here a minute please, Bob?", "start": 17.572, "end": 21.312, "zh": "鲍勃,你能过来一下吗?", "zh_hant": "鮑勃,你能過來一下嗎?"}, {"index": 3, "text": "Yes, sir?", "start": 21.752, "end": 22.912, "zh": "是,先生?", "zh_hant": "是,先生?"}, {"index": 4, "text": "Where's Pamela?", "start": 23.933, "end": 25.513, "zh": "帕梅拉在哪儿?", "zh_hant": "帕梅拉在哪兒?"}, {"index": 5, "text": "She's next door.", "start": 26.193, "end": 27.973, "zh": "她在隔壁。", "zh_hant": "她在隔壁。"}, {"index": 6, "text": "She's in her office, sir.", "start": 28.213, "end": 30.493, "zh": "她在她的办公室里,先生。", "zh_hant": "她在她的辦公室裡,先生。"}, {"index": 7, "text": "Can she type this letter for me?", "start": 31.413, "end": 34.534, "zh": "她能帮我打这封信吗?", "zh_hant": "她能幫我打這封信嗎?"}, {"index": 8, "text": "Ask her please.", "start": 35.174, "end": 36.854, "zh": "请你去问问她。", "zh_hant": "請你去問問她。"}, {"index": 9, "text": "Yes, sir.", "start": 36.874, "end": 38.034, "zh": "好的,先生。", "zh_hant": "好的,先生。"}, {"index": 10, "text": "Can you type this letter for the boss please, Pamela?", "start": 39.234, "end": 43.835, "zh": "帕梅拉,你能帮老板打一下这封信吗?", "zh_hant": "帕梅拉,你能幫老闆打一下這封信嗎?"}, {"index": 11, "text": "Yes, of course I can.", "start": 44.075, "end": 46.955, "zh": "当然可以。", "zh_hant": "當然可以。"}, {"index": 12, "text": "Here you are.", "start": 47.695, "end": 49.015, "zh": "给你。", "zh_hant": "給你。"}, {"index": 13, "text": "Thank you, Bob.", "start": 49.315, "end": 51.015, "zh": "谢谢你,鲍勃。", "zh_hant": "謝謝你,鮑勃。"}, {"index": 14, "text": "Bob!", "start": 51.836, "end": 52.876, "zh": "鲍勃!", "zh_hant": "鮑勃!"}, {"index": 15, "text": "Yes?", "start": 53.096, "end": 54.096, "zh": "什么事?", "zh_hant": "什麼事?"}, {"index": 16, "text": "What's the matter?", "start": 54.176, "end": 55.616, "zh": "怎么了?", "zh_hant": "怎麼了?"}, {"index": 17, "text": "I can't type this letter.", "start": 56.216, "end": 58.716, "zh": "我打不了这封信。", "zh_hant": "我打不了這封信。"}, {"index": 18, "text": "I can't read it!", "start": 59.336, "end": 61.197, "zh": "我看不懂!", "zh_hant": "我看不懂!"}, {"index": 19, "text": "The boss's handwriting is terrible!", "start": 61.477, "end": 65.577, "zh": "老板的字迹太糟糕了!", "zh_hant": "老闆的字跡太糟糕了!"}]