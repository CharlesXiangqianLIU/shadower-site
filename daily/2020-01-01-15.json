[{"index": 0, "text": "Lesson 29 Come in, Amy.", "start": 0.51, "end": 5.051, "zh": "第29课 进来吧,艾米。", "zh_hant": "第29課 進來吧,艾米。"}, {"index": 1, "text": "Listen to the tape then answer this question.", "start": 6.811, "end": 11.112, "zh": "听录音,然后回答这个问题。", "zh_hant": "聽錄音,然後回答這個問題。"}, {"index": 2, "text": "How must Amy clean the floor?", "start": 12.572, "end": 15.592, "zh": "艾米必须怎样清扫地板?", "zh_hant": "艾米必須怎樣清掃地板?"}, {"index": 3, "text": "Come in, Amy.", "start": 17.233, "end": 18.933, "zh": "进来,艾米。", "zh_hant": "進來,艾米。"}, {"index": 4, "text": "Shut the door, please.", "start": 19.873, "end": 21.773, "zh": "请把门关上。", "zh_hant": "請把門關上。"}, {"index": 5, "text": "This bedroom's very untidy.", "start": 22.514, "end": 25.794, "zh": "这间卧室很乱。", "zh_hant": "這間臥室很亂。"}, {"index": 6, "text": "What must I do, Mrs. Jones?", "start": 26.794, "end": 29.875, "zh": "琼斯太太,我该做什么?", "zh_hant": "瓊斯太太,我該做什麼?"}, {"index": 7, "text": "Open the window and air the room.", "start": 30.515, "end": 34.015, "zh": "打开窗户,通通风。", "zh_hant": "開啟窗戶,通通風。"}, {"index": 8, "text": "Then put these clothes in the wardrobe.", "start": 34.916, "end": 39.136, "zh": "然后把这些衣服放进衣柜。", "zh_hant": "然後把這些衣服放進衣櫃。"}, {"index": 9, "text": "Then make the bed.", "start": 39.676, "end": 41.797, "zh": "然后把床铺好。", "zh_hant": "然後把床鋪好。"}, {"index": 10, "text": "Dust the dressing table.", "start": 42.797, "end": 45.317, "zh": "擦一擦梳妆台的灰尘。", "zh_hant": "擦一擦梳妝檯的灰塵。"}, {"index": 11, "text": "Then sweep the floor.", "start": 45.857, "end": 48.458, "zh": "然后把地板扫一扫。", "zh_hant": "然後把地板掃一掃。"}]