[{"index": 0, "text": "Lesson 31 Where's Sally?", "start": 0.49, "end": 4.592, "zh": "第31课 萨莉在哪里？", "zh_hant": "第31課 薩莉在哪裡？"}, {"index": 1, "text": "Listen to the tape then answer this question.", "start": 5.632, "end": 10.274, "zh": "听录音,然后回答这个问题。", "zh_hant": "聽錄音,然後回答這個問題。"}, {"index": 2, "text": "Is the cat climbing the tree?", "start": 11.415, "end": 14.116, "zh": "猫在爬树吗?", "zh_hant": "貓在爬樹嗎?"}, {"index": 3, "text": "Where's Sally, Jack?", "start": 15.717, "end": 18.137, "zh": "杰克,萨莉在哪儿?", "zh_hant": "傑克,薩莉在哪兒?"}, {"index": 4, "text": "She's in the garden, Jean.", "start": 18.678, "end": 21.139, "zh": "琴,她在花园里。", "zh_hant": "琴,她在花園裡。"}, {"index": 5, "text": "What's she doing?", "start": 21.399, "end": 23.139, "zh": "她在做什么?", "zh_hant": "她在做什麼?"}, {"index": 6, "text": "She's sitting under the tree.", "start": 23.44, "end": 26.081, "zh": "她坐在树下。", "zh_hant": "她坐在樹下。"}, {"index": 7, "text": "Is Tim in the garden, too?", "start": 26.561, "end": 29.562, "zh": "蒂姆也在花园里吗?", "zh_hant": "蒂姆也在花園裡嗎?"}, {"index": 8, "text": "Yes, he is.", "start": 29.882, "end": 31.623, "zh": "是的,他在。", "zh_hant": "是的,他在。"}, {"index": 9, "text": "He's climbing the tree.", "start": 31.763, "end": 33.904, "zh": "他在爬树。", "zh_hant": "他在爬樹。"}, {"index": 10, "text": "I beg your pardon?", "start": 34.825, "end": 36.605, "zh": "你说什么?", "zh_hant": "你說什麼?"}, {"index": 11, "text": "Who's climbing the tree?", "start": 36.805, "end": 39.106, "zh": "谁在爬树?", "zh_hant": "誰在爬樹?"}, {"index": 12, "text": "Tim is.", "start": 39.406, "end": 40.807, "zh": "是蒂姆。", "zh_hant": "是蒂姆。"}, {"index": 13, "text": "What about the dog?", "start": 41.407, "end": 43.488, "zh": "那狗呢?", "zh_hant": "那狗呢?"}, {"index": 14, "text": "The dog's in the garden, too.", "start": 43.908, "end": 46.629, "zh": "狗也在花园里。", "zh_hant": "狗也在花園裡。"}, {"index": 15, "text": "It's running across the grass.", "start": 46.87, "end": 49.791, "zh": "它正在草地上跑。", "zh_hant": "它正在草地上跑。"}, {"index": 16, "text": "It's running after a cat.", "start": 50.011, "end": 52.872, "zh": "它在追一只猫。", "zh_hant": "它在追一隻貓。"}]