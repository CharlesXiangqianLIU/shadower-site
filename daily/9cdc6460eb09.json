[{"index": 0, "text": "Lesson 37", "start": 1.581, "end": 2.095, "zh": "第37课"}, {"index": 1, "text": "Making a bookcase", "start": 4.522, "end": 6.382, "zh": "做书柜"}, {"index": 2, "text": "Listen to the tape then answer this question.", "start": 8.123, "end": 11.745, "zh": "听录音,然后回答这个问题。"}, {"index": 3, "text": "What is Susan's favourite colour?", "start": 14.306, "end": 17.127, "zh": "苏珊最喜欢的颜色是什么?"}, {"index": 4, "text": "You're working hard, George.", "start": 19.888, "end": 21.668, "zh": "你干得很卖力啊,乔治。"}, {"index": 5, "text": "What are you doing?", "start": 22.769, "end": 23.949, "zh": "你在做什么?"}, {"index": 6, "text": "I'm making a bookcase.", "start": 26.01, "end": 28.171, "zh": "我在做一个书柜。"}, {"index": 7, "text": "Give me that hammer please, Dan.", "start": 30.112, "end": 30.852, "zh": "丹,把那把锤子递给我。"}, {"index": 8, "text": "Which hammer?", "start": 35.063, "end": 35.784, "zh": "哪把锤子?"}, {"index": 9, "text": "This one?", "start": 37.085, "end": 37.705, "zh": "这把吗?"}, {"index": 10, "text": "No, not that one.", "start": 39.286, "end": 41.287, "zh": "不,不是那把。"}, {"index": 11, "text": "The big one.", "start": 42.228, "end": 43.369, "zh": "大的那把。"}, {"index": 12, "text": "Here you are.", "start": 45.73, "end": 46.471, "zh": "给你。"}, {"index": 13, "text": "Thanks, Dan.", "start": 47.852, "end": 48.732, "zh": "谢谢,丹。"}, {"index": 14, "text": "What are you going to do now, George?", "start": 50.894, "end": 53.475, "zh": "乔治,你现在打算做什么?"}, {"index": 15, "text": "I'm going to paint it.", "start": 55.337, "end": 57.178, "zh": "我打算给它上漆。"}, {"index": 16, "text": "What colour are you going to paint it?", "start": 57.178, "end": 59.63, "zh": "你打算把它漆成什么颜色?"}, {"index": 17, "text": "I'm going to paint it pink.", "start": 59.63, "end": 60.06, "zh": "我打算把它漆成粉红色。"}, {"index": 18, "text": "This bookcase isn't for me.", "start": 60.47, "end": 61.853, "zh": "这个书柜不是给我用的。"}, {"index": 19, "text": "It's for my daughter, Susan.", "start": 61.853, "end": 65.36, "zh": "是给我女儿苏珊的。"}, {"index": 20, "text": "Pink's her favourite colour.", "start": 65.36, "end": 69.95, "zh": "粉红色是她最喜欢的颜色。"}]