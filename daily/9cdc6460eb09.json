[{"index": 0, "text": "Lesson 37", "start": 1.581, "end": 2.095}, {"index": 1, "text": "Making a bookcase", "start": 4.522, "end": 6.382}, {"index": 2, "text": "Listen to the tape then answer this question.", "start": 8.123, "end": 11.745}, {"index": 3, "text": "What is Susan's favourite colour?", "start": 14.306, "end": 17.127}, {"index": 4, "text": "You're working hard, George.", "start": 19.888, "end": 21.668}, {"index": 5, "text": "What are you doing?", "start": 22.769, "end": 23.949}, {"index": 6, "text": "I'm making a bookcase.", "start": 26.01, "end": 28.171}, {"index": 7, "text": "Give me that hammer please, Dan.", "start": 30.112, "end": 30.852}, {"index": 8, "text": "Which hammer?", "start": 35.063, "end": 35.784}, {"index": 9, "text": "This one?", "start": 37.085, "end": 37.705}, {"index": 10, "text": "No, not that one.", "start": 39.286, "end": 41.287}, {"index": 11, "text": "The big one.", "start": 42.228, "end": 43.369}, {"index": 12, "text": "Here you are.", "start": 45.73, "end": 46.471}, {"index": 13, "text": "Thanks, Dan.", "start": 47.852, "end": 48.732}, {"index": 14, "text": "What are you going to do now, George?", "start": 50.894, "end": 53.475}, {"index": 15, "text": "I'm going to paint it.", "start": 55.337, "end": 57.178}, {"index": 16, "text": "What colour are you going to paint it?", "start": 57.178, "end": 59.63}, {"index": 17, "text": "I'm going to paint it pink.", "start": 59.63, "end": 60.06}, {"index": 18, "text": "Pink!", "start": 60.06, "end": 60.2}, {"index": 19, "text": "This bookcase isn't for me.", "start": 60.47, "end": 61.853}, {"index": 20, "text": "It's for my daughter, Susan.", "start": 61.853, "end": 65.36}, {"index": 21, "text": "Pink's her favourite colour.", "start": 65.36, "end": 69.95}]