[{"index": 0, "text": "Lesson 15", "start": 1.621, "end": 1.995, "zh": "第15课"}, {"index": 1, "text": "Your passports please.", "start": 4.022, "end": 5.923, "zh": "请出示你们的护照。"}, {"index": 2, "text": "Listen to the tape then answer this question.", "start": 7.784, "end": 11.605, "zh": "听录音,然后回答这个问题。"}, {"index": 3, "text": "Is there a problem with the Customs officer?", "start": 14.187, "end": 17.368, "zh": "海关官员遇到什么问题了吗?"}, {"index": 4, "text": "Are you Swedish?", "start": 20.089, "end": 21.43, "zh": "你们是瑞典人吗?"}, {"index": 5, "text": "No we are not.", "start": 23.051, "end": 25.072, "zh": "不,我们不是。"}, {"index": 6, "text": "We are Danish.", "start": 25.852, "end": 27.273, "zh": "我们是丹麦人。"}, {"index": 7, "text": "Are your friends Danish too?", "start": 29.494, "end": 29.75, "zh": "你们的朋友也是丹麦人吗?"}, {"index": 8, "text": "No they aren't.", "start": 29.75, "end": 31.631, "zh": "不,他们不是。"}, {"index": 9, "text": "They are Norwegian.", "start": 36.733, "end": 38.474, "zh": "他们是挪威人。"}, {"index": 10, "text": "Your passports please.", "start": 40.595, "end": 42.515, "zh": "请出示你们的护照。"}, {"index": 11, "text": "Here they are.", "start": 43.876, "end": 45.176, "zh": "给您。"}, {"index": 12, "text": "these your cases?", "start": 47.417, "end": 49.438, "zh": "这些是你们的箱子吗?"}, {"index": 13, "text": "No they aren't.", "start": 50.839, "end": 52.82, "zh": "不,不是。"}, {"index": 14, "text": "Our cases are brown.", "start": 54.46, "end": 56.801, "zh": "我们的箱子是棕色的。"}, {"index": 15, "text": "Here they are.", "start": 57.802, "end": 59.002, "zh": "给您。"}, {"index": 16, "text": "you tourists?", "start": 59.002, "end": 59.873, "zh": "你们是游客吗?"}, {"index": 17, "text": "Yes we are.", "start": 59.873, "end": 63.733, "zh": "是的,我们是。"}, {"index": 18, "text": "your friends tourists too?", "start": 67.399, "end": 69.984, "zh": "你们的朋友也是游客吗?"}, {"index": 19, "text": "Yes they are.", "start": 71.246, "end": 73.029, "zh": "是的,他们是。"}, {"index": 20, "text": "That's fine.", "start": 73.029, "end": 73.229, "zh": "好的,没问题。"}, {"index": 21, "text": "Thank you very much.", "start": 73.229, "end": 73.73, "zh": "非常感谢。"}]