[{"index": 0, "text": "Lesson 15", "start": 1.621, "end": 1.995}, {"index": 1, "text": "Your passports please.", "start": 4.022, "end": 5.923}, {"index": 2, "text": "Listen to the tape then answer this question.", "start": 7.784, "end": 11.605}, {"index": 3, "text": "Is there a problem with the Customs officer?", "start": 14.187, "end": 17.368}, {"index": 4, "text": "Are you Swedish?", "start": 20.089, "end": 21.43}, {"index": 5, "text": "No we are not.", "start": 23.051, "end": 25.072}, {"index": 6, "text": "We are Danish.", "start": 25.852, "end": 27.273}, {"index": 7, "text": "Are your friends Danish too?", "start": 29.494, "end": 29.81}, {"index": 8, "text": "No  they aren't.", "start": 29.69, "end": 31.631}, {"index": 9, "text": "They are Norwegian.", "start": 36.733, "end": 38.474}, {"index": 10, "text": "Your passports please.", "start": 40.595, "end": 42.515}, {"index": 11, "text": "Here they are.", "start": 43.876, "end": 45.176}, {"index": 12, "text": "Are these your cases?", "start": 47.417, "end": 49.438}, {"index": 13, "text": "No they aren't.", "start": 50.839, "end": 52.82}, {"index": 14, "text": "Our cases are brown.", "start": 54.46, "end": 56.801}, {"index": 15, "text": "Here they are.", "start": 57.802, "end": 59.062}, {"index": 16, "text": "Are you tourists?", "start": 58.942, "end": 59.903}, {"index": 17, "text": "Yes we are.", "start": 59.843, "end": 63.733}, {"index": 18, "text": "Are your friends tourists too?", "start": 67.399, "end": 69.984}, {"index": 19, "text": "Yes they are.", "start": 71.246, "end": 73.089}, {"index": 20, "text": "That's fine.", "start": 72.969, "end": 73.289}, {"index": 21, "text": "Thank you very much.", "start": 73.169, "end": 73.73}]