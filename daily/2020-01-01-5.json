[{"index": 0, "text": "Lesson 9 How are you today?", "start": 0.55, "end": 4.772, "zh": "第9课 你今天怎么样?", "zh_hant": "第9課 你今天怎麼樣?"}, {"index": 1, "text": "Listen to the tape then answer this question.", "start": 5.773, "end": 10.654, "zh": "听录音,然后回答这个问题。", "zh_hant": "聽錄音,然後回答這個問題。"}, {"index": 2, "text": "How is Emma?", "start": 11.475, "end": 13.376, "zh": "艾玛好吗?", "zh_hant": "艾瑪好嗎?"}, {"index": 3, "text": "Hello Helen.", "start": 15.137, "end": 16.757, "zh": "你好,海伦。", "zh_hant": "你好,海倫。"}, {"index": 4, "text": "Hi Steven.", "start": 17.117, "end": 18.578, "zh": "你好,史蒂文。", "zh_hant": "你好,史蒂文。"}, {"index": 5, "text": "How are you today?", "start": 18.998, "end": 21.159, "zh": "你今天好吗?", "zh_hant": "你今天好嗎?"}, {"index": 6, "text": "I'm very well thank you.", "start": 21.739, "end": 24.08, "zh": "我很好,谢谢。", "zh_hant": "我很好,謝謝。"}, {"index": 7, "text": "And you?", "start": 24.241, "end": 25.201, "zh": "你呢?", "zh_hant": "你呢?"}, {"index": 8, "text": "I'm fine thanks.", "start": 25.861, "end": 27.822, "zh": "我很好,谢谢。", "zh_hant": "我很好,謝謝。"}, {"index": 9, "text": "How is Tony?", "start": 28.743, "end": 30.383, "zh": "托尼好吗?", "zh_hant": "託尼好嗎?"}, {"index": 10, "text": "He's fine thanks.", "start": 30.783, "end": 33.124, "zh": "他很好,谢谢。", "zh_hant": "他很好,謝謝。"}, {"index": 11, "text": "How's Emma?", "start": 33.305, "end": 34.525, "zh": "艾玛好吗?", "zh_hant": "艾瑪好嗎?"}, {"index": 12, "text": "She's very well too Helen.", "start": 34.945, "end": 37.866, "zh": "她也很好,海伦。", "zh_hant": "她也很好,海倫。"}, {"index": 13, "text": "Goodbye Helen.", "start": 39.127, "end": 40.547, "zh": "再见,海伦。", "zh_hant": "再見,海倫。"}, {"index": 14, "text": "Nice to see you.", "start": 40.688, "end": 42.188, "zh": "很高兴见到你。", "zh_hant": "很高興見到你。"}, {"index": 15, "text": "Nice to see you too Steven.", "start": 42.749, "end": 45.95, "zh": "我也很高兴见到你,史蒂文。", "zh_hant": "我也很高興見到你,史蒂文。"}, {"index": 16, "text": "Goodbye.", "start": 46.15, "end": 47.25, "zh": "再见。", "zh_hant": "再見。"}]