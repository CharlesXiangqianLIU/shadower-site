[{"index": 0, "text": "Lesson 91 Poor Ian!", "start": 0.87, "end": 5.051, "zh": "第91课 可怜的伊恩！", "zh_hant": "第91課 可憐的伊恩！"}, {"index": 1, "text": "Listen to the tape then answer this question.", "start": 6.231, "end": 10.912, "zh": "听录音,然后回答这个问题。", "zh_hant": "聽錄音,然後回答這個問題。"}, {"index": 2, "text": "Who wanted to sell the house?", "start": 12.113, "end": 15.253, "zh": "谁想卖房子?", "zh_hant": "誰想賣房子?"}, {"index": 3, "text": "Has Ian sold his house yet?", "start": 17.534, "end": 20.534, "zh": "伊恩把房子卖了吗?", "zh_hant": "伊恩把房子賣了嗎?"}, {"index": 4, "text": "Yes, he has.", "start": 21.215, "end": 23.175, "zh": "是的,他卖了。", "zh_hant": "是的,他賣了。"}, {"index": 5, "text": "He sold it last week.", "start": 23.155, "end": 25.835, "zh": "他上周把房子卖了。", "zh_hant": "他上週把房子賣了。"}, {"index": 6, "text": "Has he moved to his new house yet?", "start": 26.856, "end": 30.657, "zh": "他搬到新家了吗?", "zh_hant": "他搬到新家了嗎?"}, {"index": 7, "text": "No, not yet.", "start": 31.437, "end": 33.597, "zh": "还没有。", "zh_hant": "還沒有。"}, {"index": 8, "text": "He's still here.", "start": 33.757, "end": 35.638, "zh": "他还在这儿。", "zh_hant": "他還在這兒。"}, {"index": 9, "text": "He's going to move tomorrow.", "start": 35.978, "end": 38.798, "zh": "他明天要搬家。", "zh_hant": "他明天要搬家。"}, {"index": 10, "text": "When?", "start": 39.799, "end": 40.699, "zh": "什么时候？", "zh_hant": "什麼時候？"}, {"index": 11, "text": "Tomorrow morning?", "start": 41.059, "end": 42.979, "zh": "明天早上？", "zh_hant": "明天早上？"}, {"index": 12, "text": "No. Tomorrow afternoon.", "start": 44.12, "end": 47.28, "zh": "不,明天下午。", "zh_hant": "不,明天下午。"}, {"index": 13, "text": "I'll miss him.", "start": 47.9, "end": 49.421, "zh": "我会想念他的。", "zh_hant": "我會想念他的。"}, {"index": 14, "text": "He has always been a good neighbour.", "start": 49.841, "end": 53.741, "zh": "他一直是个好邻居。", "zh_hant": "他一直是個好鄰居。"}, {"index": 15, "text": "He's a very nice person.", "start": 54.502, "end": 57.622, "zh": "他是个很好的人。", "zh_hant": "他是個很好的人。"}, {"index": 16, "text": "We'll all miss him.", "start": 58.123, "end": 60.943, "zh": "我们都会想念他的。", "zh_hant": "我們都會想念他的。"}, {"index": 17, "text": "When will the new people move into this house?", "start": 62.283, "end": 66.764, "zh": "新住户什么时候搬进这所房子?", "zh_hant": "新住戶什麼時候搬進這所房子?"}, {"index": 18, "text": "I think that they'll move in the day after tomorrow.", "start": 67.685, "end": 72.786, "zh": "我想他们后天就搬进来。", "zh_hant": "我想他們後天就搬進來。"}, {"index": 19, "text": "Will you see Ian today, Jenny?", "start": 74.166, "end": 78.027, "zh": "珍妮,你今天会见到伊恩吗?", "zh_hant": "珍妮,你今天會見到伊恩嗎?"}, {"index": 20, "text": "Yes, I will.", "start": 79.687, "end": 81.727, "zh": "是的,我会见到他。", "zh_hant": "是的,我會見到他。"}, {"index": 21, "text": "Please give him my regards.", "start": 83.028, "end": 86.969, "zh": "请代我向他问好。", "zh_hant": "請代我向他問好。"}, {"index": 22, "text": "Poor Ian!", "start": 87.729, "end": 89.449, "zh": "可怜的伊恩!", "zh_hant": "可憐的伊恩!"}, {"index": 23, "text": "He didn't want to leave this house.", "start": 89.809, "end": 93.57, "zh": "他不想离开这个房子。", "zh_hant": "他不想離開這個房子。"}, {"index": 24, "text": "No, he didn't want to leave, but his wife did!", "start": 94.51, "end": 100.532, "zh": "是的,他不想离开,可他妻子想!", "zh_hant": "是的,他不想離開,可他妻子想!"}]