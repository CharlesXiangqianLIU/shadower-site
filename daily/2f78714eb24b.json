[{"index": 0, "text": "Lesson 127", "start": 1.591, "end": 2.4, "zh": "第127课", "zh_hant": "第127課"}, {"index": 1, "text": "A famous actress", "start": 5.092, "end": 6.493, "zh": "一位著名女演员", "zh_hant": "一位著名女演員"}, {"index": 2, "text": "Listen to the tape then answer this question.", "start": 8.354, "end": 11.335, "zh": "听录音，然后回答这个问题。", "zh_hant": "聽錄音，然後回答這個問題。"}, {"index": 3, "text": "Who is only twenty-nine, and why is it so unclear?", "start": 13.796, "end": 18.398, "zh": "她只有二十九岁，这怎么会这么不确定呢？", "zh_hant": "她只有二十九歲，這怎麼會這麼不確定呢？"}, {"index": 4, "text": "Can you recognize that woman, Liz?", "start": 21.1, "end": 23.561, "zh": "丽兹，你能认出那个女人吗？", "zh_hant": "麗茲，你能認出那個女人嗎？"}, {"index": 5, "text": "I think I can, Kate.", "start": 25.282, "end": 26.822, "zh": "凯特，我想我能认出来。", "zh_hant": "凱特，我想我能認出來。"}, {"index": 6, "text": "It must be Karen Marsh, the actress.", "start": 27.203, "end": 31.342, "zh": "那一定是女演员凯伦·马什。", "zh_hant": "那一定是女演員凱倫·馬什。"}, {"index": 7, "text": "I thought so.", "start": 31.422, "end": 32.323, "zh": "我也这么想。", "zh_hant": "我也這麼想。"}, {"index": 8, "text": "Who's that beside her?", "start": 33.163, "end": 34.604, "zh": "她旁边那位是谁？", "zh_hant": "她旁邊那位是誰？"}, {"index": 9, "text": "That must be Conrad Reeves.", "start": 36.425, "end": 39.087, "zh": "那一定是康拉德·里夫斯。", "zh_hant": "那一定是康拉德·裡夫斯。"}, {"index": 10, "text": "Conrad Reeves, the actor?", "start": 40.308, "end": 42.209, "zh": "男演员康拉德·里夫斯？", "zh_hant": "男演員康拉德·裡夫斯？"}, {"index": 11, "text": "It can't be.", "start": 42.91, "end": 44.11, "zh": "不可能吧。", "zh_hant": "不可能吧。"}, {"index": 12, "text": "Let me have another look.", "start": 44.791, "end": 45.911, "zh": "让我再看看。", "zh_hant": "讓我再看看。"}, {"index": 13, "text": "I think you're right!", "start": 47.433, "end": 48.613, "zh": "我觉得你说得对！", "zh_hant": "我覺得你說得對！"}, {"index": 14, "text": "Isn't he her third husband?", "start": 49.794, "end": 51.935, "zh": "他不是她的第三任丈夫吗？", "zh_hant": "他不是她的第三任丈夫嗎？"}, {"index": 15, "text": "No.", "start": 53.356, "end": 53.597, "zh": "不是。", "zh_hant": "不是。"}, {"index": 16, "text": "He must be her fourth or fifth.", "start": 54.177, "end": 60.283, "zh": "他一定是她第四任或第五任丈夫。", "zh_hant": "他一定是她第四任或第五任丈夫。"}, {"index": 17, "text": "Doesn't Karen Marsh look old!", "start": 60.283, "end": 61.193, "zh": "凯伦·马什看起来老多了！", "zh_hant": "凱倫·馬什看起來老多了！"}, {"index": 18, "text": "She does, doesn't she!", "start": 61.613, "end": 62.994, "zh": "是啊，可不是嘛！", "zh_hant": "是啊，可不是嘛！"}, {"index": 19, "text": "I read she's twenty-nine, but she must be at least forty.", "start": 64.274, "end": 69.555, "zh": "我看报道说她二十九岁，可她至少得有四十岁了。", "zh_hant": "我看報道說她二十九歲，可她至少得有四十歲了。"}, {"index": 20, "text": "I'm sure she is.", "start": 71.156, "end": 72.616, "zh": "我也这么确定。", "zh_hant": "我也這麼確定。"}, {"index": 21, "text": "She was a famous actress when I was still at school.", "start": 74.096, "end": 78.017, "zh": "我还在上学的时候，她就已经是位著名女演员了。", "zh_hant": "我還在上學的時候，她就已經是位著名女演員了。"}, {"index": 22, "text": "That was a long time ago, wasn't it?", "start": 79.658, "end": 91.587, "zh": "那是很久以前的事了，是吧？", "zh_hant": "那是很久以前的事了，是吧？"}, {"index": 23, "text": "Not that long ago!", "start": 91.587, "end": 91.907, "zh": "也没那么久！", "zh_hant": "也沒那麼久！"}, {"index": 24, "text": "I'm not more than twenty-nine myself.", "start": 91.907, "end": 96.093, "zh": "我自己也不过二十九岁而已。", "zh_hant": "我自己也不過二十九歲而已。"}]