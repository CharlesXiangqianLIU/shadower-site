[{"index": 0, "text": "Lesson 127", "start": 1.591, "end": 2.4}, {"index": 1, "text": "A famous actress", "start": 5.092, "end": 6.493}, {"index": 2, "text": "Listen to the tape then answer this question.", "start": 8.354, "end": 11.335}, {"index": 3, "text": "Who is only twenty-nine, and why is it so unclear?", "start": 13.796, "end": 18.398}, {"index": 4, "text": "Can you recognize that woman, Liz?", "start": 21.1, "end": 23.561}, {"index": 5, "text": "I think I can, Kate.", "start": 25.282, "end": 26.822}, {"index": 6, "text": "It must be Karen Marsh, the actress.", "start": 27.203, "end": 31.342}, {"index": 7, "text": "I thought so.", "start": 31.422, "end": 32.323}, {"index": 8, "text": "Who's that beside her?", "start": 33.163, "end": 34.604}, {"index": 9, "text": "That must be Conrad Reeves.", "start": 36.425, "end": 39.087}, {"index": 10, "text": "Conrad Reeves, the actor?", "start": 40.308, "end": 42.209}, {"index": 11, "text": "It can't be.", "start": 42.91, "end": 44.11}, {"index": 12, "text": "Let me have another look.", "start": 44.791, "end": 45.911}, {"index": 13, "text": "I think you're right!", "start": 47.433, "end": 48.613}, {"index": 14, "text": "Isn't he her third husband?", "start": 49.794, "end": 51.935}, {"index": 15, "text": "No.", "start": 53.356, "end": 53.597}, {"index": 16, "text": "He must be her fourth or fifth.", "start": 54.177, "end": 60.283}, {"index": 17, "text": "Doesn't Karen Marsh look old!", "start": 60.283, "end": 61.193}, {"index": 18, "text": "She does, doesn't she!", "start": 61.613, "end": 62.994}, {"index": 19, "text": "I read she's twenty-nine, but she must be at least forty.", "start": 64.274, "end": 69.555}, {"index": 20, "text": "I'm sure she is.", "start": 71.156, "end": 72.616}, {"index": 21, "text": "She was a famous actress when I was still at school.", "start": 74.096, "end": 78.017}, {"index": 22, "text": "That was a long time ago, wasn't it?", "start": 79.658, "end": 91.587}, {"index": 23, "text": "Not that long ago!", "start": 91.587, "end": 91.907}, {"index": 24, "text": "I'm not more than twenty-nine myself.", "start": 91.907, "end": 96.093}]