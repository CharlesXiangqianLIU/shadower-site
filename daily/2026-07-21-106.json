[{"index": 0, "text": "What's the different sections of the choir?", "start": 0.0, "end": 3.631, "zh": "合唱团分为哪几个声部?", "zh_hant": "合唱團分為哪幾個聲部?"}, {"index": 1, "text": "I go soprano, also tenor.", "start": 3.551, "end": 7.432, "zh": "我唱女高音,也唱男高音。", "zh_hant": "我唱女高音,也唱男高音。"}, {"index": 2, "text": "Who mostly are the tenors?", "start": 7.072, "end": 9.573, "zh": "男高音大多是谁唱?", "zh_hant": "男高音大多是誰唱?"}, {"index": 3, "text": "The boys or the girls?", "start": 9.473, "end": 11.613, "zh": "是男生还是女生?", "zh_hant": "是男生還是女生?"}, {"index": 4, "text": "Boys.", "start": 11.213, "end": 12.293, "zh": "男生。", "zh_hant": "男生。"}, {"index": 5, "text": "Mostly boys.", "start": 11.893, "end": 13.214, "zh": "主要是男生。", "zh_hant": "主要是男生。"}, {"index": 6, "text": "Who's mostly the sopranos?", "start": 13.074, "end": 15.434, "zh": "女高音主要是谁唱?", "zh_hant": "女高音主要是誰唱?"}, {"index": 7, "text": "Tamia.", "start": 15.194, "end": 16.354, "zh": "塔米娅。", "zh_hant": "塔米婭。"}, {"index": 8, "text": "Don't do this.", "start": 16.094, "end": 17.195, "zh": "别这样。", "zh_hant": "別這樣。"}, {"index": 9, "text": "Don't do this.", "start": 18.135, "end": 19.315, "zh": "别这样。", "zh_hant": "別這樣。"}, {"index": 10, "text": "You're not going...", "start": 20.316, "end": 21.456, "zh": "你不会…", "zh_hant": "你不會…"}, {"index": 11, "text": "Okay, Jay.", "start": 21.356, "end": 22.456, "zh": "好吧,杰。", "zh_hant": "好吧,傑。"}, {"index": 12, "text": "So, if I let you show me what you do, is it gonna be good?", "start": 22.556, "end": 27.297, "zh": "那如果我让你show一下你的本事,会很棒吗?", "zh_hant": "那如果我讓你show一下你的本事,會很棒嗎?"}, {"index": 13, "text": "Yep.", "start": 27.098, "end": 27.818, "zh": "嗯。", "zh_hant": "嗯。"}, {"index": 14, "text": "You really know what you're doing?", "start": 28.218, "end": 30.258, "zh": "你真的知道自己在做什么吗?", "zh_hant": "你真的知道自己在做什麼嗎?"}, {"index": 15, "text": "Yep.", "start": 29.858, "end": 30.678, "zh": "嗯。", "zh_hant": "嗯。"}, {"index": 16, "text": "You're the best that there is.", "start": 31.039, "end": 33.419, "zh": "你是最厉害的。", "zh_hant": "你是最厲害的。"}, {"index": 17, "text": "Yep.", "start": 33.019, "end": 34.399, "zh": "嗯。", "zh_hant": "嗯。"}, {"index": 18, "text": "You're not really six, are you?", "start": 34.72, "end": 36.58, "zh": "你其实不是六岁的吧?", "zh_hant": "你其實不是六歲的吧?"}, {"index": 19, "text": "Mm -hmm.", "start": 36.52, "end": 37.46, "zh": "嗯哼。", "zh_hant": "嗯哼。"}, {"index": 20, "text": "You're 46.", "start": 37.44, "end": 39.181, "zh": "你其实四十六岁。", "zh_hant": "你其實四十六歲。"}, {"index": 21, "text": "No. And you just short.", "start": 38.781, "end": 41.441, "zh": "不是,你就是长得矮而已。", "zh_hant": "不是,你就是長得矮而已。"}, {"index": 22, "text": "And that's it.", "start": 41.381, "end": 42.682, "zh": "就是这样。", "zh_hant": "就是這樣。"}]