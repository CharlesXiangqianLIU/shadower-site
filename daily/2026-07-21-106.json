[{"index": 0, "text": "What's the different sections of the choir?", "start": 0.0, "end": 3.482, "zh": "唱诗班分几个声部?", "zh_hant": "唱詩班分幾個聲部?"}, {"index": 1, "text": "I go soprano, also tenor.", "start": 3.502, "end": 7.154, "zh": "我唱女高音,也唱男高音。", "zh_hant": "我唱女高音,也唱男高音。"}, {"index": 2, "text": "Who mostly are the tenors?", "start": 7.154, "end": 9.425, "zh": "男高音主要是谁在唱?", "zh_hant": "男高音主要是誰在唱?"}, {"index": 3, "text": "The boys or the girls?", "start": 9.425, "end": 11.346, "zh": "是男生还是女生?", "zh_hant": "是男生還是女生?"}, {"index": 4, "text": "Boys.", "start": 11.346, "end": 12.046, "zh": "男生。", "zh_hant": "男生。"}, {"index": 5, "text": "Mostly boys.", "start": 12.046, "end": 13.046, "zh": "主要是男生。", "zh_hant": "主要是男生。"}, {"index": 6, "text": "Who's mostly the sopranos?", "start": 13.046, "end": 15.218, "zh": "女高音主要是谁在唱?", "zh_hant": "女高音主要是誰在唱?"}, {"index": 7, "text": "Tamia.", "start": 15.218, "end": 16.128, "zh": "塔米娅。", "zh_hant": "塔米婭。"}, {"index": 8, "text": "Don't do this.", "start": 16.128, "end": 17.048, "zh": "别这样。", "zh_hant": "別這樣。"}, {"index": 9, "text": "Don't do this.", "start": 18.089, "end": 19.169, "zh": "别这样。", "zh_hant": "別這樣。"}, {"index": 10, "text": "You're not going...", "start": 20.27, "end": 21.31, "zh": "你不会...", "zh_hant": "你不會..."}, {"index": 11, "text": "Okay, Jay.", "start": 21.311, "end": 22.311, "zh": "好吧,杰。", "zh_hant": "好吧,傑。"}, {"index": 12, "text": "So, if I let you show me what you do, is it gonna be good?", "start": 22.511, "end": 27.103, "zh": "那如果我让你show一下你的本事,会很厉害吗?", "zh_hant": "那如果我讓你show一下你的本事,會很厲害嗎?"}, {"index": 13, "text": "Yep.", "start": 27.103, "end": 27.674, "zh": "是的。", "zh_hant": "是的。"}, {"index": 14, "text": "You really know what you're doing?", "start": 28.174, "end": 30.025, "zh": "你真的懂自己在干嘛吗?", "zh_hant": "你真的懂自己在幹嘛嗎?"}, {"index": 15, "text": "Yep.", "start": 30.025, "end": 30.535, "zh": "是的。", "zh_hant": "是的。"}, {"index": 16, "text": "You're the best that there is.", "start": 30.996, "end": 33.657, "zh": "你是最厉害的。", "zh_hant": "你是最厲害的。"}, {"index": 17, "text": "Yep.", "start": 33.657, "end": 34.257, "zh": "是的。", "zh_hant": "是的。"}, {"index": 18, "text": "You're not really six, are you?", "start": 34.677, "end": 36.438, "zh": "你其实不是六岁吧?", "zh_hant": "你其實不是六歲吧?"}, {"index": 19, "text": "Mm -hmm.", "start": 36.478, "end": 37.358, "zh": "嗯哼。", "zh_hant": "嗯哼。"}, {"index": 20, "text": "You're 46.", "start": 37.399, "end": 38.18, "zh": "你46岁。", "zh_hant": "你46歲。"}, {"index": 21, "text": "No. And you just short.", "start": 38.739, "end": 41.271, "zh": "不是,你就是个子矮。", "zh_hant": "不是,你就是個子矮。"}, {"index": 22, "text": "And that's it.", "start": 41.334, "end": 42.519, "zh": "就这样。", "zh_hant": "就這樣。"}]