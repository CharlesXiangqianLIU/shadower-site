[{"index": 0, "text": "Why was the writer's aunt surprised?", "start": 10.491, "end": 14.351, "zh": "为什么作者的姑姑感到惊讶?", "zh_hant": "為什麼作者的姑姑感到驚訝?"}, {"index": 1, "text": "It was Sunday.", "start": 15.971, "end": 17.431, "zh": "那天是星期天。", "zh_hant": "那天是星期天。"}, {"index": 2, "text": "I never get up early on Sundays.", "start": 18.131, "end": 21.451, "zh": "我星期天从不早起。", "zh_hant": "我星期天從不早起。"}, {"index": 3, "text": "I sometimes stay in bed until lunchtime.", "start": 22.131, "end": 26.052, "zh": "我有时会一直睡到中午。", "zh_hant": "我有時會一直睡到中午。"}, {"index": 4, "text": "Last Sunday I got up very late.", "start": 26.852, "end": 30.372, "zh": "上周日我起得很晚。", "zh_hant": "上週日我起得很晚。"}, {"index": 5, "text": "I looked out of the window.", "start": 31.132, "end": 33.112, "zh": "我朝窗外看了看。", "zh_hant": "我朝窗外看了看。"}, {"index": 6, "text": "It was dark outside.", "start": 33.432, "end": 35.352, "zh": "外面天很黑。", "zh_hant": "外面天很黑。"}, {"index": 7, "text": "'What a day!'", "start": 34.952, "end": 38.132, "zh": "真是漫长的一天!", "zh_hant": "真是漫長的一天!"}, {"index": 8, "text": "I thought.", "start": 38.253, "end": 39.153, "zh": "我心想。", "zh_hant": "我心想。"}, {"index": 9, "text": "'It's raining again.'", "start": 38.773, "end": 42.096, "zh": "“又下雨了。”", "zh_hant": "“又下雨了。”"}, {"index": 10, "text": "Just then, the telephone rang.", "start": 42.633, "end": 45.533, "zh": "就在这时,电话铃响了。", "zh_hant": "就在這時,電話鈴響了。"}, {"index": 11, "text": "It was my aunt Lucy.", "start": 46.013, "end": 47.973, "zh": "是我姑姑露西打来的。", "zh_hant": "是我姑姑露西打來的。"}, {"index": 12, "text": "'I've just arrived by train,' she said.", "start": 47.573, "end": 52.653, "zh": "“我刚坐火车到,”她说。", "zh_hant": "“我剛坐火車到,”她說。"}, {"index": 13, "text": "'I'm coming to see you.'", "start": 52.413, "end": 55.114, "zh": "“我要来看你了。”", "zh_hant": "“我要來看你了。”"}, {"index": 14, "text": "'But I'm still having breakfast,' I said.", "start": 55.114, "end": 59.934, "zh": "“可我还在吃早饭呢,”我说。", "zh_hant": "“可我還在吃早飯呢,”我說。"}, {"index": 15, "text": "'What are you doing?'", "start": 59.554, "end": 62.034, "zh": "“你在做什么?”", "zh_hant": "“你在做什麼?”"}, {"index": 16, "text": "she asked.", "start": 62.254, "end": 63.454, "zh": "她问道。", "zh_hant": "她問道。"}, {"index": 17, "text": "'I'm having breakfast,' I repeated.", "start": 63.114, "end": 67.034, "zh": "“我在吃早饭,”我又说了一遍。", "zh_hant": "“我在吃早飯,”我又說了一遍。"}, {"index": 18, "text": "'Dear me,' she said.", "start": 67.216, "end": 70.015, "zh": "“天哪,”她说。", "zh_hant": "“天哪,”她說。"}, {"index": 19, "text": "'Do you always get up so late?", "start": 69.635, "end": 73.055, "zh": "“你总是起这么晚吗?", "zh_hant": "“你總是起這麼晚嗎?"}, {"index": 20, "text": "It's one o'clock!'", "start": 73.375, "end": 75.275, "zh": "现在都一点了!”", "zh_hant": "現在都一點了!”"}]