[{"index": 0, "text": "Lesson 23", "start": 1.6, "end": 1.97, "zh": "第23课", "zh_hant": "第23課"}, {"index": 1, "text": "Which glasses?", "start": 4.501, "end": 5.681, "zh": "哪副眼镜?", "zh_hant": "哪副眼鏡?"}, {"index": 2, "text": "Listen to the tape then answer this question.", "start": 7.462, "end": 11.123, "zh": "听录音,然后回答这个问题。", "zh_hant": "聽錄音,然後回答這個問題。"}, {"index": 3, "text": "Which glasses does the man want?", "start": 13.704, "end": 16.304, "zh": "这个男人想要哪副眼镜?", "zh_hant": "這個男人想要哪副眼鏡?"}, {"index": 4, "text": "Give me some glasses please, Jane.", "start": 19.125, "end": 21.726, "zh": "简,请给我拿副眼镜。", "zh_hant": "簡,請給我拿副眼鏡。"}, {"index": 5, "text": "Which glasses?", "start": 23.286, "end": 24.466, "zh": "哪副眼镜?", "zh_hant": "哪副眼鏡?"}, {"index": 6, "text": "These glasses?", "start": 25.707, "end": 26.867, "zh": "这副眼镜吗?", "zh_hant": "這副眼鏡嗎?"}, {"index": 7, "text": "No, not those.", "start": 28.127, "end": 29.908, "zh": "不,不是那副。", "zh_hant": "不,不是那副。"}, {"index": 8, "text": "The ones on the shelf.", "start": 29.908, "end": 32.438, "zh": "架子上的那副。", "zh_hant": "架子上的那副。"}, {"index": 9, "text": "These?", "start": 33.42, "end": 34.061, "zh": "这副?", "zh_hant": "這副?"}, {"index": 10, "text": "Yes, please.", "start": 35.084, "end": 36.327, "zh": "是的,麻烦你了。", "zh_hant": "是的,麻煩你了。"}, {"index": 11, "text": "Here you are.", "start": 37.089, "end": 37.65, "zh": "给你。", "zh_hant": "給你。"}, {"index": 12, "text": "Thanks.", "start": 37.65, "end": 37.83, "zh": "谢谢。", "zh_hant": "謝謝。"}]