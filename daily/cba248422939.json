[{"index": 0, "text": "Lesson 23", "start": 1.6, "end": 1.97}, {"index": 1, "text": "Which glasses?", "start": 4.501, "end": 5.681}, {"index": 2, "text": "Listen to the tape then answer this question.", "start": 7.462, "end": 11.123}, {"index": 3, "text": "Which glasses does the man want?", "start": 13.704, "end": 16.304}, {"index": 4, "text": "Give me some glasses please, Jane.", "start": 19.125, "end": 21.726}, {"index": 5, "text": "Which glasses?", "start": 23.286, "end": 24.466}, {"index": 6, "text": "These glasses?", "start": 25.707, "end": 26.867}, {"index": 7, "text": "No, not those.", "start": 28.127, "end": 29.968}, {"index": 8, "text": "The ones on the shelf.", "start": 29.848, "end": 32.438}, {"index": 9, "text": "These?", "start": 33.42, "end": 34.061}, {"index": 10, "text": "Yes, please.", "start": 35.084, "end": 36.327}, {"index": 11, "text": "Here you are.", "start": 37.089, "end": 37.71}, {"index": 12, "text": "Thanks.", "start": 37.59, "end": 37.83}]