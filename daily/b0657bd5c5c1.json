[{"index": 0, "text": "Lesson 11", "start": 1.58, "end": 2.415, "zh": "第11课", "zh_hant": "第11課"}, {"index": 1, "text": "Is this your shirt?", "start": 3.941, "end": 5.662, "zh": "这是你的衬衫吗?", "zh_hant": "這是你的襯衫嗎?"}, {"index": 2, "text": "Listen to the tape then answer this question.", "start": 7.562, "end": 11.344, "zh": "听录音,然后回答这个问题。", "zh_hant": "聽錄音,然後回答這個問題。"}, {"index": 3, "text": "Whose shirt is white?", "start": 13.804, "end": 16.285, "zh": "谁的衬衫是白色的?", "zh_hant": "誰的襯衫是白色的?"}, {"index": 4, "text": "Whose shirt is that?", "start": 18.966, "end": 20.507, "zh": "那是谁的衬衫?", "zh_hant": "那是誰的襯衫?"}, {"index": 5, "text": "Is this your shirt Dave?", "start": 22.407, "end": 24.608, "zh": "戴夫,这是你的衬衫吗?", "zh_hant": "戴夫,這是你的襯衫嗎?"}, {"index": 6, "text": "No. Sir.", "start": 26.869, "end": 27.569, "zh": "不,先生。", "zh_hant": "不,先生。"}, {"index": 7, "text": "It's not my shirt.", "start": 28.689, "end": 30.2, "zh": "这不是我的衬衫。", "zh_hant": "這不是我的襯衫。"}, {"index": 8, "text": "This is my shirt.", "start": 30.2, "end": 30.67, "zh": "这才是我的衬衫。", "zh_hant": "這才是我的襯衫。"}, {"index": 9, "text": "My shirt's blue.", "start": 30.75, "end": 37.488, "zh": "我的衬衫是蓝色的。", "zh_hant": "我的襯衫是藍色的。"}, {"index": 10, "text": "Is this shirt Tim's?", "start": 40.43, "end": 42.391, "zh": "这件衬衫是蒂姆的吗?", "zh_hant": "這件襯衫是蒂姆的嗎?"}, {"index": 11, "text": "Perhaps it is sir.", "start": 44.673, "end": 46.214, "zh": "也许是的,先生。", "zh_hant": "也許是的,先生。"}, {"index": 12, "text": "Tim's shirt's white.", "start": 47.595, "end": 49.557, "zh": "蒂姆的衬衫是白色的。", "zh_hant": "蒂姆的襯衫是白色的。"}, {"index": 13, "text": "Tim!", "start": 51.938, "end": 52.239, "zh": "蒂姆!", "zh_hant": "蒂姆!"}, {"index": 14, "text": "Yes sir?", "start": 52.239, "end": 52.379, "zh": "什么事,先生?", "zh_hant": "什麼事,先生?"}, {"index": 15, "text": "Is this your shirt?", "start": 52.379, "end": 52.819, "zh": "这是你的衬衫吗?", "zh_hant": "這是你的襯衫嗎?"}, {"index": 16, "text": "Yes sir.", "start": 52.819, "end": 53.309, "zh": "是的,先生。", "zh_hant": "是的,先生。"}, {"index": 17, "text": "Here you are.", "start": 53.309, "end": 53.73, "zh": "给你。", "zh_hant": "給你。"}, {"index": 18, "text": "Catch!", "start": 53.73, "end": 53.86, "zh": "接住!", "zh_hant": "接住!"}, {"index": 19, "text": "Thank you sir.", "start": 53.86, "end": 54.2, "zh": "谢谢您,先生。", "zh_hant": "謝謝您,先生。"}]