[{"index": 0, "text": "Lesson 11", "start": 1.58, "end": 2.415}, {"index": 1, "text": "Is this your shirt?", "start": 3.941, "end": 5.662}, {"index": 2, "text": "Listen to the tape then answer this question.", "start": 7.562, "end": 11.344}, {"index": 3, "text": "Whose shirt is white?", "start": 13.804, "end": 16.285}, {"index": 4, "text": "Whose shirt is that?", "start": 18.966, "end": 20.507}, {"index": 5, "text": "Is this your shirt Dave?", "start": 22.407, "end": 24.608}, {"index": 6, "text": "No. Sir.", "start": 26.869, "end": 27.569}, {"index": 7, "text": "It's not my shirt.", "start": 28.689, "end": 30.23}, {"index": 8, "text": "This is my shirt.", "start": 30.17, "end": 30.67}, {"index": 9, "text": "My shirt's blue.", "start": 30.75, "end": 37.488}, {"index": 10, "text": "Is this shirt Tim's?", "start": 40.43, "end": 42.391}, {"index": 11, "text": "Perhaps it is sir.", "start": 44.673, "end": 46.214}, {"index": 12, "text": "Tim's shirt's white.", "start": 47.595, "end": 49.557}, {"index": 13, "text": "Tim!", "start": 51.938, "end": 52.299}, {"index": 14, "text": "Yes sir?", "start": 52.179, "end": 52.439}, {"index": 15, "text": "Is this your shirt?", "start": 52.319, "end": 52.879}, {"index": 16, "text": "Yes sir.", "start": 52.759, "end": 53.339}, {"index": 17, "text": "Here you are.", "start": 53.279, "end": 53.78}, {"index": 18, "text": "Catch!", "start": 53.68, "end": 53.92}, {"index": 19, "text": "Thank you sir.", "start": 53.8, "end": 54.2}]