[{"index": 0, "text": "Lesson 59", "start": 1.59, "end": 2.255}, {"index": 1, "text": "Is that all?", "start": 4.011, "end": 4.891}, {"index": 2, "text": "Listen to the tape then answer this question.", "start": 6.051, "end": 9.231}, {"index": 3, "text": "Does the lady buy any chalk?", "start": 11.772, "end": 14.032}, {"index": 4, "text": "I want some envelopes, please.", "start": 16.653, "end": 18.393}, {"index": 5, "text": "Do you want the large size or the small size?", "start": 19.453, "end": 22.934}, {"index": 6, "text": "The large size, please.", "start": 23.334, "end": 24.874}, {"index": 7, "text": "Do you have any writing paper?", "start": 26.234, "end": 31.223}, {"index": 8, "text": "Yes, we do.", "start": 31.284, "end": 32.424}, {"index": 9, "text": "I don't have any small pads.", "start": 32.524, "end": 34.365}, {"index": 10, "text": "I only have large ones.", "start": 35.146, "end": 37.027}, {"index": 11, "text": "Do you want a pad?", "start": 38.388, "end": 39.348}, {"index": 12, "text": "Yes, please.", "start": 40.008, "end": 40.889}, {"index": 13, "text": "And I want some glue.", "start": 42.01, "end": 43.49}, {"index": 14, "text": "A bottle of glue.", "start": 44.671, "end": 45.652}, {"index": 15, "text": "And I want a large box of chalk, too.", "start": 47.152, "end": 50.514}, {"index": 16, "text": "I only have small boxes.", "start": 51.775, "end": 60.45}, {"index": 17, "text": "Do you want one?", "start": 60.45, "end": 60.81}, {"index": 18, "text": "No, thank you.", "start": 60.81, "end": 61.111}, {"index": 19, "text": "Is that all?", "start": 61.111, "end": 61.441}, {"index": 20, "text": "That's all, thank you.", "start": 61.441, "end": 61.911}, {"index": 21, "text": "What else do you want?", "start": 61.911, "end": 62.852}, {"index": 22, "text": "I want my change.", "start": 63.452, "end": 64.813}]