[{"index": 0, "text": "Lesson 13", "start": 1.611, "end": 1.86, "zh": "第13课", "zh_hant": "第13課"}, {"index": 1, "text": "A new dress", "start": 4.191, "end": 5.412, "zh": "一条新裙子", "zh_hant": "一條新裙子"}, {"index": 2, "text": "Listen to the tape then answer this question.", "start": 7.272, "end": 11.234, "zh": "听录音,然后回答这个问题。", "zh_hant": "聽錄音,然後回答這個問題。"}, {"index": 3, "text": "What colour is Anna's hat?", "start": 13.835, "end": 16.435, "zh": "安娜的帽子是什么颜色的?", "zh_hant": "安娜的帽子是什麼顏色的?"}, {"index": 4, "text": "What colour's your new dress?", "start": 19.276, "end": 22.437, "zh": "你的新裙子是什么颜色的?", "zh_hant": "你的新裙子是什麼顏色的?"}, {"index": 5, "text": "It's green.", "start": 23.938, "end": 24.738, "zh": "是绿色的。", "zh_hant": "是綠色的。"}, {"index": 6, "text": "Come upstairs and see it.", "start": 26.038, "end": 28.099, "zh": "上楼来看看吧。", "zh_hant": "上樓來看看吧。"}, {"index": 7, "text": "Thank you.", "start": 29.54, "end": 30.12, "zh": "谢谢。", "zh_hant": "謝謝。"}, {"index": 8, "text": "Look!", "start": 30.12, "end": 30.27, "zh": "看!", "zh_hant": "看!"}, {"index": 9, "text": "Here it is!", "start": 30.27, "end": 30.78, "zh": "在这儿呢!", "zh_hant": "在這兒呢!"}, {"index": 10, "text": "That's a nice dress.", "start": 36.273, "end": 38.294, "zh": "这条裙子真漂亮。", "zh_hant": "這條裙子真漂亮。"}, {"index": 11, "text": "It's very smart.", "start": 38.934, "end": 40.675, "zh": "非常时髦。", "zh_hant": "非常時髦。"}, {"index": 12, "text": "My hat's new too.", "start": 42.476, "end": 44.317, "zh": "我的帽子也是新的。", "zh_hant": "我的帽子也是新的。"}, {"index": 13, "text": "What colour is it?", "start": 46.258, "end": 47.659, "zh": "它是什么颜色的?", "zh_hant": "它是什麼顏色的?"}, {"index": 14, "text": "It's the same colour.", "start": 48.539, "end": 49.52, "zh": "颜色一样。", "zh_hant": "顏色一樣。"}, {"index": 15, "text": "It's green too.", "start": 49.52, "end": 49.8, "zh": "也是绿色的。", "zh_hant": "也是綠色的。"}, {"index": 16, "text": "That is a lovely hat!", "start": 49.8, "end": 50.2, "zh": "这顶帽子真可爱!", "zh_hant": "這頂帽子真可愛!"}]