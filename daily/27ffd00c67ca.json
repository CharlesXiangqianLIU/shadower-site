[{"index": 0, "text": "Lesson 13", "start": 1.611, "end": 1.86}, {"index": 1, "text": "A new dress", "start": 4.191, "end": 5.412}, {"index": 2, "text": "Listen to the tape then answer this question.", "start": 7.272, "end": 11.234}, {"index": 3, "text": "What colour is Anna's hat?", "start": 13.835, "end": 16.435}, {"index": 4, "text": "What colour's your new dress?", "start": 19.276, "end": 22.437}, {"index": 5, "text": "It's green.", "start": 23.938, "end": 24.738}, {"index": 6, "text": "Come upstairs and see it.", "start": 26.038, "end": 28.099}, {"index": 7, "text": "Thank you.", "start": 29.54, "end": 30.18}, {"index": 8, "text": "Look!", "start": 30.06, "end": 30.28}, {"index": 9, "text": "Here it is!", "start": 30.26, "end": 30.78}, {"index": 10, "text": "That's a nice dress.", "start": 36.273, "end": 38.294}, {"index": 11, "text": "It's very smart.", "start": 38.934, "end": 40.675}, {"index": 12, "text": "My hat's new too.", "start": 42.476, "end": 44.317}, {"index": 13, "text": "What colour is it?", "start": 46.258, "end": 47.659}, {"index": 14, "text": "It's the same colour.", "start": 48.539, "end": 49.58}, {"index": 15, "text": "It's green  too.", "start": 49.46, "end": 49.86}, {"index": 16, "text": "That is a lovely hat!", "start": 49.74, "end": 50.2}]