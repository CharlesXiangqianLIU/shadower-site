[{"index": 0, "text": "Lesson 19", "start": 1.591, "end": 2.055}, {"index": 1, "text": "Tired and thirsty", "start": 4.153, "end": 5.874}, {"index": 2, "text": "Listen to the tape then answer this question.", "start": 7.555, "end": 11.117}, {"index": 3, "text": "Why do the children thank their mother?", "start": 13.699, "end": 16.421}, {"index": 4, "text": "What's the matter children?", "start": 19.202, "end": 21.224}, {"index": 5, "text": "We're tired ...", "start": 22.765, "end": 22.965}, {"index": 6, "text": "... and thirsty  Mum.", "start": 22.59, "end": 26.667}, {"index": 7, "text": "Sit down here.", "start": 27.768, "end": 29.169}, {"index": 8, "text": "Are you all right now?", "start": 29.049, "end": 30.49}, {"index": 9, "text": "No we aren't.", "start": 30.65, "end": 35.917}, {"index": 10, "text": "Look!", "start": 37.538, "end": 38.078}, {"index": 11, "text": "There's an ice cream man.", "start": 39.099, "end": 41.38}, {"index": 12, "text": "Two ice cream please.", "start": 43.542, "end": 45.943}, {"index": 13, "text": "Here you are children.", "start": 48.265, "end": 50.126}, {"index": 14, "text": "Thanks Mum.", "start": 51.507, "end": 51.887}, {"index": 15, "text": "These ice creams are nice.", "start": 51.787, "end": 52.388}, {"index": 16, "text": "Are you all right now?", "start": 52.268, "end": 52.768}, {"index": 17, "text": "Yes we are thank you!", "start": 52.648, "end": 55.99}]