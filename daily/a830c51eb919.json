[{"index": 0, "text": "Lesson 19", "start": 1.591, "end": 2.055, "zh": "第19课", "zh_hant": "第19課"}, {"index": 1, "text": "Tired and thirsty", "start": 4.153, "end": 5.874, "zh": "又累又渴", "zh_hant": "又累又渴"}, {"index": 2, "text": "Listen to the tape then answer this question.", "start": 7.555, "end": 11.117, "zh": "听录音,然后回答问题。", "zh_hant": "聽錄音,然後回答問題。"}, {"index": 3, "text": "Why do the children thank their mother?", "start": 13.699, "end": 16.421, "zh": "孩子们为什么要感谢妈妈?", "zh_hant": "孩子們為什麼要感謝媽媽?"}, {"index": 4, "text": "What's the matter children?", "start": 19.202, "end": 21.224, "zh": "孩子们,怎么了?", "zh_hant": "孩子們,怎麼了?"}, {"index": 5, "text": "We're tired ...", "start": 22.765, "end": 22.777, "zh": "我们累了……", "zh_hant": "我們累了……"}, {"index": 6, "text": "... and thirsty Mum.", "start": 22.777, "end": 26.667, "zh": "……也渴了,妈妈。", "zh_hant": "……也渴了,媽媽。"}, {"index": 7, "text": "Sit down here.", "start": 27.768, "end": 29.109, "zh": "坐这儿吧。", "zh_hant": "坐這兒吧。"}, {"index": 8, "text": "Are you all right now?", "start": 29.109, "end": 30.49, "zh": "你们现在好点了吗?", "zh_hant": "你們現在好點了嗎?"}, {"index": 9, "text": "No we aren't.", "start": 30.65, "end": 35.917, "zh": "不,还没有。", "zh_hant": "不,還沒有。"}, {"index": 10, "text": "Look!", "start": 37.538, "end": 38.078, "zh": "看!", "zh_hant": "看!"}, {"index": 11, "text": "There's an ice cream man.", "start": 39.099, "end": 41.38, "zh": "有个卖冰淇淋的人。", "zh_hant": "有個賣冰淇淋的人。"}, {"index": 12, "text": "Two ice cream please.", "start": 43.542, "end": 45.943, "zh": "请给我们两个冰淇淋。", "zh_hant": "請給我們兩個冰淇淋。"}, {"index": 13, "text": "Here you are children.", "start": 48.265, "end": 50.126, "zh": "给你们,孩子们。", "zh_hant": "給你們,孩子們。"}, {"index": 14, "text": "Thanks Mum.", "start": 51.507, "end": 51.837, "zh": "谢谢,妈妈。", "zh_hant": "謝謝,媽媽。"}, {"index": 15, "text": "These ice creams are nice.", "start": 51.837, "end": 52.328, "zh": "这些冰淇淋真好吃。", "zh_hant": "這些冰淇淋真好吃。"}, {"index": 16, "text": "Are you all right now?", "start": 52.328, "end": 52.708, "zh": "你们现在好点了吗?", "zh_hant": "你們現在好點了嗎?"}, {"index": 17, "text": "Yes we are thank you!", "start": 52.708, "end": 55.99, "zh": "是的,好多了,谢谢!", "zh_hant": "是的,好多了,謝謝!"}]