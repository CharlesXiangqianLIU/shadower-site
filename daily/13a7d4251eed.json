[{"index": 0, "text": "Lesson 75", "start": 1.591, "end": 2.63}, {"index": 1, "text": "Uncomfortable shoes", "start": 4.233, "end": 5.914}, {"index": 2, "text": "Listen to the tape then answer this question.", "start": 7.194, "end": 10.717}, {"index": 3, "text": "What's wrong with the fashionable shoes?", "start": 13.278, "end": 16.3}, {"index": 4, "text": "Do you have any shoes like these?", "start": 19.042, "end": 21.344}, {"index": 5, "text": "What size?", "start": 21.904, "end": 23.025}, {"index": 6, "text": "five.", "start": 23.305, "end": 24.105}, {"index": 7, "text": "What colour?", "start": 24.666, "end": 25.486}, {"index": 8, "text": "Black.", "start": 25.887, "end": 26.387}, {"index": 9, "text": "I'm sorry.", "start": 26.967, "end": 27.808}, {"index": 10, "text": "We don't have any.", "start": 28.248, "end": 30.77}, {"index": 11, "text": "But my sister bought this pair last month.", "start": 30.77, "end": 33.151}, {"index": 12, "text": "Did she buy them here?", "start": 33.691, "end": 35.311}, {"index": 13, "text": "No, she bought them in the U. S.", "start": 36.131, "end": 38.592}, {"index": 14, "text": "We had some shoes like those a month ago, but we don't have any now.", "start": 39.912, "end": 45.514}, {"index": 15, "text": "Can you get a pair for me, please?", "start": 46.734, "end": 49.075}, {"index": 16, "text": "I'm afraid that I can't.", "start": 49.795, "end": 51.736}, {"index": 17, "text": "They were in fashion last year and the year before last.", "start": 52.376, "end": 61.853}, {"index": 18, "text": "But they're not in fashion this year.", "start": 61.853, "end": 62.734}, {"index": 19, "text": "These shoes are in fashion now.", "start": 62.734, "end": 64.114}, {"index": 20, "text": "They look very uncomfortable.", "start": 65.194, "end": 67.375}, {"index": 21, "text": "They are very uncomfortable.", "start": 68.435, "end": 70.756}, {"index": 22, "text": "But women always wear uncomfortable shoes!", "start": 71.196, "end": 74.477}]