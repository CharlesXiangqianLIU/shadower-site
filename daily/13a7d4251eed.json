[{"index": 0, "text": "Lesson 75", "start": 1.591, "end": 2.63, "zh": "第75课"}, {"index": 1, "text": "Uncomfortable shoes", "start": 4.233, "end": 5.914, "zh": "不舒服的鞋子"}, {"index": 2, "text": "Listen to the tape then answer this question.", "start": 7.194, "end": 10.717, "zh": "听录音，然后回答这个问题。"}, {"index": 3, "text": "What's wrong with the fashionable shoes?", "start": 13.278, "end": 16.3, "zh": "这双时髦的鞋子有什么问题？"}, {"index": 4, "text": "Do you have any shoes like these?", "start": 19.042, "end": 21.344, "zh": "你们有这样的鞋子吗？"}, {"index": 5, "text": "What size?", "start": 21.904, "end": 23.025, "zh": "多大尺码？"}, {"index": 6, "text": "five.", "start": 23.305, "end": 24.105, "zh": "五号。"}, {"index": 7, "text": "What colour?", "start": 24.666, "end": 25.486, "zh": "什么颜色？"}, {"index": 8, "text": "Black.", "start": 25.887, "end": 26.387, "zh": "黑色。"}, {"index": 9, "text": "I'm sorry.", "start": 26.967, "end": 27.808, "zh": "对不起。"}, {"index": 10, "text": "We don't have any.", "start": 28.248, "end": 30.77, "zh": "我们没有这种鞋。"}, {"index": 11, "text": "But my sister bought this pair last month.", "start": 30.77, "end": 33.151, "zh": "但我姐姐上个月买了这么一双。"}, {"index": 12, "text": "Did she buy them here?", "start": 33.691, "end": 35.311, "zh": "她是在这儿买的吗？"}, {"index": 13, "text": "No, she bought them in the U. S.", "start": 36.131, "end": 38.592, "zh": "不，她是在美国买的。"}, {"index": 14, "text": "We had some shoes like those a month ago, but we don't have any now.", "start": 39.912, "end": 45.514, "zh": "一个月前我们有过这种鞋，但现在没有了。"}, {"index": 15, "text": "Can you get a pair for me, please?", "start": 46.734, "end": 49.075, "zh": "能帮我找一双吗？"}, {"index": 16, "text": "I'm afraid that I can't.", "start": 49.795, "end": 51.736, "zh": "恐怕不行。"}, {"index": 17, "text": "They were in fashion last year and the year before last.", "start": 52.376, "end": 61.853, "zh": "这种鞋去年和前年很流行。"}, {"index": 18, "text": "But they're not in fashion this year.", "start": 61.853, "end": 62.734, "zh": "但今年不流行了。"}, {"index": 19, "text": "These shoes are in fashion now.", "start": 62.734, "end": 64.114, "zh": "这些鞋子现在很流行。"}, {"index": 20, "text": "They look very uncomfortable.", "start": 65.194, "end": 67.375, "zh": "看起来很不舒服。"}, {"index": 21, "text": "They are very uncomfortable.", "start": 68.435, "end": 70.756, "zh": "它们确实很不舒服。"}, {"index": 22, "text": "But women always wear uncomfortable shoes!", "start": 71.196, "end": 74.477, "zh": "可是女人总是穿不舒服的鞋子！"}]