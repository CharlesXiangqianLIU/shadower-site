[{"index": 0, "text": "Lesson 93", "start": 1.631, "end": 2.06}, {"index": 1, "text": "Our new neighbour", "start": 3.992, "end": 5.253}, {"index": 2, "text": "Listen to the tape then answer this question.", "start": 6.574, "end": 9.835}, {"index": 3, "text": "Why is Nigel a lucky man?", "start": 12.437, "end": 15.138}, {"index": 4, "text": "Nigel is our new next-door neighbour.", "start": 17.96, "end": 20.161}, {"index": 5, "text": "He's a pilot.", "start": 20.762, "end": 21.782}, {"index": 6, "text": "He was in the R.A.F.", "start": 22.442, "end": 24.363}, {"index": 7, "text": "He will fly to New York next month.", "start": 25.444, "end": 30.88}, {"index": 8, "text": "The month after next he'll fly to Tokyo.", "start": 30.76, "end": 32.421}, {"index": 9, "text": "At the moment, he's in Madrid.", "start": 32.722, "end": 34.563}, {"index": 10, "text": "He flew to Spain a week ago.", "start": 35.444, "end": 37.425}, {"index": 11, "text": "He'll return to London the week after next.", "start": 38.586, "end": 41.168}, {"index": 12, "text": "He's only forty-one years old,", "start": 42.309, "end": 44.61}, {"index": 13, "text": "and he has already been to nearly every country in the world.", "start": 45.111, "end": 60.931}, {"index": 14, "text": "Nigel is a very lucky man.", "start": 60.831, "end": 61.372}, {"index": 15, "text": "But his wife isn't very lucky.", "start": 61.252, "end": 61.893}, {"index": 16, "text": "She usually stays at home!", "start": 61.793, "end": 63.036}]