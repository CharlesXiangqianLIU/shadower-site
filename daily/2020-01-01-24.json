[{"index": 0, "text": "Lesson 47 A cup of coffee Listen to the tape then answer this question.", "start": 0.65, "end": 10.953, "zh": "第47课 一杯咖啡 听录音,然后回答这个问题。", "zh_hant": "第47課 一杯咖啡 聽錄音,然後回答這個問題。"}, {"index": 1, "text": "How does Ann like her coffee?", "start": 12.114, "end": 14.975, "zh": "安喜欢怎样的咖啡?", "zh_hant": "安喜歡怎樣的咖啡?"}, {"index": 2, "text": "Do you like coffee, Ann?", "start": 17.135, "end": 19.756, "zh": "你喜欢咖啡吗,安?", "zh_hant": "你喜歡咖啡嗎,安?"}, {"index": 3, "text": "Yes, I do.", "start": 20.576, "end": 22.317, "zh": "是的,我喜欢。", "zh_hant": "是的,我喜歡。"}, {"index": 4, "text": "you want a cup?", "start": 23.437, "end": 25.458, "zh": "你要一杯吗?", "zh_hant": "你要一杯嗎?"}, {"index": 5, "text": "Yes, please, Christine.", "start": 26.398, "end": 29.319, "zh": "好的,谢谢,克里斯汀。", "zh_hant": "好的,謝謝,克里斯汀。"}, {"index": 6, "text": "Do you want any sugar?", "start": 30.38, "end": 32.9, "zh": "你要糖吗?", "zh_hant": "你要糖嗎?"}, {"index": 7, "text": "Yes, please.", "start": 33.601, "end": 35.381, "zh": "好的,谢谢。", "zh_hant": "好的,謝謝。"}, {"index": 8, "text": "Do you want any milk?", "start": 36.041, "end": 38.542, "zh": "你要牛奶吗?", "zh_hant": "你要牛奶嗎?"}, {"index": 9, "text": "No, thank you.", "start": 39.142, "end": 40.583, "zh": "不,谢谢。", "zh_hant": "不,謝謝。"}, {"index": 10, "text": "I don't like milk in my coffee.", "start": 40.983, "end": 44.164, "zh": "我的咖啡里不喜欢加牛奶。", "zh_hant": "我的咖啡裡不喜歡加牛奶。"}, {"index": 11, "text": "I like black coffee.", "start": 44.844, "end": 47.485, "zh": "我喜欢喝黑咖啡。", "zh_hant": "我喜歡喝黑咖啡。"}, {"index": 12, "text": "Do you like biscuits?", "start": 48.445, "end": 50.786, "zh": "你喜欢饼干吗?", "zh_hant": "你喜歡餅乾嗎?"}, {"index": 13, "text": "Yes, I do.", "start": 51.326, "end": 52.906, "zh": "是的,我喜欢。", "zh_hant": "是的,我喜歡。"}, {"index": 14, "text": "you want one?", "start": 53.887, "end": 55.687, "zh": "你要一块吗?", "zh_hant": "你要一塊嗎?"}, {"index": 15, "text": "Yes, please.", "start": 56.028, "end": 57.768, "zh": "好的,谢谢。", "zh_hant": "好的,謝謝。"}]