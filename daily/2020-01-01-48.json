[{"index": 0, "text": "Lesson 95 Tickets, please.", "start": 0.99, "end": 5.071, "zh": "第95课 请出示车票。", "zh_hant": "第95課 請出示車票。"}, {"index": 1, "text": "Listen to the tape then answer this question.", "start": 6.471, "end": 11.032, "zh": "听录音,然后回答这个问题。", "zh_hant": "聽錄音,然後回答這個問題。"}, {"index": 2, "text": "Why did George and Ken miss the train?", "start": 12.492, "end": 16.613, "zh": "乔治和肯为什么错过了火车?", "zh_hant": "喬治和肯為什麼錯過了火車?"}, {"index": 3, "text": "Two return tickets to London, please.", "start": 19.314, "end": 22.814, "zh": "请给我两张去伦敦的往返票。", "zh_hant": "請給我兩張去倫敦的往返票。"}, {"index": 4, "text": "What time will the next train leave?", "start": 23.414, "end": 26.735, "zh": "下一班火车几点开?", "zh_hant": "下一班火車幾點開?"}, {"index": 5, "text": "At nineteen minutes past eight.", "start": 27.215, "end": 30.176, "zh": "八点十九分。", "zh_hant": "八點十九分。"}, {"index": 6, "text": "Which platform?", "start": 31.476, "end": 32.996, "zh": "哪个站台?", "zh_hant": "哪個站臺?"}, {"index": 7, "text": "Two.", "start": 33.316, "end": 34.877, "zh": "二号站台。", "zh_hant": "二號站臺。"}, {"index": 8, "text": "Over the bridge.", "start": 35.137, "end": 36.737, "zh": "过桥就到。", "zh_hant": "過橋就到。"}, {"index": 9, "text": "What time will the next train leave?", "start": 38.137, "end": 41.378, "zh": "下一班火车几点开?", "zh_hant": "下一班火車幾點開?"}, {"index": 10, "text": "At eight nineteen.", "start": 42.138, "end": 44.318, "zh": "八点十九分。", "zh_hant": "八點十九分。"}, {"index": 11, "text": "We've got plenty of time.", "start": 44.939, "end": 47.599, "zh": "我们时间很充裕。", "zh_hant": "我們時間很充裕。"}, {"index": 12, "text": "It's only three minutes to eight.", "start": 48.539, "end": 51.76, "zh": "现在才八点差三分。", "zh_hant": "現在才八點差三分。"}, {"index": 13, "text": "Let's go and have a drink.", "start": 52.5, "end": 55.1, "zh": "我们去喝一杯吧。", "zh_hant": "我們去喝一杯吧。"}, {"index": 14, "text": "There's a bar next door to the station.", "start": 55.46, "end": 59.441, "zh": "车站隔壁就有个酒吧。", "zh_hant": "車站隔壁就有個酒吧。"}, {"index": 15, "text": "We had better go back to the station now, Ken.", "start": 60.641, "end": 64.822, "zh": "肯,我们现在最好回车站了。", "zh_hant": "肯,我們現在最好回車站了。"}, {"index": 16, "text": "Tickets, please.", "start": 65.722, "end": 67.483, "zh": "请出示车票。", "zh_hant": "請出示車票。"}, {"index": 17, "text": "We want to catch the eight nineteen to London.", "start": 68.243, "end": 72.484, "zh": "我们要赶八点十九分去伦敦的那班车。", "zh_hant": "我們要趕八點十九分去倫敦的那班車。"}, {"index": 18, "text": "You've just missed it!", "start": 72.804, "end": 75.064, "zh": "你们刚好错过了!", "zh_hant": "你們剛好錯過了!"}, {"index": 19, "text": "What!", "start": 75.624, "end": 76.544, "zh": "什么!", "zh_hant": "什麼!"}, {"index": 20, "text": "It's only eight fifteen.", "start": 77.005, "end": 79.805, "zh": "现在才八点十五分。", "zh_hant": "現在才八點十五分。"}, {"index": 21, "text": "I'm sorry, sir.", "start": 80.345, "end": 82.085, "zh": "对不起,先生。", "zh_hant": "對不起,先生。"}, {"index": 22, "text": "That clock's ten minutes slow.", "start": 82.206, "end": 85.226, "zh": "那个钟慢了十分钟。", "zh_hant": "那個鐘慢了十分鐘。"}, {"index": 23, "text": "When's the next train?", "start": 86.186, "end": 88.327, "zh": "下一班火车是几点?", "zh_hant": "下一班火車是幾點?"}, {"index": 24, "text": "In five hours' time!", "start": 88.767, "end": 91.247, "zh": "要再等五个小时!", "zh_hant": "要再等五個小時!"}]