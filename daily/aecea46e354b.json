[{"index": 0, "text": "Lesson 87", "start": 1.55, "end": 2.17, "zh": "第87课"}, {"index": 1, "text": "A car crash", "start": 3.791, "end": 5.011, "zh": "一场车祸"}, {"index": 2, "text": "Listen to the tape then answer this question.", "start": 6.371, "end": 9.892, "zh": "听录音，然后回答这个问题。"}, {"index": 3, "text": "Can the mechanics repair Mr. Wood's car?", "start": 12.372, "end": 15.793, "zh": "技工们能修好伍德先生的车吗？"}, {"index": 4, "text": "Is my car ready yet?", "start": 18.553, "end": 20.153, "zh": "我的车修好了吗？"}, {"index": 5, "text": "I don't know, sir.", "start": 21.854, "end": 22.834, "zh": "先生，我不知道。"}, {"index": 6, "text": "What's the number of your car?", "start": 23.374, "end": 25.114, "zh": "你的车牌号是多少？"}, {"index": 7, "text": "It's LFZ 312 G.", "start": 26.735, "end": 32.168, "zh": "是LFZ 312 G。"}, {"index": 8, "text": "When did you bring it to us?", "start": 33.89, "end": 35.771, "zh": "你什么时候把车送来的？"}, {"index": 9, "text": "I brought it here three days ago.", "start": 37.232, "end": 39.594, "zh": "我三天前把车送到这里的。"}, {"index": 10, "text": "Ah yes, I remember now.", "start": 41.115, "end": 43.777, "zh": "啊，是的，我想起来了。"}, {"index": 11, "text": "Have your mechanics finished yet?", "start": 45.458, "end": 47.299, "zh": "你们的技工修好了吗？"}, {"index": 12, "text": "No, they're still working on it.", "start": 48.72, "end": 50.881, "zh": "还没有，他们还在修。"}, {"index": 13, "text": "Let's go into the garage and have a look at it.", "start": 51.782, "end": 55.205, "zh": "我们到车库去看看吧。"}, {"index": 14, "text": "Isn't that your car?", "start": 57.246, "end": 58.627, "zh": "那不是你的车吗？"}, {"index": 15, "text": "Well, it was my car.", "start": 58.627, "end": 62.549, "zh": "呃，那曾经是我的车。"}, {"index": 16, "text": "Didn't you have a crash?", "start": 64.311, "end": 65.732, "zh": "你没出车祸吗？"}, {"index": 17, "text": "That's right.", "start": 66.973, "end": 67.814, "zh": "没错。"}, {"index": 18, "text": "I drove it into a lamp-post.", "start": 68.475, "end": 70.837, "zh": "我把车撞到了电线杆上。"}, {"index": 19, "text": "Can your mechanics repair it?", "start": 71.978, "end": 73.82, "zh": "你们的技工能修好它吗？"}, {"index": 20, "text": "Well, they're trying to repair it, sir.", "start": 75.342, "end": 78.325, "zh": "呃，先生，他们正在尽力修。"}, {"index": 21, "text": "But to tell you the truth, you need a new car!", "start": 78.946, "end": 80.447, "zh": "但说实话，你需要一辆新车！"}]