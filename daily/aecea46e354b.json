[{"index": 0, "text": "Lesson 87", "start": 1.55, "end": 2.17}, {"index": 1, "text": "A car crash", "start": 3.791, "end": 5.011}, {"index": 2, "text": "Listen to the tape then answer this question.", "start": 6.371, "end": 9.892}, {"index": 3, "text": "Can the mechanics repair Mr. Wood's car?", "start": 12.372, "end": 15.793}, {"index": 4, "text": "Is my car ready yet?", "start": 18.553, "end": 20.153}, {"index": 5, "text": "I don't know, sir.", "start": 21.854, "end": 22.834}, {"index": 6, "text": "What's the number of your car?", "start": 23.374, "end": 25.114}, {"index": 7, "text": "It's LFZ 312 G.", "start": 26.735, "end": 32.168}, {"index": 8, "text": "When did you bring it to us?", "start": 33.89, "end": 35.771}, {"index": 9, "text": "I brought it here three days ago.", "start": 37.232, "end": 39.594}, {"index": 10, "text": "Ah yes, I remember now.", "start": 41.115, "end": 43.777}, {"index": 11, "text": "Have your mechanics finished yet?", "start": 45.458, "end": 47.299}, {"index": 12, "text": "No, they're still working on it.", "start": 48.72, "end": 50.881}, {"index": 13, "text": "Let's go into the garage and have a look at it.", "start": 51.782, "end": 55.205}, {"index": 14, "text": "Isn't that your car?", "start": 57.246, "end": 58.687}, {"index": 15, "text": "Well, it was my car.", "start": 58.567, "end": 62.549}, {"index": 16, "text": "Didn't you have a crash?", "start": 64.311, "end": 65.732}, {"index": 17, "text": "That's right.", "start": 66.973, "end": 67.814}, {"index": 18, "text": "I drove it into a lamp-post.", "start": 68.475, "end": 70.837}, {"index": 19, "text": "Can your mechanics repair it?", "start": 71.978, "end": 73.82}, {"index": 20, "text": "Well, they're trying to repair it, sir.", "start": 75.342, "end": 78.325}, {"index": 21, "text": "But to tell you the truth, you need a new car!", "start": 78.946, "end": 80.447}]